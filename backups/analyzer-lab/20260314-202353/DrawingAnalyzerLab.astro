  async function loadLibraryFromFolder() {
    try {
      const response = await fetch("/api/drawing-analyzer/item-library", {
        method: "GET",
        headers: { Accept: "application/json" },
      });
      const payload = await response.json();
      if (!response.ok || !payload?.success) {
        setStatus(payload?.error || "Failed to load item library.");
        return;
      }
      itemLibrary = normalizeLibraryItems(payload.items || []);
      templateSignatureCache.clear();
      renderItemLibrary();
      setStatus(`Loaded ${itemLibrary.length} item(s) from folder scan.`);
      scheduleBenchmarkRun(50);
    } catch (error) {
      console.error("[DrawingAnalyzerLab] loadLibraryFromFolder failed", error);
      setStatus("Failed to load item library from folder.");
    }
  }

  async function saveLibraryMetadata() {
    try {
      const response = await fetch("/api/drawing-analyzer/item-library", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items: itemLibrary }),
      });
      const payload = await response.json();
      if (!response.ok || !payload?.success) {
        setStatus(payload?.error || "Failed to save item library metadata.");
        return;
      }
      setStatus(
        `Saved metadata for ${itemLibrary.length} item(s) to markdowns/drawing-analyzer-lab-item-library.md.`
      );
      scheduleBenchmarkRun(50);
    } catch (error) {
      console.error("[DrawingAnalyzerLab] saveLibraryMetadata failed", error);
      setStatus("Failed to save item library metadata.");
    }
  }

  function clamp(v, min, max) {
    return Math.max(min, Math.min(max, v));
  }

  function getCtx(canvas) {
    if (!(canvas instanceof HTMLCanvasElement)) return null;
    return canvas.getContext("2d", { willReadFrequently: true });
  }

  function renderImageOnCanvas(canvas, img, maxSide = DRAWING_RENDER_MAX_SIDE) {
    if (!(canvas instanceof HTMLCanvasElement)) return null;
    const ctx = getCtx(canvas);
    if (!ctx) return null;
    const scale = Math.min(
      1,
      maxSide / Math.max(img.naturalWidth || img.width, img.naturalHeight || img.height)
    );
    const w = Math.max(1, Math.round((img.naturalWidth || img.width) * scale));
    const h = Math.max(1, Math.round((img.naturalHeight || img.height) * scale));
    canvas.width = w;
    canvas.height = h;
    ctx.clearRect(0, 0, w, h);
    ctx.drawImage(img, 0, 0, w, h);
    return ctx.getImageData(0, 0, w, h);
  }

  async function loadImageFromFile(file) {
    const url = URL.createObjectURL(file);
    try {
      const img = new Image();
      const loaded = await new Promise((resolve) => {
        img.onload = () => resolve(true);
        img.onerror = () => resolve(false);
        img.src = url;
      });
      if (!loaded) return null;
      return img;
    } finally {
      URL.revokeObjectURL(url);
    }
  }

  async function renderPdfFirstPageToImage(file, preferredScale = PDF_RENDER_SCALE) {
    const pdfjs = window["pdfjsLib"];
    if (!pdfjs) throw new Error("PDF engine not loaded yet. Try again in a moment.");
    const data = new Uint8Array(await file.arrayBuffer());
    const pdf = await pdfjs.getDocument({ data }).promise;
    const page = await pdf.getPage(1);
    const candidates = [preferredScale, ...PDF_RENDER_SCALE_FALLBACKS].filter(
      (v, i, arr) => Number.isFinite(v) && v > 0 && arr.indexOf(v) === i
    );
    let lastError = null;
    for (const scale of candidates) {
      try {
        const viewport = page.getViewport({ scale });
        const canvas = document.createElement("canvas");
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        const ctx = canvas.getContext("2d");
        if (!ctx) throw new Error("Unable to render PDF canvas context.");
        await page.render({ canvasContext: ctx, viewport }).promise;
        const img = new Image();
        const loaded = await new Promise((resolve) => {
          img.onload = () => resolve(true);
          img.onerror = () => resolve(false);
          img.src = canvas.toDataURL("image/png");
        });
        if (!loaded) throw new Error("Failed to convert PDF page to image.");
        return { img, scaleUsed: scale };
      } catch (error) {
        lastError = error;
        console.warn("[DrawingAnalyzerLab] PDF render scale fallback", { scale, error });
      }
    }
    throw lastError instanceof Error
      ? lastError
      : new Error("Failed to render PDF at all available quality levels.");
  }

  function renderImageDataWithFallback(canvas, img, preferredMaxSide = DRAWING_RENDER_MAX_SIDE) {
    const candidates = [preferredMaxSide, ...DRAWING_RENDER_MAX_SIDE_FALLBACKS].filter(
      (v, i, arr) => Number.isFinite(v) && v > 400 && arr.indexOf(v) === i
    );
    let lastError = null;
    for (const maxSide of candidates) {
      try {
        const imageData = renderImageOnCanvas(canvas, img, maxSide);
        if (imageData) return { imageData, maxSideUsed: maxSide };
      } catch (error) {
        lastError = error;
        console.warn("[DrawingAnalyzerLab] Canvas render max-side fallback", { maxSide, error });
      }
    }
    if (lastError) throw lastError;
    return { imageData: null, maxSideUsed: preferredMaxSide };
  }

  function imageToNeutralMask(imageData) {
    const { width, height, data } = imageData;
    const mask = new Uint8Array(width * height);
    for (let y = 0; y < height; y += 1) {
      const row = y * width;
      for (let x = 0; x < width; x += 1) {
        const idx = (row + x) * 4;
        const r = data[idx];
        const g = data[idx + 1];
        const b = data[idx + 2];
        const a = data[idx + 3];
        const gray = r * 0.299 + g * 0.587 + b * 0.114;
        const spread = Math.max(r, g, b) - Math.min(r, g, b);
        const dark = gray < 210 && a > 20;
        const neutral = spread < 42;
        mask[row + x] = dark && neutral ? 1 : 0;
      }
    }
    return mask;
  }

  function getComponents(mask, width, height, minArea = 18, maxArea = 999999) {
    const visited = new Uint8Array(width * height);
    const qx = new Int32Array(width * height);
    const qy = new Int32Array(width * height);
    const out = [];

    for (let y = 0; y < height; y += 1) {
      const row = y * width;
      for (let x = 0; x < width; x += 1) {
        const start = row + x;
        if (!mask[start] || visited[start]) continue;
        let head = 0;
        let tail = 0;
        qx[tail] = x;
        qy[tail] = y;
        tail += 1;
        visited[start] = 1;
        let area = 0;
        let minX = x;
        let minY = y;
        let maxX = x;
        let maxY = y;

        while (head < tail) {
          const cx = qx[head];
          const cy = qy[head];
          head += 1;
          area += 1;
          if (cx < minX) minX = cx;
          if (cy < minY) minY = cy;
          if (cx > maxX) maxX = cx;
          if (cy > maxY) maxY = cy;

          for (let oy = -1; oy <= 1; oy += 1) {
            const ny = cy + oy;
            if (ny < 0 || ny >= height) continue;
            const nrow = ny * width;
            for (let ox = -1; ox <= 1; ox += 1) {
              if (ox === 0 && oy === 0) continue;
              const nx = cx + ox;
              if (nx < 0 || nx >= width) continue;
              const nidx = nrow + nx;
              if (!mask[nidx] || visited[nidx]) continue;
              visited[nidx] = 1;
              qx[tail] = nx;
              qy[tail] = ny;
              tail += 1;
            }
          }
        }

        if (area < minArea || area > maxArea) continue;
        const w = maxX - minX + 1;
        const h = maxY - minY + 1;
        out.push({ x: minX, y: minY, w, h, area });
      }
    }
    return out;
  }

  function getMaskedByRegions(state, regions) {
    if (!state) return null;
    if (!Array.isArray(regions) || regions.length === 0) return state;
    const masked = new Uint8Array(state.mask);
    for (let y = 0; y < state.height; y += 1) {
      const row = y * state.width;
      for (let x = 0; x < state.width; x += 1) {
        const inside = regions.some((r) => x >= r.x && y >= r.y && x < r.x + r.w && y < r.y + r.h);
        if (!inside) masked[row + x] = 0;
      }
    }
    return { ...state, mask: masked };
  }

  async function loadImageDataFromUrl(src) {
    const url = String(src || "").trim();
    if (!url) return null;
    return await new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement("canvas");
        canvas.width = img.naturalWidth || img.width;
        canvas.height = img.naturalHeight || img.height;
        const ctx = canvas.getContext("2d", { willReadFrequently: true });
        if (!ctx) return resolve(null);
        ctx.drawImage(img, 0, 0);
        resolve(ctx.getImageData(0, 0, canvas.width, canvas.height));
      };
      img.onerror = () => resolve(null);
      img.src = url;
    });
  }

  function signatureFromImageData(imageData) {
    if (!imageData) return null;
    const { width, height, data } = imageData;
    const mask = new Uint8Array(width * height);
    let minX = width;
    let minY = height;
    let maxX = -1;
    let maxY = -1;
    let area = 0;
    for (let y = 0; y < height; y += 1) {
      const row = y * width;
      for (let x = 0; x < width; x += 1) {
        const i = (row + x) * 4;
        const a = data[i + 3];
        if (a < 18) continue;
        const r = data[i];
        const g = data[i + 1];
        const b = data[i + 2];
        const gray = r * 0.299 + g * 0.587 + b * 0.114;
        const isInk = gray < 245 || a > 32;
        if (!isInk) continue;
        mask[row + x] = 1;
        area += 1;
        if (x < minX) minX = x;
        if (y < minY) minY = y;
        if (x > maxX) maxX = x;
        if (y > maxY) maxY = y;
      }
    }
    if (area < 8 || maxX < minX || maxY < minY) return null;
    const w = maxX - minX + 1;
    const h = maxY - minY + 1;
    const bboxArea = Math.max(1, w * h);
    return {
      w,
      h,
      aspect: w / Math.max(1, h),
      fill: area / bboxArea,
      area,
      diameter: Math.min(w, h),
    };
  }

  async function getTemplateSignature(item) {
    const cacheKey = `${item.fileName}|${item.imageUrl}|${item.rawImageUrl || ""}`;
    if (templateSignatureCache.has(cacheKey)) return templateSignatureCache.get(cacheKey);
    let imageData = await loadImageDataFromUrl(item.imageUrl);
    if (!imageData && item.rawImageUrl) imageData = await loadImageDataFromUrl(item.rawImageUrl);
    const sig = signatureFromImageData(imageData);
    templateSignatureCache.set(cacheKey, sig);
    return sig;
  }

  function scoreComponentVsTemplate(comp, sig) {
    if (!sig) return 0;
    const compAspect = comp.w / Math.max(1, comp.h);
    const compFill = comp.area / Math.max(1, comp.w * comp.h);
    const compDiam = Math.min(comp.w, comp.h);
    const aspectScore = clamp(1 - Math.abs(compAspect - sig.aspect) / 0.55, 0, 1);
    const fillScore = clamp(1 - Math.abs(compFill - sig.fill) / 0.42, 0, 1);
    const diamScore = clamp(
      1 - Math.abs(compDiam - sig.diameter) / Math.max(8, sig.diameter * 0.7),
      0,
      1
    );
    return aspectScore * 0.42 + fillScore * 0.33 + diamScore * 0.25;
  }

  function colorForItem(fileName) {
    const palette = [
      "#ef4444",
      "#f97316",
      "#eab308",
      "#22c55e",
      "#14b8a6",
      "#06b6d4",
      "#3b82f6",
      "#6366f1",
      "#8b5cf6",
      "#d946ef",
      "#ec4899",
    ];
    let hash = 0;
    const key = String(fileName || "");
    for (let i = 0; i < key.length; i += 1) hash = (hash * 31 + key.charCodeAt(i)) >>> 0;
    return palette[hash % palette.length];
  }

  function renderBenchmarkPanel() {
    if (!(benchmarkMetaEl instanceof HTMLElement) || !(benchmarkListEl instanceof HTMLElement))
      return;
    if (benchmarkConfidenceReadoutEl instanceof HTMLElement) {
      benchmarkConfidenceReadoutEl.textContent = `${Math.round(benchmarkConfidence * 100)}%`;
    }
    if (benchmarkConfidenceEl instanceof HTMLInputElement) {
      benchmarkConfidenceEl.value = String(Math.round(benchmarkConfidence * 100));
    }
    const regionCount = baselineRegions.length;
    const total = benchmarkResults.reduce((acc, r) => acc + Number(r.count || 0), 0);
    benchmarkMetaEl.textContent = `Regions: ${regionCount} | Items: ${itemLibrary.length} | Matches: ${total} | Threshold: ${Math.round(benchmarkConfidence * 100)}%`;
    if (benchmarkResults.length === 0) {
      benchmarkListEl.innerHTML = `<p class="text-xs text-gray-500 dark:text-gray-400">No benchmark results yet.</p>`;
      return;
    }
    benchmarkListEl.innerHTML = benchmarkResults
      .map(
        (
          row
        ) => `<div class="flex items-center justify-between rounded border border-gray-200 px-2 py-1 text-sm dark:border-gray-700">
          <span class="flex min-w-0 items-center gap-2 pr-2">
            <span class="h-3 w-3 rounded-full border border-white/60" style="background:${escapeHtml(row.color)}"></span>
            <img
              src="${escapeHtml(row.imageUrl || "")}"
              data-fallback-src="${escapeHtml(row.rawImageUrl || row.imageUrl || "")}"
              onerror="if(!this.dataset.fallbackUsed){this.dataset.fallbackUsed='1';this.src=this.dataset.fallbackSrc;}"
              alt="${escapeHtml(row.name)}"
              class="h-5 w-5 rounded border border-gray-300 bg-white object-contain dark:border-gray-700"
            />
            <span class="truncate">${escapeHtml(row.name)}</span>
          </span>
          <span class="rounded bg-gray-100 px-2 py-0.5 font-semibold text-gray-800 dark:bg-gray-800 dark:text-gray-100">${row.count}</span>
        </div>`
      )
      .join("");
  }

  async function runLiveBenchmark() {
    benchmarkRunId += 1;
    const runId = benchmarkRunId;
    const focusActive = isRegionFocusOpen() && !!focusRegionState;
    trace("benchmark.run.start", {
      runId,
      focusActive,
      hasDrawing: Boolean(drawingState),
      itemLibraryCount: itemLibrary.length,
      baselineRegionCount: baselineRegions.length,
      thresholdPct: Math.round(benchmarkConfidence * 100),
    });
    if (
      !drawingState ||
      itemLibrary.length === 0 ||
      (!focusActive && baselineRegions.length === 0)
    ) {
      benchmarkResults = [];
      benchmarkDetections = [];
      focusBenchmarkDetections = [];
      renderBaselineOverlay();
      renderRegionFocusCanvas();
      benchmarkDiagnostics = {
        mode: "idle",
        width: 0,
        height: 0,
        thresholdPct: benchmarkConfidence * 100,
        componentCount: 0,
        detectedCount: 0,
        medianDiameter: 0,
        minDiameter: 0,
        maxDiameter: 0,
        topCandidates: [],
      };
      renderBenchmarkPanel();
      renderDiagnosticsPanel();
      trace("benchmark.run.skipped", {
        runId,
        reason: "missing-prerequisites",
        focusActive,
      });
      return;
    }
    const maskedState = focusActive ? focusRegionState : getMaskedByRegions(drawingState, baselineRegions);
    const comps = getComponents(
      maskedState.mask,
      maskedState.width,
      maskedState.height,
      16,
      maskedState.width * maskedState.height * 0.02
    ).filter((c) => c.w >= 6 && c.h >= 6);
    const signatures = await Promise.all(
      itemLibrary.map(async (item) => ({
        item,
        sig: await getTemplateSignature(item),
      }))
    );
    if (runId !== benchmarkRunId) {
      trace("benchmark.run.aborted", {
        runId,
        reason: "superseded",
        currentRunId: benchmarkRunId,
      });
      return;
    }
    const counts = new Map(itemLibrary.map((it) => [it.fileName, 0]));
    const detections = [];
    const candidates = [];
    const diameters = [];
    for (const comp of comps) {
      let bestFile = null;
      let bestScore = 0;
      for (const entry of signatures) {
        const score = scoreComponentVsTemplate(comp, entry.sig);
        if (score > bestScore) {
          bestScore = score;
          bestFile = entry.item.fileName;
        }
      }
      const compDiam = Math.min(comp.w, comp.h);
      diameters.push(compDiam);
      candidates.push({
        fileName: bestFile || "",
        score: bestScore,
        diameter: compDiam,
        x: comp.x + comp.w / 2,
        y: comp.y + comp.h / 2,
      });
      if (bestFile && bestScore >= benchmarkConfidence) {
        counts.set(bestFile, (counts.get(bestFile) || 0) + 1);
        detections.push({
          fileName: bestFile,
          x: Math.round(comp.x + comp.w / 2),
          y: Math.round(comp.y + comp.h / 2),
          r: Math.max(3, Math.min(7, Math.round(Math.min(comp.w, comp.h) * 0.1))),
          color: colorForItem(bestFile),
        });
      }
    }
    if (focusActive) {
      focusBenchmarkDetections = detections.slice(0, 3000);
      benchmarkDetections = [];
    } else {
      benchmarkDetections = detections.slice(0, 3000);
      focusBenchmarkDetections = [];
    }
    const sortedDiam = diameters.slice().sort((a, b) => a - b);
    const mid = sortedDiam.length > 0 ? Math.floor(sortedDiam.length / 2) : -1;
    const medianDiameter =
      mid < 0
        ? 0
        : sortedDiam.length % 2 === 0
          ? (sortedDiam[mid - 1] + sortedDiam[mid]) / 2
          : sortedDiam[mid];
    benchmarkDiagnostics = {
      mode: focusActive ? "focus-region" : "full-baseline",
      width: maskedState.width,
      height: maskedState.height,
      thresholdPct: benchmarkConfidence * 100,
      componentCount: comps.length,
      detectedCount: detections.length,
      medianDiameter,
      minDiameter: sortedDiam[0] || 0,
      maxDiameter: sortedDiam[sortedDiam.length - 1] || 0,
      topCandidates: candidates.sort((a, b) => b.score - a.score).slice(0, 12),
    };
    benchmarkResults = itemLibrary.map((it) => ({
      fileName: it.fileName,
      name: it.displayName,
      count: counts.get(it.fileName) || 0,
      color: colorForItem(it.fileName),
      imageUrl: it.imageUrl || "",
      rawImageUrl: it.rawImageUrl || "",
    }));
    renderBaselineOverlay();
    renderRegionFocusCanvas();
    renderBenchmarkPanel();
    renderDiagnosticsPanel();
    trace("benchmark.run.completed", {
      runId,
      focusActive,
      sourceWidth: maskedState.width,
      sourceHeight: maskedState.height,
      components: comps.length,
      detections: detections.length,
      topCandidates: candidates.slice(0, 5).map((c) => ({
        fileName: c.fileName || "n/a",
        score: Number(c.score || 0).toFixed(3),
        diameter: Number(c.diameter || 0).toFixed(1),
      })),
    });
  }

  let benchmarkTimer = null;
  function scheduleBenchmarkRun(delayMs = 120) {
    if (benchmarkTimer) clearTimeout(benchmarkTimer);
    trace("benchmark.run.scheduled", { delayMs });
    benchmarkTimer = window.setTimeout(() => {
      void runLiveBenchmark();
    }, delayMs);
  }

  // Baseline inspired by engineering-drawing-extractor: isolate major drawing blocks from sheet-level noise/tables.
  function extractBaselineRegions(state) {
    if (!state) return { regions: [], mode: "none" };
    const { width, height, mask } = state;
    const canvasArea = Math.max(1, width * height);
    const comps = getComponents(mask, width, height, 18, canvasArea * 0.9);
    if (comps.length === 0) return { regions: [], mode: "none" };

    const edgeMargin = Math.max(6, Math.round(Math.min(width, height) * 0.02));
    const scored = [];
    for (const c of comps) {
      const bboxArea = c.w * c.h;
      const bboxRatio = bboxArea / canvasArea;
      if (bboxRatio < 0.015 || bboxRatio > 0.72) continue;
      const aspect = c.w / Math.max(1, c.h);
      if (aspect < 0.35 || aspect > 3.0) continue;
      const inkRatio = c.area / Math.max(1, bboxArea);
      if (inkRatio < 0.0015 || inkRatio > 0.24) continue;

      const nearLeft = c.x <= edgeMargin;
      const nearTop = c.y <= edgeMargin;
      const nearRight = c.x + c.w >= width - edgeMargin;
      const nearBottom = c.y + c.h >= height - edgeMargin;
      const edgeTouchCount = [nearLeft, nearTop, nearRight, nearBottom].filter(Boolean).length;

      const cx = c.x + c.w / 2;
      const cy = c.y + c.h / 2;
      const centerDist =
        Math.hypot(cx - width / 2, cy - height / 2) /
        Math.max(1, Math.hypot(width / 2, height / 2));
      const centerBonus = 1 - clamp(centerDist, 0, 1);
      const frameBonus = clamp(1 - Math.abs(inkRatio - 0.06) / 0.14, 0, 1);
      const edgePenalty = edgeTouchCount >= 2 ? 0.22 : 0;
      const score = bboxRatio * 1.1 + frameBonus * 0.35 + centerBonus * 0.2 - edgePenalty;

      scored.push({ ...c, score });
    }

    scored.sort((a, b) => b.score - a.score);
    const selected = [];
    for (const c of scored) {
      const overlaps = selected.some((k) => {
        const x0 = Math.max(c.x, k.x);
        const y0 = Math.max(c.y, k.y);
        const x1 = Math.min(c.x + c.w - 1, k.x + k.w - 1);
        const y1 = Math.min(c.y + c.h - 1, k.y + k.h - 1);
        if (x1 < x0 || y1 < y0) return false;
        const inter = (x1 - x0 + 1) * (y1 - y0 + 1);
        return inter / Math.max(1, Math.min(c.w * c.h, k.w * k.h)) > 0.58;
      });
      if (overlaps) continue;
      const pad = Math.max(8, Math.round(Math.min(c.w, c.h) * 0.03));
      selected.push({
        x: clamp(c.x - pad, 0, width - 1),
        y: clamp(c.y - pad, 0, height - 1),
        w: clamp(c.w + pad * 2, 1, width),
        h: clamp(c.h + pad * 2, 1, height),
      });
      if (selected.length >= 4) break;
    }

    return { regions: selected, mode: selected.length > 0 ? "baseline-components" : "none" };
  }

  function renderBaselineOverlay() {
    if (
      !(drawingOverlay instanceof HTMLCanvasElement) ||
      !(drawingCanvas instanceof HTMLCanvasElement)
    )
      return;
    const ctx = getCtx(drawingOverlay);
    if (!ctx) return;

    drawingOverlay.width = drawingCanvas.width;
    drawingOverlay.height = drawingCanvas.height;
    ctx.clearRect(0, 0, drawingOverlay.width, drawingOverlay.height);
    deleteHotspots = [];
    transformHandles = [];
    if (baselineRegions.length === 0) return;

    ctx.lineWidth = 2;
    ctx.font = "12px sans-serif";
    baselineRegions.forEach((r, idx) => {
      const isSelected = idx === selectedRegionIdx;
      ctx.fillStyle = isSelected ? "rgba(14,165,233,0.16)" : "rgba(245,158,11,0.18)";
      ctx.strokeStyle = isSelected ? "rgba(14,165,233,0.98)" : "rgba(245,158,11,0.95)";
      ctx.fillRect(r.x, r.y, r.w, r.h);
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = isSelected ? "rgba(14,165,233,0.98)" : "rgba(245,158,11,0.95)";
      ctx.fillText(`Region ${idx + 1}`, r.x + 4, Math.max(12, r.y - 4));

      const radius = 9;
      const cx = r.x + r.w - radius - 2;
      const cy = r.y + radius + 2;
      ctx.beginPath();
      ctx.fillStyle = "rgba(255,255,255,0.96)";
      ctx.strokeStyle = "rgba(220,38,38,0.95)";
      ctx.lineWidth = 2;
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(cx - 4, cy - 4);
      ctx.lineTo(cx + 4, cy + 4);
      ctx.moveTo(cx + 4, cy - 4);
      ctx.lineTo(cx - 4, cy + 4);
      ctx.strokeStyle = "rgba(220,38,38,0.95)";
      ctx.lineWidth = 1.8;
      ctx.stroke();
      deleteHotspots.push({ idx, cx, cy, radius });

      if (!isSelected) return;
      const hs = 10;
      const handles = [
        { kind: "nw", x: r.x, y: r.y, cursor: "nwse-resize" },
        { kind: "n", x: r.x + r.w / 2, y: r.y, cursor: "ns-resize" },
        { kind: "ne", x: r.x + r.w, y: r.y, cursor: "nesw-resize" },
        { kind: "e", x: r.x + r.w, y: r.y + r.h / 2, cursor: "ew-resize" },
        { kind: "se", x: r.x + r.w, y: r.y + r.h, cursor: "nwse-resize" },
        { kind: "s", x: r.x + r.w / 2, y: r.y + r.h, cursor: "ns-resize" },
        { kind: "sw", x: r.x, y: r.y + r.h, cursor: "nesw-resize" },
        { kind: "w", x: r.x, y: r.y + r.h / 2, cursor: "ew-resize" },
      ];
      handles.forEach((h) => {
        ctx.fillStyle = "rgba(37,99,235,0.92)";
        ctx.fillRect(h.x - hs / 2, h.y - hs / 2, hs, hs);
        ctx.strokeStyle = "rgba(255,255,255,0.98)";
        ctx.lineWidth = 1.1;
        ctx.strokeRect(h.x - hs / 2, h.y - hs / 2, hs, hs);
        transformHandles.push({ idx, x: h.x, y: h.y, size: hs, kind: h.kind, cursor: h.cursor });
      });
    });

    if (benchmarkDetections.length > 0) {
      for (const marker of benchmarkDetections) {
        const radius = Math.max(5, Math.min(18, marker.r || 6));
        ctx.beginPath();
        ctx.fillStyle = marker.color || "#ef4444";
        ctx.globalAlpha = 0.9;
        ctx.arc(marker.x, marker.y, radius, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
        ctx.strokeStyle = "rgba(255,255,255,0.98)";
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.beginPath();
        ctx.strokeStyle = "rgba(15,23,42,0.92)";
        ctx.lineWidth = 1;
        ctx.arc(marker.x, marker.y, Math.max(2, radius - 2), 0, Math.PI * 2);
        ctx.stroke();
      }
    }
  }

  function updateBaselineReadout() {
    if (!baselineReadoutEl || !drawingState) {
      if (baselineReadoutEl)
        baselineReadoutEl.textContent = "Baseline regions: waiting for drawing.";
      return;
    }
    if (baselineRegions.length === 0) {
      baselineReadoutEl.textContent = `Baseline regions: none (${baselineMode}).`;
      return;
    }
    const totalArea = baselineRegions.reduce((acc, r) => acc + r.w * r.h, 0);
    const pct = (totalArea / Math.max(1, drawingState.width * drawingState.height)) * 100;
    baselineReadoutEl.textContent = `Baseline regions: ${baselineRegions.length} (${pct.toFixed(1)}% combined canvas). Mode: ${baselineMode}.`;
  }

  function getCanvasPointer(evt) {
    if (!(drawingOverlay instanceof HTMLCanvasElement)) return null;
    const rect = drawingOverlay.getBoundingClientRect();
    const sx = drawingOverlay.width / Math.max(1, rect.width);
    const sy = drawingOverlay.height / Math.max(1, rect.height);
    return {
      x: (evt.clientX - rect.left) * sx,
      y: (evt.clientY - rect.top) * sy,
    };
  }

  function getHotspotAtPointer(evt) {
    const p = getCanvasPointer(evt);
    if (!p) return null;
    for (let i = deleteHotspots.length - 1; i >= 0; i -= 1) {
      const h = deleteHotspots[i];
      if (Math.hypot(p.x - h.cx, p.y - h.cy) <= h.radius + 2) return h;
    }
    return null;
  }

  function getTransformHandleAtPointer(evt) {
    const p = getCanvasPointer(evt);
    if (!p) return null;
    for (let i = transformHandles.length - 1; i >= 0; i -= 1) {
      const h = transformHandles[i];
      if (Math.abs(p.x - h.x) <= h.size && Math.abs(p.y - h.y) <= h.size) return h;
    }
    return null;
  }

  function getRegionAtPointer(evt) {
    const p = getCanvasPointer(evt);
    if (!p) return null;
    for (let i = baselineRegions.length - 1; i >= 0; i -= 1) {
      const r = baselineRegions[i];
      if (p.x >= r.x && p.y >= r.y && p.x <= r.x + r.w && p.y <= r.y + r.h) return { idx: i, r, p };
    }
    return null;
  }

  function applyResizeFromHandle(startRegion, handle, p) {
    if (!(drawingOverlay instanceof HTMLCanvasElement)) return { ...startRegion };
    const minSize = 20;
    const dx = p.x - dragState.startX;
    const dy = p.y - dragState.startY;
    let left = startRegion.x;
    let top = startRegion.y;
    let right = startRegion.x + startRegion.w;
    let bottom = startRegion.y + startRegion.h;

    if (handle.includes("w")) left += dx;
    if (handle.includes("e")) right += dx;
    if (handle.includes("n")) top += dy;
    if (handle.includes("s")) bottom += dy;

    if (right - left < minSize) {
      if (handle.includes("w")) left = right - minSize;
      else right = left + minSize;
    }
    if (bottom - top < minSize) {
      if (handle.includes("n")) top = bottom - minSize;
      else bottom = top + minSize;
    }

    left = clamp(left, 0, drawingOverlay.width - minSize);
    top = clamp(top, 0, drawingOverlay.height - minSize);
    right = clamp(right, left + minSize, drawingOverlay.width);
    bottom = clamp(bottom, top + minSize, drawingOverlay.height);

    return {
      x: Math.round(left),
      y: Math.round(top),
      w: Math.round(right - left),
      h: Math.round(bottom - top),
    };
  }

  function updateUndoUi() {
    if (!(undoRemoveBtn instanceof HTMLButtonElement)) return;
    if (removedRegionsUndo.length === 0) {
      undoRemoveBtn.setAttribute("disabled", "true");
      return;
    }
    undoRemoveBtn.removeAttribute("disabled");
  }

  function removeBaselineRegion(index) {
    if (!Number.isFinite(index) || index < 0 || index >= baselineRegions.length) return false;
    const removed = baselineRegions[index];
    removedRegionsUndo.push({
      index,
      region: { x: removed.x, y: removed.y, w: removed.w, h: removed.h },
    });
    if (removedRegionsUndo.length > 30) removedRegionsUndo.shift();
    baselineRegions.splice(index, 1);
    if (selectedRegionIdx === index) selectedRegionIdx = -1;
    else if (selectedRegionIdx > index) selectedRegionIdx -= 1;
    renderBaselineOverlay();
    updateBaselineReadout();
    updateUndoUi();
    setStatus(`Removed region ${index + 1}. ${baselineRegions.length} region(s) remaining.`);
    scheduleBenchmarkRun(40);
    return true;
  }

  function undoLastRemovedRegion() {
    const item = removedRegionsUndo.pop();
    if (!item) return false;
    const insertAt = clamp(item.index, 0, baselineRegions.length);
    baselineRegions.splice(insertAt, 0, item.region);
    selectedRegionIdx = insertAt;
    renderBaselineOverlay();
    updateBaselineReadout();
    updateUndoUi();
    setStatus(`Undo restore complete. ${baselineRegions.length} region(s) active.`);
    scheduleBenchmarkRun(40);
    return true;
  }

  async function handleDrawingUpload(file) {
    try {
      const type = file.type || "";
      const isPdf = type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf");
      trace("drawing.upload.start", {
        fileName: file.name,
        fileType: type,
        fileSizeBytes: file.size,
        isPdf,
      });
      let img = null;
      let pdfScaleUsed = null;
      if (isPdf) {
        const pdfResult = await renderPdfFirstPageToImage(file, PDF_RENDER_SCALE);
        img = pdfResult?.img || null;
        pdfScaleUsed = pdfResult?.scaleUsed ?? null;
      } else {
        img = await loadImageFromFile(file);
      }
      if (!img) {
        setStatus("Failed to load drawing file.");
        trace("drawing.upload.failed", { reason: "image-load-null" });
        return;
      }

      const { imageData, maxSideUsed } = renderImageDataWithFallback(
        drawingCanvas,
        img,
        DRAWING_RENDER_MAX_SIDE
      );
      if (!imageData) {
        setStatus("Failed to render drawing.");
        trace("drawing.upload.failed", { reason: "image-render-null" });
        return;
      }

      drawingState = {
        width: imageData.width,
        height: imageData.height,
        imageData,
        mask: imageToNeutralMask(imageData),
      };
      applyDrawingDisplayScale(1);

      const baseline = extractBaselineRegions(drawingState);
      baselineRegions = baseline.regions;
      baselineMode = baseline.mode;
      selectedRegionIdx = baselineRegions.length > 0 ? 0 : -1;
      removedRegionsUndo = [];
      dragState = null;

      renderBaselineOverlay();
      updateBaselineReadout();
      updateUndoUi();
      const qualitySuffix = isPdf
        ? ` [PDF scale ${pdfScaleUsed ?? "?"}, max side ${maxSideUsed}]`
        : ` [max side ${maxSideUsed}]`;
      setStatus(
        baselineRegions.length > 0
          ? `Drawing loaded. Baseline extracted ${baselineRegions.length} region(s).${qualitySuffix}`
          : `Drawing loaded. Baseline found no regions.${qualitySuffix}`
      );
      if (baselineRegions.length > 0) {
        openRegionFocusOverlayFirstRegion();
        scheduleBenchmarkRun(60);
      } else {
        closeRegionFocusOverlay();
        scheduleBenchmarkRun(60);
      }
      trace("drawing.upload.completed", {
        isPdf,
        pdfScaleUsed,
        maxSideUsed,
        drawingWidth: drawingState.width,
        drawingHeight: drawingState.height,
        baselineRegions: baselineRegions.length,
        baselineMode,
      });
    } catch (error) {
      console.warn("[DrawingAnalyzerLab] handleDrawingUpload failed after fallbacks", error);
      setStatus("Drawing load failed at maximum quality. Try upload again or use a smaller source.");
      trace("drawing.upload.failed", {
        reason: "exception",
        error: error instanceof Error ? error.message : String(error),
      });
    }
  }

  async function autoLoadDefaultDrawing() {
    if (drawingState) return;
    try {
      const resp = await fetch(DEFAULT_DRAWING_PUBLIC_PATH, { cache: "no-store" });
      if (!resp.ok) {
        setStatus(`Default drawing not found (${resp.status}). Upload manually if needed.`);
        return;
      }
      const blob = await resp.blob();
      const defaultFile = new File([blob], DEFAULT_DRAWING_FILE_NAME, {
        type: blob.type || "application/pdf",
      });
      setStatus(`Loaded default drawing from ${DEFAULT_DRAWING_PUBLIC_PATH}.`);
      await handleDrawingUpload(defaultFile);
    } catch (err) {
      console.warn("[DrawingAnalyzerLab] Failed to auto-load default drawing", err);
      setStatus("Could not auto-load default drawing. Upload manually if needed.");
    }
  }

  drawingFileInput?.addEventListener("change", async (e) => {
    const target = e.target;
    const file = target instanceof HTMLInputElement ? target.files?.[0] : null;
    if (file) await handleDrawingUpload(file);
  });

  zoomOutBtn?.addEventListener("click", () => {
    applyDrawingDisplayScale(drawingDisplayScale * 0.9);
  });

  zoomResetBtn?.addEventListener("click", () => {
    applyDrawingDisplayScale(1);
  });

  zoomInBtn?.addEventListener("click", () => {
    applyDrawingDisplayScale(drawingDisplayScale * 1.1);
  });

  drawingStage?.addEventListener(
    "wheel",
    (evt) => {
      if (!(drawingStage instanceof HTMLElement)) return;
      if (!(evt.ctrlKey || evt.metaKey)) return;
      evt.preventDefault();
      const stageRect = drawingStage.getBoundingClientRect();
      const cursorX = evt.clientX - stageRect.left;
      const cursorY = evt.clientY - stageRect.top;
      const contentX = drawingStage.scrollLeft + cursorX;
      const contentY = drawingStage.scrollTop + cursorY;
      const prevScale = drawingDisplayScale;
      const factor = evt.deltaY < 0 ? 1.1 : 0.9;
      const nextScale = clamp(prevScale * factor, MAIN_MIN_ZOOM, MAIN_MAX_ZOOM);
      if (Math.abs(nextScale - prevScale) < 0.0001) return;
      applyDrawingDisplayScale(nextScale);
      const ratio = nextScale / prevScale;
      drawingStage.scrollLeft = contentX * ratio - cursorX;
      drawingStage.scrollTop = contentY * ratio - cursorY;
      trace("drawing.zoom", {
        prevScale: Number(prevScale.toFixed(3)),
        nextScale: Number(nextScale.toFixed(3)),
        scrollLeft: drawingStage.scrollLeft,
        scrollTop: drawingStage.scrollTop,
      });
    },
    { passive: false }
  );


  tabWorkspaceBtn?.addEventListener("click", () => setActiveTab("workspace"));
  tabItemLibraryBtn?.addEventListener("click", () => setActiveTab("item-library"));

  libraryRefreshBtn?.addEventListener("click", async () => {
    await loadLibraryFromFolder();
  });

  librarySaveBtn?.addEventListener("click", async () => {
    await saveLibraryMetadata();
  });

  itemLibraryListEl?.addEventListener("click", (evt) => {
    const target = evt.target instanceof HTMLElement ? evt.target : null;
    if (!target) return;
    const actionEl = target.closest("[data-action]");
    if (!(actionEl instanceof HTMLElement)) return;
    const action = actionEl.dataset.action;
    const itemFile = String(actionEl.dataset.itemFile || "");
    if (!itemFile) return;
    const itemIndex = itemLibrary.findIndex((it) => it.fileName === itemFile);
    const item = itemIndex >= 0 ? itemLibrary[itemIndex] : null;
    if (!item) return;

    if (action === "move-up") {
      if (itemIndex <= 0) return;
      const prev = itemLibrary[itemIndex - 1];
      itemLibrary[itemIndex - 1] = item;
      itemLibrary[itemIndex] = prev;
      itemLibrary = itemLibrary.map((it, idx) => ({ ...it, priority: idx + 1 }));
      renderItemLibrary();
      setStatus(`Moved "${item.displayName}" up.`);
      scheduleBenchmarkRun(40);
      return;
    }

    if (action === "move-down") {
      if (itemIndex >= itemLibrary.length - 1) return;
      const next = itemLibrary[itemIndex + 1];
      itemLibrary[itemIndex + 1] = item;
      itemLibrary[itemIndex] = next;
      itemLibrary = itemLibrary.map((it, idx) => ({ ...it, priority: idx + 1 }));
      renderItemLibrary();
      setStatus(`Moved "${item.displayName}" down.`);
      scheduleBenchmarkRun(40);
      return;
    }

    if (action === "add-dep") {
      const idx = Number(actionEl.dataset.itemIndex);
      const depSelect = document.getElementById(`dep-select-${idx}`);
      const depQty = document.getElementById(`dep-qty-${idx}`);
      const depFile = depSelect instanceof HTMLSelectElement ? String(depSelect.value || "") : "";
      const qtyRaw = depQty instanceof HTMLInputElement ? Number(depQty.value) : 1;
      const qty = Number.isFinite(qtyRaw) ? Math.max(1, Math.round(qtyRaw)) : 1;
      if (!depFile || depFile === item.fileName) {
        setStatus("Choose a valid dependency item.");
        return;
      }
      const existing = item.dependencies.find((d) => d.fileName === depFile);
      if (existing) existing.qty = qty;
      else item.dependencies.push({ fileName: depFile, qty });
      renderItemLibrary();
      setStatus(`Updated dependencies for "${item.displayName}".`);
      scheduleBenchmarkRun(40);
      return;
    }

    if (action === "remove-dep") {
      const depFile = String(actionEl.dataset.depFile || "");
      item.dependencies = item.dependencies.filter((dep) => dep.fileName !== depFile);
      renderItemLibrary();
      setStatus(`Dependency removed from "${item.displayName}".`);
      scheduleBenchmarkRun(40);
    }
  });

  itemLibraryListEl?.addEventListener("input", (evt) => {
    const target = evt.target instanceof HTMLElement ? evt.target : null;
    if (!(target instanceof HTMLInputElement)) return;
    if (target.dataset.action !== "price") return;
    const itemFile = String(target.dataset.itemFile || "");
    if (!itemFile) return;
    const item = itemLibrary.find((it) => it.fileName === itemFile);
    if (!item) return;
    const value = Number(target.value || 0);
    item.price = Number.isFinite(value) ? Math.max(0, value) : 0;
    scheduleBenchmarkRun(120);
  });

  drawingOverlay?.addEventListener("pointerdown", (evt) => {
    const deleteHit = getHotspotAtPointer(evt);
    if (deleteHit) {
      evt.preventDefault();
      evt.stopPropagation();
      removeBaselineRegion(deleteHit.idx);
      return;
    }
    const handleHit = getTransformHandleAtPointer(evt);
    if (handleHit) {
      const p = getCanvasPointer(evt);
      const r = baselineRegions[handleHit.idx];
      if (!p || !r) return;
      selectedRegionIdx = handleHit.idx;
      dragState = {
        idx: handleHit.idx,
        mode: "resize",
        handle: handleHit.kind,
        startX: p.x,
        startY: p.y,
        startRegion: { x: r.x, y: r.y, w: r.w, h: r.h },
      };
      renderBaselineOverlay();
      drawingOverlay?.setPointerCapture?.(evt.pointerId);
      return;
    }
    const regionHit = getRegionAtPointer(evt);
    if (!regionHit) {
      if (selectedRegionIdx !== -1) {
        selectedRegionIdx = -1;
        renderBaselineOverlay();
      }
      return;
    }
    selectedRegionIdx = regionHit.idx;
    dragState = {
      idx: regionHit.idx,
      mode: "move",
      offsetX: regionHit.p.x - regionHit.r.x,
      offsetY: regionHit.p.y - regionHit.r.y,
      startRegion: { x: regionHit.r.x, y: regionHit.r.y, w: regionHit.r.w, h: regionHit.r.h },
    };
    renderBaselineOverlay();
    drawingOverlay?.setPointerCapture?.(evt.pointerId);
  });

  drawingOverlay?.addEventListener("pointermove", (evt) => {
    if (!(drawingOverlay instanceof HTMLCanvasElement)) return;
    const p = getCanvasPointer(evt);
    if (!p) return;
    if (dragState) {
      const region = baselineRegions[dragState.idx];
      if (!region) return;
      if (dragState.mode === "move") {
        region.x = clamp(Math.round(p.x - dragState.offsetX), 0, drawingOverlay.width - region.w);
        region.y = clamp(Math.round(p.y - dragState.offsetY), 0, drawingOverlay.height - region.h);
      } else if (dragState.mode === "resize") {
        const resized = applyResizeFromHandle(
          dragState.startRegion,
          String(dragState.handle || "se"),
          p
        );
        region.x = resized.x;
        region.y = resized.y;
        region.w = resized.w;
        region.h = resized.h;
      }
      renderBaselineOverlay();
      updateBaselineReadout();
      if (dragState.mode === "resize") {
        const cursorByHandle = {
          n: "ns-resize",
          s: "ns-resize",
          e: "ew-resize",
          w: "ew-resize",
          ne: "nesw-resize",
          sw: "nesw-resize",
          nw: "nwse-resize",
          se: "nwse-resize",
        };
        drawingOverlay.style.cursor =
          cursorByHandle[String(dragState.handle || "se")] || "nwse-resize";
      } else {
        drawingOverlay.style.cursor = "move";
      }
      return;
    }
    const hotspot = getHotspotAtPointer(evt);
    if (hotspot) {
      drawingOverlay.style.cursor = "pointer";
      return;
    }
    const handle = getTransformHandleAtPointer(evt);
    if (handle) {
      drawingOverlay.style.cursor = handle.cursor || "nwse-resize";
      return;
    }
    const region = getRegionAtPointer(evt);
    drawingOverlay.style.cursor = region ? "move" : "default";
  });

  drawingOverlay?.addEventListener("pointerup", (evt) => {
    if (!dragState) return;
    drawingOverlay?.releasePointerCapture?.(evt.pointerId);
    const mode = dragState.mode;
    dragState = null;
    setStatus(mode === "resize" ? "Region size updated." : "Region position updated.");
    trace("baseline.region.updated", {
      mode,
      selectedRegionIdx,
      baselineRegions: baselineRegions.length,
    });
    scheduleBenchmarkRun(40);
  });

  drawingOverlay?.addEventListener("pointerleave", () => {
    if (!dragState && drawingOverlay instanceof HTMLCanvasElement)
      drawingOverlay.style.cursor = "default";
  });

  undoRemoveBtn?.addEventListener("click", () => {
    undoLastRemovedRegion();
  });

  function setBenchmarkCollapsed(collapsed) {
    isBenchmarkCollapsed = Boolean(collapsed);
    benchmarkBodyEl?.classList.toggle("hidden", isBenchmarkCollapsed);
    if (benchmarkCollapseBtn instanceof HTMLButtonElement) {
      benchmarkCollapseBtn.textContent = isBenchmarkCollapsed ? "Expand" : "Collapse";
      benchmarkCollapseBtn.setAttribute("aria-expanded", String(!isBenchmarkCollapsed));
    }
    benchmarkPanelEl?.classList.toggle("w-[340px]", !isBenchmarkCollapsed);
    benchmarkPanelEl?.classList.toggle("w-[220px]", isBenchmarkCollapsed);
  }

  function setDiagnosticsCollapsed(collapsed) {
    isDiagnosticsCollapsed = Boolean(collapsed);
    diagnosticsBodyEl?.classList.toggle("hidden", isDiagnosticsCollapsed);
    if (diagnosticsCollapseBtn instanceof HTMLButtonElement) {
      diagnosticsCollapseBtn.textContent = isDiagnosticsCollapsed ? "Expand" : "Collapse";
      diagnosticsCollapseBtn.setAttribute("aria-expanded", String(!isDiagnosticsCollapsed));
    }
    diagnosticsPanelEl?.classList.toggle("w-[380px]", !isDiagnosticsCollapsed);
    diagnosticsPanelEl?.classList.toggle("w-[220px]", isDiagnosticsCollapsed);
  }

  benchmarkCollapseBtn?.addEventListener("click", () => {
    setBenchmarkCollapsed(!isBenchmarkCollapsed);
  });

  diagnosticsCollapseBtn?.addEventListener("click", () => {
    setDiagnosticsCollapsed(!isDiagnosticsCollapsed);
  });

  benchmarkConfidenceEl?.addEventListener("input", () => {
    if (!(benchmarkConfidenceEl instanceof HTMLInputElement)) return;
    const raw = Number(benchmarkConfidenceEl.value || 64);
    benchmarkConfidence = clamp(raw / 100, 0, 1);
    renderBenchmarkPanel();
    scheduleBenchmarkRun(60);
  });

  benchmarkHeaderEl?.addEventListener("pointerdown", (evt) => {
    const target = evt.target instanceof HTMLElement ? evt.target : null;
    if (target?.closest("#lab-benchmark-collapse-btn")) return;
    if (!(benchmarkPanelEl instanceof HTMLElement)) return;
    const rect = benchmarkPanelEl.getBoundingClientRect();
    benchmarkDrag = {
      offsetX: evt.clientX - rect.left,
      offsetY: evt.clientY - rect.top,
    };
    benchmarkPanelEl.style.left = `${Math.round(rect.left)}px`;
    benchmarkPanelEl.style.top = `${Math.round(rect.top)}px`;
    benchmarkPanelEl.style.right = "auto";
    benchmarkPanelEl.style.bottom = "auto";
    benchmarkHeaderEl.setPointerCapture?.(evt.pointerId);
    benchmarkHeaderEl.style.cursor = "grabbing";
    evt.preventDefault();
  });

  benchmarkHeaderEl?.addEventListener("pointermove", (evt) => {
    if (!benchmarkDrag || !(benchmarkPanelEl instanceof HTMLElement)) return;
    const nextLeft = clamp(
      Math.round(evt.clientX - benchmarkDrag.offsetX),
      4,
      Math.max(4, window.innerWidth - benchmarkPanelEl.offsetWidth - 4)
    );
    const nextTop = clamp(
      Math.round(evt.clientY - benchmarkDrag.offsetY),
      4,
      Math.max(4, window.innerHeight - benchmarkPanelEl.offsetHeight - 4)
    );
    benchmarkPanelEl.style.left = `${nextLeft}px`;
    benchmarkPanelEl.style.top = `${nextTop}px`;
  });

  benchmarkHeaderEl?.addEventListener("pointerup", (evt) => {
    benchmarkDrag = null;
    benchmarkHeaderEl.releasePointerCapture?.(evt.pointerId);
    benchmarkHeaderEl.style.cursor = "grab";
  });

  benchmarkHeaderEl?.addEventListener("pointercancel", () => {
    benchmarkDrag = null;
    if (benchmarkHeaderEl instanceof HTMLElement) benchmarkHeaderEl.style.cursor = "grab";
  });

  regionFocusCloseBtn?.addEventListener("click", () => {
    closeRegionFocusOverlay();
  });

  regionFocusOverlayEl?.addEventListener("click", (evt) => {
    if (evt.target === regionFocusOverlayEl) closeRegionFocusOverlay();
  });

  regionFocusViewportEl?.addEventListener(
    "wheel",
    (evt) => {
      if (!(regionFocusOverlayEl instanceof HTMLElement)) return;
      if (regionFocusOverlayEl.classList.contains("hidden")) return;
      evt.preventDefault();
      const factor = evt.deltaY < 0 ? 1.08 : 0.92;
      regionFocusScale = clamp(regionFocusScale * factor, FOCUS_MIN_ZOOM, FOCUS_MAX_ZOOM);
      applyRegionFocusTransform();
      trace("focus.zoom", {
        nextScale: Number(regionFocusScale.toFixed(3)),
        offsetX: Math.round(regionFocusOffsetX),
        offsetY: Math.round(regionFocusOffsetY),
      });
    },
    { passive: false }
  );

  regionFocusCanvasEl?.addEventListener("pointerdown", (evt) => {
    if (!(regionFocusCanvasEl instanceof HTMLCanvasElement)) return;
    if (evt.button !== 0) return;
    regionFocusDrag = {
      startX: evt.clientX,
      startY: evt.clientY,
      offsetX: regionFocusOffsetX,
      offsetY: regionFocusOffsetY,
    };
    regionFocusCanvasEl.setPointerCapture?.(evt.pointerId);
    applyRegionFocusTransform();
    evt.preventDefault();
  });

  regionFocusCanvasEl?.addEventListener("pointermove", (evt) => {
    if (!regionFocusDrag) return;
    regionFocusOffsetX = regionFocusDrag.offsetX + (evt.clientX - regionFocusDrag.startX);
    regionFocusOffsetY = regionFocusDrag.offsetY + (evt.clientY - regionFocusDrag.startY);
    applyRegionFocusTransform();
  });

  regionFocusCanvasEl?.addEventListener("pointerup", (evt) => {
    if (!(regionFocusCanvasEl instanceof HTMLCanvasElement)) return;
    regionFocusDrag = null;
    regionFocusCanvasEl.releasePointerCapture?.(evt.pointerId);
    applyRegionFocusTransform();
    trace("focus.pan.end", {
      offsetX: Math.round(regionFocusOffsetX),
      offsetY: Math.round(regionFocusOffsetY),
      scale: Number(regionFocusScale.toFixed(3)),
    });
  });

  regionFocusCanvasEl?.addEventListener("pointercancel", (evt) => {
    if (!(regionFocusCanvasEl instanceof HTMLCanvasElement)) return;
    regionFocusDrag = null;
    regionFocusCanvasEl.releasePointerCapture?.(evt.pointerId);
    applyRegionFocusTransform();
  });

  document.addEventListener("keydown", (evt) => {
    if (evt.key === "Escape") closeRegionFocusOverlay();
  });

  setActiveTab("workspace");
  renderItemLibrary();
  renderBenchmarkPanel();
  renderDiagnosticsPanel();
  setBenchmarkCollapsed(false);
  setDiagnosticsCollapsed(false);
  updateZoomReadout();
  if (benchmarkHeaderEl instanceof HTMLElement) benchmarkHeaderEl.style.cursor = "grab";
  updateUndoUi();
  updateBaselineReadout();
  void loadLibraryFromFolder();
  void autoLoadDefaultDrawing();
</script>
