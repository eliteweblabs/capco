---
/**
 * Clone & Deploy – Admin/SuperAdmin only
 * Form to enter Railway + Supabase config, then generate clone script / .env.
 * Values are generated client-side only; nothing is sent to the server.
 * Route at /clone-deploy to avoid catch-all [...slug] shadowing /admin/* in server mode.
 */
import { checkAuth } from "../lib/auth";
import { isAdminOrSuperAdmin } from "../lib/user-utils";
import LayoutFullWidth from "../components/layouts/LayoutFullWidth.astro";
import { globalClasses } from "./api/global/global-classes";

const { currentUser, session, currentRole } = await checkAuth(Astro.cookies);

if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}

if (!isAdminOrSuperAdmin(currentRole)) {
  return Astro.redirect("/project/dashboard");
}

const { globalFormClasses, globalInputClasses, globalFormLabel, globalCardStyle } = globalClasses();
---

<LayoutFullWidth
  title="Clone & Deploy"
  classList="p-4"
  description="Generate clone script and env file for cloning a Railway site + Supabase database. Admin only."
>
  <div class="px-4 py-8">
    <div class="mb-6">
      <h1 class="mb-2 text-3xl font-bold">Clone & Deploy</h1>
      <p class="text-gray-600 dark:text-gray-400">
        Enter source and destination config for Railway + Supabase. Values are used client-side only
        to generate a script and .env file—nothing is sent to the server.
      </p>
      <p class="mt-2 text-sm text-amber-600 dark:text-amber-400">
        Activate SuperAdmin first at <a href="/admin/super-admin" class="underline">SuperAdmin</a> if
        you need access.
      </p>
    </div>

    <div
      id="clone-message"
      class="mb-4 hidden rounded-lg border p-4"
      role="alert"
      aria-live="polite"
    >
    </div>

    <form id="clone-deploy-form" class={globalFormClasses}>
      <div class={`space-y-6 ${globalCardStyle} p-6`}>
        <section>
          <h2 class="mb-4 text-lg font-semibold">Source (clone FROM)</h2>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="source_supabase_ref" class={globalFormLabel}>
                Source Supabase project ref
              </label>
              <input
                type="text"
                id="source_supabase_ref"
                name="source_supabase_ref"
                class={globalInputClasses}
                placeholder="e.g. qudlxlryegnainztkrtk"
              />
              <p class="mt-1 text-xs text-gray-500">
                From <code class="rounded bg-gray-100 px-1 dark:bg-gray-800"
                  >https://XXX.supabase.co</code
                >
              </p>
            </div>
            <div>
              <label for="source_supabase_db_password" class={globalFormLabel}>
                Source DB password
              </label>
              <input
                type="password"
                id="source_supabase_db_password"
                name="source_supabase_db_password"
                class={globalInputClasses}
                autocomplete="off"
                placeholder="From Supabase Dashboard > Database"
              />
            </div>
          </div>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">Destination (clone TO)</h2>
          <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
            Create a new Supabase project first at supabase.com, then fill these.
          </p>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="dest_supabase_ref" class={globalFormLabel}>
                Dest Supabase project ref
              </label>
              <input
                type="text"
                id="dest_supabase_ref"
                name="dest_supabase_ref"
                class={globalInputClasses}
                placeholder="e.g. abcdefghijk"
              />
            </div>
            <div>
              <label for="dest_supabase_db_password" class={globalFormLabel}>
                Dest DB password
              </label>
              <input
                type="password"
                id="dest_supabase_db_password"
                name="dest_supabase_db_password"
                class={globalInputClasses}
                autocomplete="off"
              />
            </div>
            <div>
              <label for="dest_supabase_anon_key" class={globalFormLabel}>
                Dest anon key (public)
              </label>
              <input
                type="text"
                id="dest_supabase_anon_key"
                name="dest_supabase_anon_key"
                class={`${globalInputClasses} font-mono text-xs`}
                placeholder="eyJhbGciOiJIUzI1NiIs..."
              />
              <p class="mt-1 text-xs text-gray-500">Supabase Dashboard &gt; API</p>
            </div>
            <div>
              <label for="dest_supabase_service_role_key" class={globalFormLabel}>
                Dest service role key (secret)
              </label>
              <input
                type="password"
                id="dest_supabase_service_role_key"
                name="dest_supabase_service_role_key"
                class={`${globalInputClasses} font-mono text-xs`}
                autocomplete="off"
                placeholder="eyJhbGciOiJIUzI1NiIs..."
              />
            </div>
          </div>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">Railway (for checklist)</h2>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="dest_railway_project_name" class={globalFormLabel}>
                New Railway project name
              </label>
              <input
                type="text"
                id="dest_railway_project_name"
                name="dest_railway_project_name"
                class={globalInputClasses}
                placeholder="e.g. New Client Fire Protection"
              />
            </div>
            <div>
              <label for="dest_railway_domain" class={globalFormLabel}>
                Railway domain (optional)
              </label>
              <input
                type="text"
                id="dest_railway_domain"
                name="dest_railway_domain"
                class={globalInputClasses}
                placeholder="e.g. client.up.railway.app"
              />
            </div>
            <div class="md:col-span-2">
              <label for="github_repo" class={globalFormLabel}>
                GitHub repo (optional, for checklist)
              </label>
              <input
                type="text"
                id="github_repo"
                name="github_repo"
                class={globalInputClasses}
                placeholder="e.g. owner/repo-name"
              />
            </div>
          </div>
        </section>

        <section>
          <label class="flex items-center gap-2">
            <input
              type="checkbox"
              id="use_docker"
              name="use_docker"
              class="rounded border-gray-300"
            />
            <span class="text-sm">Use Docker for pg_dump/psql (if postgres not installed)</span>
          </label>
        </section>

        <div class="flex flex-wrap gap-3">
          <button
            type="button"
            id="btn-generate-env"
            class="rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600"
          >
            Generate .env file
          </button>
          <button
            type="button"
            id="btn-generate-checklist"
            class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"
          >
            Generate Railway checklist
          </button>
        </div>
      </div>
    </form>

    <div class="mt-6">
      <h3 class="mb-2 text-lg font-semibold">Usage</h3>
      <ol class="list-inside list-decimal space-y-1 text-sm text-gray-600 dark:text-gray-400">
        <li>Fill in the form above (create dest Supabase project first)</li>
        <li>
          Click &quot;Generate .env file&quot; and save as <code
            class="rounded bg-gray-100 px-1 dark:bg-gray-800">scripts/clone-site-and-db.env</code
          >
        </li>
        <li>
          Run <code class="rounded bg-gray-100 px-1 dark:bg-gray-800"
            >./scripts/clone-site-and-db.sh</code
          > locally
        </li>
        <li>Use the Railway checklist output to configure your new Railway project</li>
      </ol>
      <p class="mt-3 text-xs text-gray-500">
        See <code class="rounded bg-gray-100 px-1 dark:bg-gray-800"
          >scripts/clone-site-and-db.example.env</code
        > and
        <code class="rounded bg-gray-100 px-1 dark:bg-gray-800"
          >markdowns/MULTI_CLIENT_SETUP_GUIDE.md</code
        >.
      </p>
    </div>
  </div>
</LayoutFullWidth>

<script>
  (function () {
    const messageEl = document.getElementById("clone-message");
    const form = document.getElementById("clone-deploy-form");

    function showMessage(text, isError) {
      if (!messageEl) return;
      messageEl.classList.remove("hidden");
      messageEl.classList.toggle(
        "border-green-200 bg-green-50 dark:border-green-800 dark:bg-green-900/20",
        !isError
      );
      messageEl.classList.toggle(
        "border-red-200 bg-red-50 dark:border-red-800 dark:bg-red-900/20",
        isError
      );
      messageEl.textContent = text;
    }

    function getFormValue(id) {
      const el = document.getElementById(id);
      return el?.value?.trim() ?? "";
    }

    function download(content, filename) {
      const blob = new Blob([content], { type: "text/plain" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      URL.revokeObjectURL(a.href);
    }

    document.getElementById("btn-generate-env")?.addEventListener("click", () => {
      const sourceRef = getFormValue("source_supabase_ref");
      const sourcePass = getFormValue("source_supabase_db_password");
      const destRef = getFormValue("dest_supabase_ref");
      const destPass = getFormValue("dest_supabase_db_password");
      const destAnon = getFormValue("dest_supabase_anon_key");
      const destService = getFormValue("dest_supabase_service_role_key");
      const railwayName = getFormValue("dest_railway_project_name") || "New Client Site";
      const railwayDomain = getFormValue("dest_railway_domain");
      const githubRepo = getFormValue("github_repo");
      const useDocker = document.getElementById("use_docker")?.checked ? "1" : "0";

      if (!sourceRef || !sourcePass || !destRef || !destPass || !destAnon || !destService) {
        showMessage(
          "Fill in all required fields (source ref/password, dest ref/password/anon/service_role).",
          true
        );
        return;
      }

      const lines = [
        "# Clone Site + DB – generated from /clone-deploy",
        "# Copy to scripts/clone-site-and-db.env",
        "",
        "SOURCE_SUPABASE_REF=" + sourceRef,
        "SOURCE_SUPABASE_DB_PASSWORD=" + sourcePass,
        "",
        "DEST_SUPABASE_REF=" + destRef,
        "DEST_SUPABASE_DB_PASSWORD=" + destPass,
        "DEST_SUPABASE_ANON_KEY=" + destAnon,
        "DEST_SUPABASE_SERVICE_ROLE_KEY=" + destService,
        "",
        "DEST_RAILWAY_PROJECT_NAME=" + railwayName,
        railwayDomain ? "DEST_RAILWAY_DOMAIN=" + railwayDomain : "# DEST_RAILWAY_DOMAIN=",
        githubRepo ? "GITHUB_REPO=" + githubRepo : "# GITHUB_REPO=",
        "",
        "USE_DOCKER_FOR_PG_DUMP=" + useDocker,
      ];
      const content = lines.filter((l) => l || l === "").join("\n");
      download(content, "clone-site-and-db.env");
      showMessage(
        "Saved clone-site-and-db.env. Place it in scripts/ and run ./scripts/clone-site-and-db.sh",
        false
      );
    });

    document.getElementById("btn-generate-checklist")?.addEventListener("click", () => {
      const destRef = getFormValue("dest_supabase_ref");
      const destAnon = getFormValue("dest_supabase_anon_key");
      const destService = getFormValue("dest_supabase_service_role_key");
      const railwayName = getFormValue("dest_railway_project_name") || "New Client Site";
      const railwayDomain = getFormValue("dest_railway_domain");
      const githubRepo = getFormValue("github_repo");

      if (!destRef || !destAnon || !destService) {
        showMessage("Fill in dest Supabase ref, anon key, and service role key.", true);
        return;
      }

      const lines = [
        "# Railway Variables Checklist",
        "# Add these to your new Railway project",
        "",
        'RAILWAY_PROJECT_NAME="' + railwayName + '"',
        'PUBLIC_SUPABASE_URL="https://' + destRef + '.supabase.co"',
        'PUBLIC_SUPABASE_PUBLISHABLE="' + destAnon + '"',
        'SUPABASE_SECRET="' + destService + '"',
        railwayDomain
          ? 'RAILWAY_PUBLIC_DOMAIN="' + railwayDomain + '"'
          : "# RAILWAY_PUBLIC_DOMAIN=",
        "",
        "# See markdowns/MULTI_CLIENT_SETUP_GUIDE.md for full checklist",
      ];
      const content = lines.join("\n");
      download(content, "railway-variables-checklist.txt");
      showMessage(
        "Saved Railway checklist. Configure your Railway project with these variables.",
        false
      );
    });
  })();
</script>
