---
/**
 * Clone & Deploy – Admin/superAdmin only
 * Simple form: enter new site name + URL, copy current Supabase DB and Railway config to new deployment.
 * Source = this site (auto-filled). User creates new Supabase project, pastes credentials.
 */
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { globalClasses } from "../api/global/global-classes";

const { currentUser, session, currentRole } = await checkAuth(Astro.cookies);

if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}

const role = currentRole ?? currentUser?.profile?.role;
if (!isAdminOrSuperAdmin(role)) {
  return Astro.redirect("/project/dashboard");
}

const { globalFormClasses, globalInputClasses, globalFormLabel, globalCardStyle } = globalClasses();
---

<LayoutFullWidth
  title="Clone & Deploy"
  classList="p-4"
  description="Clone current site and database to a new deployment. Enter new site name and URL."
>
  <div class="px-4 py-8">
    <div class="mb-6">
      <h1 class="mb-2 text-3xl font-bold">Clone & Deploy</h1>
      <p class="text-gray-600 dark:text-gray-400">
        Copy the current Supabase database and Railway project to a new site. Enter the new site name
        and URL, create a new Supabase project, then generate the script.
      </p>
    </div>

    <div
      id="clone-message"
      class="mb-4 hidden rounded-lg border p-4"
      role="alert"
      aria-live="polite"
    >
    </div>

    <form id="clone-deploy-form" class={globalFormClasses}>
      <div class={`space-y-6 ${globalCardStyle} p-6`}>
        <section>
          <h2 class="mb-4 text-lg font-semibold">Source (this site – auto-filled)</h2>
          <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
            We use the current deployment as source. Source ref and DB password come from your deployment env (SUPABASE_DB_PASSWORD).
          </p>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="source_supabase_ref" class={globalFormLabel}>
                Current Supabase project ref
              </label>
              <input
                type="text"
                id="source_supabase_ref"
                name="source_supabase_ref"
                class={globalInputClasses}
                readonly
                autocomplete="off"
                placeholder="Loading…”
              />
            </div>
          </div>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">New site</h2>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="dest_site_name" class={globalFormLabel}>
                New site name
              </label>
              <input
                type="text"
                id="dest_site_name"
                name="dest_site_name"
                class={globalInputClasses}
                autocomplete="off"
                placeholder="e.g. New Client Fire Protection"
              />
            </div>
            <div>
              <label for="dest_site_url" class={globalFormLabel}>
                New site URL
              </label>
              <input
                type="text"
                id="dest_site_url"
                name="dest_site_url"
                class={globalInputClasses}
                autocomplete="off"
                placeholder="e.g. client.up.railway.app"
              />
            </div>
          </div>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">New Supabase project</h2>
          <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
            Create a new project at supabase.com, then paste these from the Dashboard.
          </p>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <label for="dest_supabase_ref" class={globalFormLabel}>
                New project ref
              </label>
              <input
                type="text"
                id="dest_supabase_ref"
                name="dest_supabase_ref"
                class={globalInputClasses}
                autocomplete="off"
                placeholder="e.g. abcdefghijk"
              />
            </div>
            <div>
              <label for="dest_supabase_db_password" class={globalFormLabel}>
                New DB password
              </label>
              <input
                type="password"
                id="dest_supabase_db_password"
                name="dest_supabase_db_password"
                class={globalInputClasses}
                autocomplete="new-password"
              />
            </div>
            <div>
              <label for="dest_supabase_anon_key" class={globalFormLabel}>
                Anon key (public)
              </label>
              <input
                type="text"
                id="dest_supabase_anon_key"
                name="dest_supabase_anon_key"
                class={`${globalInputClasses} font-mono text-xs`}
                autocomplete="off"
                placeholder="eyJhbGciOiJIUzI1NiIs..."
              />
            </div>
            <div>
              <label for="dest_supabase_service_role_key" class={globalFormLabel}>
                Service role key (secret)
              </label>
              <input
                type="password"
                id="dest_supabase_service_role_key"
                name="dest_supabase_service_role_key"
                class={`${globalInputClasses} font-mono text-xs`}
                autocomplete="new-password"
                placeholder="eyJhbGciOiJIUzI1NiIs..."
              />
            </div>
          </div>
        </section>

        <section>
          <label class="flex items-center gap-2">
            <input
              type="checkbox"
              id="use_docker"
              name="use_docker"
              class="rounded border-gray-300"
            />
            <span class="text-sm">Use Docker for pg_dump/psql (if postgres not installed locally)</span>
          </label>
        </section>

        <div class="flex flex-wrap gap-3">
          <button
            type="button"
            id="btn-generate-env"
            class="rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600"
          >
            Generate .env file
          </button>
          <button
            type="button"
            id="btn-generate-checklist"
            class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"
          >
            Generate Railway checklist
          </button>
        </div>
      </div>
    </form>

    <div class="mt-6">
      <h3 class="mb-2 text-lg font-semibold">Usage</h3>
      <ol class="list-inside list-decimal space-y-1 text-sm text-gray-600 dark:text-gray-400">
        <li>Create a new Supabase project at supabase.com</li>
        <li>Fill in the form above (new site name, URL, and new Supabase credentials). Source uses SUPABASE_DB_PASSWORD from env.</li>
        <li>Click &quot;Generate .env file&quot; and save as <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">scripts/clone-site-and-db.env</code></li>
        <li>Run <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">./scripts/clone-site-and-db.sh</code> locally</li>
        <li>Create Railway project from GitHub, add variables from the checklist</li>
      </ol>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
        See <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">markdowns/RAILWAY-CLONE-PROJECT.md</code> for how to create a new Railway project from the same repo.
      </p>
    </div>

    <div class={`mt-6 ${globalCardStyle} p-6`}>
      <h3 class="mb-2 text-lg font-semibold">Clone via MCP (Cursor AI)</h3>
      <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
        In Cursor, you can ask the AI to clone a site using Railway and Supabase MCP tools. The AI can create a new Supabase project, create/link a Railway project, set env vars, and run the DB clone script. Source DB password comes from SUPABASE_DB_PASSWORD in env.
      </p>
      <p class="mb-2 text-sm font-medium">Prompt to use:</p>
      <blockquote class="rounded-lg border border-gray-200 bg-gray-50 p-4 font-mono text-sm dark:border-gray-600 dark:bg-gray-800">
        Clone a new site: name &quot;[New Site Name]&quot;, URL [e.g. client.up.railway.app]. Use Supabase MCP to create the new project, run the clone script (source from SUPABASE_DB_PASSWORD), and Railway MCP to create the project and set variables.
      </blockquote>
      <p class="mt-2 text-xs text-gray-500">
        MCP can create Supabase project + Railway project + set vars. DB clone uses SUPABASE_DB_PASSWORD from env via <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">./scripts/clone-site-and-db.sh</code>.
      </p>
    </div>
  </div>
</LayoutFullWidth>

<script define:vars={{ apiBase: "/api/admin/clone-config", generateEnvUrl: "/api/admin/clone-generate-env" }}>
  (function () {
    const messageEl = document.getElementById("clone-message");
    const sourceRefEl = document.getElementById("source_supabase_ref");

    async function loadSourceConfig() {
      try {
        const res = await fetch(apiBase, { credentials: "include" });
        if (!res.ok) return;
        const data = await res.json();
        if (data.sourceSupabaseRef && sourceRefEl) {
          sourceRefEl.placeholder = "";
          sourceRefEl.value = data.sourceSupabaseRef;
        }
      } catch {
        if (sourceRefEl) sourceRefEl.placeholder = "Not available (run on deployed site)";
      }
    }

    loadSourceConfig();

    function showMessage(text, isError) {
      if (!messageEl) return;
      messageEl.classList.remove("hidden");
      const successClasses = ["border-green-200", "bg-green-50", "dark:border-green-800", "dark:bg-green-900/20"];
      const errorClasses = ["border-red-200", "bg-red-50", "dark:border-red-800", "dark:bg-red-900/20"];
      if (isError) {
        successClasses.forEach((c) => messageEl.classList.remove(c));
        errorClasses.forEach((c) => messageEl.classList.add(c));
      } else {
        errorClasses.forEach((c) => messageEl.classList.remove(c));
        successClasses.forEach((c) => messageEl.classList.add(c));
      }
      messageEl.textContent = text;
    }

    function getFormValue(id) {
      const el = document.getElementById(id);
      return el?.value?.trim() ?? "";
    }

    document.getElementById("btn-generate-env")?.addEventListener("click", async () => {
      const destRef = getFormValue("dest_supabase_ref");
      const destPass = getFormValue("dest_supabase_db_password");
      const destAnon = getFormValue("dest_supabase_anon_key");
      const destService = getFormValue("dest_supabase_service_role_key");
      const siteName = getFormValue("dest_site_name") || "New Client Site";
      const siteUrl = getFormValue("dest_site_url");
      const useDocker = document.getElementById("use_docker")?.checked ?? false;

      if (!destRef || !destPass || !destAnon || !destService) {
        showMessage("Fill in all new Supabase fields (ref, password, anon key, service key).", true);
        return;
      }

      try {
        const res = await fetch(generateEnvUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            destRef,
            destPass,
            destAnon,
            destService,
            siteName,
            siteUrl,
            useDocker,
          }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: res.statusText }));
          showMessage(err.error || "Failed to generate", true);
          return;
        }
        const content = await res.text();
        const blob = new Blob([content], { type: "text/plain" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "clone-site-and-db.env";
        a.click();
        URL.revokeObjectURL(a.href);
        showMessage("Saved clone-site-and-db.env. Place it in scripts/ and run ./scripts/clone-site-and-db.sh", false);
      } catch (e) {
        showMessage("Request failed", true);
      }
    });

    document.getElementById("btn-generate-checklist")?.addEventListener("click", () => {
      const destRef = getFormValue("dest_supabase_ref");
      const destAnon = getFormValue("dest_supabase_anon_key");
      const destService = getFormValue("dest_supabase_service_role_key");
      const siteName = getFormValue("dest_site_name") || "New Client Site";
      const siteUrl = getFormValue("dest_site_url");

      if (!destRef || !destAnon || !destService) {
        showMessage("Fill in new Supabase ref, anon key, and service key.", true);
        return;
      }

      const lines = [
        "# Railway Variables Checklist",
        "# Add these to your new Railway project",
        "",
        'RAILWAY_PROJECT_NAME="' + siteName + '"',
        'PUBLIC_SUPABASE_URL="https://' + destRef + '.supabase.co"',
        'PUBLIC_SUPABASE_PUBLISHABLE="' + destAnon + '"',
        'SUPABASE_SECRET="' + destService + '"',
        siteUrl ? 'RAILWAY_PUBLIC_DOMAIN="' + siteUrl + '"' : "# RAILWAY_PUBLIC_DOMAIN=",
        "",
        "# See markdowns/MULTI_CLIENT_SETUP_GUIDE.md for full checklist",
      ];
      const content = lines.join("\n");
      download(content, "railway-variables-checklist.txt");
      showMessage("Saved Railway checklist. Configure your new Railway project with these variables.", false);
    });
  })();
</script>
