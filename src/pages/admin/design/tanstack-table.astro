---
/**
 * Design: TanStack Table & Tables Overview
 * Documents all table types available in the project.
 */
import { checkAuth } from "../../../lib/auth";
import LayoutFullWidth from "../../../components/layouts/LayoutFullWidth.astro";
import TanStackDataTable from "../../../components/common/TanStackDataTable.astro";
import AccordionDataTable from "../../../components/common/AccordionDataTable.astro";
import { globalClasses } from "../../api/global/global-classes";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;

if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}
if (currentRole !== "Admin") {
  return Astro.redirect("/dashboard");
}

const { primaryTextClasses, mutedTextClasses, globalCodeInline } = globalClasses();

const demoData = [
  { id: "1", slug: "about", title: "About", template: "fullwidth" },
  { id: "2", slug: "contact", title: "Contact", template: "fullform" },
  { id: "3", slug: "services", title: "Services", template: "fullwidth" },
];
---

<LayoutFullWidth
  title="TanStack Table & Tables Overview"
  classList="p-4"
  description="Table types available: TanStackDataTable, AccordionDataTable, FlowbiteTable, ProjectList."
>
  <div class="px-4 py-8">
    <h1 class={`mb-2 text-3xl font-bold ${primaryTextClasses}`}>
      TanStack Table & Tables Overview
    </h1>
    <p class={`mb-6 ${mutedTextClasses}`}>
      All table components in the project. TanStack Table is headless and has no built-in drag
      visuals — row reorder uses HTML5 DnD; for smoother feedback consider @dnd-kit or similar.
    </p>

    <section class="mb-10">
      <h2 class={`mb-4 text-xl font-semibold ${primaryTextClasses}`}>1. TanStackDataTable</h2>
      <p class={`mb-4 ${mutedTextClasses}`}>
        <code class={globalCodeInline}>src/components/common/TanStackDataTable.astro</code>. Powered
        by <code class={globalCodeInline}>@tanstack/table-core</code>. Sortable columns, optional
        expandable rows, optional drag handle. Uses HTML5 drag-and-drop when <code
          class={globalCodeInline}>reorderCallback</code
        > is set — no built-in visual feedback from TanStack.
      </p>
      <TanStackDataTable
        id="tanstack-overview-demo"
        title="TanStack Table"
        description="Sortable, expandable, drag handle (grip)."
        data={demoData}
        columns={[
          { id: "slug", accessorKey: "slug", header: "Slug", meta: { icon: "link", width: 24 } },
          { id: "title", accessorKey: "title", header: "Title", meta: { width: 56 } },
          { id: "template", accessorKey: "template", header: "Template", meta: { width: 20 } },
        ]}
        getRowIdKey="slug"
        showDragHandle={true}
        expandable={true}
      />
    </section>

    <section class="mb-10">
      <h2 class={`mb-4 text-xl font-semibold ${primaryTextClasses}`}>2. AccordionDataTable</h2>
      <p class={`mb-4 ${mutedTextClasses}`}>
        <code class={globalCodeInline}>src/components/common/AccordionDataTable.astro</code>.
        Full-featured: resizable columns, select column, actions (edit/delete), expandable rows,
        optional <code class={globalCodeInline}>draggable</code> with <code class={globalCodeInline}
          >reorderCallback</code
        >. Uses <code class={globalCodeInline}>accordion-reorder-init.ts</code> for drag (HTML5 DnD).
      </p>
      <p class={`mb-4 text-sm ${mutedTextClasses}`}>
        See <a href="/admin/design/data-table-accordion" class="text-primary-500 hover:underline"
          >Data Table Accordion</a
        > for all iterations.
      </p>
    </section>

    <section class="mb-10">
      <h2 class={`mb-4 text-xl font-semibold ${primaryTextClasses}`}>3. FlowbiteTable</h2>
      <p class={`mb-4 ${mutedTextClasses}`}>
        <code class={globalCodeInline}>src/components/common/FlowbiteTable.astro</code>. Basic
        Flowbite-style table with optional pagination and action buttons. No drag, no accordion.
      </p>
    </section>

    <section class="mb-10">
      <h2 class={`mb-4 text-xl font-semibold ${primaryTextClasses}`}>4. ProjectList</h2>
      <p class={`mb-4 ${mutedTextClasses}`}>
        <code class={globalCodeInline}>src/components/project/ProjectList.astro</code>.
        Project-specific table for dashboard. Columns driven by <code class={globalCodeInline}
          >projectListColumns</code
        > config.
      </p>
    </section>

    <section class="mb-10">
      <h2 class={`mb-4 text-xl font-semibold ${primaryTextClasses}`}>Table Types Summary</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="border-b border-gray-200 dark:border-gray-700">
            <tr>
              <th class="px-4 py-2 font-semibold">Component</th>
              <th class="px-4 py-2 font-semibold">Sort</th>
              <th class="px-4 py-2 font-semibold">Expand</th>
              <th class="px-4 py-2 font-semibold">Drag</th>
              <th class="px-4 py-2 font-semibold">Resize</th>
              <th class="px-4 py-2 font-semibold">Select/Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr>
              <td class="px-4 py-2">TanStackDataTable</td>
              <td class="px-4 py-2">✓</td>
              <td class="px-4 py-2">✓</td>
              <td class="px-4 py-2">✓ (reorderCallback)</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
            </tr>
            <tr>
              <td class="px-4 py-2">AccordionDataTable</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">✓</td>
              <td class="px-4 py-2">✓ (draggable)</td>
              <td class="px-4 py-2">✓</td>
              <td class="px-4 py-2">✓</td>
            </tr>
            <tr>
              <td class="px-4 py-2">FlowbiteTable</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
            </tr>
            <tr>
              <td class="px-4 py-2">ProjectList</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">—</td>
              <td class="px-4 py-2">Config-driven</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class={`mt-4 text-sm ${mutedTextClasses}`}>
        Note: TanStack Table is headless. Drag uses HTML5 DnD; for row-move animations / bump
        feedback, an external lib (e.g. @dnd-kit) would be required.
      </p>
    </section>
  </div>
</LayoutFullWidth>
