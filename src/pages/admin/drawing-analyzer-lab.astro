---
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import DrawingAnalyzerLabFeature from "../../features/drawing-analyzer/DrawingAnalyzerLab.astro";
import { globalClasses } from "../api/global/global-classes";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const { primaryTextClasses, secondaryTextClasses } = globalClasses();

if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}
if (!isAdminOrSuperAdmin(currentRole)) {
  return Astro.redirect("/dashboard");
}
---

<LayoutFullWidth
  title="Drawing Analyzer Lab"
  classList="p-4"
  description="Side-by-side drawing detection method lab for comparing circle/object matching strategies"
>
  <div class="px-4 py-8">
    <div class="mb-8">
      <h1 class={`mb-2 text-3xl font-bold ${primaryTextClasses}`}>Drawing Analyzer Lab</h1>
      <p class={`${secondaryTextClasses} text-gray-600 dark:text-gray-400`}>
        Experimental page for testing multiple detection systems on the same drawing and candidate
        symbol. Use this to compare behavior (template-style, roundness, radial, and proposal
        methods) before merging logic into the primary analyzer.
      </p>
    </div>

    <DrawingAnalyzerLabFeature />
  </div>
</LayoutFullWidth>
