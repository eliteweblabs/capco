---
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const isLocalBypass = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
if (!isLocalBypass && (!currentUser || !session)) return Astro.redirect("/auth/login");
if (!isLocalBypass && !isAdminOrSuperAdmin(currentRole)) return Astro.redirect("/dashboard");
---

<LayoutFullWidth title="Plan Scanner" classList="p-0" description="Fire protection plan analysis">
<div class="min-h-screen bg-gray-900 text-white">

  <!-- Step indicator -->
  <div class="bg-gray-800 border-b border-gray-700 px-6 py-3 flex items-center gap-6">
    <span class="text-sm font-semibold text-gray-300">Plan Scanner</span>
    <div id="steps" class="flex items-center gap-2 text-xs">
      <span id="step-1" class="px-2 py-1 rounded bg-blue-600">1. Upload</span>
      <span class="text-gray-600">→</span>
      <span id="step-2" class="px-2 py-1 rounded bg-gray-700 text-gray-400">2. Sections</span>
      <span class="text-gray-600">→</span>
      <span id="step-3" class="px-2 py-1 rounded bg-gray-700 text-gray-400">3. Count</span>
      <span class="text-gray-600">→</span>
      <span id="step-4" class="px-2 py-1 rounded bg-gray-700 text-gray-400">4. Summary</span>
    </div>
    <button id="btn-restart" class="ml-auto text-xs text-gray-400 hover:text-white hidden">Start Over</button>
  </div>

  <!-- STEP 1: Upload -->
  <div id="view-1" class="p-8">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="text-xl font-semibold mb-2">Upload Fire Protection Plan</h2>
      <p class="text-gray-400 mb-6 text-sm">PDF will be rendered and you'll confirm each step</p>
      <label class="cursor-pointer inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-lg font-medium transition">
        Choose PDF
        <input type="file" id="file-input" accept=".pdf" class="hidden" />
      </label>
      <p id="upload-msg" class="mt-4 text-sm text-gray-400"></p>
    </div>
  </div>

  <!-- STEP 2: Section detection -->
  <div id="view-2" class="hidden p-4">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold">Detected Floor Plans</h2>
        <p class="text-sm text-gray-400">Click ✕ to remove false detections. Click "Confirm" when ready.</p>
      </div>
      <button id="btn-confirm-sections" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg font-medium text-sm">
        Confirm Sections →
      </button>
    </div>
    <div class="relative inline-block">
      <img id="plan-full" class="max-w-full" />
      <div id="overlays" class="absolute top-0 left-0 w-full h-full pointer-events-none"></div>
    </div>
  </div>

  <!-- STEP 3: Per-floor counting -->
  <div id="view-3" class="hidden p-4">
    <div class="mb-4">
      <h2 class="text-lg font-semibold">Analyzing: <span id="current-floor-label" class="text-blue-400"></span></h2>
      <p class="text-sm text-gray-400">
        Floor <span id="floor-progress">1</span> of <span id="floor-total">5</span>
      </p>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <!-- Left: the cropped floor image -->
      <div>
        <h3 class="text-sm text-gray-400 mb-2">Input image sent to AI:</h3>
        <div class="border border-gray-700 rounded-lg overflow-hidden bg-gray-950">
          <img id="floor-image" class="w-full" />
        </div>
      </div>
      <!-- Right: results -->
      <div>
        <h3 class="text-sm text-gray-400 mb-2">AI Response:</h3>
        <div id="floor-result" class="border border-gray-700 rounded-lg p-4 bg-gray-800 min-h-[200px]">
          <div id="floor-loading" class="flex items-center gap-3">
            <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
            <span class="text-sm text-gray-400">Counting items...</span>
          </div>
          <div id="floor-data" class="hidden"></div>
        </div>
        <div id="floor-actions" class="hidden mt-4 flex gap-3">
          <button id="btn-accept" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-medium">
            Accept → Next Floor
          </button>
          <button id="btn-recount" class="bg-yellow-600 hover:bg-yellow-700 px-4 py-2 rounded-lg text-sm font-medium">
            Re-count
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- STEP 4: Summary -->
  <div id="view-4" class="hidden p-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-xl font-semibold mb-4">Takeoff Summary</h2>
      <div id="summary-table"></div>
      <button id="btn-new-scan" class="mt-6 bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-medium">
        New Scan
      </button>
    </div>
  </div>

</div>

<script is:inline>
(function() {
  var API = 'http://localhost:5555';
  var pdfFile = null;
  var fullImage = null;
  var sections = [];
  var confirmedSections = [];
  var floorResults = [];
  var currentFloor = 0;

  // Elements
  var fileInput = document.getElementById('file-input');
  var uploadMsg = document.getElementById('upload-msg');

  function show(id) { document.getElementById('view-' + id).classList.remove('hidden'); }
  function hide(id) { document.getElementById('view-' + id).classList.add('hidden'); }

  function setStep(n) {
    for (var i = 1; i <= 4; i++) {
      var el = document.getElementById('step-' + i);
      if (i === n) {
        el.className = 'px-2 py-1 rounded bg-blue-600 text-white';
      } else if (i < n) {
        el.className = 'px-2 py-1 rounded bg-green-800 text-green-300';
      } else {
        el.className = 'px-2 py-1 rounded bg-gray-700 text-gray-400';
      }
    }
    for (var i = 1; i <= 4; i++) { if (i === n) show(i); else hide(i); }
    document.getElementById('btn-restart').classList.toggle('hidden', n === 1);
  }

  // ==================== STEP 1: Upload & Render ====================
  fileInput.addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file || file.type !== 'application/pdf') return;
    pdfFile = file;

    uploadMsg.textContent = 'Rendering PDF...';
    uploadMsg.style.color = '#9ca3af';

    var fd = new FormData();
    fd.append('file', file);
    fd.append('scale', '2');

    fetch(API + '/render', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        fullImage = d.image;

        uploadMsg.textContent = 'Detecting sections...';

        // Now detect sections
        var fd2 = new FormData();
        fd2.append('file', pdfFile);
        fd2.append('scale', '3');

        return fetch(API + '/detect', { method: 'POST', body: fd2 });
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        sections = d.sections;
        showSections();
      })
      .catch(function(err) {
        uploadMsg.textContent = 'Error: ' + err.message;
        uploadMsg.style.color = '#f87171';
      });
  });

  // ==================== STEP 2: Show Sections ====================
  function showSections() {
    setStep(2);

    var img = document.getElementById('plan-full');
    img.src = fullImage;

    img.onload = function() {
      var overlays = document.getElementById('overlays');
      overlays.innerHTML = '';

      var colors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4', '#f97316'];
      var scaleX = img.clientWidth / img.naturalWidth;
      var scaleY = img.clientHeight / img.naturalHeight;

      for (var i = 0; i < sections.length; i++) {
        (function(idx) {
          var s = sections[idx];
          var color = colors[idx % colors.length];

          var div = document.createElement('div');
          div.className = 'absolute pointer-events-auto';
          div.style.left = (s.x * scaleX) + 'px';
          div.style.top = (s.y * scaleY) + 'px';
          div.style.width = (s.width * scaleX) + 'px';
          div.style.height = (s.height * scaleY) + 'px';
          div.style.border = '2px solid ' + color;
          div.style.backgroundColor = color + '15';
          div.style.cursor = 'move';
          div.setAttribute('data-idx', idx);

          // Label bar (drag handle)
          var label = document.createElement('div');
          label.style.cssText = 'position:absolute;top:0;left:0;right:0;height:28px;background:' + color + 'cc;color:white;padding:4px 8px;font-size:12px;font-weight:600;cursor:move;display:flex;justify-content:space-between;align-items:center;';
          var labelText = document.createElement('span');
          labelText.textContent = s.label;
          label.appendChild(labelText);

          // Remove button
          var btn = document.createElement('button');
          btn.style.cssText = 'background:#ef4444;color:white;width:20px;height:20px;border-radius:50%;border:none;cursor:pointer;font-size:12px;line-height:20px;text-align:center;flex-shrink:0;';
          btn.textContent = '✕';
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            e.preventDefault();
            div.remove();
            sections[idx]._removed = true;
          });
          label.appendChild(btn);
          div.appendChild(label);

          // Resize handles (bottom, right, bottom-right corner)
          var handles = [
            { cursor: 'e-resize',  pos: 'top:0;right:-4px;width:8px;height:100%;' },
            { cursor: 's-resize',  pos: 'bottom:-4px;left:0;width:100%;height:8px;' },
            { cursor: 'se-resize', pos: 'bottom:-6px;right:-6px;width:12px;height:12px;background:' + color + ';border-radius:2px;' },
            { cursor: 'w-resize',  pos: 'top:0;left:-4px;width:8px;height:100%;' },
            { cursor: 'n-resize',  pos: 'top:-4px;left:0;width:100%;height:8px;' }
          ];

          for (var h = 0; h < handles.length; h++) {
            var handle = document.createElement('div');
            handle.style.cssText = 'position:absolute;' + handles[h].pos + 'cursor:' + handles[h].cursor + ';z-index:5;';
            handle.setAttribute('data-cursor', handles[h].cursor);
            div.appendChild(handle);
          }

          // --- Drag & Resize Logic ---
          (function(el, sectionData) {
            var startX, startY, startLeft, startTop, startW, startH, mode;
            var parentRect;

            function onMouseDown(e) {
              if (e.target.tagName === 'BUTTON') return;
              e.preventDefault();
              parentRect = el.parentElement.getBoundingClientRect();

              startX = e.clientX;
              startY = e.clientY;
              startLeft = parseInt(el.style.left);
              startTop = parseInt(el.style.top);
              startW = parseInt(el.style.width);
              startH = parseInt(el.style.height);

              var cursor = e.target.getAttribute('data-cursor');
              if (cursor === 'e-resize') mode = 'resize-e';
              else if (cursor === 's-resize') mode = 'resize-s';
              else if (cursor === 'se-resize') mode = 'resize-se';
              else if (cursor === 'w-resize') mode = 'resize-w';
              else if (cursor === 'n-resize') mode = 'resize-n';
              else mode = 'drag';

              document.addEventListener('mousemove', onMouseMove);
              document.addEventListener('mouseup', onMouseUp);
            }

            function onMouseMove(e) {
              var dx = e.clientX - startX;
              var dy = e.clientY - startY;

              if (mode === 'drag') {
                el.style.left = Math.max(0, startLeft + dx) + 'px';
                el.style.top = Math.max(0, startTop + dy) + 'px';
              } else if (mode === 'resize-e') {
                el.style.width = Math.max(50, startW + dx) + 'px';
              } else if (mode === 'resize-s') {
                el.style.height = Math.max(50, startH + dy) + 'px';
              } else if (mode === 'resize-se') {
                el.style.width = Math.max(50, startW + dx) + 'px';
                el.style.height = Math.max(50, startH + dy) + 'px';
              } else if (mode === 'resize-w') {
                var newW = Math.max(50, startW - dx);
                el.style.left = (startLeft + startW - newW) + 'px';
                el.style.width = newW + 'px';
              } else if (mode === 'resize-n') {
                var newH = Math.max(50, startH - dy);
                el.style.top = (startTop + startH - newH) + 'px';
                el.style.height = newH + 'px';
              }

              // Update section data in real time (convert back to image coords)
              var sx = img.clientWidth > 0 ? img.naturalWidth / img.clientWidth : 1;
              var sy = img.clientHeight > 0 ? img.naturalHeight / img.clientHeight : 1;
              sectionData.x = Math.round(parseInt(el.style.left) * sx);
              sectionData.y = Math.round(parseInt(el.style.top) * sy);
              sectionData.width = Math.round(parseInt(el.style.width) * sx);
              sectionData.height = Math.round(parseInt(el.style.height) * sy);
            }

            function onMouseUp() {
              document.removeEventListener('mousemove', onMouseMove);
              document.removeEventListener('mouseup', onMouseUp);
            }

            el.addEventListener('mousedown', onMouseDown);
          })(div, s);

          overlays.appendChild(div);
        })(i);
      }
    };
  }

  // ==================== Confirm Sections → Step 3 ====================
  document.getElementById('btn-confirm-sections').addEventListener('click', function() {
    confirmedSections = [];
    for (var i = 0; i < sections.length; i++) {
      if (!sections[i]._removed) confirmedSections.push(sections[i]);
    }
    if (confirmedSections.length === 0) {
      alert('No sections selected. Please keep at least one section.');
      return;
    }

    floorResults = [];
    currentFloor = 0;
    processFloor(0);
  });

  // ==================== STEP 3: Process each floor ====================
  function processFloor(idx) {
    if (idx >= confirmedSections.length) {
      showSummary();
      return;
    }

    currentFloor = idx;
    var section = confirmedSections[idx];

    setStep(3);
    document.getElementById('current-floor-label').textContent = section.label;
    document.getElementById('floor-progress').textContent = (idx + 1);
    document.getElementById('floor-total').textContent = confirmedSections.length;

    // Show loading, hide results
    document.getElementById('floor-loading').classList.remove('hidden');
    document.getElementById('floor-data').classList.add('hidden');
    document.getElementById('floor-actions').classList.add('hidden');

    // Crop the section
    var fd = new FormData();
    fd.append('file', pdfFile);
    fd.append('scale', '3');
    fd.append('x', section.x);
    fd.append('y', section.y);
    fd.append('w', section.width);
    fd.append('h', section.height);

    fetch(API + '/crop', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);

        // Show the crop
        document.getElementById('floor-image').src = d.image;

        // Now count
        var fd2 = new FormData();
        fd2.append('image', d.image);
        fd2.append('label', section.label);

        return fetch(API + '/count', { method: 'POST', body: fd2 });
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error || d.raw || 'Count failed');

        // Show results
        document.getElementById('floor-loading').classList.add('hidden');
        document.getElementById('floor-data').classList.remove('hidden');
        document.getElementById('floor-actions').classList.remove('hidden');

        var r = d.result;
        var html = '';
        html += '<div class="space-y-3">';

        // Heads
        var headTotal = r.heads ? r.heads.total : 0;
        html += '<div class="flex justify-between items-center">';
        html += '  <span class="text-gray-300">Sprinkler Heads</span>';
        html += '  <span class="text-2xl font-bold text-blue-400">' + headTotal + '</span>';
        html += '</div>';

        // Head types
        if (r.heads && r.heads.types) {
          for (var t = 0; t < r.heads.types.length; t++) {
            var ht = r.heads.types[t];
            html += '<div class="flex justify-between text-sm pl-4">';
            html += '  <span class="text-gray-500">' + ht.type + '</span>';
            html += '  <span class="text-gray-300">' + ht.count + '</span>';
            html += '</div>';
          }
        }

        // Fittings
        if (r.tees > 0) {
          html += '<div class="flex justify-between text-sm">';
          html += '  <span class="text-gray-400">Tee Junctions</span>';
          html += '  <span class="text-yellow-400 font-semibold">' + r.tees + '</span>';
          html += '</div>';
        }
        if (r.elbows > 0) {
          html += '<div class="flex justify-between text-sm">';
          html += '  <span class="text-gray-400">Elbow Junctions</span>';
          html += '  <span class="text-orange-400 font-semibold">' + r.elbows + '</span>';
          html += '</div>';
        }
        if (r.risers > 0) {
          html += '<div class="flex justify-between text-sm">';
          html += '  <span class="text-gray-400">Risers</span>';
          html += '  <span class="text-green-400 font-semibold">' + r.risers + '</span>';
          html += '</div>';
        }

        // Notes
        if (r.notes) {
          html += '<div class="text-xs text-gray-500 mt-2 border-t border-gray-700 pt-2">' + r.notes + '</div>';
        }

        html += '</div>';

        // Raw JSON toggle
        html += '<details class="mt-3"><summary class="text-xs text-gray-600 cursor-pointer">Raw AI response</summary>';
        html += '<pre class="text-xs text-gray-500 mt-1 overflow-auto max-h-40 bg-gray-900 p-2 rounded">' + JSON.stringify(r, null, 2) + '</pre>';
        html += '</details>';

        document.getElementById('floor-data').innerHTML = html;

        // Store result
        floorResults[idx] = r;
      })
      .catch(function(err) {
        document.getElementById('floor-loading').classList.add('hidden');
        document.getElementById('floor-data').classList.remove('hidden');
        document.getElementById('floor-data').innerHTML = '<p class="text-red-400">Error: ' + err.message + '</p>';
        document.getElementById('floor-actions').classList.remove('hidden');
      });
  }

  // Accept → next floor
  document.getElementById('btn-accept').addEventListener('click', function() {
    processFloor(currentFloor + 1);
  });

  // Re-count current floor
  document.getElementById('btn-recount').addEventListener('click', function() {
    processFloor(currentFloor);
  });

  // ==================== STEP 4: Summary ====================
  function showSummary() {
    setStep(4);

    var html = '<table class="w-full text-sm">';
    html += '<thead><tr class="text-left text-gray-400 border-b border-gray-700">';
    html += '<th class="py-2">Floor</th><th class="py-2 text-right">Heads</th><th class="py-2 text-right">Tees</th><th class="py-2 text-right">Elbows</th><th class="py-2 text-right">Risers</th>';
    html += '</tr></thead><tbody>';

    var totals = { heads: 0, tees: 0, elbows: 0, risers: 0 };

    for (var i = 0; i < confirmedSections.length; i++) {
      var r = floorResults[i] || {};
      var heads = r.heads ? r.heads.total : 0;
      var tees = r.tees || 0;
      var elbows = r.elbows || 0;
      var risers = r.risers || 0;

      totals.heads += heads;
      totals.tees += tees;
      totals.elbows += elbows;
      totals.risers += risers;

      html += '<tr class="border-b border-gray-800">';
      html += '<td class="py-2">' + confirmedSections[i].label + '</td>';
      html += '<td class="py-2 text-right font-mono text-blue-400">' + heads + '</td>';
      html += '<td class="py-2 text-right font-mono text-yellow-400">' + tees + '</td>';
      html += '<td class="py-2 text-right font-mono text-orange-400">' + elbows + '</td>';
      html += '<td class="py-2 text-right font-mono text-green-400">' + risers + '</td>';
      html += '</tr>';
    }

    html += '<tr class="font-bold text-lg">';
    html += '<td class="py-3">TOTAL</td>';
    html += '<td class="py-3 text-right font-mono text-blue-400">' + totals.heads + '</td>';
    html += '<td class="py-3 text-right font-mono text-yellow-400">' + totals.tees + '</td>';
    html += '<td class="py-3 text-right font-mono text-orange-400">' + totals.elbows + '</td>';
    html += '<td class="py-3 text-right font-mono text-green-400">' + totals.risers + '</td>';
    html += '</tr>';

    html += '</tbody></table>';

    document.getElementById('summary-table').innerHTML = html;
  }

  // ==================== Restart ====================
  document.getElementById('btn-restart').addEventListener('click', function() {
    pdfFile = null;
    fullImage = null;
    sections = [];
    confirmedSections = [];
    floorResults = [];
    currentFloor = 0;
    fileInput.value = '';
    uploadMsg.textContent = '';
    uploadMsg.style.color = '';
    document.getElementById('plan-full').src = '';
    setStep(1);
  });

  document.getElementById('btn-new-scan').addEventListener('click', function() {
    document.getElementById('btn-restart').click();
  });

})();
</script>

</LayoutFullWidth>
