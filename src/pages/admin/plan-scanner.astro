---
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const isLocalBypass = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
if (!isLocalBypass && (!currentUser || !session)) return Astro.redirect("/auth/login");
if (!isLocalBypass && !isAdminOrSuperAdmin(currentRole)) return Astro.redirect("/dashboard");
---

<LayoutFullWidth title="Plan Scanner" classList="p-0" description="Fire protection plan analysis">
<div class="h-screen flex flex-col bg-gray-900 text-white overflow-hidden">

  <!-- Top bar -->
  <div class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center gap-4 shrink-0">
    <select id="plan-select" class="text-sm bg-gray-700 text-gray-200 border border-gray-600 rounded px-2 py-1">
      <option value="">Select a test plan...</option>
      <option value="demo-plan">Demo Plan (SimpleScan default)</option>
      <option value="85-tremont">85 Tremont Street Cambridge MA FP.pdf</option>
      <option value="lane-park">Lane Park plan (5 heads)</option>
    </select>
    <button id="btn-new" class="text-sm text-blue-400 hover:text-blue-300 font-medium">Custom Upload</button>
    <span id="plan-title" class="text-sm text-gray-300 font-semibold"></span>
    <span id="plan-status" class="ml-auto text-xs text-gray-500"></span>
  </div>

  <!-- Main layout: plan + sidebar -->
  <div class="flex flex-1 overflow-hidden">

    <!-- Left: Plan view -->
    <div class="flex-1 overflow-auto p-4 relative" id="plan-container">
      <!-- Upload prompt (shown when no file loaded) -->
      <div id="upload-prompt" class="flex items-center justify-center h-full">
        <label class="cursor-pointer text-center">
          <div class="text-gray-500 mb-3">
            <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <span class="text-gray-400">Upload a fire protection plan (PDF)</span>
          <input type="file" id="file-input" accept=".pdf" class="hidden" />
        </label>
      </div>
      <!-- Plan image with section overlays -->
      <div id="plan-view" class="hidden relative inline-block">
        <img id="plan-img" class="max-w-full" />
        <div id="section-overlays" class="absolute top-0 left-0 w-full h-full pointer-events-none"></div>
      </div>
    </div>

    <!-- Right: Sidebar -->
    <div class="w-80 shrink-0 border-l border-gray-700 flex flex-col bg-gray-850" id="sidebar">
      <!-- Simplified sidebar - Areas only -->
      <div class="border-b border-gray-700 py-2 px-3 shrink-0">
        <h3 class="text-xs font-semibold text-blue-400 uppercase tracking-wider">Floor Plan Sections</h3>
      </div>

      <!-- Areas content -->
      <div id="areas-content" class="flex-1 overflow-auto p-3">
        <p class="text-xs text-gray-500 mb-3">Detected floor plan sections. Adjust regions before scanning for items.</p>
        
        <button id="btn-scan-items" class="w-full py-2 rounded bg-green-600 hover:bg-green-700 text-xs font-semibold text-white mb-3" disabled>
          ▶ Scan for Items
        </button>

        <div id="area-list" class="space-y-2">
          <p class="text-xs text-gray-600 italic">Upload a plan to detect areas</p>
        </div>
      </div>

      <!-- Removed Library and Results tabs for simplified interface -->
    </div>
  </div>
</div>

<style>
  .bg-gray-850 { background-color: #1a1d23; }
  .area-card { @apply bg-gray-800 rounded-lg p-2 text-xs; }
  .area-card.active { @apply ring-1 ring-blue-500; }
  .result-row {
    @apply flex items-center justify-between py-1;
  }
  .result-row .dot {
    @apply w-6 h-6 rounded-full bg-gray-700 shrink-0;
  }
  .result-row .label {
    @apply text-sm text-gray-300 ml-3 flex-1;
  }
  .result-row .count {
    @apply text-lg font-bold tabular-nums;
  }
  .symbol-card {
    @apply bg-gray-800 rounded-lg p-2 flex items-center gap-2;
  }
  .symbol-card img {
    @apply w-10 h-10 object-contain bg-white rounded;
  }

  /* Crop overlay */
  #crop-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    cursor: crosshair;
    z-index: 50;
  }
  #crop-selection {
    position: absolute;
    border: 2px dashed #3b82f6;
    background: rgba(59, 130, 246, 0.1);
    pointer-events: none;
  }
</style>

<script is:inline>
(function() {
  var API = 'http://localhost:5555';
  var pdfFile = null;
  var fullImageSrc = null;
  var sections = [];       // detected/confirmed areas
  var detectedTiles = [];  // actual tile positions from flood fill
  var detectedHull = [];   // convex hull polygon points
  var symbolLibrary = [];  // { id, label, type, image (base64) }
  var floorResults = {};   // keyed by section index
  var recalcTimer = null;
  var analyzing = false;
  var abortController = null;  // AbortController for in-flight fetch requests

  // ==================== Test Plan Loader ====================
  function loadTestPlan(planId, fileName) {
    if (!planId) return;
    
    currentPlanType = planId; // Track for optimization
    
    fetch(API + '/test-plans/' + planId)
      .then(function(response) {
        if (!response.ok) throw new Error('Plan not found');
        return response.blob();
      })
      .then(function(blob) {
        var file = new File([blob], fileName, { type: 'application/pdf' });
        pdfFile = file;
        sections = [];
        floorResults = {};
        
        document.getElementById('plan-title').textContent = fileName;
        document.getElementById('plan-status').textContent = 'Rendering...';
        
        var fd = new FormData();
        fd.append('file', file);
        fd.append('scale', '2');
        
        return fetch(API + '/render', { method: 'POST', body: fd });
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        fullImageSrc = d.image;
        
        return runDetect();
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        sections = d.sections;
        detectedTiles = d.tiles || [];
        detectedHull = d.hull || [];
        document.getElementById('plan-status').textContent = sections.length + ' section(s) detected';
        showPlan();
        renderAreaList();
        document.getElementById('btn-scan-items').disabled = false;
      })
      .catch(function(err) {
        document.getElementById('plan-status').textContent = 'Error: ' + err.message;
      });
  }

  // Plan selector dropdown
  document.getElementById('plan-select').addEventListener('change', function(e) {
    var planId = e.target.value;
    var planName = e.target.options[e.target.selectedIndex].text;
    if (planId) {
      loadTestPlan(planId, planName);
    }
  });

  // Auto-load demo plan by default (same as SimpleScan)
  window.addEventListener('load', function() {
    setTimeout(function() {
      document.getElementById('plan-select').value = 'demo-plan';
      loadTestPlan('demo-plan', 'Demo Plan (SimpleScan default)');
    }, 500);
  });

  // ==================== Detection ====================
  function getThreshold() { return 200; }

  var currentPlanType = null;

  function runDetect() {
    var fd = new FormData();
    fd.append('file', pdfFile);
    fd.append('scale', '3');
    fd.append('threshold', getThreshold());
    if (currentPlanType) {
      fd.append('plan_type', currentPlanType);
    }
    document.getElementById('plan-status').textContent = 'Detecting sections...';
    return fetch(API + '/detect', { method: 'POST', body: fd });
  }

  // Removed slider controls - using SimpleScan detection with defaults

  // Refine: re-run detection within the CURRENT section bounds
  // First click locks the crop area from step 1. Subsequent slider changes stay within it.
  var lastDetectionBounds = null;
  function runDetection() {
    runDetect()
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        sections = d.sections;
        detectedTiles = d.tiles || [];
        detectedHull = d.hull || [];
        floorResults = {};
        document.getElementById('plan-status').textContent = sections.length + ' section(s) detected';
        renderOverlays();
        renderAreaList();
        document.getElementById('btn-scan-items').disabled = false;
      })
      .catch(function(err) {
        document.getElementById('plan-status').textContent = 'Detection error: ' + err.message;
      });
  }

  // Explicit scan button — only runs item counting when user is ready
  document.getElementById('btn-scan-items').addEventListener('click', function() {
    if (!pdfFile || sections.length === 0) return;
    scheduleRecalc();
  });

  // ==================== File Upload ====================
  document.getElementById('file-input').addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file || file.type !== 'application/pdf') return;
    pdfFile = file;
    currentPlanType = null; // Custom upload - enable text stripping
    sections = [];
    floorResults = {};

    var name = file.name.replace('.pdf', '').replace('.PDF', '');
    document.getElementById('plan-title').textContent = name;
    document.getElementById('plan-status').textContent = 'Rendering...';

    var fd = new FormData();
    fd.append('file', file);
    fd.append('scale', '2');

    fetch(API + '/render', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        fullImageSrc = d.image;
        document.getElementById('plan-status').textContent = 'Detecting sections...';

        return runDetect();
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.success) throw new Error(d.error);
        sections = d.sections;
        detectedTiles = d.tiles || [];
        detectedHull = d.hull || [];
        document.getElementById('plan-status').textContent = detectedTiles.length + ' tiles, ' + detectedHull.length + ' hull points';
        showPlan();
        renderAreaList();
        document.getElementById('btn-scan-items').disabled = false;
      })
      .catch(function(err) {
        document.getElementById('plan-status').textContent = 'Error: ' + err.message;
      });
  });

  // ==================== New Scan ====================
  document.getElementById('btn-new').addEventListener('click', function() {
    cancelAnalysis();
    pdfFile = null;
    fullImageSrc = null;
    sections = [];
    floorResults = {};
    document.getElementById('plan-title').textContent = '';
    document.getElementById('plan-status').textContent = '';
    document.getElementById('file-input').value = '';
    document.getElementById('upload-prompt').classList.remove('hidden');
    document.getElementById('plan-view').classList.add('hidden');
    document.getElementById('area-list').innerHTML = '<p class="text-xs text-gray-600 italic">Upload a plan to detect areas</p>';
    document.getElementById('results-content').classList.add('hidden');
    document.getElementById('results-empty').classList.remove('hidden');
    document.getElementById('btn-scan-items').disabled = true;
  });

  // ==================== Show Plan ====================
  function showPlan() {
    document.getElementById('upload-prompt').classList.add('hidden');
    document.getElementById('plan-view').classList.remove('hidden');
    var img = document.getElementById('plan-img');
    img.src = fullImageSrc;
    img.onload = function() { renderOverlays(); };
  }

  // ==================== Section Overlays ====================
  var COLORS = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4', '#f97316'];

  function renderOverlays() {
    var img = document.getElementById('plan-img');
    var container = document.getElementById('section-overlays');
    container.innerHTML = '';
    if (!img.naturalWidth) return;

    var scaleX = img.clientWidth / img.naturalWidth;
    var scaleY = img.clientHeight / img.naturalHeight;

    // Draw tiles as semi-transparent fill
    if (detectedTiles.length > 0) {
      for (var t = 0; t < detectedTiles.length; t++) {
        var tile = detectedTiles[t];
        var td = document.createElement('div');
        td.className = 'absolute';
        td.style.left = (tile.x * scaleX) + 'px';
        td.style.top = (tile.y * scaleY) + 'px';
        td.style.width = (tile.w * scaleX) + 'px';
        td.style.height = (tile.h * scaleY) + 'px';
        td.style.backgroundColor = 'rgba(59, 130, 246, 0.12)';
        container.appendChild(td);
      }
    }

    // Draw convex hull polygon as SVG overlay
    if (detectedHull.length >= 3) {
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;';
      svg.setAttribute('viewBox', '0 0 ' + img.naturalWidth + ' ' + img.naturalHeight);
      svg.setAttribute('preserveAspectRatio', 'none');

      var points = detectedHull.map(function(p) { return p[0] + ',' + p[1]; }).join(' ');
      var polygon = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
      polygon.setAttribute('points', points);
      polygon.setAttribute('fill', 'none');
      polygon.setAttribute('stroke', '#3b82f6');
      polygon.setAttribute('stroke-width', '3');
      polygon.setAttribute('stroke-dasharray', '8,4');
      svg.appendChild(polygon);

      // Label at first hull point
      var labelX = detectedHull[0][0] + 5;
      var labelY = detectedHull[0][1] + 16;
      var text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', labelX);
      text.setAttribute('y', labelY);
      text.setAttribute('fill', 'white');
      text.setAttribute('font-size', '14');
      text.setAttribute('font-weight', 'bold');
      text.textContent = 'Floor Plans';
      // Background rect for label
      var bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      bg.setAttribute('x', labelX - 4);
      bg.setAttribute('y', labelY - 13);
      bg.setAttribute('width', '90');
      bg.setAttribute('height', '18');
      bg.setAttribute('fill', '#3b82f6cc');
      bg.setAttribute('rx', '2');
      svg.appendChild(bg);
      svg.appendChild(text);

      container.appendChild(svg);
    }
  }

  // ==================== Area List (sidebar) ====================
  function renderAreaList() {
    var list = document.getElementById('area-list');
    list.innerHTML = '';

    var active = sections.filter(function(s) { return !s._removed; });
    if (active.length === 0) {
      list.innerHTML = '<p class="text-xs text-gray-600 italic">No areas detected</p>';
      return;
    }

    for (var i = 0; i < sections.length; i++) {
      if (sections[i]._removed) continue;
      (function(idx) {
        var s = sections[idx];
        var color = COLORS[idx % COLORS.length];

        var card = document.createElement('div');
        card.className = 'area-card flex items-center gap-2';

        var dot = document.createElement('div');
        dot.style.cssText = 'width:10px;height:10px;border-radius:50%;background:' + color + ';flex-shrink:0;';
        card.appendChild(dot);

        var name = document.createElement('span');
        name.className = 'flex-1 text-gray-300';
        name.textContent = s.label;
        card.appendChild(name);

        // Status indicator
        var status = document.createElement('span');
        status.className = 'text-gray-600';
        status.id = 'area-status-' + idx;
        if (floorResults[idx]) {
          var h = floorResults[idx].heads ? floorResults[idx].heads.total : 0;
          status.textContent = h + ' heads';
          status.className = 'text-green-400';
        }
        card.appendChild(status);

        var btn = document.createElement('button');
        btn.className = 'text-gray-600 hover:text-red-400 text-sm';
        btn.textContent = '✕';
        btn.addEventListener('click', function() {
          sections[idx]._removed = true;
          delete floorResults[idx];
          renderAreaList();
          renderOverlays();
          scheduleRecalc();
        });
        card.appendChild(btn);

        list.appendChild(card);
      })(i);
    }
  }

  // Symbol library / crop features removed for simplified UI

  // ==================== Auto-recalculate ====================
  function scheduleRecalc() {
    if (recalcTimer) clearTimeout(recalcTimer);
    recalcTimer = setTimeout(function() { runAnalysis(); }, 2500);
  }

  function cancelAnalysis() {
    if (abortController) {
      abortController.abort();
      abortController = null;
    }
    analyzing = false;
  }

  function runAnalysis() {
    if (!pdfFile) return;

    // Kill any in-flight scan
    cancelAnalysis();

    var active = [];
    for (var i = 0; i < sections.length; i++) {
      if (!sections[i]._removed) active.push({ idx: i, section: sections[i] });
    }
    if (active.length === 0) {
      floorResults = {};
      showResults();
      return;
    }

    analyzing = true;
    abortController = new AbortController();
    var signal = abortController.signal;

    switchTab('results');
    document.getElementById('results-empty').classList.add('hidden');
    document.getElementById('results-loading').classList.remove('hidden');
    document.getElementById('results-content').classList.add('hidden');

    var completed = 0;
    floorResults = {};

    for (var a = 0; a < active.length; a++) {
      (function(item) {
        var section = item.section;

        // Crop
        var fd = new FormData();
        fd.append('file', pdfFile);
        fd.append('scale', '3');
        fd.append('x', section.x);
        fd.append('y', section.y);
        fd.append('w', section.width);
        fd.append('h', section.height);

        fetch(API + '/crop', { method: 'POST', body: fd, signal: signal })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (signal.aborted) return;
            if (!d.success) throw new Error(d.error);

            // Count
            var fd2 = new FormData();
            fd2.append('image', d.image);
            fd2.append('label', section.label);

            if (symbolLibrary.length > 0) {
              fd2.append('library', JSON.stringify(symbolLibrary.map(function(s) {
                return { type: s.type, image: s.image };
              })));
            }

            return fetch(API + '/count', { method: 'POST', body: fd2, signal: signal });
          })
          .then(function(r) { if (r) return r.json(); })
          .then(function(d) {
            if (!d || signal.aborted) return;
            if (!d.success) throw new Error(d.error || 'Count failed');
            floorResults[item.idx] = d.result;
            completed++;
            updateProgress(completed, active.length);
            if (completed >= active.length) {
              analyzing = false;
              abortController = null;
              showResults();
              renderAreaList();
            }
          })
          .catch(function(err) {
            if (signal.aborted) return;  // Intentional cancel, ignore
            floorResults[item.idx] = { error: err.message };
            completed++;
            if (completed >= active.length) {
              analyzing = false;
              abortController = null;
              showResults();
              renderAreaList();
            }
          });
      })(active[a]);
    }
  }

  function updateProgress(done, total) {
    document.getElementById('plan-status').textContent = 'Analyzing floor ' + done + ' of ' + total + '...';
  }

  // ==================== Show Results ====================
  function showResults() {
    document.getElementById('results-loading').classList.add('hidden');
    document.getElementById('plan-status').textContent = '';

    var totals = { pendent: 0, sidewall: 0, heads: 0, tees: 0, elbows: 0, risers: 0 };
    var floorDetails = [];

    for (var i = 0; i < sections.length; i++) {
      if (sections[i]._removed || !floorResults[i]) continue;
      var r = floorResults[i];
      if (r.error) {
        floorDetails.push({ label: sections[i].label, error: r.error });
        continue;
      }

      var headTotal = r.heads ? r.heads.total : 0;
      var pendent = 0, sidewall = 0;
      if (r.heads && r.heads.types) {
        for (var t = 0; t < r.heads.types.length; t++) {
          var ht = r.heads.types[t];
          if (ht.type === 'pendent') pendent += ht.count;
          else if (ht.type === 'sidewall') sidewall += ht.count;
        }
      }

      totals.pendent += pendent;
      totals.sidewall += sidewall;
      totals.heads += headTotal;
      totals.tees += (r.tees || 0);
      totals.elbows += (r.elbows || 0);
      totals.risers += (r.risers || 0);

      floorDetails.push({
        label: sections[i].label,
        heads: headTotal,
        pendent: pendent,
        sidewall: sidewall,
        tees: r.tees || 0,
        elbows: r.elbows || 0,
        risers: r.risers || 0,
        notes: r.notes || ''
      });
    }

    if (floorDetails.length === 0) {
      document.getElementById('results-empty').classList.remove('hidden');
      document.getElementById('results-content').classList.add('hidden');
      return;
    }

    document.getElementById('results-empty').classList.add('hidden');
    document.getElementById('results-content').classList.remove('hidden');

    // Items found
    var items = document.getElementById('results-items');
    items.innerHTML = '';

    var rows = [
      { label: 'Pendent Heads', count: totals.pendent, color: '#3b82f6' },
      { label: 'Sidewall Heads', count: totals.sidewall, color: '#3b82f6' },
      { label: 'Sprinkler Heads', count: totals.heads, color: '#3b82f6', suffix: 'total', bold: true },
      { label: 'Tee Junctions', count: totals.tees, color: '#1f2937' },
      { label: 'Elbow Junctions', count: totals.elbows, color: '#1f2937' },
      { label: 'Risers', count: totals.risers, color: '#1f2937' }
    ];

    for (var r = 0; r < rows.length; r++) {
      var row = rows[r];
      var div = document.createElement('div');
      div.className = 'result-row';
      div.innerHTML =
        '<div class="dot" style="background:' + row.color + '"></div>' +
        '<span class="label">' + row.label + (row.suffix ? ' <span class="text-xs text-gray-500">' + row.suffix + '</span>' : '') + '</span>' +
        '<span class="count" style="color:' + (row.bold ? '#fff' : '#9ca3af') + '">' + row.count + '</span>';
      items.appendChild(div);
    }

    // Confidence
    var conf = document.getElementById('results-confidence');
    var confLevel = totals.heads > 0 ? (symbolLibrary.length > 0 ? 'high' : 'medium') : 'low';
    conf.textContent = confLevel;
    conf.className = 'text-xs font-semibold ' + (confLevel === 'high' ? 'text-green-400' : confLevel === 'medium' ? 'text-yellow-400' : 'text-red-400');

    // Project info
    document.getElementById('results-project').innerHTML =
      '<div>Standard: <strong>NFPA 13</strong></div>' +
      '<div>System: <strong>wet</strong></div>' +
      '<div>Hazard: <strong>Light Hazard</strong></div>';

    // Per floor
    var floors = document.getElementById('results-floors');
    floors.innerHTML = '';
    for (var f = 0; f < floorDetails.length; f++) {
      var fl = floorDetails[f];
      var div = document.createElement('div');
      div.className = 'bg-gray-800 rounded p-2 text-xs';
      if (fl.error) {
        div.innerHTML = '<span class="text-gray-400">' + fl.label + '</span> <span class="text-red-400">Error</span>';
      } else {
        div.innerHTML =
          '<div class="flex justify-between"><span class="text-gray-400">' + fl.label + '</span><span class="text-blue-400 font-semibold">' + fl.heads + ' heads</span></div>' +
          '<div class="text-gray-600 mt-1">' + fl.pendent + 'P / ' + fl.sidewall + 'S · ' + fl.tees + 'T · ' + fl.elbows + 'E · ' + fl.risers + 'R</div>' +
          (fl.notes ? '<div class="text-gray-600 mt-1">' + fl.notes + '</div>' : '');
      }
      floors.appendChild(div);
    }
  }

})();
</script>

</LayoutFullWidth>
