---
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";
import { globalClasses } from "../api/global/global-classes";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const { primaryTextClasses, mutedTextSmClasses } = globalClasses();
const isLocalBypass = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";

if (!isLocalBypass && (!currentUser || !session)) {
  return Astro.redirect("/auth/login");
}
if (!isLocalBypass && !isAdminOrSuperAdmin(currentRole)) {
  return Astro.redirect("/dashboard");
}
---

<LayoutFullWidth
  title="Plan Scanner"
  classList="p-0"
  description="Fire protection plan analysis"
>
<div id="app" class="min-h-screen bg-gray-900 text-white flex flex-col">

  <!-- Upload State -->
  <div id="upload-view" class="flex-1 flex items-center justify-center">
    <div class="text-center">
      <div class="mb-6">
        <svg class="mx-auto w-16 h-16 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2">Upload Fire Protection Plan</h2>
      <p class="text-gray-400 mb-6 text-sm">PDF will be analyzed automatically</p>
      <label class="cursor-pointer inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Choose PDF
        <input type="file" id="file-input" accept=".pdf" class="hidden" />
      </label>
      <div id="upload-status" class="mt-4 text-sm text-gray-400"></div>
    </div>
  </div>

  <!-- Processing State -->
  <div id="processing-view" class="hidden flex-1 flex items-center justify-center">
    <div class="text-center">
      <div class="mb-6">
        <div class="w-16 h-16 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
      </div>
      <h2 class="text-xl font-semibold mb-2">Analyzing Plan</h2>
      <p id="processing-status" class="text-gray-400 text-sm">Rendering PDF...</p>
    </div>
  </div>

  <!-- Results State -->
  <div id="results-view" class="hidden flex-1 flex flex-col">
    
    <!-- Top Bar -->
    <div class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-4">
        <button id="new-scan-btn" class="text-sm text-gray-400 hover:text-white flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          New Scan
        </button>
        <span id="project-title" class="text-sm font-medium"></span>
      </div>
      <div></div>
    </div>

    <!-- Main Content: Plan + Sidebar -->
    <div class="flex-1 flex overflow-hidden">
      
      <!-- Plan Viewer -->
      <div id="plan-viewer" class="flex-1 overflow-auto bg-gray-950 relative">
        <div id="plan-container" class="relative inline-block w-full">
          <img id="plan-image" class="w-full" draggable="false" />
          <canvas id="highlight-canvas" class="absolute top-0 left-0 pointer-events-none" style="z-index:10"></canvas>
        </div>
      </div>

      <!-- Results Sidebar -->
      <div id="results-sidebar" class="w-80 bg-gray-800 border-l border-gray-700 overflow-y-auto shrink-0">
        
        <!-- Items Found -->
        <div class="p-4 border-b border-gray-700">
          <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Items Found</h3>
          <div id="layers-panel" class="space-y-1"></div>
        </div>

        <!-- Equipment -->
        <div class="p-4 border-b border-gray-700">
          <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Equipment</h3>
          <div id="equipment-panel" class="space-y-1 text-sm"></div>
        </div>

        <!-- Project Info -->
        <div class="p-4">
          <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Project</h3>
          <div id="project-panel" class="space-y-1 text-sm text-gray-400"></div>
        </div>

      </div>
    </div>
  </div>

</div>

<script is:inline>
const PLAN_API = 'http://localhost:5555';

// State
let analysisData = null;

// Elements
const fileInput = document.getElementById('file-input');
const uploadView = document.getElementById('upload-view');
const processingView = document.getElementById('processing-view');
const resultsView = document.getElementById('results-view');
const processingStatus = document.getElementById('processing-status');
const uploadStatus = document.getElementById('upload-status');
const planImage = document.getElementById('plan-image');
const planViewer = document.getElementById('plan-viewer');

// ============================================================================
// FILE HANDLING
// ============================================================================

fileInput?.addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file || file.type !== 'application/pdf') return;
  
  uploadView.classList.add('hidden');
  processingView.classList.remove('hidden');
  processingStatus.textContent = 'Checking plan detector...';

  try {
    const healthResp = await fetch(PLAN_API + '/health', { signal: AbortSignal.timeout(3000) });
    if (!healthResp.ok) throw new Error('Plan detector API not running');
    
    processingStatus.textContent = 'Rendering and analyzing plan...';
    
    const formData = new FormData();
    formData.append('file', file);
    formData.append('scale', '3');
    
    const resp = await fetch(PLAN_API + '/analyze', { method: 'POST', body: formData });
    const data = await resp.json();
    
    if (!data.success) throw new Error(data.error || 'Analysis failed');
    
    analysisData = data;
    showResults(data);
    
  } catch (err) {
    console.error('Analysis error:', err);
    processingView.classList.add('hidden');
    uploadView.classList.remove('hidden');
    uploadStatus.textContent = 'Error: ' + err.message;
    uploadStatus.style.color = '#f87171';
    fileInput.value = '';
  }
});

// ============================================================================
// RESULTS DISPLAY
// ============================================================================

function showResults(data) {
  processingView.classList.add('hidden');
  resultsView.classList.remove('hidden');
  
  var analysis = data.analysis;
  var pages = data.pages;
  
  // Show plan image
  if (pages && pages.length > 0) {
    planImage.src = pages[0].image;
  }
  
  // Project title
  var titleEl = document.getElementById('project-title');
  if (titleEl && analysis.project) {
    titleEl.textContent = (analysis.project.name || '') + ' — ' + (analysis.project.address || '');
  }
  
  renderLayers(analysis);
  renderEquipment(analysis);
  renderProjectInfo(analysis);
}

// ============================================================================
// LAYER COLORS
// ============================================================================

var LAYER_COLORS = {
  'Sprinkler Heads': '#3b82f6',
  'Pendent Heads': '#3b82f6',
  'Upright Heads': '#6366f1',
  'Sidewall Heads': '#8b5cf6',
  'Dry-Sidewall Heads': '#a855f7',
  'Pipes': '#ef4444',
  'Tee Junctions': '#f59e0b',
  'Elbow Junctions': '#f97316',
  'Risers': '#10b981',
  'Control Valves': '#06b6d4',
  'Flow Switches': '#14b8a6',
  'FDC': '#ec4899'
};

var MARKER_TYPE_MAP = {
  'sprinkler_head': 'Sprinkler Heads',
  'pendent': 'Pendent Heads',
  'upright': 'Upright Heads',
  'sidewall': 'Sidewall Heads',
  'dry_sidewall': 'Dry-Sidewall Heads',
  'tee': 'Tee Junctions',
  'elbow': 'Elbow Junctions',
  'riser': 'Risers',
  'valve': 'Control Valves',
  'control_valve': 'Control Valves',
  'flow_switch': 'Flow Switches',
  'fdc': 'FDC'
};

var activeHighlights = {};

// ============================================================================
// LAYERS PANEL
// ============================================================================

function renderLayers(analysis) {
  var panel = document.getElementById('layers-panel');
  if (!panel) return;
  
  var t = analysis.totals || {};
  var items = [];
  
  // Collect head types across all floors
  var headTypes = {};
  if (analysis.floors) {
    for (var f = 0; f < analysis.floors.length; f++) {
      var floor = analysis.floors[f];
      if (floor.sprinkler_heads && floor.sprinkler_heads.types) {
        for (var h = 0; h < floor.sprinkler_heads.types.length; h++) {
          var ht = floor.sprinkler_heads.types[h];
          var key = ht.type;
          if (!headTypes[key]) headTypes[key] = { type: ht.type, count: 0, k_factor: ht.k_factor };
          headTypes[key].count += ht.count;
        }
      }
    }
  }
  
  // Head type toggles
  var headTypeKeys = Object.keys(headTypes);
  if (headTypeKeys.length > 1) {
    for (var i = 0; i < headTypeKeys.length; i++) {
      var ht = headTypes[headTypeKeys[i]];
      var label = ht.type.charAt(0).toUpperCase() + ht.type.slice(1) + ' Heads';
      items.push({ label: label, count: ht.count, detail: ht.k_factor ? 'K=' + ht.k_factor : '' });
    }
  } else {
    items.push({ label: 'Sprinkler Heads', count: t.total_heads || 0, detail: '' });
  }
  
  // Fittings & devices
  if (t.total_tees > 0) items.push({ label: 'Tee Junctions', count: t.total_tees });
  if (t.total_elbows > 0) items.push({ label: 'Elbow Junctions', count: t.total_elbows });
  if (t.total_risers > 0) items.push({ label: 'Risers', count: t.total_risers });
  
  // Devices from floors
  var deviceTotals = {};
  if (analysis.floors) {
    for (var f = 0; f < analysis.floors.length; f++) {
      var devices = analysis.floors[f].devices;
      if (devices) {
        for (var d = 0; d < devices.length; d++) {
          var lbl = devices[d].type.replace(/_/g, ' ');
          lbl = lbl.replace(/\b\w/g, function(c) { return c.toUpperCase(); });
          deviceTotals[lbl] = (deviceTotals[lbl] || 0) + devices[d].count;
        }
      }
    }
  }
  var devKeys = Object.keys(deviceTotals);
  for (var i = 0; i < devKeys.length; i++) {
    if (deviceTotals[devKeys[i]] > 0) {
      items.push({ label: devKeys[i], count: deviceTotals[devKeys[i]] });
    }
  }
  
  // Build HTML
  var html = '';
  for (var i = 0; i < items.length; i++) {
    var item = items[i];
    var color = LAYER_COLORS[item.label] || '#9ca3af';
    var id = 'layer-toggle-' + i;
    
    html += '<label class="flex items-center justify-between py-2.5 px-3 rounded-lg hover:bg-gray-700/50 cursor-pointer" for="' + id + '">';
    html += '  <div class="flex items-center gap-3">';
    html += '    <div class="relative">';
    html += '      <input type="checkbox" id="' + id + '" class="layer-toggle peer sr-only" data-layer="' + item.label + '" data-color="' + color + '" />';
    html += '      <div class="toggle-track h-6 w-11 rounded-full bg-gray-600 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-500 after:bg-white after:transition-all after:content-[\'\'] peer-checked:after:translate-x-full peer-checked:after:border-white"></div>';
    html += '    </div>';
    html += '    <div>';
    html += '      <span class="text-sm text-gray-200">' + item.label + '</span>';
    if (item.detail) html += ' <span class="text-xs text-gray-500">' + item.detail + '</span>';
    html += '    </div>';
    html += '  </div>';
    html += '  <span class="text-lg font-semibold font-mono" style="color:' + color + '">' + item.count + '</span>';
    html += '</label>';
  }
  
  // Total summary
  if (t.total_heads) {
    html += '<div class="mt-3 pt-3 border-t border-gray-700 flex justify-between items-center px-3">';
    html += '  <span class="text-sm text-gray-400">Total Sprinkler Heads</span>';
    html += '  <span class="text-lg font-bold text-white">' + t.total_heads + '</span>';
    html += '</div>';
  }
  
  // Confidence
  if (analysis.confidence) {
    var cc = analysis.confidence === 'high' ? '#4ade80' : analysis.confidence === 'medium' ? '#facc15' : '#f87171';
    html += '<div class="mt-1 px-3 text-xs text-gray-500">Confidence: <span style="color:' + cc + '">' + analysis.confidence + '</span></div>';
  }
  
  panel.innerHTML = html;
  
  // Wire toggle events
  var toggles = panel.querySelectorAll('.layer-toggle');
  for (var i = 0; i < toggles.length; i++) {
    toggles[i].addEventListener('change', function(e) {
      var track = e.target.nextElementSibling;
      var layerName = e.target.getAttribute('data-layer');
      var color = e.target.getAttribute('data-color');
      
      if (e.target.checked) {
        track.style.backgroundColor = color;
        activeHighlights[layerName] = true;
      } else {
        track.style.backgroundColor = '';
        delete activeHighlights[layerName];
      }
      drawHighlights();
    });
  }
}

// ============================================================================
// HIGHLIGHT DRAWING
// ============================================================================

function drawHighlights() {
  var canvas = document.getElementById('highlight-canvas');
  var img = document.getElementById('plan-image');
  if (!canvas || !img) return;
  
  var w = img.clientWidth;
  var h = img.clientHeight;
  
  if (w === 0 || h === 0) return;
  
  canvas.width = w;
  canvas.height = h;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  
  var ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, w, h);
  
  var hasActive = Object.keys(activeHighlights).length > 0;
  if (!hasActive) return;
  
  var markers = analysisData && analysisData.analysis && analysisData.analysis.markers;
  if (!markers || markers.length === 0) return;
  
  var radius = Math.max(10, Math.min(w, h) * 0.007);
  
  for (var i = 0; i < markers.length; i++) {
    var marker = markers[i];
    var layerName = MARKER_TYPE_MAP[marker.type] || '';
    
    // Check if this marker's layer is active
    var isActive = activeHighlights[layerName];
    
    // Also check generic "Sprinkler Heads" for any head type
    if (!isActive) {
      var isHead = marker.type === 'sprinkler_head' || marker.type === 'pendent' || 
                   marker.type === 'upright' || marker.type === 'sidewall' || marker.type === 'dry_sidewall';
      if (isHead && activeHighlights['Sprinkler Heads']) isActive = true;
    }
    
    if (!isActive) continue;
    
    var x = marker.x * w;
    var y = marker.y * h;
    var color = LAYER_COLORS[layerName] || '#3b82f6';
    
    // Outer glow
    ctx.beginPath();
    ctx.arc(x, y, radius + 4, 0, Math.PI * 2);
    ctx.strokeStyle = color + '40';
    ctx.lineWidth = 2;
    ctx.stroke();
    
    // Main ring (stroke only — item underneath stays visible)
    ctx.beginPath();
    ctx.arc(x, y, radius, 0, Math.PI * 2);
    ctx.strokeStyle = color;
    ctx.lineWidth = 2.5;
    ctx.stroke();
  }
}

// Redraw on image resize
var ro = new ResizeObserver(function() { drawHighlights(); });
if (planImage) ro.observe(planImage);

// ============================================================================
// EQUIPMENT & PROJECT
// ============================================================================

function renderEquipment(analysis) {
  var panel = document.getElementById('equipment-panel');
  if (!panel || !analysis.equipment) return;
  
  var eq = analysis.equipment;
  var html = '';
  
  if (eq.fdc && eq.fdc.count > 0) html += '<div class="flex justify-between"><span class="text-gray-400">FDC</span><span>' + eq.fdc.count + '× ' + (eq.fdc.size || '') + ' ' + (eq.fdc.type || '') + '</span></div>';
  if (eq.fire_pump && eq.fire_pump.count > 0) html += '<div class="flex justify-between"><span class="text-gray-400">Fire Pump</span><span>' + (eq.fire_pump.model || '') + ' ' + (eq.fire_pump.hp || '') + 'HP</span></div>';
  if (eq.tank && eq.tank.count > 0) html += '<div class="flex justify-between"><span class="text-gray-400">Tank</span><span>' + (eq.tank.capacity_gallons || 0) + ' gal</span></div>';
  if (eq.backflow_preventer && eq.backflow_preventer.count > 0) html += '<div class="flex justify-between"><span class="text-gray-400">Backflow</span><span>' + (eq.backflow_preventer.size || '') + '</span></div>';
  
  panel.innerHTML = html || '<p class="text-gray-500">None detected</p>';
}

function renderProjectInfo(analysis) {
  var panel = document.getElementById('project-panel');
  if (!panel || !analysis.project) return;
  
  var p = analysis.project;
  var html = '';
  if (p.engineer) html += '<div><span class="text-gray-500">Engineer:</span> ' + p.engineer + '</div>';
  if (p.standard) html += '<div><span class="text-gray-500">Standard:</span> ' + p.standard + '</div>';
  if (p.system_type) html += '<div><span class="text-gray-500">System:</span> ' + p.system_type + '</div>';
  if (p.hazard_class) html += '<div><span class="text-gray-500">Hazard:</span> ' + p.hazard_class + '</div>';
  
  panel.innerHTML = html;
}

// ============================================================================
// NEW SCAN
// ============================================================================

document.getElementById('new-scan-btn')?.addEventListener('click', function() {
  resultsView.classList.add('hidden');
  uploadView.classList.remove('hidden');
  uploadStatus.textContent = '';
  uploadStatus.style.color = '';
  fileInput.value = '';
  analysisData = null;
  planImage.src = '';
  activeHighlights = {};
});
</script>

</LayoutFullWidth>
