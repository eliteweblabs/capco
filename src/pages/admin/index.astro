---
/**
 * Admin Dashboard Index
 * Redirects to the main admin dashboard (Global Activity)
 */
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";

const { currentUser, session, currentRole } = await checkAuth(Astro.cookies);

// Redirect to login if not authenticated
if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}

// Use checkAuth-derived role (trimmed/normalized inside auth); aligns with APIs
if (!isAdminOrSuperAdmin(currentRole)) {
  return Astro.redirect("/dashboard");
}

// Redirect to main admin dashboard
return Astro.redirect("/admin/global-activity");
---
