---
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const isLocalBypass = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
if (!isLocalBypass && (!currentUser || !session)) return Astro.redirect("/auth/login");
if (!isLocalBypass && !isAdminOrSuperAdmin(currentRole)) return Astro.redirect("/dashboard");
---

<LayoutFullWidth title="Step-by-Step Scanner" classList="p-0" description="Progressive fire protection plan analysis">
<div class="h-screen flex bg-gray-900 text-white overflow-hidden">

  <!-- Collapsible Sidebar -->
  <div id="sidebar" class="bg-gray-800 border-r border-gray-700 flex flex-col transition-all duration-300 w-80 shrink-0">
    <!-- Sidebar Header -->
    <div class="bg-gray-700 border-b border-gray-600 p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Step-by-Step Scanner</h2>
      <button id="sidebar-toggle" class="text-gray-400 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
        </svg>
      </button>
    </div>

    <!-- Sidebar Content -->
    <div class="flex-1 overflow-auto p-4 space-y-6">
      <!-- Plan Selection -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Floor Plan</label>
        <select id="plan-select" class="w-full bg-gray-700 text-gray-200 border border-gray-600 rounded px-3 py-2 text-sm">
          <option value="">Select a test plan...</option>
          <option value="demo-plan">Demo Plan (SimpleScan default)</option>
          <option value="85-tremont">85 Tremont Street Cambridge MA FP.pdf</option>
          <option value="lane-park">Lane Park plan (5 heads)</option>
        </select>
      </div>

      <!-- Plan Status -->
      <div id="plan-status" class="text-xs text-gray-400">
        Ready to load plan
      </div>

      <!-- Debug Log -->
      <div class="mt-4">
        <div class="text-xs font-medium text-gray-400 mb-1">Debug Log:</div>
        <div id="debug-log" class="text-xs text-gray-300 bg-gray-900 p-2 rounded max-h-32 overflow-y-auto font-mono"></div>
      </div>

      <!-- Steps Progress -->
      <div id="steps-container" class="space-y-4">
        <div class="text-sm font-medium text-gray-300">Processing Steps</div>
        <!-- Steps will be populated here -->
      </div>
    </div>
  </div>

  <!-- Main Content Area -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Main Toolbar (when sidebar collapsed) -->
    <div id="main-toolbar" class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center gap-4 hidden">
      <button id="sidebar-expand" class="text-gray-400 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
        </svg>
      </button>
      <span id="current-plan-title" class="text-sm text-gray-300 font-semibold"></span>
    </div>

    <!-- Plan Viewer -->
    <div class="flex-1 overflow-auto bg-gray-950 flex items-center justify-center">
      <!-- Upload prompt (shown when no file loaded) -->
      <div id="upload-prompt" class="text-center w-full h-full flex flex-col items-center justify-center">
        <div class="text-gray-500 mb-3">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
          </svg>
        </div>
        <span class="text-gray-400">Select a floor plan to begin</span>
      </div>
      
      <!-- Plan display -->
      <div id="plan-view" class="hidden relative w-full h-full flex items-center justify-center">
        <img id="plan-img" class="max-w-full max-h-full object-contain" />
        <!-- Step overlays will go here -->
        <div id="plan-overlays" class="absolute top-0 left-0 w-full h-full pointer-events-none"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Sidebar transitions */
  .sidebar-collapsed {
    width: 0 !important;
    overflow: hidden;
  }
</style>

<script is:inline>
(function() {
  const API = 'http://localhost:5556';
  let currentPlan = null;
  let currentStep = 0;

  // DOM elements
  const sidebar = document.getElementById('sidebar');
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebarExpand = document.getElementById('sidebar-expand');
  const mainToolbar = document.getElementById('main-toolbar');
  const planSelect = document.getElementById('plan-select');
  const planStatus = document.getElementById('plan-status');
  const currentPlanTitle = document.getElementById('current-plan-title');
  const uploadPrompt = document.getElementById('upload-prompt');
  const planView = document.getElementById('plan-view');
  const planImg = document.getElementById('plan-img');
  const planOverlays = document.getElementById('plan-overlays');
  const stepsContainer = document.getElementById('steps-container');
  const debugLog = document.getElementById('debug-log');

  // Debug logging function
  function log(message) {
    const timestamp = new Date().toLocaleTimeString();
    const logMessage = `[${timestamp}] ${message}`;
    console.log(logMessage);
    
    if (debugLog) {
      debugLog.innerHTML += logMessage + '<br>';
      debugLog.scrollTop = debugLog.scrollHeight; // Auto-scroll to bottom
    }
  }

  // Debug: Log which elements were found
  log('=== INITIALIZATION ===');
  log('DOM Elements found:');
  log('- sidebar: ' + !!sidebar);
  log('- planSelect: ' + !!planSelect);
  log('- planStatus: ' + !!planStatus);  
  log('- uploadPrompt: ' + !!uploadPrompt);
  log('- planView: ' + !!planView);
  log('- planImg: ' + !!planImg);
  log('- stepsContainer: ' + !!stepsContainer);
  log('- debugLog: ' + !!debugLog);

  // Sidebar toggle functionality
  sidebarToggle?.addEventListener('click', () => {
    sidebar?.classList.add('sidebar-collapsed');
    mainToolbar?.classList.remove('hidden');
  });

  sidebarExpand?.addEventListener('click', () => {
    sidebar?.classList.remove('sidebar-collapsed');
    mainToolbar?.classList.add('hidden');
  });

  // Plan selection functionality
  planSelect?.addEventListener('change', (e) => {
    log('Plan select changed: ' + e.target.value);
    const planId = e.target.value;
    if (planId) {
      log('Loading plan from dropdown: ' + planId);
      loadTestPlan(planId);
    } else {
      log('Clearing plan (no selection)');
      clearPlan();
    }
  });

  function clearPlan() {
    log('Clearing plan');
    currentPlan = null;
    uploadPrompt?.classList.remove('hidden');
    planView?.classList.add('hidden');
    updatePlanStatus('No plan selected');
    updatePlanTitle('');
  }

  function updatePlanStatus(message) {
    log('Plan status updated: ' + message);
    if (planStatus) {
      planStatus.textContent = message;
      log('Status element updated successfully');
    } else {
      log('ERROR: planStatus element not found!');
    }
  }

  function updatePlanTitle(title) {
    log('Plan title updated: ' + title);
    if (currentPlanTitle) {
      currentPlanTitle.textContent = title;
    } else {
      log('ERROR: currentPlanTitle element not found!');
    }
  }

  async function loadTestPlan(planId) {
    try {
      log('Loading test plan: ' + planId);
      updatePlanStatus('Loading plan...');
      
      // First get the PDF
      log('Fetching PDF from: ' + API + '/test-plans/' + planId);
      const pdfResponse = await fetch(`${API}/test-plans/${planId}`);
      if (!pdfResponse.ok) throw new Error('Failed to load plan: ' + pdfResponse.status);
      
      const pdfBlob = await pdfResponse.blob();
      log('Plan PDF loaded, size: ' + pdfBlob.size);
      
      // Convert PDF to image using /render endpoint
      updatePlanStatus('Rendering plan...');
      const formData = new FormData();
      formData.append('file', pdfBlob, `${planId}.pdf`);
      formData.append('page', '0'); // First page
      formData.append('dpi', '150'); // Good quality
      
      log('Sending render request to: ' + API + '/render');
      const renderResponse = await fetch(`${API}/render`, {
        method: 'POST',
        body: formData
      });
      
      if (!renderResponse.ok) throw new Error('Failed to render plan: ' + renderResponse.status);
      
      const imageBlob = await renderResponse.blob();
      const imageUrl = URL.createObjectURL(imageBlob);
      log('Plan image rendered, URL: ' + imageUrl.substring(0, 50) + '...');
      
      // Load rendered image
      log('Setting up image load handlers');
      
      planImg.onload = () => {
        log('SUCCESS: planImg.onload fired - image loaded successfully!');
        log('Image dimensions: ' + planImg.naturalWidth + 'x' + planImg.naturalHeight);
        log('uploadPrompt element: ' + !!uploadPrompt);
        log('planView element: ' + !!planView);
        
        log('Before UI update - uploadPrompt classes: ' + (uploadPrompt ? uploadPrompt.className : 'null'));
        log('Before UI update - planView classes: ' + (planView ? planView.className : 'null'));
        
        uploadPrompt?.classList.add('hidden');
        planView?.classList.remove('hidden');
        
        log('After UI update - uploadPrompt classes: ' + (uploadPrompt ? uploadPrompt.className : 'null'));
        log('After UI update - planView classes: ' + (planView ? planView.className : 'null'));
        
        log('UI updated: uploadPrompt hidden, planView shown');
        
        currentPlan = { id: planId, imageUrl: imageUrl, pdfBlob: pdfBlob };
        
        const planNames = {
          'demo-plan': 'Demo Plan (SimpleScan default)',
          '85-tremont': '85 Tremont Street Cambridge MA FP.pdf',
          'lane-park': 'Lane Park plan (5 heads)'
        };
        
        const planName = planNames[planId] || planId;
        updatePlanStatus(`Loaded: ${planName}`);
        updatePlanTitle(planName);
        
        log('Calling initializeSteps()');
        initializeSteps();
      };
      
      planImg.onerror = (e) => {
        log('ERROR: planImg.onerror fired: ' + e);
        updatePlanStatus('Failed to display plan image');
        clearPlan();
      };
      
      log('Setting planImg.src to: ' + imageUrl.substring(0, 50) + '...');
      planImg.src = imageUrl;
      
    } catch (error) {
      log('ERROR loading plan: ' + error.message);
      updatePlanStatus('Error loading plan: ' + error.message);
      clearPlan();
    }
  }

  function initializeSteps() {
    log('initializeSteps() called');
    // Initialize the step-by-step process
    currentStep = 0;
    log('currentStep set to: ' + currentStep);
    renderStepsUI();
  }

  function renderStepsUI() {
    log('renderStepsUI() called');
    if (!stepsContainer) {
      log('ERROR: stepsContainer not found!');
      return;
    }
    log('Rendering steps UI for step: ' + currentStep);
    
    const steps = [
      { id: 'detect-regions', title: 'Step 1: Detect Viable Areas', status: 'ready' },
      { id: 'apply-regions', title: 'Step 2: Apply Viable Areas', status: 'pending' },
      { id: 'find-colors', title: 'Step 3: Find Colored Lines', status: 'pending' },
      { id: 'remove-hairlines', title: 'Step 4: Remove Hairlines', status: 'pending' },
      { id: 'find-dashes', title: 'Step 5: Find Dashed Lines', status: 'pending' },
      { id: 'remove-text', title: 'Step 6: Remove Text', status: 'pending' },
      { id: 'final-output', title: 'Step 7: Final Output', status: 'pending' }
    ];

    stepsContainer.innerHTML = steps.map((step, index) => {
      const isActive = index === currentStep;
      const isComplete = index < currentStep;
      const isPending = index > currentStep;
      
      let statusClass = 'text-gray-500';
      let statusIcon = '⏸️';
      
      if (isComplete) {
        statusClass = 'text-green-400';
        statusIcon = '✅';
      } else if (isActive) {
        statusClass = 'text-blue-400';
        statusIcon = '▶️';
      }
      
      return `
        <div class="p-3 rounded border ${isActive ? 'border-blue-500 bg-blue-500/10' : 'border-gray-600 bg-gray-700/50'}">
          <div class="flex items-center gap-3">
            <span class="text-lg">${statusIcon}</span>
            <div class="flex-1">
              <div class="font-medium text-sm ${statusClass}">${step.title}</div>
              <div class="text-xs text-gray-400 capitalize">${step.status}</div>
            </div>
            ${isActive ? '<button class="text-xs bg-blue-600 hover:bg-blue-700 px-2 py-1 rounded text-white">Run</button>' : ''}
          </div>
        </div>
      `;
    }).join('');
    
    log('Steps UI rendered successfully');
  }

  // Auto-load demo plan on start (same as plan-scanner approach)
  log('=== AUTO-LOAD INIT ===');
  log('Document ready state: ' + document.readyState);
  log('API URL: ' + API);
  
  if (document.readyState === 'loading') {
    log('Waiting for DOMContentLoaded...');
    document.addEventListener('DOMContentLoaded', function() {
      log('DOMContentLoaded fired - setting up auto-load');
      log('planSelect element at DOMContentLoaded: ' + !!planSelect);
      if (planSelect) {
        log('Setting planSelect.value to demo-plan');
        planSelect.value = 'demo-plan';
        log('planSelect.value now: ' + planSelect.value);
        log('Calling loadTestPlan(demo-plan)');
        loadTestPlan('demo-plan');
      } else {
        log('ERROR: planSelect element not found at DOMContentLoaded!');
      }
    });
  } else {
    // DOM already ready, run immediately
    log('DOM already ready - setting up auto-load immediately');
    setTimeout(() => {
      log('Timeout fired - setting up auto-load');
      log('planSelect element in timeout: ' + !!planSelect);
      if (planSelect) {
        log('Setting planSelect.value to demo-plan');
        planSelect.value = 'demo-plan';
        log('planSelect.value now: ' + planSelect.value);
        log('Calling loadTestPlan(demo-plan)');
        loadTestPlan('demo-plan');
      } else {
        log('ERROR: planSelect element not found in timeout!');
      }
    }, 200);
  }

})();
</script>
</LayoutFullWidth>