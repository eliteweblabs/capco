---
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";
import { supabaseAdmin } from "../../lib/supabase-admin";
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import Hero from "../../components/common/Hero.astro";
import { globalClasses } from "../api/global/global-classes";

const { primaryTextClasses, secondaryTextClasses, globalCardStyle } = globalClasses();

// Check authentication
const { currentUser, supabase } = await checkAuth(Astro.cookies);

if (!currentUser) {
  return Astro.redirect("/auth/login");
}

const { data: profile } = await supabase
  .from("profiles")
  .select("role")
  .eq("id", currentUser.id)
  .single();

if (!isAdminOrSuperAdmin(profile?.role)) {
  return Astro.redirect("/dashboard");
}

let logs: Array<{
  id: number;
  formId: string | null;
  formAction: string | null;
  error: string;
  statusCode: number | null;
  context: Record<string, unknown> | null;
  userAgent: string | null;
  createdAt: string;
}> = [];

let traceLogs: Array<{
  timestamp: string;
  action: string;
  user: string;
  message: string;
  traceId?: string;
  phase?: string;
  traceName?: string;
  isError?: boolean;
  metadata?: Record<string, unknown> | null;
}> = [];

if (supabaseAdmin) {
  const { data, error } = await supabaseAdmin
    .from("formFailureLogs")
    .select("id, formId, formAction, error, statusCode, context, userAgent, createdAt")
    .order("createdAt", { ascending: false })
    .limit(100);

  if (error) {
    console.error("Error fetching form failure logs:", error);
  } else {
    logs = data || [];
  }

  const { data: traceSource, error: traceError } = await supabaseAdmin
    .from("projects")
    .select("log")
    .eq("id", 0)
    .single();

  if (traceError) {
    console.error("Error fetching trace logs:", traceError);
  } else {
    const fullLog = Array.isArray(traceSource?.log) ? traceSource.log : [];
    traceLogs = fullLog
      .filter((entry: any) => String(entry?.message || "").includes("[TRACE]"))
      .slice(-100)
      .reverse()
      .map((entry: any) => ({
        timestamp: entry?.timestamp || "",
        action: entry?.action || "systemEvent",
        user: entry?.user || "System",
        message: entry?.message || "",
        traceId: entry?.metadata?.traceId || "",
        phase: entry?.metadata?.phase || "",
        traceName: entry?.metadata?.name || "",
        isError:
          entry?.metadata?.phase === "error" ||
          String(entry?.message || "")
            .toLowerCase()
            .includes("[trace][error]"),
        metadata: entry?.metadata || null,
      }));
  }
}

function formatDate(iso: string) {
  try {
    const d = new Date(iso);
    return d.toLocaleString(undefined, {
      dateStyle: "short",
      timeStyle: "medium",
    });
  } catch {
    return iso;
  }
}
---

<LayoutFullWidth
  title="Form Failure Logs"
  classList="p-4"
  description="Review client-side form submission failures for debugging"
>
  <Hero
    enableAos={false}
    title="Form Failure Logs"
    description="Recent form submission failures. Use to monitor and debug contact forms, registration, and other submissions."
    {primaryTextClasses}
    {secondaryTextClasses}
  />

  <div class="mb-4 flex items-center gap-2">
    <button
      type="button"
      id="diag-tab-form"
      class="rounded border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-gray-600 dark:text-gray-200"
    >
      Form Failures
    </button>
    <button
      type="button"
      id="diag-tab-trace"
      class="rounded border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-gray-600 dark:text-gray-200"
    >
      Trace Logs
    </button>
  </div>

  <div class={globalCardStyle} id="diagnostic-form-section">
    {
      logs.length === 0 ? (
        <p class="py-8 text-center text-gray-500 dark:text-gray-400">
          No form failures recorded yet.
        </p>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th
                  scope="col"
                  class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400"
                >
                  Time
                </th>
                <th
                  scope="col"
                  class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400"
                >
                  Form
                </th>
                <th
                  scope="col"
                  class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400"
                >
                  Error
                </th>
                <th
                  scope="col"
                  class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400"
                >
                  Context
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {logs.map((log) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                  <td class="whitespace-nowrap px-4 py-2 text-sm text-gray-600 dark:text-gray-300">
                    {formatDate(log.createdAt)}
                  </td>
                  <td class="px-4 py-2 text-sm">
                    <span class="font-medium text-gray-900 dark:text-white">
                      {log.formId || "—"}
                    </span>
                    {log.formAction && (
                      <span
                        class="block max-w-[200px] truncate text-xs text-gray-500"
                        title={log.formAction}
                      >
                        {log.formAction}
                      </span>
                    )}
                  </td>
                  <td class="max-w-[300px] px-4 py-2 text-sm text-red-600 dark:text-red-400">
                    {log.error}
                  </td>
                  <td class="px-4 py-2 text-xs text-gray-500 dark:text-gray-400">
                    {log.context && Object.keys(log.context).length > 0 ? (
                      <pre
                        class="m-0 max-w-[200px] truncate rounded bg-gray-100 p-1 dark:bg-gray-900"
                        title={JSON.stringify(log.context)}
                      >
                        {JSON.stringify(log.context)}
                      </pre>
                    ) : (
                      "—"
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </div>

  <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
    Logs are captured automatically when a form fails to submit. Stored in Supabase and viewable
    here.
  </p>

  <div class={`${globalCardStyle} mt-6`} id="diagnostic-trace-section">
    <h3 class="mb-3 text-lg font-semibold text-gray-900 dark:text-white">
      Trace Logs (Toggleable)
    </h3>
    <div class="mb-3 grid grid-cols-1 gap-2 md:grid-cols-5">
      <input
        id="trace-filter-text"
        type="text"
        class="rounded border border-gray-300 px-2 py-1 text-sm dark:border-gray-700 dark:bg-gray-900"
        placeholder="Search message or trace name"
      />
      <input
        id="trace-filter-id"
        type="text"
        class="rounded border border-gray-300 px-2 py-1 text-sm dark:border-gray-700 dark:bg-gray-900"
        placeholder="traceId"
      />
      <input
        id="trace-filter-feature"
        type="text"
        class="rounded border border-gray-300 px-2 py-1 text-sm dark:border-gray-700 dark:bg-gray-900"
        placeholder="feature/name contains"
      />
      <select
        id="trace-filter-phase"
        class="rounded border border-gray-300 px-2 py-1 text-sm dark:border-gray-700 dark:bg-gray-900"
      >
        <option value="">All phases</option>
        <option value="start">start</option>
        <option value="end">end</option>
        <option value="error">error</option>
      </select>
      <label
        class="flex items-center gap-2 rounded border border-gray-300 px-2 py-1 text-sm dark:border-gray-700"
      >
        <input id="trace-filter-error-only" type="checkbox" />
        Error only
      </label>
    </div>
    {
      traceLogs.length === 0 ? (
        <p class="py-4 text-sm text-gray-500 dark:text-gray-400">
          No trace logs yet. Enable with{" "}
          <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">window.TraceLog.enable()</code> in
          the browser console and reproduce.
        </p>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  Time
                </th>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  User
                </th>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  Message
                </th>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  Metadata
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {traceLogs.map((log) => (
                <tr
                  class="trace-row hover:bg-gray-50 dark:hover:bg-gray-800/50"
                  data-trace-id={log.traceId || ""}
                  data-trace-phase={log.phase || ""}
                  data-trace-name={log.traceName || ""}
                  data-trace-error={log.isError ? "1" : "0"}
                  data-trace-message={log.message}
                >
                  <td class="whitespace-nowrap px-4 py-2 text-sm text-gray-600 dark:text-gray-300">
                    {formatDate(log.timestamp)}
                  </td>
                  <td class="px-4 py-2 text-sm text-gray-700 dark:text-gray-300">{log.user}</td>
                  <td class="max-w-[360px] px-4 py-2 text-sm text-gray-900 dark:text-gray-100">
                    {log.message}
                  </td>
                  <td class="px-4 py-2 text-xs text-gray-500 dark:text-gray-400">
                    {log.metadata ? (
                      <pre
                        class="m-0 max-w-[240px] truncate rounded bg-gray-100 p-1 dark:bg-gray-900"
                        title={JSON.stringify(log.metadata)}
                      >
                        {JSON.stringify(log.metadata)}
                      </pre>
                    ) : (
                      "—"
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </div>

  <script>
    const formTab = document.getElementById("diag-tab-form");
    const traceTab = document.getElementById("diag-tab-trace");
    const formSection = document.getElementById("diagnostic-form-section");
    const traceSection = document.getElementById("diagnostic-trace-section");

    function showDiagnosticsTab(mode) {
      if (!formSection || !traceSection) return;
      formSection.classList.toggle("hidden", mode !== "form");
      traceSection.classList.toggle("hidden", mode !== "trace");
    }

    formTab?.addEventListener("click", () => showDiagnosticsTab("form"));
    traceTab?.addEventListener("click", () => showDiagnosticsTab("trace"));
    showDiagnosticsTab("trace");

    const textInput = document.getElementById("trace-filter-text");
    const idInput = document.getElementById("trace-filter-id");
    const featureInput = document.getElementById("trace-filter-feature");
    const phaseSelect = document.getElementById("trace-filter-phase");
    const errorOnly = document.getElementById("trace-filter-error-only");

    function applyTraceFilters() {
      const text = (textInput as HTMLInputElement)?.value?.toLowerCase() || "";
      const traceId = (idInput as HTMLInputElement)?.value?.toLowerCase() || "";
      const feature = (featureInput as HTMLInputElement)?.value?.toLowerCase() || "";
      const phase = (phaseSelect as HTMLSelectElement)?.value || "";
      const onlyErrors = (errorOnly as HTMLInputElement)?.checked || false;

      document.querySelectorAll("tr.trace-row").forEach((row) => {
        const el = row as HTMLElement;
        const rowMessage = (el.dataset.traceMessage || "").toLowerCase();
        const rowTraceId = (el.dataset.traceId || "").toLowerCase();
        const rowTraceName = (el.dataset.traceName || "").toLowerCase();
        const rowPhase = el.dataset.tracePhase || "";
        const rowIsError = el.dataset.traceError === "1";

        const passesText = !text || rowMessage.includes(text) || rowTraceName.includes(text);
        const passesId = !traceId || rowTraceId.includes(traceId);
        const passesFeature = !feature || rowTraceName.includes(feature);
        const passesPhase = !phase || rowPhase === phase;
        const passesError = !onlyErrors || rowIsError;
        el.classList.toggle(
          "hidden",
          !(passesText && passesId && passesFeature && passesPhase && passesError)
        );
      });
    }

    [textInput, idInput, featureInput, phaseSelect, errorOnly].forEach((el) =>
      el?.addEventListener("input", applyTraceFilters)
    );
  </script>
</LayoutFullWidth>
