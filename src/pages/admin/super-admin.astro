---
/**
 * superAdmin: info page for users with role superAdmin (DB role only).
 * Access restricted to superAdmin; link to Clone & Deploy.
 */
import { checkAuth } from "../../lib/auth";
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { globalClasses } from "../api/global/global-classes";

const { globalCardStyle } = globalClasses();

const { currentUser, session, currentRole } = await checkAuth(Astro.cookies);

if (!currentUser || !session) {
  return Astro.redirect("/auth/login");
}

if (currentRole !== "superAdmin") {
  return Astro.redirect("/project/dashboard");
}
---

<LayoutFullWidth
  title="superAdmin"
  classList="p-4"
  description="superAdmin tools and Clone & Deploy."
>
  <div class="px-4 py-8">
    <div class="mb-6">
      <h1 class="mb-2 text-3xl font-bold">superAdmin</h1>
      <p class="text-gray-600 dark:text-gray-400">Your role is superAdmin. Use the tools below.</p>
    </div>

    <div class={`space-y-6 ${globalCardStyle} p-6`}>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        Current role: <strong>{currentRole}</strong>
      </p>

      <section>
        <h2 class="mb-3 text-lg font-semibold">Clone & Deploy</h2>
        <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
          Generate Railway + Supabase clone scripts for new deployments.
        </p>
        <a
          href="/admin/clone-deploy"
          class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600"
        >
          Open Clone & Deploy
        </a>
      </section>
    </div>
  </div>
</LayoutFullWidth>
