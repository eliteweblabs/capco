---
const requireAuthRedirect = "/auth/login";
import { checkAuth } from "../../lib/auth";
const {
  currentUser,
  session,
  supabase: _supabase,
  refreshToken: _refreshToken,
  accessToken: _accessToken,
} = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role || "Client";

// Handle auth redirect first
if (requireAuthRedirect && (!session || !currentUser)) {
  return Astro.redirect(requireAuthRedirect);
}

import { globalCompanyData } from "../api/global/global-company-data.ts";
import { globalClasses } from "../api/global/global-classes.ts";
import DashboardContent from "../../components/project/Dashboard.astro";
// ⚡ OPTIMIZATION: Run all data fetches in PARALLEL
console.time("🏗️ [DASHBOARD] Total data fetch");

const [companyData, statusData, projectsData] = await Promise.all([
  // Fetch 1: Company data
  globalCompanyData().catch((err) => {
    console.error("🏗️ [DASHBOARD] ❌ Company data fetch failed:", err);
    return {
      globalCompanyName: "",
      globalCompanySlogan: "",
      globalCompanyAddress: "",
      globalCompanyPhone: "",
      globalCompanyEmail: "",
      globalCompanyWebsite: "",
      globalCompanyLogo: "",
    };
  }),

  // Fetch 2: Status data
  fetch(new URL("/api/status/get", Astro.url.origin).toString(), {
    method: "GET",
    headers: { Cookie: Astro.request.headers.get("Cookie") || "" },
  })
    .then((r) => {
      console.log(`🏗️ [DASHBOARD] Status API response: ${r.status}`);
      return r.json();
    })
    .then((d) => {
      console.log(`🏗️ [DASHBOARD] Status data:`, d);
      return d.statuses || [];
    })
    .catch((err) => {
      console.error("🏗️ [DASHBOARD] ❌ Status fetch failed:", err);
      return [];
    }),

  // Fetch 3: Projects (with timeout)
  (async () => {
    if (!currentUser?.id) {
      console.log("🏗️ [DASHBOARD] No user ID, skipping project fetch");
      return [];
    }

    try {
      const apiUrl = new URL("/api/projects/get", Astro.url.origin);
      if (currentRole === "Client") {
        apiUrl.searchParams.set("authorId", currentUser.id);
      }
      apiUrl.searchParams.set("limit", "50");

      console.log(`🏗️ [DASHBOARD] 📡 Fetching projects from: ${apiUrl.toString()}`);

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000); // 5s timeout

      const startTime = Date.now();
      const response = await fetch(apiUrl.toString(), {
        method: "GET",
        headers: {
          "Content-Type": "application/json",
          Cookie: Astro.request.headers.get("Cookie") || "",
        },
        signal: controller.signal,
      });

      clearTimeout(timeoutId);
      const elapsed = Date.now() - startTime;

      console.log(`🏗️ [DASHBOARD] 📦 Response status: ${response.status}, took ${elapsed}ms`);

      if (response.ok) {
        const data = await response.json();
        const projectCount = data.projects?.length || 0;
        console.log(`🏗️ [DASHBOARD] ✅ Successfully loaded ${projectCount} projects`);
        console.log(`🏗️ [DASHBOARD] 📋 Response structure:`, Object.keys(data));
        console.log(
          `🏗️ [DASHBOARD] 📋 Projects array type:`,
          Array.isArray(data.projects),
          "length:",
          data.projects?.length
        );
        return data.projects || [];
      }

      console.error(`🏗️ [DASHBOARD] ❌ API returned error status: ${response.status}`);
      const errorText = await response.text();
      console.error(`🏗️ [DASHBOARD] ❌ Error response:`, errorText);
      return [];
    } catch (error) {
      if (error.name === "AbortError") {
        console.error("🏗️ [DASHBOARD] ⏱️  Request timeout after 5s - returning empty array");
      } else {
        console.error("🏗️ [DASHBOARD] ❌ Fetch error:", error);
      }
      return [];
    }
  })(),
]);

console.timeEnd("🏗️ [DASHBOARD] Total data fetch");
console.log(
  `🏗️ [DASHBOARD] 🎯 Final projectsData:`,
  Array.isArray(projectsData),
  "length:",
  projectsData?.length
);

const {
  globalCompanyName: _globalCompanyName,
  globalCompanySlogan: _globalCompanySlogan,
  globalCompanyAddress: _globalCompanyAddress,
  globalCompanyPhone: _globalCompanyPhone,
  globalCompanyEmail: _globalCompanyEmail,
  globalCompanyWebsite: _globalCompanyWebsite,
  globalCompanyLogo: _globalCompanyLogo,
} = companyData;

const { globalInputClasses, primaryTextClasses, secondaryTextClasses } = globalClasses();
const projects = projectsData;
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
---

<LayoutFullWidth
  title="Global Dashboard"
  description="View all projects."
  {projects}
  {statusData}
  {currentUser}
  classList="p-4"
>
  <!-- <DashboardProjectAccordionTable
  {projects}
  {statusData}
  {currentUser}
  {globalInputClasses}
/> -->

  <DashboardContent
    {projects}
    {statusData}
    {currentUser}
    {globalInputClasses}
    {secondaryTextClasses}
    {primaryTextClasses}
  />
</LayoutFullWidth>

{/* refresh-manager loaded in App.astro for Staff/Admin when PUBLIC_ENABLE_AUTO_REFRESH=true */}
<script
  define:vars={{
    currentUserId: currentUser?.id,
    currentUserRole: currentUser?.profile?.role,
    enableAutoRefresh: import.meta.env.PUBLIC_ENABLE_AUTO_REFRESH !== "false",
  }}
  is:inline
  data-astro-rerun
>
  // Wait for refreshManager to be available (optional: if not loaded, skip polling quietly)
  function waitForRefreshManager() {
    return new Promise((resolve) => {
      if (window.refreshManager) {
        resolve(window.refreshManager);
        return;
      }

      let attempts = 0;
      const maxAttempts = 100; // 5 seconds max (100 * 50ms)

      const checkInterval = setInterval(() => {
        attempts++;

        if (window.refreshManager) {
          clearInterval(checkInterval);
          resolve(window.refreshManager);
        } else if (attempts >= maxAttempts) {
          clearInterval(checkInterval);
          resolve(null); // Not loaded (e.g. auto-refresh shut off) — skip without error
        }
      }, 50);
    });
  }

  // Run init only when enabled and for Staff/Admin
  async function runDashboardInit() {
    if (!enableAutoRefresh) return;
    if (!window.location.pathname.startsWith("/project")) return;
    if (currentUserRole !== "Admin" && currentUserRole !== "Staff") return;
    const refreshManager = await waitForRefreshManager();
    if (!refreshManager) return; // refresh-manager not loaded — polling disabled, no console spam
    try {
      await initializeRefreshSystem(refreshManager);
    } catch (error) {
      console.error("🔄 [DASHBOARD] Failed to initialize refresh system:", error);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runDashboardInit);
  } else {
    runDashboardInit();
  }
  // SPA disabled: document.addEventListener("astro:page-load", runDashboardInit);
  window["__initProjectDashboard"] = runDashboardInit;

  // Clear any previous global count interval so SPA re-init doesn't stack
  if (window.__projectDashboardPollInterval) {
    clearInterval(window.__projectDashboardPollInterval);
    window.__projectDashboardPollInterval = null;
  }

  async function initializeRefreshSystem(refreshManager) {
    // Fetch the actual count from the database immediately
    console.log(`🌐 [DASHBOARD] Fetching initial project count from database...`);

    // The API endpoint uses the session to determine what projects to count
    // Clients see only their projects, Admins see all - handled server-side
    const countUrl = "/api/projects/get?count=true";

    console.log(`🌐 [DASHBOARD] Count URL: ${countUrl}`);

    try {
      const response = await fetch(countUrl);
      if (response.ok) {
        const data = await response.json();
        const databaseCount = data.count || 0;
        console.log(`🌐 [DASHBOARD] ✅ Database count: ${databaseCount}`);

        // Set initial global state from database
        refreshManager.setGlobalState("projectCount", databaseCount);
      } else {
        console.error(`🌐 [DASHBOARD] ❌ Failed to fetch count: ${response.status}`);
        // Fallback: set to 0 and let polling update it
        refreshManager.setGlobalState("projectCount", 0);
      }
    } catch (error) {
      console.error(`🌐 [DASHBOARD] ❌ Error fetching initial count:`, error);
      // Fallback: set to 0 and let polling update it
      refreshManager.setGlobalState("projectCount", 0);
    }

    // Start the refresh manager for project-level updates
    refreshManager.startAutoRefreshWithInterval(5); // Poll every 5 seconds

    console.log("🔄 [DASHBOARD] Refresh manager started:", refreshManager.getRefreshStats());

    // Start polling for global counts (check every 10 seconds)
    if (window.__projectDashboardPollInterval) clearInterval(window.__projectDashboardPollInterval);
    window.__projectDashboardPollInterval = setInterval(async () => {
      console.log(`🌐 [DASHBOARD] ⏰ Polling for global counts... (every 10s)`);
      await refreshManager.refreshGlobalCounts();
    }, 10000);

    console.log(`🌐 [DASHBOARD] Global count polling started (every 10 seconds)`);

    // Make refresh manager globally accessible for debugging
    window.refreshManager = refreshManager;
    window.manualRefreshCounts = async () => {
      console.log(`🌐 [DASHBOARD] 🔧 Manual refresh triggered`);
      await refreshManager.refreshGlobalCounts();
    };

    console.log(`🌐 [DASHBOARD] Debug: Run window.manualRefreshCounts() to manually check counts`);
  }

  // Listen for project deletions to update global count
  document.addEventListener("projectDeleted", (_event) => {
    console.log("🗑️  [DASHBOARD] Project deleted, updating global count");
    const currentCount = refreshManager.getGlobalState("projectCount") || 0;
    const newCount = Math.max(0, currentCount - 1);
    refreshManager.setGlobalState("projectCount", newCount);
    console.log(`🌐 [DASHBOARD] Updated count: ${currentCount} -> ${newCount}`);
  });

  // Listen for project creations to update global count
  document.addEventListener("projectCreated", (_event) => {
    console.log("➕ [DASHBOARD] Project created, updating global count");
    const currentCount = refreshManager.getGlobalState("projectCount") || 0;
    const newCount = currentCount + 1;
    refreshManager.setGlobalState("projectCount", newCount);
    console.log(`🌐 [DASHBOARD] Updated count: ${currentCount} -> ${newCount}`);
  });
</script>
