---
/**
 * Checkout Step 1: Collect email, create order, redirect to payment
 */
import App from "../components/ui/App.astro";
import { globalClasses } from "../api/global/global-classes";
import FormActionButton from "../components/form/FormActionButton.astro";

const { globalContainer, globalTextH2, globalFormLabel, globalInputClasses } = globalClasses();
---

<App title="Checkout" description="Complete your purchase">
  <main class={`${globalContainer} py-8 sm:py-12`}>
    <h1 class={`${globalTextH2} mb-8`}>Checkout</h1>

    <form id="checkout-form" class="max-w-lg space-y-6">
      <div>
        <label for="email" class={globalFormLabel}>Email *</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class={globalInputClasses}
          placeholder="you@example.com"
        />
      </div>
      <FormActionButton action="submit" id="submit-checkout" label="Continue to Payment" />
    </form>

    <div id="checkout-error" class="mt-4 hidden text-red-600"></div>
  </main>
</App>

<script is:inline>
  (async () => {
    const form = document.getElementById("checkout-form");
    const errorEl = document.getElementById("checkout-error");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (document.getElementById("email") as HTMLInputElement).value?.trim();
      if (!email) return;

      const submitBtn = document.getElementById("submit-checkout");
      if (submitBtn) {
        submitBtn.setAttribute("disabled", "true");
        (submitBtn as HTMLButtonElement).textContent = "Creating order...";
      }
      errorEl?.classList.add("hidden");

      const cartRes = await fetch("/api/shop/cart");
      const { cart, cartId, error } = await cartRes.json();

      if (error || !cart || cart.length === 0) {
        errorEl!.textContent = "Cart is empty. Add items before checkout.";
        errorEl?.classList.remove("hidden");
        submitBtn?.removeAttribute("disabled");
        (submitBtn as HTMLButtonElement).textContent = "Continue to Payment";
        return;
      }

      const orderRes = await fetch("/api/square/create-order", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cartId, email }),
      });
      const orderData = await orderRes.json();

      if (!orderData.success) {
        errorEl!.textContent = orderData.error || "Failed to create order";
        errorEl?.classList.remove("hidden");
        submitBtn?.removeAttribute("disabled");
        (submitBtn as HTMLButtonElement).textContent = "Continue to Payment";
        return;
      }

      window.location.href = `/shop/checkout/pay?orderId=${orderData.orderId}`;
    });
  })();
</script>
