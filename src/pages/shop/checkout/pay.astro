---
/**
 * Checkout Step 2: Square payment form
 * Requires ?orderId=uuid - fetches order and renders PaymentFormSquare
 */
import App from "../../../components/ui/App.astro";
import { globalClasses } from "../../api/global/global-classes";
import PaymentFormSquare from "../../../components/shop/PaymentFormSquare.astro";
import { supabaseAdmin } from "../../../lib/supabase-admin";

const { globalContainer, globalTextH2 } = globalClasses();

const orderId = Astro.url.searchParams.get("orderId");
let order: { id: string; orderNumber: string; totalCents: number; email: string } | null = null;

if (orderId && supabaseAdmin) {
  const { data } = await supabaseAdmin
    .from("ecomOrders")
    .select("id, orderNumber, totalCents, email")
    .eq("id", orderId)
    .eq("status", "pending")
    .single();
  order = data;
}
---

<App title="Payment" description="Complete your payment">
  <main class={`${globalContainer} py-8 sm:py-12`}>
    <h1 class={`${globalTextH2} mb-8`}>Payment</h1>

    {
      order ? (
        <div class="max-w-lg">
          <p class="mb-6 text-gray-600 dark:text-gray-400">
            Order {order.orderNumber} — ${(order.totalCents / 100).toFixed(2)}
          </p>
          <PaymentFormSquare
            amount={order.totalCents}
            orderId={order.id}
            orderNumber={order.orderNumber}
            email={order.email}
          />
        </div>
      ) : (
        <div class="text-red-600">
          <p>Invalid or expired order.</p>
          <a href="/shop/checkout" class="underline">
            Return to checkout
          </a>
        </div>
      )
    }
  </main>
</App>
