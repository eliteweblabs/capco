/**
 * Redirect: Voice Assistant (VAPI) has been merged into AI Agent.
 * This page redirects to /ai-agent/voice for backwards compatibility.
 * Preserves query params (e.g. ?gmail=connected) for Gmail OAuth callback.
 */
const url = new URL(Astro.request.url);
const target = `/ai-agent/voice${url.search}`;
return Astro.redirect(target);
