---
// AI Agent Chat Page
// Main page for interacting with the AI agent

import App from "../../components/ui/App.astro";
import AIChatAgent from "../../features/ai-chat-agent/AIChatAgent.astro";
import { checkAuth } from "../../lib/auth";
import { globalClasses } from "../api/global/global-classes";

const { currentUser } = await checkAuth(Astro.cookies);
const { globalCardStyle, globalContainer } = globalClasses();

if (!currentUser) {
  return Astro.redirect("/login");
}
---

<App title="AI Assistant - Fire Protection Expert" {currentUser}>
  <div class={`${globalContainer} py-8`}>
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">AI Assistant</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          Your intelligent fire protection engineering assistant powered by Claude AI
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <a
          href="/ai-agent/voice"
          class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
            />
          </svg>
          Voice
        </a>
        <a
          href="/ai-agent/knowledge"
          class="rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          Manage Knowledge
        </a>
      </div>
    </div>

    <div
      class={`${globalCardStyle} shadow-sm`}
      style="height: calc(100vh - 200px); min-height: 600px;"
    >
      <AIChatAgent {currentUser} />
    </div>
  </div>
</App>
