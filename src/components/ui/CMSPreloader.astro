---
/**
 * Page intro: full-viewport dot grid (body PixelGrid) + centered brand icon, then staged fade —
 * icon out → header (nav + aside) → footer (+ FABs) → main content.
 * Dispatches `cms-preloader-hidden` when the sequence finishes (AOS / listeners).
 */

interface Props {
  globalCompanyName: string;
  /** ms to hold on grid + icon before icon fades */
  holdMs?: number;
  /** ms for centered icon opacity transition */
  iconFadeMs?: number;
  /** ms between each chrome stage after icon fade begins */
  stageGapMs?: number;
}

import SimpleIcon from "../common/SimpleIcon.astro";

const {
  globalCompanyName,
  holdMs = 220,
  iconFadeMs = 500,
  stageGapMs = 200,
} = Astro.props;

const chromeTransitionMs = 500;
---

<div
  id="site-intro-icon-layer"
  class="pointer-events-none fixed inset-0 z-[110] flex items-center justify-center bg-transparent opacity-100 transition-opacity duration-500 ease-out motion-reduce:hidden"
  aria-hidden="true"
>
  <div class="relative flex h-32 w-32 items-center justify-center">
    <SimpleIcon name={globalCompanyName} size="6xl" />
  </div>
</div>

<script
  is:inline
  define:vars={{ holdMs, iconFadeMs, stageGapMs, chromeTransitionMs }}
>
  (function () {
    var HOLD = typeof holdMs === "number" ? holdMs : 220;
    var ICON_MS = typeof iconFadeMs === "number" ? iconFadeMs : 500;
    var GAP = typeof stageGapMs === "number" ? stageGapMs : 200;
    var CHROME_MS = typeof chromeTransitionMs === "number" ? chromeTransitionMs : 500;

    var SEL_HEADER = '[data-intro-stage="header"]';
    var SEL_FOOTER = '[data-intro-stage="footer"]';
    var SEL_MAIN = '[data-intro-stage="main"]';

    function qsa(sel) {
      return Array.prototype.slice.call(document.querySelectorAll(sel));
    }

    function reveal(el) {
      el.classList.remove("opacity-0", "pointer-events-none");
      el.classList.add("opacity-100");
    }

    function conceal(el) {
      el.classList.add("opacity-0", "pointer-events-none");
      el.classList.remove("opacity-100");
    }

    function setIconVisible(show) {
      var iconEl = document.getElementById("site-intro-icon-layer");
      if (!iconEl) return;
      if (show) {
        iconEl.classList.remove("opacity-0");
        iconEl.classList.add("opacity-100");
      } else {
        iconEl.classList.remove("opacity-100");
        iconEl.classList.add("opacity-0");
      }
    }

    function showChromeImmediate() {
      qsa(SEL_HEADER).forEach(reveal);
      qsa(SEL_FOOTER).forEach(reveal);
      qsa(SEL_MAIN).forEach(reveal);
      setIconVisible(false);
      window.dispatchEvent(new Event("cms-preloader-hidden"));
    }

    function runSequence() {
      var iconEl = document.getElementById("site-intro-icon-layer");

      setTimeout(function () {
        if (iconEl) {
          iconEl.classList.remove("opacity-100");
          iconEl.classList.add("opacity-0");
        }
      }, HOLD);

      setTimeout(function () {
        qsa(SEL_HEADER).forEach(reveal);
      }, HOLD + ICON_MS);

      setTimeout(function () {
        qsa(SEL_FOOTER).forEach(reveal);
      }, HOLD + ICON_MS + GAP);

      setTimeout(function () {
        qsa(SEL_MAIN).forEach(reveal);
      }, HOLD + ICON_MS + GAP * 2);

      setTimeout(function () {
        window.dispatchEvent(new Event("cms-preloader-hidden"));
      }, HOLD + ICON_MS + GAP * 2 + CHROME_MS);
    }

    function init() {
      window.cmsPreloader = {
        show: function () {
          qsa(SEL_HEADER).forEach(conceal);
          qsa(SEL_FOOTER).forEach(conceal);
          qsa(SEL_MAIN).forEach(conceal);
          setIconVisible(true);
        },
        hide: function () {
          showChromeImmediate();
        },
        toggle: function () {
          var nodes = qsa(SEL_MAIN);
          var hidden = nodes.length > 0 && nodes[0].classList.contains("opacity-0");
          if (hidden) {
            window.cmsPreloader.hide();
          } else {
            window.cmsPreloader.show();
          }
        },
      };

      if (
        typeof window.matchMedia === "function" &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        showChromeImmediate();
        return;
      }

      runSequence();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
