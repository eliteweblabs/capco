---
import Button from "../common/Button.astro";
import SimpleIcon from "../common/SimpleIcon.astro";

const { globalIconButtonClasses } = await Astro.props;
---

<Button
  type="button"
  id="theme-toggle"
  variant="anchor"
  iconOnly
  title="Toggle dark mode"
  ariaLabel="Toggle light / dark mode"
  class={globalIconButtonClasses}
>
  <SimpleIcon name="moon" size="md" id="theme-toggle-dark-icon" class="hidden" />
  <SimpleIcon name="sun" size="md" id="theme-toggle-light-icon" class="hidden" />
  <span class="sr-only">Toggle light / dark mode</span>
</Button>
{
  /* Theme toggle: inline script in App.astro ensures it works when app-globals chunk fails (SSR production). app-globals.ts also binds; data-theme-toggle-inited prevents double-init. */
}
