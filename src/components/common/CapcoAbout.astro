---
/**
 * CapcoAbout — "About CAP Design Group" section.
 * Eyebrow label + serif heading with orange accent + body copy.
 * Theme-aware (white in light mode, dark in dark mode). Matches the About screenshot.
 */
import { globalClasses } from "../../pages/api/global/global-classes";

const { globalContainer } = globalClasses();

interface Props {
  /** Heading level for the main title (h1 on a dedicated /about page, h2 inside a longer page). */
  as?: "h1" | "h2";
}

const { as = "h1" } = Astro.props;
const Heading = as;
---

<section class="w-full py-16 md:py-24">
  <div class={globalContainer}>
    <div class="max-w-3xl">
      <p
        class="mb-6 flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-primary-600 dark:text-primary-500"
      >
        <span class="inline-block h-px w-10 bg-primary-600 dark:bg-primary-500"></span>
        About CAP Design Group
      </p>

      <Heading
        class="mb-8 text-4xl font-bold leading-[1.1] text-gray-900 dark:text-white md:text-5xl"
      >
        A boutique firm with a{" "}
        <em class="not-italic text-primary-600 dark:text-primary-500">life safety</em> heart.
      </Heading>

      <div class="space-y-6 text-lg leading-relaxed text-gray-600 dark:text-gray-300">
        <p>
          CAP Design Group is a specialized engineering design firm serving clients across
          Massachusetts and the greater New England region. We combine deep technical expertise with
          a collaborative, client-first approach that delivers compliant, constructible designs — on
          time and on budget.
        </p>
        <p>
          Our principal-led team brings direct accountability to every project — from initial
          permit-set drawings through construction administration. Whether you're developing a
          mid-rise residential building, a historic renovation, or a complex commercial facility,
          our engineers have the experience to navigate code challenges and AHJ requirements at
          every stage.
        </p>
      </div>
    </div>
  </div>
</section>
