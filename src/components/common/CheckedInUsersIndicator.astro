---
/**
 * Checked-In Users Indicator (Admin only)
 * Shows a navbar trigger that opens a dropdown listing checked-in users.
 */
import { isAdminOrSuperAdmin } from "../../lib/user-utils";
import Dropdown from "../ui/Dropdown.astro";
import SimpleIcon from "./SimpleIcon.astro";
import { globalClasses } from "../../pages/api/global/global-classes";
interface Props {
  currentUser?: any;
  globalIconButtonClasses?: string;
}

const { globalDropdownClose } = globalClasses();
const { currentUser, globalIconButtonClasses = "w-10 h-10 inline-flex items-center rounded-full justify-center p-2 text-black dark:text-white md:hover:bg-gray-100 dark:hover:bg-gray-700 dark:focus:ring-gray-700 focus:outline-none" } = Astro.props;

const currentRole = currentUser?.profile?.role;
const showCheckedIn = isAdminOrSuperAdmin(currentRole);
---

{showCheckedIn && (
<>
<div
  id="checked-in-users-indicator"
  class="hidden"
  aria-label="Team members currently checked in"
>
  <button
    type="button"
    class={`relative ${globalIconButtonClasses}`}
    data-popover-trigger="click"
    data-popover-target="checked-in-users-dropdown"
    data-popover-placement="bottom"
    aria-label="Open checked-in users"
  >
    <span class="sr-only">Open checked-in users</span>
    <span class="auth-icon-default" aria-hidden="true">
      <SimpleIcon name="users" size="md" />
    </span>
    <span class={globalDropdownClose} aria-hidden="true" style="opacity: 0; pointer-events: none;">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </span>
    <span
      id="checked-in-users-count"
      class="absolute -right-1 -top-1 hidden min-w-[1.1rem] rounded-full bg-emerald-500 px-1 text-center text-[10px] font-bold leading-4 text-white"
    ></span>
  </button>
</div>

<Dropdown id="checked-in-users" title="Checked-In Team">
  <div id="checked-in-users-list" class="max-h-72 space-y-2 overflow-y-auto p-3">
    <p class="text-sm text-gray-500 dark:text-gray-400">No one is currently checked in.</p>
  </div>
</Dropdown>

<script>
  (function () {
    const POLL_MS = 30000;
    const IDLE_MS = 3 * 60 * 1000;

    function init() {
      const indicator = document.getElementById("checked-in-users-indicator");
      const container = document.getElementById("checked-in-users-list");
      const countBubble = document.getElementById("checked-in-users-count");
      if (!container) return;
      let pollInterval = null;
      let idleTimer = null;
      let isIdle = false;

      const canPoll = () => !document.hidden && !isIdle;

      const resetIdleTimer = () => {
        isIdle = false;
        if (idleTimer) clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          isIdle = true;
          stopPolling();
        }, IDLE_MS);
      };

      async function fetchCheckedIn() {
        try {
          const res = await fetch("/api/time-entries/checked-in", { credentials: "include" });
          const data = await res.json();
          return data.users || [];
        } catch {
          return [];
        }
      }

      function render(users) {
        if (!indicator) return;
        container.innerHTML = "";
        if (!Array.isArray(users) || users.length === 0) {
          indicator.classList.add("hidden");
          if (countBubble) {
            countBubble.classList.add("hidden");
            countBubble.textContent = "";
          }
          container.innerHTML =
            '<p class="text-sm text-gray-500 dark:text-gray-400">No one is currently checked in.</p>';
          return;
        }

        indicator.classList.remove("hidden");
        if (countBubble) {
          countBubble.classList.remove("hidden");
          countBubble.textContent = String(users.length);
        }

        users.forEach((u) => {
          const row = document.createElement("div");
          row.className =
            "rounded-md border border-gray-200 bg-gray-50 p-2 text-sm dark:border-gray-700 dark:bg-gray-800";

          const where = u.address || u.location || "Location unavailable";
          row.innerHTML = `
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <div class="truncate font-medium text-gray-900 dark:text-white">${u.name || "Unknown user"}</div>
                <div class="text-xs text-gray-600 dark:text-gray-300">${u.durationFormatted || ""}</div>
                <div class="mt-1 break-words text-xs text-gray-500 dark:text-gray-400">${where}</div>
              </div>
              ${
                u.timeEntryId
                  ? `<button
                type="button"
                class="inline-flex items-center rounded-md bg-red-600 px-2 py-1 text-xs font-medium text-white hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-60 dark:bg-red-700 dark:hover:bg-red-800"
                data-stop-time-entry-id="${u.timeEntryId}"
                title="Stop timer for ${u.name || "this user"}"
              >
                Stop
              </button>`
                  : ""
              }
            </div>
          `;
          container.appendChild(row);
        });
      }

      async function stopTimerForEntry(entryId, triggerEl) {
        if (!entryId) return;
        const shouldStop = window.confirm("Stop this active timer?");
        if (!shouldStop) return;
        const button = triggerEl instanceof HTMLButtonElement ? triggerEl : null;
        if (button) button.disabled = true;
        try {
          const res = await fetch(`/api/time-entries/${entryId}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ endedAt: new Date().toISOString() }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data?.error || "Failed to stop timer");
          await load();
          if (typeof window.showNotice === "function") {
            window.showNotice("success", "Timer stopped", "The timer was stopped successfully.", 2500);
          }
        } catch (error) {
          if (typeof window.showNotice === "function") {
            window.showNotice(
              "error",
              "Unable to stop timer",
              error instanceof Error ? error.message : "Please try again.",
              4000
            );
          }
        } finally {
          if (button) button.disabled = false;
        }
      }

      async function load() {
        if (!canPoll()) return;
        const users = await fetchCheckedIn();
        render(users);
      }

      function startPolling() {
        if (pollInterval) return;
        pollInterval = setInterval(load, POLL_MS);
      }

      function stopPolling() {
        if (!pollInterval) return;
        clearInterval(pollInterval);
        pollInterval = null;
      }

      container.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const stopBtn = target.closest("[data-stop-time-entry-id]");
        if (!(stopBtn instanceof HTMLButtonElement)) return;
        const timeEntryIdRaw = stopBtn.getAttribute("data-stop-time-entry-id");
        const timeEntryId = Number.parseInt(timeEntryIdRaw || "", 10);
        if (!Number.isFinite(timeEntryId)) return;
        stopTimerForEntry(timeEntryId, stopBtn);
      });

      load();
      startPolling();

      const markActive = () => {
        resetIdleTimer();
        startPolling();
      };

      ["pointerdown", "keydown", "scroll", "touchstart"].forEach((evt) => {
        document.addEventListener(evt, markActive, { passive: true });
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stopPolling();
          return;
        }
        markActive();
        load();
      });

      resetIdleTimer();
      window.addEventListener("beforeunload", () => {
        stopPolling();
        if (idleTimer) clearTimeout(idleTimer);
      });
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
</>
)}
