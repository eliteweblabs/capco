---
interface Props {
  role?: string;
  projectLength: number;
}

import Breadcrumb from "./Breadcrumb.astro";

const { role, projectLength } = Astro.props;

const isStaff = role === "Staff";
const isAdminView = role === "Admin" || role === "superAdmin";
const isClientView = role === "Client";

const title = isStaff
  ? "Team dashboard"
  : isAdminView
    ? "Operations dashboard"
    : "Your dashboard";

const description = isStaff
  ? "Staff tools are expanding soon. You can still review and work on assigned projects below."
  : isAdminView
    ? "Organization overview: clients, projects, and receivables. Open a project or start a new one from the menu."
    : isClientView
      ? "Your projects, invoices, and payments in one place. Start a new submission any time."
      : "Your workspace for projects and account activity.";

---

<Breadcrumb
  items={[
    {
      label: "Dashboard",
      href: "/dashboard",
      icon: "home",
    },
    {
      label:
        projectLength === 0
          ? "0 <span class='hidden sm:inline'>Projects</span>"
          : projectLength === 1
            ? "1 <span class='hidden sm:inline'>Project</span>"
            : `${projectLength} <span class='hidden sm:inline'>Projects</span>`,
      current: true,
      refreshField: "projectCount",
      metaValue: projectLength,
    },
    {
      label:
        "<span class='text-black dark:text-white'>New<span class='hidden sm:inline'> Project</span></span> +",
      href: "/project/new",
    },
  ]}
  class="mb-8"
/>

<div class="mb-8 px-1">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{title}</h1>
  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{description}</p>
</div>
