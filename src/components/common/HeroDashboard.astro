---
interface Props {
  role?: string;
  projectLength: number;
}

import Breadcrumb from "./Breadcrumb.astro";

const { role, projectLength } = Astro.props;
const isClient = role === "Client";

const title = projectLength === 0 ? "Project Dashboard" : "Start A New Project";
const description = isClient
  ? projectLength === 0
    ? "Manage and track your fire protection projects"
    : "Welcome to the Project Management System. All aspects of your project can be managed here."
  : projectLength === 0
    ? "Manage and track all fire protection projects"
    : "Welcome to the Project Management System. All aspects of your project can be managed here.";
---

<Breadcrumb
  items={[
    {
      label: "Dashboard",
      href: "#",
      icon: "home",
    },
    {
      label:
        projectLength === 0
          ? "New<span class='hidden sm:inline'> Project</span>"
          : projectLength === 1
            ? "1 <span class='hidden sm:inline'>Active </span>Project"
            : `${projectLength} <span class='hidden sm:inline'>Active </span>Projects`,
      current: true,
      refreshField: "projectCount",
      metaValue: projectLength,
    },
    {
      label:
        "<span class='text-black dark:text-white'>New<span class='hidden sm:inline'> Project</span></span> +",
      href: "/project/new",
    },
  ]}
  class="mb-8"
/>

<div class="mb-8 px-1">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{title}</h1>
  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{description}</p>
</div>
