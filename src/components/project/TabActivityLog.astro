---
import SimpleProjectLog from "./SimpleProjectLog.astro";
import { projectTabPanelClass } from "../../lib/project-tab-panel";

interface Props {
  project?: any;
  currentUser?: any;
  projectStatus?: number;
  secondaryTextClasses?: string;
  primaryTextClasses?: string;
  globalInputClasses?: string;
  statusData?: any;
  isActiveTab?: boolean;
}

const {
  project,
  currentUser,
  secondaryTextClasses,
  primaryTextClasses,
  globalInputClasses,
  statusData,
  isActiveTab = false,
} = Astro.props;

const currentRole = currentUser?.profile?.role;
const projectId = project?.id;
const panelClass = projectTabPanelClass(
  isActiveTab,
  "tab-content color-background relative min-h-[calc(100dvh-24rem)] p-4 shadow-lg"
);
if (currentRole === "Client") {
  return;
}
---

{
  (currentRole === "Admin" || currentRole === "Staff" || currentRole === "superAdmin") && (
    <div id="content-activity-log" class={panelClass}>
      <SimpleProjectLog
        projectId={projectId}
        globalInputClasses={globalInputClasses}
        secondaryTextClasses={secondaryTextClasses}
        primaryTextClasses={primaryTextClasses}
      />
    </div>
  )
}
