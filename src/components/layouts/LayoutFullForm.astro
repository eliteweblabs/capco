---
/**
 * Layout: Full Form
 * Full viewport height and width for forms (e.g. MultiStepForm).
 * Uses data-dynamic-height="height" for calc(100dvh - navbar).
 * No reveal-text or typewriter effect on this template (data-template="fullform" skips them).
 */
interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description = "" } = Astro.props;

import App from "../ui/App.astro";
import PixelGrid from "../ui/PixelGrid.astro";
---

<App {title} {description} layout="fullform">
  <PixelGrid
    id="pixelGrid"
    class="touch-manipulation-none fixed inset-0 -z-[1000]"
    cellSize="0.5rem"
    baseColor="primary-500"
    initialAnimation="plasma"
    circularMask={true}
  />
  <div
    class="mx-auto flex w-full max-w-4xl flex-col items-center justify-center p-4 md:p-8"
    role="main"
    data-dynamic-height="height"
    data-ios-focus-root
  >
    <slot />
  </div>
</App>

<script is:inline>
  (function () {
    var isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    if (!isTouch) return;

    var root = document.querySelector("[data-ios-focus-root]");
    if (!root) return;

    // iOS only opens the keyboard from a <button> click handler — not from
    // taps on divs or non-interactive elements.
    // Strategy: overlay an invisible <button> on the first visible input.
    // When the user taps what looks like the input, they hit the button,
    // which calls .focus() → iOS opens the keyboard. Button removes itself.
    // Ref: https://gist.github.com/cathyxz/73739c1bdea7d7011abb236541dc9aaa

    var overlayBtn = null;

    function getVisibleInput() {
      var candidates = root.querySelectorAll(
        "input[autofocus], input:not([type=hidden]):not([readonly]):not([disabled]), textarea, select"
      );
      for (var i = 0; i < candidates.length; i++) {
        var el = candidates[i];
        if (el.offsetParent !== null && el.offsetHeight > 0) return el;
      }
      return null;
    }

    function removeOverlay() {
      if (overlayBtn && overlayBtn.parentNode) {
        overlayBtn.parentNode.removeChild(overlayBtn);
        overlayBtn = null;
      }
    }

    function placeOverlay(input) {
      if (overlayBtn) return; // already placed
      var wrapper = input.closest(".input-wrapper") || input.parentElement;
      if (!wrapper) return;
      wrapper.style.position = wrapper.style.position || "relative";
      var btn = document.createElement("button");
      btn.type = "button";
      btn.setAttribute("aria-label", "Tap to start typing");
      btn.style.cssText =
        "position:absolute;inset:0;width:100%;height:100%;opacity:0;" +
        "z-index:10;cursor:text;-webkit-tap-highlight-color:transparent;";
      btn.addEventListener("click", function () {
        removeOverlay();
        if (document.activeElement === input) input.blur();
        input.focus();
      });
      wrapper.appendChild(btn);
      overlayBtn = btn;
    }

    // Place overlay as soon as a visible input appears.
    // For /login: input is visible immediately.
    // For /register: input appears after typewriter cascade (~2-3s).
    function tryPlace() {
      if (overlayBtn) return true;
      var input = getVisibleInput();
      if (!input) return false;
      placeOverlay(input);
      return true;
    }

    // Try immediately (covers /login)
    if (!tryPlace()) {
      // Poll for visibility (covers /register cascade)
      var attempts = 0;
      var poll = setInterval(function () {
        if (tryPlace() || ++attempts > 40) clearInterval(poll);
      }, 150);
    }

    // Also listen for typewriter-complete to re-check (register page)
    document.addEventListener("typewriter-complete", function () {
      setTimeout(tryPlace, 300);
    });
  })();
</script>
