---
/**
 * Layout: Full Form
 * Full viewport height and width for forms (e.g. MultiStepForm).
 * Uses data-dynamic-height="height" for calc(100dvh - navbar).
 * No reveal-text or typewriter effect on this template (data-template="fullform" skips them).
 */
interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description = "" } = Astro.props;

import App from "../ui/App.astro";
import PixelGrid from "../ui/PixelGrid.astro";
---

<App {title} {description} layout="fullform">
  <PixelGrid
    id="pixelGrid"
    class="touch-manipulation-none fixed inset-0 -z-[1000]"
    cellSize="0.5rem"
    baseColor="primary-500"
    initialAnimation="plasma"
    circularMask={true}
  />
  <div
    class="mx-auto flex w-full max-w-4xl flex-col items-center justify-center p-4 md:p-8"
    role="main"
    data-dynamic-height="height"
    data-ios-focus-root
  >
    <slot />
  </div>
</App>

<script is:inline>
  (function () {
    var isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    if (!isTouch) return;

    var root = document.querySelector("[data-ios-focus-root]");
    if (!root) return;

    function getFirstInput() {
      return root.querySelector(
        "input[autofocus], input:not([type=hidden]):not([readonly]):not([disabled]), textarea, select"
      );
    }

    // --- Attempt 1: synthetic click on page load (works on iOS 18+ PWA / some Safari) ---
    var input = getFirstInput();
    if (input) {
      try {
        var ev = new MouseEvent("click", { bubbles: true, cancelable: true, view: window });
        input.dispatchEvent(ev);
        input.focus();
      } catch (e) { /* silent */ }
    }

    // --- Attempt 2: first real tap anywhere on the form focuses first input ---
    // iOS only opens the keyboard when .focus() runs synchronously inside a
    // user-gesture handler (click/touchend). No setTimeout, rAF, or Promise.
    // Ref: https://gist.github.com/cathyxz/73739c1bdea7d7011abb236541dc9aaa
    var done = false;
    function focusFirst(e) {
      if (done) return;
      var tgt = e.target;
      if (tgt.closest && tgt.closest("a, button, [data-share-trigger]")) return;
      // If they tapped an input directly, let it handle its own focus
      if (tgt.tagName === "INPUT" || tgt.tagName === "TEXTAREA" || tgt.tagName === "SELECT") {
        done = true;
        return;
      }
      var el = getFirstInput();
      if (!el) return;
      done = true;
      root.removeEventListener("touchend", focusFirst, true);
      root.removeEventListener("click", focusFirst, true);
      el.focus();
    }

    root.addEventListener("touchend", focusFirst, true);
    root.addEventListener("click", focusFirst, true);
    root.setAttribute("data-ios-tap-hint", "");
  })();
</script>
