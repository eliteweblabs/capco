---
/**
 * PaymentFormSquare - Square Web Payments SDK integration
 * Same structure as PaymentForm.astro but uses Square instead of Stripe.
 * Used for e-commerce checkout (luxemeds, etc.)
 */
import FormActionButton from "../form/FormActionButton.astro";
import { globalClasses } from "../../pages/api/global/global-classes";

const { globalFormLabel, globalInputClasses } = globalClasses();

interface Props {
  amount: number; // in cents
  orderId: string;
  orderNumber: string;
  email?: string;
  onSuccess?: () => void;
}

const { amount, orderId, orderNumber, email = "", onSuccess } = Astro.props;
---

<div class="payment-form-square">
  <div class="billing-info mb-6">
    <h4 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">Billing Information</h4>
    <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label for="firstName" class={globalFormLabel}>First Name *</label>
        <input
          type="text"
          id="firstName"
          name="firstName"
          required
          class={globalInputClasses}
          placeholder="John"
        />
      </div>
      <div>
        <label for="lastName" class={globalFormLabel}>Last Name *</label>
        <input
          type="text"
          id="lastName"
          name="lastName"
          required
          class={globalInputClasses}
          placeholder="Smith"
        />
      </div>
    </div>
    <div class="mb-4">
      <label for="email" class={globalFormLabel}>Email *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        value={email}
        class={globalInputClasses}
        placeholder="you@example.com"
      />
    </div>
  </div>

  <div class="billing-address mb-6">
    <h4 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">Billing Address</h4>
    <div class="mb-4">
      <label for="address" class={globalFormLabel}>Street Address *</label>
      <input
        type="text"
        id="address"
        name="address"
        required
        class={globalInputClasses}
        placeholder="123 Main St"
      />
    </div>
    <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div>
        <label for="city" class={globalFormLabel}>City *</label>
        <input
          type="text"
          id="city"
          name="city"
          required
          class={globalInputClasses}
          placeholder="Boston"
        />
      </div>
      <div>
        <label for="state" class={globalFormLabel}>State *</label>
        <select id="state" name="state" required class={globalInputClasses}>
          <option value="">Select</option>
          <option value="AL">AL</option>
          <option value="CA">CA</option>
          <option value="FL">FL</option>
          <option value="MA">MA</option>
          <option value="NY">NY</option>
          <option value="TX">TX</option>
        </select>
      </div>
      <div>
        <label for="zip" class={globalFormLabel}>ZIP *</label>
        <input
          type="text"
          id="zip"
          name="zip"
          required
          pattern="[0-9]{5}(-[0-9]{4})?"
          class={globalInputClasses}
          placeholder="02101"
        />
      </div>
    </div>
  </div>

  <div class="card-info mb-6">
    <h4 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">Payment</h4>
    <div id="card-container" class="min-h-[200px]"></div>
    <div id="card-errors" class="mt-2 text-sm text-red-600" role="alert"></div>
  </div>

  <div class="mb-4 flex items-start gap-3">
    <input
      type="checkbox"
      id="terms-agreement"
      name="termsAgreement"
      required
      class="mt-1 h-4 w-4 rounded border-gray-300"
    />
    <label for="terms-agreement" class="text-sm text-gray-700 dark:text-gray-300">
      I agree to the <a href="/terms" class="text-primary-600 hover:underline" target="_blank"
        >Terms</a
      > and <a href="/privacy" class="text-primary-600 hover:underline" target="_blank"
        >Privacy Policy</a
      > *
    </label>
  </div>

  <FormActionButton
    action="submit"
    id="submit-payment"
    variant="primary"
    size="lg"
    fullWidth
    disabled
    class="font-bold"
    type="button"
  >
    <span id="button-text">Pay ${(amount / 100).toFixed(2)}</span>
    <div id="spinner" class="hidden">
      <div class="mx-auto h-4 w-4 animate-spin rounded-lg border-b-2 border-white"></div>
    </div>
  </FormActionButton>
</div>

<script define:vars={{ amount, orderId, orderNumber }} is:inline>
  (async () => {
    const appId = (window as any).SQUARE_APPLICATION_ID;
    const locationId = (window as any).SQUARE_LOCATION_ID;
    const isSandbox = (window as any).SQUARE_ENVIRONMENT === "sandbox";

    if (!appId || !locationId) {
      console.error("[PaymentFormSquare] Square not configured");
      document.getElementById("card-errors")!.textContent = "Payment system not configured.";
      return;
    }

    const script = document.createElement("script");
    script.src = isSandbox
      ? "https://sandbox.web.squarecdn.com/v1/square.js"
      : "https://web.squarecdn.com/v1/square.js";
    script.async = true;
    document.head.appendChild(script);
    await new Promise((resolve, reject) => {
      script.onload = resolve;
      script.onerror = () => reject(new Error("Failed to load Square SDK"));
    });

    const Square = (window as any).Square;
    if (!Square) {
      document.getElementById("card-errors")!.textContent = "Failed to load payment form.";
      return;
    }

    const payments = Square.payments(appId, locationId);
    const card = await payments.card();
    await card.attach("#card-container");

    const cardErrors = document.getElementById("card-errors")!;
    const submitBtn = document.getElementById("submit-payment")!;
    const buttonText = document.getElementById("button-text")!;
    const spinner = document.getElementById("spinner")!;

    function validateForm() {
      const required = ["firstName", "lastName", "email", "address", "city", "state", "zip"];
      const terms = document.getElementById("terms-agreement") as HTMLInputElement;
      const ok =
        required.every((id) => (document.getElementById(id) as HTMLInputElement)?.value?.trim()) &&
        terms?.checked;
      submitBtn.toggleAttribute("disabled", !ok);
    }

    card.addEventListener("focus", () => {
      cardErrors.textContent = "";
    });
    card.addEventListener("blur", () => validateForm());
    document.querySelectorAll("input, select").forEach((el) => {
      el.addEventListener("input", validateForm);
      el.addEventListener("change", validateForm);
    });
    validateForm();

    submitBtn.addEventListener("click", async () => {
      submitBtn.setAttribute("disabled", "true");
      buttonText.classList.add("hidden");
      spinner.classList.remove("hidden");

      try {
        const tokenResult = await card.tokenize();
        if (tokenResult.status !== "OK") {
          cardErrors.textContent = tokenResult.errors?.[0]?.message || "Card tokenization failed";
          return;
        }
        const sourceId = tokenResult.token;

        const billingAddress = {
          addressLine1: (document.getElementById("address") as HTMLInputElement).value,
          locality: (document.getElementById("city") as HTMLInputElement).value,
          administrativeDistrictLevel1: (document.getElementById("state") as HTMLSelectElement)
            .value,
          postalCode: (document.getElementById("zip") as HTMLInputElement).value,
          country: "US",
        };

        const res = await fetch("/api/square/create-payment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            sourceId,
            amount,
            orderId,
            orderNumber,
            buyerEmail: (document.getElementById("email") as HTMLInputElement).value,
            billingAddress,
          }),
        });

        const data = await res.json();
        if (data.success) {
          if (typeof (window as any).showNotice === "function") {
            (window as any).showNotice(
              "success",
              "Payment Successful",
              "Thank you for your order!"
            );
          }
          if (typeof (window as any).onPaymentSuccess === "function") {
            (window as any).onPaymentSuccess(data);
          }
          window.location.href = `/shop/confirmation?order=${data.orderId}`;
        } else {
          cardErrors.textContent = data.error || "Payment failed";
        }
      } catch (err) {
        cardErrors.textContent = err instanceof Error ? err.message : "Payment failed";
      } finally {
        submitBtn.removeAttribute("disabled");
        buttonText.classList.remove("hidden");
        spinner.classList.add("hidden");
      }
    });
  })();
</script>
