---
/**
 * RothcoTitleText
 *
 * Simple two-line title block for CMS shortcodes:
 * <RothcoTitleText line1="Capability Snapshot" line2="Delivered with accountability." />
 */
import {
  getContainerWrapperClasses,
  paddingClasses,
  type MaxWidthOption,
  type PaddingOption,
} from "../../lib/container-width";

interface Props {
  line1?: string;
  line2?: string;
  id?: string;
  className?: string;
  maxWidth?: MaxWidthOption;
  padding?: PaddingOption;
}

const {
  line1 = "",
  line2 = "",
  id,
  className = "",
  maxWidth = "full",
  padding = "none",
} = Astro.props;

const containerClasses = getContainerWrapperClasses(maxWidth);
---

<section {id} class:list={["rothco-title-text-block", paddingClasses[padding], className]}>
  <div class:list={containerClasses}>
    <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
      {
        line1 && (
          <span
            class="relative bottom-[-29px] z-0 block font-tertiary text-5xl text-secondary-500 md:text-7xl"
            set:html={line1}
          />
        )
      }
      {line2 && <span class="block text-xl uppercase md:text-2xl" set:html={line2} />}
    </h2>
  </div>
</section>
