---
/**
 * TabberBlock - Sliding pill nav tabs with content panels
 *
 * CMS-ready tabber using SlidingTabs for the nav. Content can be HTML from rich text.
 *
 * @example Direct usage:
 * <TabberBlock tabs={[
 *   { label: "Overview", content: "<p>Overview content...</p>" },
 *   { label: "Details", content: "<p>Details content...</p>" }
 * ]} />
 *
 * @example CMS shortcode:
 * <TabberBlock
 *   tab1Label="Overview"
 *   tab1Content="<p>Overview content...</p>"
 *   tab2Label="Details"
 *   tab2Content="<p>Details content...</p>"
 * />
 */
import SlidingTabs from "../common/SlidingTabs.astro";
import { parseJsonProp, buildArrayFromFlatProps } from "./BlockRegistry";

interface TabItem {
  label: string;
  content?: string;
  icon?: string;
}

interface Props {
  tabs?: string | TabItem[];

  // Flat props for CMS (tab1Label, tab1Content, tab2Label, tab2Content, ...)
  tab1Label?: string;
  tab1Content?: string;
  tab1Icon?: string;
  tab2Label?: string;
  tab2Content?: string;
  tab2Icon?: string;
  tab3Label?: string;
  tab3Content?: string;
  tab3Icon?: string;
  tab4Label?: string;
  tab4Content?: string;
  tab4Icon?: string;
  tab5Label?: string;
  tab5Content?: string;
  tab5Icon?: string;
  tab6Label?: string;
  tab6Content?: string;
  tab6Icon?: string;

  className?: string;
  id?: string;
  /** Unique nav ID for SlidingTabs; defaults to generated */
  navId?: string;
  /** Compact nav (smaller padding) */
  compact?: boolean | string;
  /** Zero-based index of the initially active tab (default 0) */
  activeItem?: number;
}

const props = Astro.props;
const { className = "", id, navId: propsNavId, compact = false, activeItem = 0 } = props;
const isCompact = compact === true || compact === "true";

// Build tabs from JSON or flat props
let tabs: TabItem[] = [];
if (props.tabs) {
  tabs = parseJsonProp<TabItem[]>(props.tabs, []);
} else {
  tabs = buildArrayFromFlatProps<TabItem>(props, "tab", ["label", "content", "icon"], 6);
}

tabs = tabs.filter((t) => t.label);

// Unique ID for this tabber instance
const blockId = id || `tabber-${Math.random().toString(36).slice(2, 9)}`;
const navId = propsNavId || `${blockId}-nav`;

// SlidingTabs expects NavItem shape
const navItems = tabs.map((t) => ({
  label: t.label,
  icon: t.icon,
  id: undefined,
  variant: "tab" as const,
}));
---

<section
  id={blockId}
  class={`tabber-block ${className}`}
  data-tabber
  style="
position: relative;
top: -38px;
"
>
  <SlidingTabs
    items={navItems}
    navId={navId}
    activeItem={activeItem}
    compact={isCompact}
    urlParam=""
  />
  <div class="tabber-panels mt-6 px-4">
    {
      /* activeItem panel visible on server, rest hidden – see .cursor/rules/tabber-sliding-tabs-ssr.mdc */
    }
    {
      tabs.map((tab, index) => (
        <div
          data-tab-index={index}
          data-tabber-panel
          class:list={[
            "tabber-panel prose max-w-none dark:prose-invert",
            index === activeItem ? "" : "hidden",
          ]}
          set:html={tab.content || ""}
        />
      ))
    }
  </div>
</section>

<script>
  const tabberMobileQuery = "(max-width: 767px)";
  const tabberScrollCooldownMs = 360;
  const tabberWheelTriggerThreshold = 120;
  const tabberTouchThresholdPx = 26;

  function tabberDebug(fnName, args = [], result = undefined) {
    const debug = (window as any).Debug;
    if (debug && typeof debug.log === "function") {
      debug.log("tabber", fnName, args, result);
    }
  }

  function isMobileTabberMode() {
    return window.matchMedia(tabberMobileQuery).matches;
  }

  function getNavbarBottomOffset() {
    const navbar = document.getElementById("main-navbar");
    if (!navbar) return 0;
    return navbar.getBoundingClientRect().bottom;
  }

  function getTabberTriggerLineY() {
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
    return getNavbarBottomOffset() + viewportHeight * 0.25;
  }

  function isTabberAtTriggerLine(block) {
    const rect = block.getBoundingClientRect();
    const triggerLineY = getTabberTriggerLineY();
    return rect.top <= triggerLineY && rect.bottom >= triggerLineY;
  }

  function isTabberOutOfViewport(block) {
    const rect = block.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
    return rect.bottom < 0 || rect.top > viewportHeight;
  }

  function getTabButtons(nav) {
    return Array.from(nav.querySelectorAll("button[data-index]"));
  }

  function getActiveTabIndex(buttons) {
    const activeButton = buttons.find((btn) => btn.getAttribute("data-active") === "true");
    const indexSource = activeButton || buttons[0];
    if (!indexSource) return -1;
    return parseInt(indexSource.getAttribute("data-index") || "0", 10);
  }

  function setActiveTabIndex(buttons, index) {
    const target = buttons.find((btn) => parseInt(btn.getAttribute("data-index") || "-1", 10) === index);
    if (!target || target.getAttribute("data-active") === "true") return false;
    target.click();
    return true;
  }

  function initTabberScrollProgression(block) {
    if (block.getAttribute("data-tabber-scroll-progression-init") === "true") return;
    block.setAttribute("data-tabber-scroll-progression-init", "true");

    let lastStepTimestamp = 0;
    let touchStartY = null;
    let wheelDeltaBuffer = 0;
    let lockedDirection = 0;
    let lastReleasedDirection = 0;

    const isLocked = () => lockedDirection !== 0;
    const unlock = () => {
      if (lockedDirection !== 0) {
        lastReleasedDirection = lockedDirection;
      }
      lockedDirection = 0;
      wheelDeltaBuffer = 0;
      tabberDebug("unlock", [block.id || "tabber", lastReleasedDirection]);
    };

    const maybeResetPassState = () => {
      if (isTabberOutOfViewport(block)) {
        lastReleasedDirection = 0;
        if (isLocked()) unlock();
      }
    };

    const tryStepTabByDirection = (direction) => {
      if (!isMobileTabberMode()) return { consumed: false, released: false };
      if (!isTabberAtTriggerLine(block)) return { consumed: false, released: false };
      const nav = block.querySelector("nav");
      if (!nav) return { consumed: false, released: false };

      const buttons = getTabButtons(nav);
      if (buttons.length < 2) return { consumed: false, released: false };

      if (!isLocked()) {
        if (lastReleasedDirection !== 0 && direction === lastReleasedDirection) {
          return { consumed: false, released: false };
        }
        lockedDirection = direction;
        lastReleasedDirection = 0;
        tabberDebug("lock", [block.id || "tabber", lockedDirection]);
      }

      const activeIndex = getActiveTabIndex(buttons);
      if (activeIndex < 0) return { consumed: false, released: false };

      const lastIndex = buttons.length - 1;
      const atLockBoundary =
        (lockedDirection > 0 && activeIndex === lastIndex) ||
        (lockedDirection < 0 && activeIndex === 0);
      if (atLockBoundary) {
        unlock();
        return { consumed: false, released: true };
      }

      const now = Date.now();
      if (now - lastStepTimestamp < tabberScrollCooldownMs) return { consumed: true, released: false };

      const nextIndex = direction > 0 ? activeIndex + 1 : activeIndex - 1;
      if (nextIndex < 0 || nextIndex >= buttons.length) {
        const reachedLockBoundary =
          (lockedDirection > 0 && activeIndex === lastIndex && direction > 0) ||
          (lockedDirection < 0 && activeIndex === 0 && direction < 0);
        if (reachedLockBoundary) {
          unlock();
          return { consumed: false, released: true };
        }
        return { consumed: true, released: false };
      }

      const changed = setActiveTabIndex(buttons, nextIndex);
      if (changed) {
        lastStepTimestamp = now;
        tabberDebug("step", [block.id || "tabber", activeIndex, nextIndex, lockedDirection]);
        const reachedBoundaryAfterStep =
          (lockedDirection > 0 && nextIndex === lastIndex) || (lockedDirection < 0 && nextIndex === 0);
        if (reachedBoundaryAfterStep) {
          unlock();
        }
      }
      return { consumed: true, released: false };
    };

    document.addEventListener(
      "wheel",
      (event) => {
        maybeResetPassState();
        const shouldHandleThisScroll = isLocked() || isTabberAtTriggerLine(block);
        if (!shouldHandleThisScroll) return;

        const dominantDelta =
          Math.abs(event.deltaY) >= Math.abs(event.deltaX) ? event.deltaY : event.deltaX;
        if (!dominantDelta) return;

        const direction = dominantDelta > 0 ? 1 : -1;
        wheelDeltaBuffer += dominantDelta;
        if (Math.abs(wheelDeltaBuffer) < tabberWheelTriggerThreshold) {
          if (isLocked()) {
            event.preventDefault();
            event.stopPropagation();
          }
          return;
        }
        const { consumed } = tryStepTabByDirection(direction);
        wheelDeltaBuffer = 0;
        if (consumed || isLocked()) {
          event.preventDefault();
          event.stopPropagation();
        }
      },
      { passive: false }
    );

    document.addEventListener(
      "touchstart",
      (event) => {
        touchStartY = event.touches?.[0]?.clientY ?? null;
      },
      { passive: true }
    );

    document.addEventListener(
      "touchmove",
      (event) => {
        maybeResetPassState();
        const shouldHandleThisScroll = isLocked() || isTabberAtTriggerLine(block);
        if (!shouldHandleThisScroll) return;

        if (touchStartY === null) return;
        const currentY = event.touches?.[0]?.clientY;
        if (typeof currentY !== "number") return;
        const deltaY = touchStartY - currentY;
        if (Math.abs(deltaY) < tabberTouchThresholdPx) {
          if (isLocked()) {
            event.preventDefault();
            event.stopPropagation();
          }
          return;
        }

        const { consumed } = tryStepTabByDirection(deltaY > 0 ? 1 : -1);
        if (consumed || isLocked()) {
          event.preventDefault();
          event.stopPropagation();
          touchStartY = currentY;
        }
      },
      { passive: false }
    );

    document.addEventListener(
      "touchend",
      () => {
        touchStartY = null;
      },
      { passive: true }
    );
    document.addEventListener(
      "touchcancel",
      () => {
        touchStartY = null;
      },
      { passive: true }
    );
  }

  function initTabberPanels() {
    document.querySelectorAll("[data-tabber]").forEach((block) => {
      const nav = block.querySelector("nav");
      const panels = block.querySelectorAll("[data-tabber-panel]");
      if (!nav || !panels.length) return;
      initTabberScrollProgression(block);

      const buttons = nav.querySelectorAll("button[data-index]");
      buttons.forEach((btn) => {
        if (btn.getAttribute("data-tabber-panel-init") === "true") return;
        btn.setAttribute("data-tabber-panel-init", "true");
        btn.addEventListener("click", function () {
          const idx = parseInt((this as HTMLElement).dataset.index ?? "0", 10);
          panels.forEach((panel, i) => {
            (panel as HTMLElement).classList.toggle("hidden", i !== idx);
          });
        });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTabberPanels);
  } else {
    initTabberPanels();
  }

  document.addEventListener("astro:page-load", initTabberPanels);
</script>
