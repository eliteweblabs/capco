            <span>Dark only</span>
            <span>Light gray</span>
          </div>
          <button id="v2-hv-reanalyze"
            class="mt-2 w-full rounded border border-blue-300 bg-white px-2 py-1 text-[11px] font-medium text-blue-700 hover:bg-blue-50 dark:border-blue-700 dark:bg-blue-900/20 dark:text-blue-300">
            Re-analyze
          </button>
        </div>

        <div class="rounded-lg border border-amber-200 bg-amber-50 p-3 dark:border-amber-800/40 dark:bg-amber-900/10">
          <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-wide text-amber-600 dark:text-amber-400">How to edit</p>
          <ul class="space-y-1.5 text-xs text-amber-700 dark:text-amber-300">
