                      class="rounded px-1.5 py-0.5 text-[10px] font-medium ${isCon ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400" : "bg-gray-100 text-gray-600 hover:bg-emerald-100 hover:text-emerald-700 dark:bg-gray-700 dark:text-gray-300"}"
                      >${isCon ? "✓ Floor" : "Floor"}</button>
                    <button data-region-legend="${i}"
                      class="rounded px-1.5 py-0.5 text-[10px] font-medium bg-gray-100 text-gray-600 hover:bg-violet-100 hover:text-violet-700 dark:bg-gray-700 dark:text-gray-300"
