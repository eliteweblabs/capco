      hvSliderTimer = setTimeout(() => { reanalyzePipesWithCurrentSettings(regionIdx); }, 700);
    });
    document.getElementById("v2-hv-reanalyze")?.addEventListener("click", () => {
      if (sliderEl) hvSensitivity = parseInt(sliderEl.value);
      if (hvSliderTimer !== null) { clearTimeout(hvSliderTimer); hvSliderTimer = null; }
