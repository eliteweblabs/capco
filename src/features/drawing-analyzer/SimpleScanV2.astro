                  <span class="ml-1 text-[10px] text-gray-400">${r.w}×${r.h}</span>
                </span>
                <span class="flex items-center gap-1 text-[10px] text-gray-500 dark:text-gray-400">
                  <span class="inline-block h-2 w-2 rounded-full ${dotColor}"></span>
