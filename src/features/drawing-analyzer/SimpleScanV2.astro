                  ` : ""}
                  ${(isLeg || isExc) ? `
                    <button data-region-reset="${i}"
                      class="rounded px-1.5 py-0.5 text-[10px] font-medium bg-gray-100 text-gray-600 hover:bg-amber-100 hover:text-amber-700 dark:bg-gray-700 dark:text-gray-300"
                      >Reset</button>
                  ` : ""}
                  ${!isCon && !isLeg ? `
                    <button data-region-exclude="${i}"
