      renderRegionBoxes();
      renderRegionsStep();
    });

    document.getElementById("v2-pipe-next-floor")?.addEventListener("click", async () => {
      currentFloorIdx++;
      const confirmedIdxs = baselineRegions
        .map((_,i) => i)
        .filter(i => regionMeta[i].confirmed);
      if (currentFloorIdx < confirmedIdxs.length) {
        await analyzePipeForFloor(confirmedIdxs[currentFloorIdx]);
      }
    });

    document.getElementById("v2-pipe-finish")?.addEventListener("click", () => {
      renderSummaryStep();
    });
  }

  // ── Step: Summary ──────────────────────────────────────────

  function renderSummaryStep(): void {
    step = "summary";
    updateStepBar();
    viewportEl.style.cursor = "grab";
    hintEl.classList.add("hidden");

    const confirmedFloors = baselineRegions.filter((_,i)=>regionMeta[i].confirmed).length;

    renderSidebar(`
      <div class="flex flex-col gap-4">
        <div>
          <h3 class="mb-1 text-base font-semibold text-gray-900 dark:text-white">Summary</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">Review complete.</p>
        </div>

        <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 dark:border-emerald-800/40 dark:bg-emerald-900/10">
          <p class="mb-1 text-[11px] font-semibold uppercase tracking-wide text-emerald-600 dark:text-emerald-400">Results</p>
          <ul class="space-y-1 text-xs text-emerald-700 dark:text-emerald-300">
            <li>${confirmedFloors} floor plan${confirmedFloors!==1?"s":""} analyzed</li>
