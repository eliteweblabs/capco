            Mark any legend area to skip it.
          </p>
        </div>

        <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
          ${baselineRegions.map((r, i) => {
            const m = regionMeta[i];
            const isLeg  = m.isLegend;
            const isCon  = m.confirmed;
            const isExc  = m.excluded;
