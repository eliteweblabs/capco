  // ═══════════════════════════════════════════════════════════
  //  DRAWING UPLOAD / LOAD
  // ═══════════════════════════════════════════════════════════

  async function loadDrawing(src: string | File): Promise<void> {
    try {
      showOverlay("Loading drawing…");
      setStatus("Loading…");

      // Reset state — cancel any in-flight animation/tooltip first
      if (hoverAnimRAF !== null) { cancelAnimationFrame(hoverAnimRAF); hoverAnimRAF = null; }
      hideSegmentTooltip();
      if (hvSliderTimer !== null) { clearTimeout(hvSliderTimer); hvSliderTimer = null; }

      fullRenderData = null; workingImageData = null;
      baselineRegions = []; regionMeta = [];
      pipeLayer = null; pipeAnalysis = null;
      pipeComponentMap = null; pipeSegments = [];
      hoveredSegId = null; isAddMode = false; floorKnowledge.length = 0;
      currentFloorIdx = 0;
      step = "regions";
      updateStepBar();
      if (contentEl) contentEl.innerHTML = "";
      if (hintEl) hintEl.classList.add("hidden");

      let imgData: ImageData;

      if (typeof src === "string" && src.toLowerCase().endsWith(".pdf")) {
        setStatus("Rendering PDF…");
        imgData = await renderPdf(src);
      } else if (src instanceof File && src.type === "application/pdf") {
        setStatus("Rendering PDF…");
        imgData = await renderPdf(await src.arrayBuffer());
      } else {
        // Image file or URL
        setStatus("Loading image…");
        imgData = await loadImageAsImageData(src);
      }

      fullRenderData = imgData;
      setStatus("Detecting regions…");
      await new Promise(r => setTimeout(r, 0));

      baselineRegions = detectRegions(imgData);
      regionMeta = baselineRegions.map(() => ({ confirmed: false, excluded: false, isLegend: false }));

      // Auto-confirm if single region
      if (baselineRegions.length === 1) {
        regionMeta[0].confirmed = true;
      }

      renderCanvas(imgData);
      renderRegionBoxes();
      renderRegionsStep();

      setStatus(`${baselineRegions.length} area${baselineRegions.length!==1?"s":""} detected — confirm regions to continue`);
      updateStepBar();
    } catch(err) {
      logW("loadDrawing error:", err);
      toast("error","Load failed",String(err));
    } finally {
      hideOverlay();
    }
  }

  async function loadImageAsImageData(src: string | File): Promise<ImageData> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        const c = document.createElement("canvas");
        c.width = img.naturalWidth; c.height = img.naturalHeight;
        const ctx = c.getContext("2d")!;
        ctx.drawImage(img, 0, 0);
        resolve(ctx.getImageData(0, 0, c.width, c.height));
      };
      img.onerror = () => reject(new Error("Failed to load image"));
      if (src instanceof File) {
        const url = URL.createObjectURL(src);
        img.onload = () => { URL.revokeObjectURL(url); const c2 = document.createElement("canvas"); c2.width=img.naturalWidth;c2.height=img.naturalHeight; const ctx2=c2.getContext("2d")!;ctx2.drawImage(img,0,0); resolve(ctx2.getImageData(0,0,c2.width,c2.height)); };
        img.src = url;
      } else {
        img.crossOrigin = "anonymous";
        img.src = src as string;
      }
    });
  }

  // ═══════════════════════════════════════════════════════════
  //  INIT / EVENT WIRING
  // ═══════════════════════════════════════════════════════════

  const fileInput  = document.getElementById("v2-file-input") as HTMLInputElement;
  const testSelect = document.getElementById("v2-test-select") as HTMLSelectElement;
  const runBtn     = document.getElementById("v2-run-btn") as HTMLButtonElement;

  // Changing the selector always restarts from scratch
  testSelect?.addEventListener("change", async () => {
    const val = testSelect.value;
    if (val) {
      // Clear any uploaded file so Run button won't re-use it
      if (fileInput) fileInput.value = "";
      await loadDrawing(val);
    }
  });

  // Picking a file always restarts from scratch
  fileInput?.addEventListener("change", async () => {
    const file = fileInput.files?.[0];
    if (file) await loadDrawing(file);
  });

  // "Load Drawing" button is a manual fallback (e.g. re-run same file)
  runBtn?.addEventListener("click", async () => {
    const file = fileInput?.files?.[0];
    if (file) { await loadDrawing(file); return; }
    const val = testSelect?.value;
    if (val) await loadDrawing(val);
  });

  // Auto-load the first test drawing on page open
  const defaultVal = testSelect?.value;
  if (defaultVal) {
    setTimeout(() => loadDrawing(defaultVal), 200);
  }
</script>
