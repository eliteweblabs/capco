  function wireRegionButtons(): void {
    sidebarEl?.querySelectorAll<HTMLElement>("[data-region-confirm]").forEach(btn => {
      btn.addEventListener("click", () => {
        const i = Number(btn.dataset.regionConfirm);
        regionMeta[i].confirmed = !regionMeta[i].confirmed;
        if (regionMeta[i].confirmed) { regionMeta[i].excluded=false; regionMeta[i].isLegend=false; }
        renderRegionBoxes(); renderRegionsStep();
      });
    });
    sidebarEl?.querySelectorAll<HTMLElement>("[data-region-legend]").forEach(btn => {
      btn.addEventListener("click", () => {
        const i = Number(btn.dataset.regionLegend);
        regionMeta[i].isLegend = true; regionMeta[i].confirmed=false; regionMeta[i].excluded=false;
        renderRegionBoxes(); renderRegionsStep();
      });
    });
    sidebarEl?.querySelectorAll<HTMLElement>("[data-region-exclude]").forEach(btn => {
      btn.addEventListener("click", () => {
        const i = Number(btn.dataset.regionExclude);
        regionMeta[i].excluded=true; regionMeta[i].confirmed=false; regionMeta[i].isLegend=false;
        renderRegionBoxes(); renderRegionsStep();
      });
    });
    sidebarEl?.querySelectorAll<HTMLElement>("[data-region-reset]").forEach(btn => {
      btn.addEventListener("click", () => {
        const i = Number(btn.dataset.regionReset);
        regionMeta[i] = { confirmed:false, excluded:false, isLegend:false };
        renderRegionBoxes(); renderRegionsStep();
      });
    });
    document.getElementById("v2-regions-next")?.addEventListener("click", startPipeReview);
  }

  function renderRegionBoxes(): void {
    document.querySelectorAll(".v2-region-box").forEach(el => el.remove());
    if (!fullRenderData || !contentEl) return;

    const iw = fullRenderData.width;
    const ih = fullRenderData.height;

    baselineRegions.forEach((r, i) => {
      const m = regionMeta[i];
      // Percentage positioning — always correct regardless of CSS scale / zoom transform timing.
      // `contentEl` is inline-block sized to the background image, so percentages map
      // directly to image-pixel fractions on both axes.
      const pctL = (r.x / iw * 100).toFixed(4);
      const pctT = (r.y / ih * 100).toFixed(4);
      const pctW = (r.w / iw * 100).toFixed(4);
      const pctH = (r.h / ih * 100).toFixed(4);

      const borderColor = m.isLegend ? "#8b5cf6" : m.confirmed ? "#10b981" : m.excluded ? "#9ca3af" : "#f59e0b";
      const bgColor     = m.isLegend ? "rgba(139,92,246,0.08)" : m.confirmed ? "rgba(16,185,129,0.06)" : m.excluded ? "rgba(156,163,175,0.06)" : "rgba(245,158,11,0.06)";

      const el = document.createElement("div");
      el.className = "v2-region-box pointer-events-none";
      el.style.cssText = `
        position:absolute;
        left:${pctL}%; top:${pctT}%;
        width:${pctW}%; height:${pctH}%;
        border:2px solid ${borderColor};
        background:${bgColor};
        border-radius:4px;
        box-sizing:border-box;
      `;

      const labelBg = m.isLegend ? "#8b5cf6" : m.confirmed ? "#10b981" : "#f59e0b";
      const label = document.createElement("div");
      label.style.cssText = `
        position:absolute; top:4px; left:4px;
        font-size:10px; font-weight:700; padding:1px 5px;
        border-radius:3px; line-height:1.4;
        background:${labelBg}; color:white;
      `;
      label.textContent = m.isLegend ? "LEGEND" : m.confirmed ? `FLOOR ${i+1}` : `AREA ${i+1}`;
      el.appendChild(label);
      contentEl.appendChild(el);
    });
  }

  // ── Step: Pipe Review ──────────────────────────────────────

  async function startPipeReview(): Promise<void> {
    const confirmedFloors = baselineRegions
      .map((r, i) => ({ r, i, m: regionMeta[i] }))
      .filter(f => f.m.confirmed);

    if (confirmedFloors.length === 0) { toast("error","No floors confirmed",""); return; }

    currentFloorIdx = 0;
    await analyzePipeForFloor(confirmedFloors[0].i);
  }

  async function analyzePipeForFloor(regionIdx: number): Promise<void> {
    const region = baselineRegions[regionIdx];
    if (!region || !fullRenderData) return;

    showOverlay("Extracting pipe layer…");

    await new Promise<void>(resolve => setTimeout(async () => {
      try {
        // Crop region
        const canvas = document.createElement("canvas");
        canvas.width = region.w; canvas.height = region.h;
        const ctx = canvas.getContext("2d")!;
        const tmpC = document.createElement("canvas");
        tmpC.width = fullRenderData!.width; tmpC.height = fullRenderData!.height;
        tmpC.getContext("2d")!.putImageData(fullRenderData!, 0, 0);
        ctx.drawImage(tmpC, region.x, region.y, region.w, region.h, 0, 0, region.w, region.h);
        workingImageData = ctx.getImageData(0, 0, region.w, region.h);
        lastCropOffsetX = region.x; lastCropOffsetY = region.y;

        // Apply knowledge from previous floor if available
        const prevKnowledge = floorKnowledge[currentFloorIdx - 1];
        const satMin = prevKnowledge ? Math.max(0.10, prevKnowledge.grayThresh / 255) : 0.15;
        const hvGrayThresh = Math.round(40 + hvSensitivity * 1.8);

        setStatus("Extracting pipe layer (color + H/V lines)…");
        const colorLayer = extractColored(workingImageData, satMin);
        const hvLayer    = extractHVLines(workingImageData, hvGrayThresh);
        pipeLayer = mergeLayers(colorLayer, hvLayer);

        log(`analyzePipeForFloor: color=${colorLayer.pixelCount}px  hv=${hvLayer.pixelCount}px  merged=${pipeLayer.pixelCount}px`);

        if (pipeLayer.pixelCount < 50) {
          toast("error","No lines found","Could not detect pipe lines. Try raising the sensitivity slider.");
          pipeLayer = null;
          hideOverlay();
          resolve();
          return;
        }

        setStatus("Analyzing pipe skeleton…");
        await new Promise(r2 => setTimeout(r2, 0)); // allow UI update
        pipeAnalysis = analyzePipes(pipeLayer);

        // Record knowledge for next floor
        if (pipeAnalysis) {
          const { data } = pipeLayer.rawImageData;
          const pRs: number[]=[], pGs: number[]=[], pBs: number[]=[];
          for (let i=0;i<pipeLayer.rawImageData.width*pipeLayer.rawImageData.height;i++) {
            if (data[i*4+3]>50) { pRs.push(data[i*4]); pGs.push(data[i*4+1]); pBs.push(data[i*4+2]); }
          }
          pRs.sort((a,b)=>a-b); pGs.sort((a,b)=>a-b); pBs.sort((a,b)=>a-b);
          const mid=Math.floor(pRs.length/2);
          const pipeColor: [number,number,number] = [pRs[mid]??59, pGs[mid]??130, pBs[mid]??246];
          floorKnowledge[currentFloorIdx] = { grayThresh: satMin * 255, pipeColor };
        }

        // Prune to single connected network before entering review
        const pruned = enforceConnectedNetwork();
        if (pruned > 0) log(`Initial analysis: pruned ${pruned}px of disconnected pipe`);
        buildPipeSegmentMap();

        step = "pipe-review";
        updateStepBar();
        viewportEl.style.cursor = "crosshair";
        renderCanvas(workingImageData, pipeLayer?.rawImageData);
        renderPipeReviewSidebar(regionIdx);
        updatePipeHint(null);
        hintEl.classList.remove("hidden");

        setStatus(`Floor ${currentFloorIdx+1} — ${pipeSegments.length} pipe segments found`);
        toast("success","Pipe analysis complete",`${pipeSegments.length} segments detected`);
      } catch(err) {
        logW("analyzePipeForFloor error:", err);
        toast("error","Analysis error", String(err));
      } finally {
        hideOverlay();
        resolve();
      }
    }, 50));
  }

  /**
   * Re-run only the layer extraction + analysis using the current workingImageData.
   * Used by the sensitivity slider — does NOT re-crop the region.
   */
  async function reanalyzePipesWithCurrentSettings(regionIdx: number): Promise<void> {
    if (!workingImageData) return;
    showOverlay("Re-analyzing…");
    await new Promise<void>(resolve => setTimeout(async () => {
      try {
        const satMin = 0.15;
        const hvGrayThresh = Math.round(40 + hvSensitivity * 1.8);
        setStatus("Re-extracting pipe layer…");
        const colorLayer = extractColored(workingImageData!, satMin);
        const hvLayer    = extractHVLines(workingImageData!, hvGrayThresh);
        pipeLayer = mergeLayers(colorLayer, hvLayer);
        log(`reanalyze: color=${colorLayer.pixelCount}px hv=${hvLayer.pixelCount}px merged=${pipeLayer.pixelCount}px`);

        if (pipeLayer.pixelCount < 50) {
          toast("info", "Few lines detected", "Try raising the sensitivity slider.");
          hideOverlay(); resolve(); return;
        }

        setStatus("Skeletonizing…");
        await new Promise(r2 => setTimeout(r2, 0));
        pipeAnalysis = analyzePipes(pipeLayer);
        enforceConnectedNetwork();
        buildPipeSegmentMap();
        renderCanvas(workingImageData!, pipeLayer.rawImageData);
        renderPipeReviewSidebar(regionIdx);
        updateSidebarStats();
        setStatus(`Re-analyzed — ${pipeSegments.length} segments`);
      } catch (err) {
        logW("reanalyze error:", err);
        toast("error", "Re-analysis failed", String(err));
      } finally {
        hideOverlay();
        resolve();
      }
    }, 30));
  }

