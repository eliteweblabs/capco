---
/**
 * Drawing Analyzer v1
 *
 * Step 1: Upload a PDF or screenshot
 * Step 2: Display it as large as possible
 * Step 3: Select a "viable area" and mask everything else
 */
import { globalClasses } from "../../pages/api/global/global-classes";
import SimpleIcon from "../../components/common/SimpleIcon.astro";
import SlidingTabs from "../../components/common/SlidingTabs.astro";

const { globalTextH3, globalSectionHeaderBar, globalFormLabel } = globalClasses();
export interface Props {
  projectId?: number;
}
const { projectId } = Astro.props;
---

<div
  class="drawing-analyzer rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800"
>
  <div class={globalSectionHeaderBar}>
    <h2 class={globalTextH3}>Drawing Analyzer</h2>
  </div>

  <p class="mb-4 text-sm text-gray-600 dark:text-gray-400">
    Upload a PDF or screenshot, then draw the <strong>viable area</strong>. Everything outside this
    region is masked and ignored.
  </p>

  <SlidingTabs
    navId="drawing-analyzer-tabs"
    activeItem={0}
    urlParam=""
    switchHandler="switchDrawingAnalyzerTab"
    items={[
      {
        id: "drawing-workspace-tab",
        label: "Workspace",
        variant: "tab",
        showLabel: true,
        onclick: "window.switchDrawingAnalyzerTab('drawing-workspace-content')",
      },
      {
        id: "drawing-library-tab",
        label: "Graphics Library",
        variant: "tab",
        showLabel: true,
        onclick: "window.switchDrawingAnalyzerTab('drawing-library-content')",
      },
    ]}
  />

  <div id="drawing-workspace-content" role="tabpanel" aria-labelledby="drawing-workspace-tab">
    <div id="drawing-upload-section" class="mb-4">
      <label for="drawing-file-input" class={globalFormLabel}>Upload PDF or screenshot</label>
      <div
        id="drawing-dropzone"
        class="flex cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 p-8 transition-colors hover:border-primary-400 hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-900 dark:hover:border-primary-500"
      >
        <SimpleIcon name="image" class="mb-3 h-12 w-12 text-gray-400" />
        <p class="mb-1 font-medium text-gray-700 dark:text-gray-300">
          Drop PDF/image here, or click to browse
        </p>
        <p class="text-xs text-gray-500 dark:text-gray-400">PDF, PNG, JPG, JPEG, GIF, WebP</p>
        <input
          id="drawing-file-input"
          type="file"
          accept=".pdf,image/png,image/jpeg,image/jpg,image/gif,image/webp"
          class="hidden"
        />
      </div>
    </div>

    <div id="drawing-toolbar" class="mb-3 hidden flex-wrap items-center gap-2">
      <button
        id="drawing-reset-viable-area"
        type="button"
        class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
      >
        Reset viable area
      </button>
      <button
        id="drawing-clear-file"
        type="button"
        class="rounded-md border border-red-300 px-3 py-1.5 text-sm text-red-700 hover:bg-red-50 dark:border-red-700 dark:text-red-300 dark:hover:bg-red-900/20"
      >
        Remove file
      </button>
      <label class="text-xs text-gray-600 dark:text-gray-300">
        Selection:
        <select
          id="drawing-selection-purpose"
          class="ml-1 rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
          ><option value="symbol">Capture symbol</option></select
        >
      </label>
      <label class="text-xs text-gray-600 dark:text-gray-300">
        Shape:
        <select
          id="drawing-selection-shape"
          class="ml-1 rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
        >
          <option value="square">Square</option>
          <option value="circle">Circle</option>
        </select>
      </label>
      <div class="ml-auto flex items-center gap-2">
        <button
          id="drawing-zoom-out"
          type="button"
          class="rounded border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          -
        </button>
        <input id="drawing-zoom-range" type="range" min="50" max="300" value="100" class="w-28" />
        <button
          id="drawing-zoom-in"
          type="button"
          class="rounded border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          +
        </button>
        <button
          id="drawing-zoom-reset"
          type="button"
          class="rounded border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          100%
        </button>
        <span
          id="drawing-zoom-readout"
          class="w-12 text-right text-xs text-gray-500 dark:text-gray-400">100%</span
        >
      </div>
      <span id="drawing-viable-area-readout" class="text-xs text-gray-500 dark:text-gray-400"
      ></span>
    </div>

    <div
      id="drawing-calibration"
      class="mb-4 hidden grid-cols-1 gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-900 md:grid-cols-2"
    >
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Detected Scale (full image OCR)</span>
        <input
          id="drawing-scale-full-ocr"
          type="text"
          readonly
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
          placeholder="Searching..."
        />
      </label>
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Detected Scale (viable area OCR)</span>
        <input
          id="drawing-scale-viable-ocr"
          type="text"
          readonly
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
          placeholder="Will update after viable area focus"
        />
      </label>
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Assumed real width (ft)</span>
        <input
          id="drawing-assumed-width-ft"
          type="number"
          min="1"
          step="0.1"
          value="36"
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
        />
      </label>
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Full drawing width (px)</span>
        <input
          id="drawing-full-width-px"
          type="text"
          readonly
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
        />
      </label>
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Viable area width (px)</span>
        <input
          id="drawing-viable-width-px"
          type="text"
          readonly
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
        />
      </label>
      <label class="block">
        <span class={`${globalFormLabel} mb-1`}>Working scale</span>
        <input
          id="drawing-working-scale"
          type="text"
          readonly
          class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200"
          placeholder="Waiting for viable area..."
        />
      </label>
    </div>

    <div
      id="drawing-stage"
      class="relative hidden min-h-[75vh] w-full items-center justify-center overflow-auto rounded-lg border border-gray-200 bg-gray-100 p-2 dark:border-gray-700 dark:bg-gray-900"
    >
      <div id="drawing-media-wrapper" class="relative inline-block max-h-[82vh] max-w-full">
        <img
          id="drawing-image"
          alt="Uploaded drawing preview"
          class="block max-h-[82vh] max-w-full select-none"
        />

        <div id="drawing-overlay" class="absolute inset-0 cursor-crosshair">
          <div id="mask-top" class="absolute left-0 top-0 bg-black/55 backdrop-blur-sm"></div>
          <div id="mask-left" class="absolute left-0 bg-black/55 backdrop-blur-sm"></div>
          <div id="mask-right" class="absolute right-0 bg-black/55 backdrop-blur-sm"></div>
          <div id="mask-bottom" class="absolute bottom-0 left-0 bg-black/55 backdrop-blur-sm"></div>
          <div id="viable-rect" class="drawing-selection-rect bg-primary-500/10 absolute"></div>
        </div>
      </div>
    </div>

    <p id="drawing-status" class="mt-3 hidden text-sm text-gray-600 dark:text-gray-300"></p>
  </div>

  <div
    id="drawing-library-content"
    role="tabpanel"
    aria-labelledby="drawing-library-tab"
    class="hidden"
  >
    <div
      class="mb-3 rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-900"
    >
      <p class="text-sm text-gray-700 dark:text-gray-300">
        Build a reusable symbol library for varying drawing iconography. Set priority by dragging
        items in the list, then re-scan using those symbols.
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        <button
          id="drawing-enable-symbol-capture"
          type="button"
          class="dark:hover:bg-primary-900/20 rounded-md border border-primary-500 px-3 py-1.5 text-sm text-primary-700 hover:bg-primary-50 dark:text-primary-300"
        >
          Capture Symbol (from Workspace)
        </button>
        <button
          id="drawing-rescan-library-symbols"
          type="button"
          class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          Re-scan Drawing For Library Symbols
        </button>
      </div>
    </div>
    <div id="drawing-library-list" class="space-y-2"></div>
  </div>
</div>

<style>
  .drawing-selection-rect {
    border: 1px dashed rgb(var(--color-primary-500, 130 91 221));
    animation: drawing-selection-dash 700ms linear infinite;
  }

  @keyframes drawing-selection-dash {
    0% {
      border-color: rgba(130, 91, 221, 0.65);
      opacity: 0.94;
    }
    100% {
      border-color: rgba(130, 91, 221, 1);
      opacity: 1;
    }
  }
</style>

<script src="/js/pdf.min.js" defer></script>
<script type="module" define:vars={{ projectId: projectId ?? null }}>
  import { TraceLog } from "../../lib/trace-log";

  const dropzone = document.getElementById("drawing-dropzone");
  const fileInput = document.getElementById("drawing-file-input");
  const stage = document.getElementById("drawing-stage");
  const mediaWrapper = document.getElementById("drawing-media-wrapper");
  const toolbar = document.getElementById("drawing-toolbar");
  const statusEl = document.getElementById("drawing-status");
  const imgEl = document.getElementById("drawing-image");
  const overlay = document.getElementById("drawing-overlay");
  const resetBtn = document.getElementById("drawing-reset-viable-area");
  const clearBtn = document.getElementById("drawing-clear-file");
  const selectionPurposeSelect = document.getElementById("drawing-selection-purpose");
  const selectionShapeSelect = document.getElementById("drawing-selection-shape");
  const readoutEl = document.getElementById("drawing-viable-area-readout");
  const viableRect = document.getElementById("viable-rect");
  const maskTop = document.getElementById("mask-top");
  const maskLeft = document.getElementById("mask-left");
  const maskRight = document.getElementById("mask-right");
  const maskBottom = document.getElementById("mask-bottom");
  const calibrationEl = document.getElementById("drawing-calibration");
  const fullScaleInput = document.getElementById("drawing-scale-full-ocr");
  const viableScaleInput = document.getElementById("drawing-scale-viable-ocr");
  const assumedWidthInput = document.getElementById("drawing-assumed-width-ft");
  const fullWidthPxInput = document.getElementById("drawing-full-width-px");
  const viableWidthPxInput = document.getElementById("drawing-viable-width-px");
  const workingScaleInput = document.getElementById("drawing-working-scale");
  const enableSymbolCaptureBtn = document.getElementById("drawing-enable-symbol-capture");
  const rescanLibrarySymbolsBtn = document.getElementById("drawing-rescan-library-symbols");
  const libraryListEl = document.getElementById("drawing-library-list");
  const zoomOutBtn = document.getElementById("drawing-zoom-out");
  const zoomInBtn = document.getElementById("drawing-zoom-in");
  const zoomResetBtn = document.getElementById("drawing-zoom-reset");
  const zoomRange = document.getElementById("drawing-zoom-range");
  const zoomReadout = document.getElementById("drawing-zoom-readout");

  let pointerStart = null;
  let viableArea = null;
  let fullImageNaturalWidth = 0;
  let latestViableWidthPx = 0;
  let ocrRequestCounter = 0;
  let selectionPurpose = "symbol";
  let selectionShape = "square";
  let symbolLibrary = [];
  let zoomLevel = 1;
  let libraryMutationVersion = 0;
  let libraryLoadRequestId = 0;
  const currentProjectId = projectId != null ? Number(projectId) : null;

  window.switchDrawingAnalyzerTab = function (tabId) {
    const workspacePanel = document.getElementById("drawing-workspace-content");
    const libraryPanel = document.getElementById("drawing-library-content");
    const tabsNav = document.getElementById("drawing-analyzer-tabs");
    const workspaceTabBtn = document.getElementById("drawing-workspace-tab");
    const libraryTabBtn = document.getElementById("drawing-library-tab");
    if (!workspacePanel || !libraryPanel) return;
    if (tabId === "drawing-library-content") {
      workspacePanel.classList.add("hidden");
      libraryPanel.classList.remove("hidden");
      workspaceTabBtn?.setAttribute("data-active", "false");
      libraryTabBtn?.setAttribute("data-active", "true");
    } else {
      workspacePanel.classList.remove("hidden");
      libraryPanel.classList.add("hidden");
      workspaceTabBtn?.setAttribute("data-active", "true");
      libraryTabBtn?.setAttribute("data-active", "false");
    }

    // Keep sliding indicator visually synced on programmatic switches.
    const activeBtn = tabId === "drawing-library-content" ? libraryTabBtn : workspaceTabBtn;
    const indicator = tabsNav?.querySelector("[data-sliding-tabs-indicator]");
    if (tabsNav && activeBtn && indicator) {
      const navRect = tabsNav.getBoundingClientRect();
      const btnRect = activeBtn.getBoundingClientRect();
      const left = btnRect.left - navRect.left + tabsNav.scrollLeft;
      indicator.style.left = `${left}px`;
      indicator.style.width = `${btnRect.width}px`;
    }
  };

  function markLibraryMutated(reason, payload = {}) {
    libraryMutationVersion += 1;
    if (TraceLog.enabled()) {
      const ctx = TraceLog.start("drawingAnalyzer.library.mutated", {
        reason,
        mutationVersion: libraryMutationVersion,
        ...payload,
      });
      TraceLog.end(ctx);
    }
  }

  function showStatus(message, isError = false) {
    if (!statusEl) return;
    statusEl.classList.remove("hidden");
    statusEl.className = `mt-3 text-sm ${isError ? "text-red-600 dark:text-red-400" : "text-gray-600 dark:text-gray-300"}`;
    statusEl.textContent = message;
  }

  function clearStatus() {
    statusEl?.classList.add("hidden");
    if (statusEl) statusEl.textContent = "";
  }

  function setOverlaySizeFromImage() {
    if (!imgEl || !overlay) return;
    overlay.style.width = `${imgEl.clientWidth}px`;
    overlay.style.height = `${imgEl.clientHeight}px`;
  }

  function setZoom(nextZoom) {
    if (!mediaWrapper) return;
    zoomLevel = Math.max(0.5, Math.min(3, nextZoom));
    mediaWrapper.style.transformOrigin = "top left";
    mediaWrapper.style.transform = `scale(${zoomLevel})`;
    if (zoomRange) zoomRange.value = String(Math.round(zoomLevel * 100));
    if (zoomReadout) zoomReadout.textContent = `${Math.round(zoomLevel * 100)}%`;
  }

  function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
  }

  function updateMask(rect) {
    if (!overlay || !viableRect || !maskTop || !maskLeft || !maskRight || !maskBottom) return;
    const width = overlay.clientWidth;
    const height = overlay.clientHeight;

    viableRect.style.left = `${rect.left}px`;
    viableRect.style.top = `${rect.top}px`;
    viableRect.style.width = `${rect.width}px`;
    viableRect.style.height = `${rect.height}px`;

    maskTop.style.left = "0px";
    maskTop.style.top = "0px";
    maskTop.style.width = `${width}px`;
    maskTop.style.height = `${rect.top}px`;

    maskLeft.style.left = "0px";
    maskLeft.style.top = `${rect.top}px`;
    maskLeft.style.width = `${rect.left}px`;
    maskLeft.style.height = `${rect.height}px`;

    maskRight.style.left = `${rect.left + rect.width}px`;
    maskRight.style.top = `${rect.top}px`;
    maskRight.style.width = `${Math.max(0, width - (rect.left + rect.width))}px`;
    maskRight.style.height = `${rect.height}px`;

    maskBottom.style.left = "0px";
    maskBottom.style.top = `${rect.top + rect.height}px`;
    maskBottom.style.width = `${width}px`;
    maskBottom.style.height = `${Math.max(0, height - (rect.top + rect.height))}px`;
  }

  function setFullViableArea() {
    if (!overlay) return;
    viableArea = { left: 0, top: 0, width: overlay.clientWidth, height: overlay.clientHeight };
    updateMask(viableArea);
    updateReadout();
  }

  function updateReadout() {
    if (!overlay || !readoutEl || !viableArea) return;
    const w = overlay.clientWidth || 1;
    const h = overlay.clientHeight || 1;
    const leftPct = ((viableArea.left / w) * 100).toFixed(1);
    const topPct = ((viableArea.top / h) * 100).toFixed(1);
    const widthPct = ((viableArea.width / w) * 100).toFixed(1);
    const heightPct = ((viableArea.height / h) * 100).toFixed(1);
    readoutEl.textContent = `Viable area: x ${leftPct}% | y ${topPct}% | w ${widthPct}% | h ${heightPct}%`;
  }

  function getViableWidthNaturalPx() {
    if (!imgEl || !overlay || !viableArea) return 0;
    const displayWidth = overlay.clientWidth || 1;
    const naturalWidth = imgEl.naturalWidth || displayWidth;
    return Math.max(1, Math.round(viableArea.width * (naturalWidth / displayWidth)));
  }

  function updateWorkingScale() {
    const assumedWidthFt = Math.max(1, parseFloat(assumedWidthInput?.value || "36"));
    const viableWidthPx = latestViableWidthPx || fullImageNaturalWidth || 0;
    if (fullWidthPxInput) fullWidthPxInput.value = String(fullImageNaturalWidth || 0);
    if (viableWidthPxInput) viableWidthPxInput.value = String(viableWidthPx || 0);
    if (!workingScaleInput || !viableWidthPx) return;

    const pxPerFt = viableWidthPx / assumedWidthFt;
    const ftPerPx = assumedWidthFt / viableWidthPx;
    const cropFactor =
      fullImageNaturalWidth && viableWidthPx ? fullImageNaturalWidth / viableWidthPx : 1;
    workingScaleInput.value = `${pxPerFt.toFixed(2)} px/ft (${ftPerPx.toFixed(4)} ft/px), crop factor ${cropFactor.toFixed(2)}x`;
  }

  function detectScaleText(rawText) {
    if (!rawText) return "";
    const lines = rawText
      .split(/\r?\n/)
      .map((l) => l.trim())
      .filter(Boolean);
    const scaleLineIdx = lines.findIndex((l) => /\bscale\b/i.test(l));
    if (scaleLineIdx >= 0) {
      const line = lines[scaleLineIdx];
      if (/scale\s*[:\-]?\s*$/i.test(line) && lines[scaleLineIdx + 1]) {
        return `${line} ${lines[scaleLineIdx + 1]}`.trim();
      }
      return line;
    }
    const patterns = [
      /\b\d+\s*"\s*=\s*[\d./]+\s*'[\d" -]*\b/i,
      /\b\d+\s*:\s*\d+\b/i,
      /\b[\d./]+\s*in(?:ch|ches)?\s*=\s*[\d./]+\s*ft\b/i,
    ];
    for (const p of patterns) {
      const match = rawText.match(p);
      if (match) return match[0];
    }
    return "";
  }

  async function runScaleOcr(source) {
    if (!imgEl) return;
    const requestId = ++ocrRequestCounter;
    const targetInput = source === "full" ? fullScaleInput : viableScaleInput;
    if (targetInput) targetInput.value = "Searching...";

    try {
      const canvas = document.createElement("canvas");
      const maxDim = 2200;
      const ratio = Math.min(
        1,
        maxDim / Math.max(imgEl.naturalWidth || 1, imgEl.naturalHeight || 1)
      );
      canvas.width = Math.max(1, Math.round((imgEl.naturalWidth || 1) * ratio));
      canvas.height = Math.max(1, Math.round((imgEl.naturalHeight || 1) * ratio));
      const ctx = canvas.getContext("2d");
      if (!ctx) throw new Error("Canvas not available");
      ctx.drawImage(imgEl, 0, 0, canvas.width, canvas.height);

      const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/jpeg", 0.9));
      if (!blob) throw new Error("OCR image conversion failed");

      const formData = new FormData();
      formData.append("file", blob, `scale-${source}.jpg`);
      formData.append("language", "eng");
      formData.append("isOverlayRequired", "true");
      formData.append("OCREngine", "2");

      const response = await fetch("https://api.ocr.space/parse/image", {
        method: "POST",
        headers: { apikey: "K81932338788957" },
        body: formData,
      });
      const data = await response.json();
      if (requestId !== ocrRequestCounter) return;

      const rawText = data?.ParsedResults?.[0]?.ParsedText || "";
      const detected = detectScaleText(rawText);
      if (targetInput) targetInput.value = detected || "No scale text found";
    } catch (error) {
      console.error("[DrawingAnalyzer] scale OCR failed", error);
      if (requestId === ocrRequestCounter && targetInput) targetInput.value = "OCR failed";
    }
  }

  function focusViableArea() {
    if (!imgEl || !overlay || !viableArea) return;
    const displayWidth = overlay.clientWidth || 1;
    const displayHeight = overlay.clientHeight || 1;
    const naturalWidth = imgEl.naturalWidth || displayWidth;
    const naturalHeight = imgEl.naturalHeight || displayHeight;
    const scaleX = naturalWidth / displayWidth;
    const scaleY = naturalHeight / displayHeight;

    const sx = Math.max(0, Math.round(viableArea.left * scaleX));
    const sy = Math.max(0, Math.round(viableArea.top * scaleY));
    const sw = Math.max(1, Math.round(viableArea.width * scaleX));
    const sh = Math.max(1, Math.round(viableArea.height * scaleY));
    const cropWidth = Math.min(sw, naturalWidth - sx);
    const cropHeight = Math.min(sh, naturalHeight - sy);

    const canvas = document.createElement("canvas");
    canvas.width = cropWidth;
    canvas.height = cropHeight;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    ctx.drawImage(imgEl, sx, sy, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);

    // Replace image with cropped viable area, then treat whole new image as viable.
    const croppedSrc = canvas.toDataURL("image/png");
    imgEl.onload = () => {
      setOverlaySizeFromImage();
      setFullViableArea();
      latestViableWidthPx = cropWidth;
      updateWorkingScale();
      runScaleOcr("viable");
    };
    imgEl.src = croppedSrc;
    showStatus("Viable area focused. Only this content will be sent to the agent.");
  }

  async function uploadImageBlob(blob, name) {
    const file = new File([blob], name, { type: "image/png" });
    const formData = new FormData();
    formData.append("file", file);
    formData.append("folder", "drawing-analyzer-library");
    const res = await fetch("/api/agent/upload-image", {
      method: "POST",
      credentials: "include",
      body: formData,
    });
    if (!res.ok) throw new Error("Upload failed");
    const data = await res.json();
    return data.url || data.publicUrl || "";
  }

  async function loadLibraryItems() {
    const requestId = ++libraryLoadRequestId;
    const startMutationVersion = libraryMutationVersion;
    const ctx = TraceLog.start("drawingAnalyzer.library.load", {
      requestId,
      projectId: currentProjectId,
      startMutationVersion,
    });
    try {
      const params = new URLSearchParams();
      if (currentProjectId && !Number.isNaN(currentProjectId)) {
        params.set("projectId", String(currentProjectId));
      }
      const res = await fetch(`/api/drawing-library/items?${params.toString()}`, {
        credentials: "include",
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        TraceLog.end(ctx, { requestId, ok: false, status: res.status, reason: "non-success response" });
        return;
      }
      if (requestId !== libraryLoadRequestId) {
        TraceLog.end(ctx, { requestId, ok: true, skipped: "stale-request" });
        return;
      }
      if (libraryMutationVersion !== startMutationVersion) {
        TraceLog.end(ctx, {
          requestId,
          ok: true,
          skipped: "local-library-mutated-during-load",
          startMutationVersion,
          endMutationVersion: libraryMutationVersion,
        });
        return;
      }
      symbolLibrary = (data.items || []).map((item) => ({
        id: item.id,
        clientId: `db-${item.id}`,
        name: item.name || `Symbol ${item.id}`,
        localDataUrl: item.imageUrl,
        uploadedUrl: item.imageUrl,
        imageUrl: item.imageUrl,
        selectionShape: item.selectionShape || "square",
        price: Number(item.price || 0),
        priority: Number(item.priority || 1),
        dependencies: Array.isArray(item.dependencies) ? item.dependencies : [],
      }));
      renderLibraryList();
      TraceLog.end(ctx, {
        requestId,
        ok: true,
        loadedCount: symbolLibrary.length,
        mutationVersion: libraryMutationVersion,
      });
    } catch (error) {
      console.error("[DrawingAnalyzer] failed to load library", error);
      TraceLog.error(ctx, error, { requestId });
    }
  }

  async function saveLibraryItem(item) {
    const ctx = TraceLog.start("drawingAnalyzer.library.saveItem", {
      hasId: Boolean(item?.id),
      clientId: item?.clientId,
      projectId: currentProjectId,
    });
    if (!item || !item.uploadedUrl) {
      TraceLog.end(ctx, { ok: false, reason: "missing-item-or-upload-url" });
      return;
    }
    const payload = {
      projectId: currentProjectId,
      name: item.name,
      imageUrl: item.uploadedUrl,
      selectionShape: item.selectionShape || "square",
      price: Number(item.price || 0),
      priority: Number(item.priority || 1),
      dependencies: Array.isArray(item.dependencies) ? item.dependencies : [],
    };
    if (item.id) {
      const res = await fetch("/api/drawing-library/items", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ id: item.id, ...payload }),
      });
      if (!res.ok) throw new Error("Failed to update library item");
      TraceLog.end(ctx, { ok: true, mode: "update", id: item.id });
      return item.id;
    }
    const res = await fetch("/api/drawing-library/items", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify(payload),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok || !data?.item?.id) throw new Error("Failed to create library item");
    item.id = data.item.id;
    item.clientId = `db-${item.id}`;
    TraceLog.end(ctx, { ok: true, mode: "create", id: item.id });
    return item.id;
  }

  async function deleteLibraryItem(item) {
    if (!item?.id) return;
    await fetch("/api/drawing-library/items", {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ id: item.id }),
    });
  }

  function renderLibraryList() {
    if (!libraryListEl) return;
    if (symbolLibrary.length === 0) {
      libraryListEl.innerHTML =
        '<p class="rounded border border-dashed border-gray-300 px-3 py-2 text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400">No symbols captured yet.</p>';
      return;
    }
    const selectableDependencyItems = symbolLibrary.filter((x) => Number.isFinite(Number(x.id)));
    libraryListEl.innerHTML = symbolLibrary
      .map(
        (
          item,
          i
        ) => `<div class="flex items-center gap-3 rounded border border-gray-200 bg-white p-2 dark:border-gray-700 dark:bg-gray-800" draggable="true" data-symbol-index="${i}">
          <span class="cursor-grab text-gray-400">::</span>
          <img src="${item.localDataUrl}" alt="${item.name}" class="h-10 w-10 rounded border border-gray-300 object-contain dark:border-gray-600" />
          <div class="min-w-0 flex-1 space-y-2">
            <p class="truncate text-sm text-gray-800 dark:text-gray-200">${item.name}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Priority ${i + 1}</p>
            <div class="flex items-center gap-2">
              <label class="text-xs text-gray-500 dark:text-gray-400">Price</label>
              <input type="number" step="0.01" min="0" value="${Number(item.price || 0)}" data-price-symbol="${item.clientId}" class="w-24 rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-900 dark:text-gray-200" />
            </div>
            <div class="space-y-1" data-dependencies-wrap="${item.clientId}">
              ${(item.dependencies || [])
                .map(
                  (dep, depIdx) => `<div class="flex items-center gap-2">
                    <select data-dep-item-symbol="${item.clientId}" data-dep-index="${depIdx}" class="rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-900 dark:text-gray-200">
                      <option value="">Depends on...</option>
                      ${selectableDependencyItems
                        .filter((x) => x.clientId !== item.clientId)
                        .map(
                          (x) =>
                            `<option value="${x.id}" ${String(dep.dependsOnItemId || "") === String(x.id) ? "selected" : ""}>${x.name}</option>`
                        )
                        .join("")}
                    </select>
                    <input type="number" min="1" step="1" value="${Math.max(1, Number(dep.quantity || 1))}" data-dep-qty-symbol="${item.clientId}" data-dep-index="${depIdx}" class="w-16 rounded border border-gray-300 bg-white px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-900 dark:text-gray-200" />
                    <button type="button" data-remove-dep-symbol="${item.clientId}" data-dep-index="${depIdx}" class="rounded border border-red-300 px-2 py-1 text-xs text-red-700 hover:bg-red-50 dark:border-red-700 dark:text-red-300 dark:hover:bg-red-900/20">Remove</button>
                  </div>`
                )
                .join("")}
            </div>
            <button type="button" data-add-dep-symbol="${item.clientId}" class="rounded border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">Add dependency</button>
          </div>
          <button type="button" class="rounded border border-red-300 px-2 py-1 text-xs text-red-700 hover:bg-red-50 dark:border-red-700 dark:text-red-300 dark:hover:bg-red-900/20" data-remove-symbol="${item.clientId}">Remove</button>
        </div>`
      )
      .join("");

    libraryListEl.querySelectorAll("[data-remove-symbol]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const clientId = btn.getAttribute("data-remove-symbol");
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (item?.id) {
          try {
            await deleteLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] delete failed", error);
          }
        }
        symbolLibrary = symbolLibrary.filter((x) => x.clientId !== clientId);
        symbolLibrary.forEach((x, idx) => (x.priority = idx + 1));
        renderLibraryList();
      });
    });

    libraryListEl.querySelectorAll("[data-price-symbol]").forEach((input) => {
      input.addEventListener("change", async () => {
        const clientId = input.getAttribute("data-price-symbol");
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (!item) return;
        item.price = Number(input.value || 0);
        if (item.id) {
          try {
            await saveLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] price save failed", error);
          }
        }
      });
    });

    libraryListEl.querySelectorAll("[data-add-dep-symbol]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const clientId = btn.getAttribute("data-add-dep-symbol");
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (!item) return;
        item.dependencies = item.dependencies || [];
        item.dependencies.push({ dependsOnItemId: null, quantity: 1 });
        renderLibraryList();
        if (item.id) {
          try {
            await saveLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] dependency add save failed", error);
          }
        }
      });
    });

    libraryListEl.querySelectorAll("[data-dep-item-symbol]").forEach((select) => {
      select.addEventListener("change", async () => {
        const clientId = select.getAttribute("data-dep-item-symbol");
        const depIndex = parseInt(select.getAttribute("data-dep-index") || "-1", 10);
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (!item || depIndex < 0) return;
        item.dependencies = item.dependencies || [];
        if (!item.dependencies[depIndex]) return;
        item.dependencies[depIndex].dependsOnItemId = select.value ? Number(select.value) : null;
        if (item.id) {
          try {
            await saveLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] dependency select save failed", error);
          }
        }
      });
    });

    libraryListEl.querySelectorAll("[data-dep-qty-symbol]").forEach((input) => {
      input.addEventListener("change", async () => {
        const clientId = input.getAttribute("data-dep-qty-symbol");
        const depIndex = parseInt(input.getAttribute("data-dep-index") || "-1", 10);
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (!item || depIndex < 0) return;
        item.dependencies = item.dependencies || [];
        if (!item.dependencies[depIndex]) return;
        item.dependencies[depIndex].quantity = Math.max(1, Number(input.value || 1));
        if (item.id) {
          try {
            await saveLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] dependency qty save failed", error);
          }
        }
      });
    });

    libraryListEl.querySelectorAll("[data-remove-dep-symbol]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const clientId = btn.getAttribute("data-remove-dep-symbol");
        const depIndex = parseInt(btn.getAttribute("data-dep-index") || "-1", 10);
        const item = symbolLibrary.find((x) => x.clientId === clientId);
        if (!item || depIndex < 0) return;
        item.dependencies.splice(depIndex, 1);
        renderLibraryList();
        if (item.id) {
          try {
            await saveLibraryItem(item);
          } catch (error) {
            console.error("[DrawingAnalyzer] dependency remove save failed", error);
          }
        }
      });
    });

    let dragFrom = -1;
    libraryListEl.querySelectorAll("[data-symbol-index]").forEach((row) => {
      row.addEventListener("dragstart", () => {
        dragFrom = parseInt(row.getAttribute("data-symbol-index") || "-1", 10);
      });
      row.addEventListener("dragover", (e) => e.preventDefault());
      row.addEventListener("drop", () => {
        const dragTo = parseInt(row.getAttribute("data-symbol-index") || "-1", 10);
        if (dragFrom < 0 || dragTo < 0 || dragFrom === dragTo) return;
        const next = [...symbolLibrary];
        const [moved] = next.splice(dragFrom, 1);
        next.splice(dragTo, 0, moved);
        symbolLibrary = next.map((x, idx) => ({ ...x, priority: idx + 1 }));
        renderLibraryList();
        symbolLibrary
          .filter((x) => x.id)
          .forEach(async (x) => {
            try {
              await saveLibraryItem(x);
            } catch (error) {
              console.error("[DrawingAnalyzer] priority save failed", error);
            }
          });
      });
    });
  }

  async function captureSymbolFromSelection() {
    const traceCtx = TraceLog.start("drawingAnalyzer.captureSymbolFromSelection", {
      hasImage: Boolean(imgEl?.src),
      hasOverlay: Boolean(overlay),
      hasViableArea: Boolean(viableArea),
      selectionShape,
    });
    if (!imgEl || !overlay || !viableArea) {
      TraceLog.end(traceCtx, { ok: false, reason: "missing-image-overlay-or-viable-area" });
      return;
    }
    const displayWidth = overlay.clientWidth || 1;
    const displayHeight = overlay.clientHeight || 1;
    const naturalWidth = imgEl.naturalWidth || displayWidth;
    const naturalHeight = imgEl.naturalHeight || displayHeight;
    const scaleX = naturalWidth / displayWidth;
    const scaleY = naturalHeight / displayHeight;
    const sx = Math.max(0, Math.round(viableArea.left * scaleX));
    const sy = Math.max(0, Math.round(viableArea.top * scaleY));
    const sw = Math.max(1, Math.round(viableArea.width * scaleX));
    const sh = Math.max(1, Math.round(viableArea.height * scaleY));
    const cropWidth = Math.min(sw, naturalWidth - sx);
    const cropHeight = Math.min(sh, naturalHeight - sy);
    const canvas = document.createElement("canvas");
    canvas.width = cropWidth;
    canvas.height = cropHeight;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    if (selectionShape === "circle") {
      const r = Math.min(cropWidth, cropHeight) / 2;
      ctx.beginPath();
      ctx.arc(cropWidth / 2, cropHeight / 2, r, 0, Math.PI * 2);
      ctx.closePath();
      ctx.clip();
    }
    ctx.drawImage(imgEl, sx, sy, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
    const localDataUrl = canvas.toDataURL("image/png");
    const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/png"));
    const id = `sym-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;
    symbolLibrary = [
      ...symbolLibrary,
      {
        clientId: id,
        name: `Symbol ${symbolLibrary.length + 1}`,
        localDataUrl,
        uploadedUrl: "",
        imageUrl: "",
        selectionShape,
        price: 0,
        dependencies: [],
        priority: symbolLibrary.length + 1,
      },
    ];
    markLibraryMutated("symbol-captured-local", {
      clientId: id,
      libraryCount: symbolLibrary.length,
    });
    renderLibraryList();
    showStatus(`Symbol captured. Library count: ${symbolLibrary.length}`);
    // Immediate feedback: jump to library so user can see result.
    window.switchDrawingAnalyzerTab("drawing-library-content");
    if (blob) {
      try {
        const uploadedUrl = await uploadImageBlob(blob, `${id}.png`);
        const item = symbolLibrary.find((x) => x.clientId === id);
        if (item) {
          item.uploadedUrl = uploadedUrl;
          item.imageUrl = uploadedUrl;
          await saveLibraryItem(item);
          markLibraryMutated("symbol-uploaded-and-saved", {
            clientId: id,
            itemId: item.id,
          });
        } else {
          TraceLog.end(traceCtx, {
            ok: false,
            reason: "captured-item-missing-before-save",
            clientId: id,
            libraryCount: symbolLibrary.length,
          });
        }
      } catch (error) {
        console.warn("[DrawingAnalyzer] symbol upload failed", error);
        TraceLog.error(traceCtx, error, { clientId: id });
      }
    }
    renderLibraryList();
    TraceLog.end(traceCtx, {
      ok: true,
      clientId: id,
      selectionShape,
      libraryCount: symbolLibrary.length,
    });
  }

  async function rescanForLibrarySymbols() {
    if (!imgEl?.src || symbolLibrary.length === 0) {
      showStatus("Add at least one symbol to the library before re-scan.", true);
      return;
    }
    showStatus("Re-scanning drawing with current symbol library...");
    try {
      const canvas = document.createElement("canvas");
      canvas.width = imgEl.naturalWidth;
      canvas.height = imgEl.naturalHeight;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      ctx.drawImage(imgEl, 0, 0);
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/png"));
      if (!blob) throw new Error("Could not prepare image");
      const imageUrl = await uploadImageBlob(blob, `rescan-${Date.now()}.png`);
      const symbolContext = symbolLibrary
        .map((s) => ({ name: s.name, url: s.uploadedUrl || "", priority: s.priority }))
        .filter((s) => s.url);
      const res = await fetch("/api/agent/analyze-drawing", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          imageUrls: [imageUrl],
          projectId: projectId || undefined,
          scale: "auto-from-working-scale",
          userSelections: symbolContext.map((s) => ({
            elementType: `library-symbol:${s.name}`,
            notes: `priority:${s.priority}|url:${s.url}`,
            floorIndex: "0",
            floorName: "Plan",
            centerX: 50,
            centerY: 50,
          })),
        }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || err.message || "Re-scan failed");
      }
      showStatus("Re-scan submitted with symbol library context.");
    } catch (error) {
      console.error("[DrawingAnalyzer] re-scan failed", error);
      showStatus(error?.message || "Re-scan failed", true);
    }
  }

  async function renderPdfFirstPage(file) {
    if (!window.pdfjsLib) throw new Error("PDF engine not loaded yet. Try again in a moment.");
    const data = new Uint8Array(await file.arrayBuffer());
    const pdf = await window.pdfjsLib.getDocument({ data }).promise;
    const page = await pdf.getPage(1);
    const viewport = page.getViewport({ scale: 2.2 });
    const canvas = document.createElement("canvas");
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    const ctx = canvas.getContext("2d");
    await page.render({ canvasContext: ctx, viewport }).promise;
    return canvas.toDataURL("image/png");
  }

  async function handleFile(file) {
    if (!file || !imgEl || !stage || !toolbar) return;
    clearStatus();
    const type = file.type || "";
    const isPdf = type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf");
    const isImage = type.startsWith("image/");
    if (!isPdf && !isImage) {
      showStatus("Unsupported file type. Use PDF or image.", true);
      return;
    }

    try {
      let src = "";
      if (isPdf) {
        showStatus("Rendering PDF preview (page 1)...");
        src = await renderPdfFirstPage(file);
      } else {
        src = URL.createObjectURL(file);
      }

      imgEl.onload = () => {
        // Show first, then measure. Hidden containers report 0x0.
        stage.classList.remove("hidden");
        stage.classList.add("flex");
        toolbar.classList.remove("hidden");
        toolbar.classList.add("flex");
        calibrationEl?.classList.remove("hidden");
        calibrationEl?.classList.add("grid");
        requestAnimationFrame(() => {
          setOverlaySizeFromImage();
          setFullViableArea();
          fullImageNaturalWidth = imgEl.naturalWidth || 0;
          latestViableWidthPx = fullImageNaturalWidth;
          updateWorkingScale();
          runScaleOcr("full");
        });
        clearStatus();
      };
      imgEl.src = src;
    } catch (error) {
      console.error("[DrawingAnalyzer] failed to render file", error);
      showStatus(error?.message || "Could not render file.", true);
    }
  }

  function getOverlayPoint(clientX, clientY) {
    if (!overlay) return null;
    const rect = overlay.getBoundingClientRect();
    const ratioX = overlay.clientWidth / (rect.width || 1);
    const ratioY = overlay.clientHeight / (rect.height || 1);
    return {
      x: clamp((clientX - rect.left) * ratioX, 0, overlay.clientWidth),
      y: clamp((clientY - rect.top) * ratioY, 0, overlay.clientHeight),
    };
  }

  overlay?.addEventListener("pointerdown", (e) => {
    if (!overlay) return;
    const p = getOverlayPoint(e.clientX, e.clientY);
    if (!p) return;
    pointerStart = p;
    overlay.setPointerCapture(e.pointerId);
  });

  overlay?.addEventListener("pointermove", (e) => {
    if (!pointerStart || !overlay) return;
    const p = getOverlayPoint(e.clientX, e.clientY);
    if (!p) return;
    const left = Math.min(pointerStart.x, p.x);
    const top = Math.min(pointerStart.y, p.y);
    const width = Math.abs(p.x - pointerStart.x);
    const height = Math.abs(p.y - pointerStart.y);
    viableArea = { left, top, width, height };
    if (viableRect) viableRect.style.borderRadius = selectionShape === "circle" ? "9999px" : "0";
    updateMask(viableArea);
    latestViableWidthPx = getViableWidthNaturalPx();
    updateWorkingScale();
  });

  overlay?.addEventListener("pointerup", (e) => {
    if (!overlay || !viableArea) return;
    const ctx = TraceLog.start("drawingAnalyzer.overlay.pointerup", {
      width: viableArea.width,
      height: viableArea.height,
      selectionPurpose,
      selectionShape,
    });
    overlay.releasePointerCapture(e.pointerId);
    if (viableArea.width < 8 || viableArea.height < 8) {
      setFullViableArea();
      TraceLog.end(ctx, { action: "reset-full-viable-area", reason: "selection-too-small" });
    } else {
      updateReadout();
      if (selectionPurpose === "symbol") {
        captureSymbolFromSelection();
        TraceLog.end(ctx, { action: "capture-symbol" });
      } else {
        TraceLog.end(ctx, { action: "selection-no-capture", selectionPurpose });
      }
      // Viable-area focus is intentionally disabled for now.
      // if (selectionPurpose === "viable") focusViableArea();
    }
    pointerStart = null;
  });

  resetBtn?.addEventListener("click", () => setFullViableArea());

  clearBtn?.addEventListener("click", () => {
    if (!imgEl || !stage || !toolbar || !fileInput) return;
    imgEl.src = "";
    fileInput.value = "";
    stage.classList.add("hidden");
    stage.classList.remove("flex");
    toolbar.classList.add("hidden");
    toolbar.classList.remove("flex");
    pointerStart = null;
    viableArea = null;
    fullImageNaturalWidth = 0;
    latestViableWidthPx = 0;
    if (fullScaleInput) fullScaleInput.value = "";
    if (viableScaleInput) viableScaleInput.value = "";
    if (fullWidthPxInput) fullWidthPxInput.value = "";
    if (viableWidthPxInput) viableWidthPxInput.value = "";
    if (workingScaleInput) workingScaleInput.value = "";
    calibrationEl?.classList.add("hidden");
    calibrationEl?.classList.remove("grid");
    selectionPurpose = "symbol";
    selectionShape = "square";
    if (selectionPurposeSelect) selectionPurposeSelect.value = "symbol";
    if (selectionShapeSelect) selectionShapeSelect.value = "square";
    setZoom(1);
    clearStatus();
  });

  dropzone?.addEventListener("click", () => fileInput?.click());
  dropzone?.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropzone.classList.add("border-primary-500", "bg-primary-50/50");
  });
  dropzone?.addEventListener("dragleave", () => {
    dropzone.classList.remove("border-primary-500", "bg-primary-50/50");
  });
  dropzone?.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("border-primary-500", "bg-primary-50/50");
    const file = e.dataTransfer?.files?.[0];
    if (file) handleFile(file);
  });
  fileInput?.addEventListener("change", (e) => {
    const target = e.target;
    const file = target?.files?.[0];
    if (file) handleFile(file);
    target.value = "";
  });

  assumedWidthInput?.addEventListener("input", () => {
    updateWorkingScale();
  });

  selectionPurposeSelect?.addEventListener("change", () => {
    selectionPurpose = "symbol";
    selectionPurposeSelect.value = "symbol";
  });

  selectionShapeSelect?.addEventListener("change", () => {
    selectionShape = selectionShapeSelect.value === "circle" ? "circle" : "square";
    if (viableRect) viableRect.style.borderRadius = selectionShape === "circle" ? "9999px" : "0";
  });

  enableSymbolCaptureBtn?.addEventListener("click", () => {
    selectionPurpose = "symbol";
    selectionShape = "square";
    if (selectionPurposeSelect) selectionPurposeSelect.value = "symbol";
    if (selectionShapeSelect) selectionShapeSelect.value = "square";
    if (viableRect) viableRect.style.borderRadius = "0";
    window.switchDrawingAnalyzerTab("drawing-workspace-content");
    showStatus("Symbol capture enabled. Draw around the symbol in workspace.");
  });

  zoomOutBtn?.addEventListener("click", () => setZoom(zoomLevel - 0.1));
  zoomInBtn?.addEventListener("click", () => setZoom(zoomLevel + 0.1));
  zoomResetBtn?.addEventListener("click", () => setZoom(1));
  zoomRange?.addEventListener("input", () => {
    const pct = parseInt(zoomRange.value || "100", 10);
    setZoom(pct / 100);
  });

  rescanLibrarySymbolsBtn?.addEventListener("click", () => {
    rescanForLibrarySymbols();
  });

  window.addEventListener("resize", () => {
    if (!imgEl?.src) return;
    setOverlaySizeFromImage();
    if (!viableArea) setFullViableArea();
    else updateMask(viableArea);
    updateReadout();
    latestViableWidthPx = getViableWidthNaturalPx();
    updateWorkingScale();
  });

  setZoom(1);
  TraceLog.initForEnvironment({ isDev: import.meta.env.DEV });
  loadLibraryItems();
</script>
