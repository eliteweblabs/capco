---
/**
 * Fire Protection Drawing Analyzer (PdfExtractor-like flow)
 *
 * 1. Upload document (PDF or image)
 * 2. Drawing is displayed; user selects what to look for (element type)
 * 3. User clicks and drags on the drawing to select regions
 * 4. Each selection (region + element type) is added to a list
 * 5. User clicks "Analyze" to send image + selections to AI agent
 * 6. AI uses user selections to inform analysis of pipe lengths, sprinklers, etc.
 */
import { globalClasses } from "../../pages/api/global/global-classes";
import SimpleIcon from "../../components/common/SimpleIcon.astro";

const { globalCardStyle, globalTextH3, globalSectionHeaderBar, globalFormLabel } = globalClasses();

export interface Props {
  projectId?: number;
}
const { projectId } = Astro.props;
---

<div
  class="drawing-analyzer rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800"
>
  <div class={globalSectionHeaderBar}>
    <h2 class={globalTextH3}>Drawing Analyzer</h2>
  </div>
  <p class="mb-4 text-sm text-gray-600 dark:text-gray-400">
    Upload a drawing, then <strong>select examples</strong> on the drawing (choose element type, click
    and drag to mark regions). Those selections teach the AI what to look for. Click &quot;Analyze drawing&quot;
    and the AI finds all similar instances and calculates counts/lengths into the form.
  </p>

  <!-- Editable Scale -->
  <div class="mb-4">
    <label for="drawing-scale" class={globalFormLabel}>Drawing Scale</label>
    <input
      id="drawing-scale"
      type="text"
      placeholder='e.g. 1" = 10&apos;-0" or 1:100'
      value='1" = 10&apos;-0"'
      class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white"
      maxlength="80"
    />
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
      Enter the scale shown on the drawing so lengths are converted to real-world units. Add general
      guidance at
      <a href="/ai-agent/knowledge" class="text-primary-600 hover:underline dark:text-primary-400"
        >AI Agent › Knowledge</a
      >
      (category: drawing_analysis).
    </p>
  </div>

  <!-- Dropzone (hidden after upload) -->
  <div
    id="drawing-dropzone-container"
    class="mb-6 flex cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 p-8 transition-colors hover:border-primary-400 hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-900 dark:hover:border-primary-500"
  >
    <SimpleIcon name="image" class="mb-3 h-12 w-12 text-gray-400" />
    <p class="mb-1 font-medium text-gray-700 dark:text-gray-300">
      Drop PDF or image here, or click to browse
    </p>
    <p class="text-xs text-gray-500 dark:text-gray-400">PDF, PNG, JPG, GIF, WebP (max 10MB)</p>
    <input
      id="drawing-file-input"
      type="file"
      accept=".pdf,image/png,image/jpeg,image/jpg,image/gif,image/webp"
      class="hidden"
    />
  </div>

  <!-- Guided interface + viewer (shown after upload, like PdfExtractor) -->
  <div id="drawing-viewer-section" class="mb-6 hidden">
    <div
      id="drawing-guided-interface"
      class="bg-primary-50/30 dark:bg-primary-900/20 mb-4 rounded-lg border border-primary-200 p-4 dark:border-primary-800"
    >
      <div class="flex flex-wrap items-end gap-3">
        <div class="min-w-[200px] flex-1">
          <label for="drawing-element-type" class={globalFormLabel}>What element to identify?</label
          >
          <select
            id="drawing-element-type"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white"
          >
            <option value="">Choose before selecting on drawing...</option>
            <optgroup label="Pipe">
              <option value='pipe-2"'>Pipe 2&quot;</option>
              <option value='pipe-1-1/2"'>Pipe 1-1/2&quot;</option>
              <option value='pipe-1"'>Pipe 1&quot;</option>
              <option value="pipe-other">Pipe (other)</option>
            </optgroup>
            <option value="sprinkler">Sprinkler head</option>
            <option value="smoke">Smoke alarm</option>
            <option value="pull">Pull station</option>
            <option value="fdc">FDC (Fire Dept connection)</option>
            <option value="horn">Horn/strobe</option>
            <option value="other">Other (describe in notes)</option>
          </select>
        </div>
        <input
          id="drawing-element-notes"
          type="text"
          placeholder="Notes (e.g. length)"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
          maxlength="120"
        />
      </div>
      <p class="mt-2 text-xs text-primary-800 dark:text-primary-300">
        <strong>Select element type above</strong>, then click and drag on the drawing below to mark
        the region. Add as many as you like, then click &quot;Analyze drawing&quot;.
      </p>
    </div>

    <div
      id="drawing-selections-list"
      class="mb-3 max-h-32 min-h-0 overflow-y-auto rounded border border-gray-200 bg-gray-50 p-2 text-sm dark:border-gray-700 dark:bg-gray-900"
    >
      <p class="text-gray-500 dark:text-gray-400">No selections yet. Add regions above.</p>
    </div>

    <div class="mb-4 flex flex-wrap items-center gap-2">
      <button
        type="button"
        id="drawing-analyze-btn"
        class="rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700"
      >
        Analyze drawing
      </button>
      <button
        type="button"
        id="drawing-close-viewer-btn"
        class="rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
      >
        Remove and start over
      </button>
    </div>

    <div
      id="drawing-viewer-content"
      class="space-y-4 rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800"
    >
      <!-- Drawing wrappers with overlays inserted here after upload -->
    </div>
    <div
      id="drawing-selection-hint"
      class="drawing-selection-hint dark:bg-primary-900/20 mt-2 hidden rounded border border-primary-200 bg-primary-50 p-2 text-sm text-primary-800 dark:border-primary-800 dark:text-primary-300"
    >
      <strong>Selection mode:</strong> Click and drag on the drawing above to mark regions.
    </div>
  </div>

  <!-- Status -->
  <div
    id="drawing-status"
    class="mb-4 hidden rounded-lg border border-gray-200 bg-gray-50 p-3 text-sm dark:border-gray-700 dark:bg-gray-900"
  >
    <span id="drawing-status-text"></span>
  </div>

  <!-- Results -->
  <div id="drawing-results" class="hidden">
    <div class="mb-3 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Analysis Results</h3>
      <button
        type="button"
        id="drawing-new-btn"
        class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
      >
        New drawing
      </button>
    </div>

    <!-- Editable form: focus an input to enable selection, then click+drag on drawing to extract -->
    <div
      id="drawing-editable-form"
      class="mb-6 rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900"
    >
      <h4 class="mb-3 text-sm font-semibold text-gray-900 dark:text-white">
        Extracted values (edit directly or click a field, then select region on drawing to
        re-extract)
      </h4>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <label class="block">
          <span class={globalFormLabel}>Pipe 2&quot; (ft)</span>
          <input
            type="text"
            id="drawing-field-pipe-2"
            data-field-type='pipe-2"'
            class="drawing-field-input w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            placeholder="—"
          />
        </label>
        <label class="block">
          <span class={globalFormLabel}>Pipe 1-1/2&quot; (ft)</span>
          <input
            type="text"
            id="drawing-field-pipe-1-1-2"
            data-field-type='pipe-1-1/2"'
            class="drawing-field-input w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            placeholder="—"
          />
        </label>
        <label class="block">
          <span class={globalFormLabel}>Pipe 1&quot; (ft)</span>
          <input
            type="text"
            id="drawing-field-pipe-1"
            data-field-type='pipe-1"'
            class="drawing-field-input w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            placeholder="—"
          />
        </label>
        <label class="block">
          <span class={globalFormLabel}>Sprinkler count</span>
          <input
            type="text"
            id="drawing-field-sprinkler"
            data-field-type="sprinkler"
            class="drawing-field-input w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            placeholder="—"
          />
        </label>
        <label class="block">
          <span class={globalFormLabel}>Smoke alarm count</span>
          <input
            type="text"
            id="drawing-field-smoke"
            data-field-type="smoke"
            class="drawing-field-input w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            placeholder="—"
          />
        </label>
      </div>
      <div
        id="drawing-form-selection-hint"
        class="dark:bg-primary-900/20 mt-3 hidden rounded border border-primary-200 bg-primary-50 p-2 text-sm text-primary-800 dark:border-primary-800 dark:text-primary-300"
      >
        <strong>Selection mode:</strong> Click and drag on the drawing below to extract the value for
        the focused field.
      </div>
    </div>

    <div id="drawing-results-content" class="space-y-4"></div>

    <!-- Correct by selection: human-in-the-loop -->
    <div
      id="drawing-selection-correction"
      class="bg-primary-50/30 dark:bg-primary-900/20 mt-6 rounded-lg border border-primary-200 p-4 dark:border-primary-800"
    >
      <h4 class="mb-2 text-sm font-semibold text-primary-900 dark:text-primary-200">
        Correct the AI by selecting on the drawing
      </h4>
      <p class="mb-3 text-xs text-primary-800 dark:text-primary-300">
        If the schematic shows elements that don&apos;t exist, or is missing something,
        <strong>click and drag</strong> on the original drawing above to select the area, then choose
        what it is below.
      </p>
      <button
        type="button"
        id="drawing-selection-toggle"
        class="dark:bg-primary-900/40 dark:hover:bg-primary-900/60 rounded-md border border-primary-500 bg-white px-3 py-1.5 text-sm font-medium text-primary-700 transition-colors hover:bg-primary-100 dark:border-primary-600 dark:text-primary-200"
      >
        Cancel selection
      </button>
      <div
        id="drawing-selection-form"
        class="mt-4 hidden rounded border border-gray-200 bg-white p-3 dark:border-gray-600 dark:bg-gray-800"
      >
        <p class="mb-2 text-sm font-medium text-gray-700 dark:text-gray-300">
          What did you select?
        </p>
        <div class="flex flex-wrap gap-2">
          <select
            id="correction-element-type"
            class="rounded border border-gray-300 px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
          >
            <option value="">Choose element type...</option>
            <optgroup label="Pipe">
              <option value='pipe-2"'>Pipe 2&quot;</option>
              <option value='pipe-1-1/2"'>Pipe 1-1/2&quot;</option>
              <option value='pipe-1"'>Pipe 1&quot;</option>
              <option value="pipe-other">Pipe (other)</option>
            </optgroup>
            <option value="sprinkler">Sprinkler head</option>
            <option value="smoke">Smoke alarm</option>
            <option value="pull">Pull station</option>
            <option value="fdc">FDC (Fire Dept connection)</option>
            <option value="horn">Horn/strobe</option>
            <option value="other">Other (describe below)</option>
            <option value="ignore">Not an element — AI should ignore this</option>
          </select>
          <input
            id="correction-element-notes"
            type="text"
            placeholder="Notes (e.g. length, spec)"
            class="rounded border border-gray-300 px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            maxlength="120"
          />
        </div>
        <div class="mt-2 flex items-center gap-2">
          <button
            type="button"
            id="correction-selection-submit"
            class="rounded-md bg-primary-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-primary-700"
          >
            Save correction
          </button>
          <button
            type="button"
            id="correction-selection-cancel"
            class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
          >
            Cancel
          </button>
          <span id="correction-selection-status" class="text-sm text-gray-500"></span>
        </div>
      </div>
    </div>

    <!-- Help the AI learn (text) -->
    <details
      class="mt-6 rounded-lg border border-gray-200 dark:border-gray-700"
      id="drawing-correction-details"
    >
      <summary
        class="cursor-pointer px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-800"
      >
        Help the AI learn — submit a correction
      </summary>
      <div class="border-t border-gray-200 p-4 dark:border-gray-700">
        <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">
          If the analysis was wrong, describe the correction. It will be saved to the AI knowledge
          base and used in future runs.
        </p>
        <input
          id="correction-title"
          type="text"
          placeholder="Title (e.g. Pipe length correction for scale 1&quot;=10')"
          class="mb-2 w-full rounded-md border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
        />
        <textarea
          id="correction-content"
          rows="3"
          placeholder='e.g. For drawings at 1" = 10&apos;-0", the 2" main feed is 45 ft (labeled 4.5" on the drawing), not 20 ft.'
          class="mb-2 w-full rounded-md border border-gray-300 px-3 py-2 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white"
        ></textarea>
        <button
          type="button"
          id="correction-submit"
          class="rounded-md bg-primary-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-primary-700"
        >
          Save to knowledge base
        </button>
        <span id="correction-status" class="ml-2 text-sm"></span>
      </div>
    </details>
  </div>
</div>

<style>
  .drawing-original-wrapper.selection-active {
    box-shadow: 0 0 0 2px #825bdd;
  }
  .dark .drawing-original-wrapper.selection-active {
    box-shadow: 0 0 0 2px #a78bfa;
  }
  .drawing-original-wrapper.selection-active .drawing-selection-overlay {
    pointer-events: auto;
    cursor: crosshair;
    z-index: 10;
  }
  .drawing-selection-overlay {
    z-index: 5;
    background: transparent !important;
    /* Fully transparent so the drawing stays visible; overlay only captures pointer events */
  }
  .drawing-selection-rect {
    position: absolute;
    border: 2px solid rgb(var(--color-primary-500, 130 91 221));
    background: rgba(130, 91, 221, 0.2);
    pointer-events: none;
  }
</style>
<script src="/js/pdf.min.js" defer></script>
<script define:vars={{ projectId: projectId ?? null }}>
  const dropzoneContainer = document.getElementById("drawing-dropzone-container");
  const dropzone = dropzoneContainer; // Entire area is clickable
  const fileInput = document.getElementById("drawing-file-input");
  const viewerSection = document.getElementById("drawing-viewer-section");
  const viewerContent = document.getElementById("drawing-viewer-content");
  const selectionsListEl = document.getElementById("drawing-selections-list");
  const guidedElementType = document.getElementById("drawing-element-type");
  const guidedElementNotes = document.getElementById("drawing-element-notes");

  /** User selections: { floorIndex, floorName, elementType, notes, region: { left, top, width, height }, centerX, centerY } */
  let userSelections = [];
  /** Image URLs from current upload (for Analyze button) */
  let currentImageUrls = [];
  const statusEl = document.getElementById("drawing-status");
  const statusText = document.getElementById("drawing-status-text");
  const resultsEl = document.getElementById("drawing-results");
  const resultsContent = document.getElementById("drawing-results-content");

  function showStatus(text, type = "info") {
    if (!statusEl || !statusText) return;
    statusEl.classList.remove("hidden");
    statusEl.className = "mb-4 rounded-lg border p-3 text-sm";
    if (type === "error") {
      statusEl.classList.add(
        "border-red-200",
        "bg-red-50",
        "text-red-800",
        "dark:border-red-800",
        "dark:bg-red-900/20",
        "dark:text-red-200"
      );
    } else if (type === "success") {
      statusEl.classList.add(
        "border-green-200",
        "bg-green-50",
        "text-green-800",
        "dark:border-green-800",
        "dark:bg-green-900/20",
        "dark:text-green-200"
      );
    } else {
      statusEl.classList.add(
        "border-gray-200",
        "bg-gray-50",
        "text-gray-700",
        "dark:border-gray-700",
        "dark:bg-gray-900",
        "dark:text-gray-300"
      );
    }
    statusText.textContent = text;
  }

  function hideStatus() {
    statusEl?.classList.add("hidden");
  }

  function renderSelectionsList() {
    if (!selectionsListEl) return;
    if (userSelections.length === 0) {
      selectionsListEl.innerHTML =
        '<p class="text-gray-500 dark:text-gray-400">No selections yet. Add regions above.</p>';
      return;
    }
    selectionsListEl.innerHTML = userSelections
      .map(
        (s, i) =>
          `<div class="flex items-center justify-between gap-2 py-1 border-b border-gray-200 dark:border-gray-700 last:border-0">
            <span class="text-gray-700 dark:text-gray-300">${esc(s.elementType)}${s.notes ? " — " + esc(s.notes) : ""} (${s.floorName})</span>
            <button type="button" class="drawing-remove-selection text-red-600 hover:text-red-700 text-xs" data-index="${i}">Remove</button>
          </div>`
      )
      .join("");
    selectionsListEl.querySelectorAll(".drawing-remove-selection").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = parseInt(btn.getAttribute("data-index") || "0", 10);
        userSelections.splice(idx, 1);
        renderSelectionsList();
      });
    });
  }

  function setupOverlayListeners(overlay, wrapper) {
    if (!overlay) return;
    overlay.addEventListener(
      "mousedown",
      (e) => {
        if (!selectionMode) return;
        e.preventDefault();
        e.stopPropagation();
        const rect = overlay.getBoundingClientRect();
        selectionStart = { x: e.clientX - rect.left, y: e.clientY - rect.top };
        selectionWrapper = wrapper;
        selectionRectEl = document.createElement("div");
        selectionRectEl.className = "drawing-selection-rect";
        selectionRectEl.style.left = selectionStart.x + "px";
        selectionRectEl.style.top = selectionStart.y + "px";
        selectionRectEl.style.width = "0";
        selectionRectEl.style.height = "0";
        overlay.appendChild(selectionRectEl);
      },
      { capture: true }
    );
  }

  function showViewer(imageUrls = []) {
    if (!viewerSection || !viewerContent) return;
    userSelections = [];
    renderSelectionsList();
    viewerContent.innerHTML = "";
    imageUrls.forEach((url, idx) => {
      const floorName = imageUrls.length > 1 ? `Page ${idx + 1}` : "Plan";
      const wrapper = document.createElement("div");
      wrapper.className =
        "drawing-original-wrapper relative my-4 overflow-hidden rounded-lg border border-gray-200 bg-white dark:border-gray-600 dark:bg-gray-900";
      wrapper.dataset.imageUrl = url;
      wrapper.dataset.floorIndex = String(idx);
      wrapper.dataset.floorName = floorName;

      const img = document.createElement("img");
      img.src = url;
      img.alt = `Drawing - ${floorName}`;
      img.className = "max-h-96 w-full object-contain select-none";
      img.draggable = false;

      const overlay = document.createElement("div");
      overlay.className = "drawing-selection-overlay absolute inset-0 z-10 cursor-crosshair";
      overlay.style.pointerEvents = "auto";
      overlay.style.background = "transparent";
      overlay.setAttribute("aria-hidden", "true");

      wrapper.appendChild(img);
      wrapper.appendChild(overlay);
      viewerContent.appendChild(wrapper);

      setupOverlayListeners(overlay, wrapper);
    });

    dropzoneContainer?.classList.add("hidden");
    viewerSection?.classList.remove("hidden");
    selectionMode = true;
    document
      .querySelectorAll(".drawing-original-wrapper")
      .forEach((w) => w.classList.add("selection-active"));
    document.getElementById("drawing-selection-hint")?.classList.remove("hidden");

    // Show form immediately (empty until Analyze runs)
    if (resultsEl) {
      resultsEl.classList.remove("hidden");
      if (resultsContent) {
        resultsContent.innerHTML =
          '<p class="rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-800 dark:border-blue-800 dark:bg-blue-900/20 dark:text-blue-200">Click &quot;Analyze drawing&quot; above to extract values into the form.</p>';
      }
    }
  }

  function extractValuesFromParsed(parsed) {
    if (!parsed) return {};
    const floors = normalizeFloors(parsed);
    const sumPipeLength = (match) => {
      let total = 0;
      floors.forEach((f) => {
        (f.pipeSegments || []).forEach((p) => {
          const d = String(p.diameter || "");
          if (match(d)) {
            const m = String(p.length || "").match(/[\d.]+/);
            if (m) total += parseFloat(m);
          }
        });
      });
      return total ? `${total} ft` : "";
    };
    const pipe2 = sumPipeLength((d) => d.includes("2") && !d.includes("1/2"));
    const pipe112 = sumPipeLength((d) => d.includes("1-1/2") || d.includes("1½"));
    const pipe1 = sumPipeLength(
      (d) => d.includes('1"') && !d.includes("1-1/2") && !d.includes("1½")
    );
    let sprinkler = 0;
    let smoke = 0;
    floors.forEach((f) => {
      sprinkler += f.sprinklerHeads?.count ?? f.sprinklerHeads?.positions?.length ?? 0;
      smoke += f.smokeAlarms?.count ?? f.smokeAlarms?.positions?.length ?? 0;
    });
    return {
      'pipe-2"': pipe2,
      'pipe-1-1/2"': pipe112,
      'pipe-1"': pipe1,
      sprinkler: sprinkler ? String(sprinkler) : "",
      smoke: smoke ? String(smoke) : "",
    };
  }

  function populateExtractedForm(parsed) {
    const vals = extractValuesFromParsed(parsed);
    document.querySelectorAll(".drawing-field-input").forEach((el) => {
      const ft = el.dataset.fieldType;
      if (ft && vals[ft] !== undefined) el.value = vals[ft] || "";
    });
  }

  function showResults(html, imageUrls = [], parsed = null) {
    if (!resultsEl || !resultsContent) return;
    resultsContent.innerHTML = html;
    resultsEl.classList.remove("hidden");
    if (parsed) populateExtractedForm(parsed);
    selectionMode = true;
    const wrappers = document.querySelectorAll(".drawing-original-wrapper");
    wrappers.forEach((w) => {
      w.classList.add("selection-active");
      const overlay = w.querySelector(".drawing-selection-overlay");
      if (overlay) {
        overlay.style.pointerEvents = "auto";
        setupOverlayListeners(overlay, w);
      }
    });
    document.getElementById("drawing-selection-hint")?.classList.remove("hidden");
    const toggleBtn = document.getElementById("drawing-selection-toggle");
    if (toggleBtn) toggleBtn.textContent = "Cancel selection";
  }

  function ensurePdfJs() {
    return new Promise((resolve) => {
      if (typeof window !== "undefined" && window.pdfjsLib) {
        resolve(window.pdfjsLib);
        return;
      }
      const script = document.createElement("script");
      script.src = "/js/pdf.min.js";
      script.onload = () => {
        setTimeout(() => resolve(window.pdfjsLib), 100);
      };
      document.head.appendChild(script);
    });
  }

  async function pdfPagesToBlobs(file) {
    const pdfjsLib = await ensurePdfJs();
    const arrayBuffer = await file.arrayBuffer();
    const typedarray = new Uint8Array(arrayBuffer);
    const pdf = await pdfjsLib.getDocument({ data: typedarray }).promise;
    const numPages = pdf.numPages;
    const blobs = [];

    for (let i = 1; i <= numPages; i++) {
      const page = await pdf.getPage(i);
      const viewport = page.getViewport({ scale: 2.0 });
      const canvas = document.createElement("canvas");
      const ctx = canvas.getContext("2d");
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      await page.render({ canvasContext: ctx, viewport }).promise;
      const blob = await new Promise((res) => canvas.toBlob(res, "image/png"));
      blobs.push(blob);
    }
    return blobs;
  }

  async function uploadImage(blob, name) {
    const file = new File([blob], name, { type: "image/png" });
    const formData = new FormData();
    formData.append("file", file);
    formData.append("folder", "drawing-analyzer");

    const res = await fetch("/api/agent/upload-image", {
      method: "POST",
      credentials: "include",
      body: formData,
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.error || err.message || "Upload failed");
    }
    const data = await res.json();
    return data.url || data.publicUrl;
  }

  function esc(s) {
    if (s == null) return "";
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function normalizeFloors(parsed) {
    if (!parsed) return [];
    const floors = parsed.floors;
    if (Array.isArray(floors) && floors.length > 0) return floors;
    return [
      {
        name: "Plan",
        pageIndex: 0,
        pipeSegments: parsed.pipeSegments || [],
        sprinklerHeads: parsed.sprinklerHeads || { count: 0, locations: [] },
        smokeAlarms: parsed.smokeAlarms || { count: 0, locations: [] },
        otherEquipment: parsed.otherEquipment || [],
      },
    ];
  }

  const PIPE_COLORS = ["#dc2626", "#ea580c", "#2563eb", "#059669", "#7c3aed"];
  const SPRINKLER_COLOR = "#059669";
  const SMOKE_COLOR = "#7c3aed";
  const OTHER_COLOR = "#6b7280";

  function hasPositions(floor) {
    const pipes = floor.pipeSegments || [];
    const hasPipePaths = pipes.some((p) => Array.isArray(p.path) && p.path.length >= 2);
    const sprinklerPos = floor.sprinklerHeads?.positions;
    const smokePos = floor.smokeAlarms?.positions;
    const otherPos = floor.otherEquipment?.some(
      (e) => Array.isArray(e.positions) && e.positions.length > 0
    );
    return (
      hasPipePaths ||
      (Array.isArray(sprinklerPos) && sprinklerPos.length > 0) ||
      (Array.isArray(smokePos) && smokePos.length > 0) ||
      otherPos
    );
  }

  function strokeWidthForDiameter(d) {
    const s = String(d || "");
    if (s.indexOf("2") >= 0 && s.indexOf("1/2") < 0) return 3;
    if (s.indexOf("1") >= 0) return 2;
    return 2.5;
  }

  function renderFloorSvg(floor) {
    const pipes = floor.pipeSegments || [];
    const sprinklers = floor.sprinklerHeads || {};
    const smoke = floor.smokeAlarms || {};
    const other = floor.otherEquipment || [];
    const sprinklerCount =
      sprinklers.count ?? sprinklers.locations?.length ?? sprinklers.positions?.length ?? 0;
    const smokeCount = smoke.count ?? smoke.locations?.length ?? smoke.positions?.length ?? 0;

    const aspectRatio = Math.max(0.5, Math.min(3, Number(floor.aspectRatio) || 1.4));
    const vbW = 100;
    const vbH = 100;

    if (!hasPositions(floor)) {
      return renderFloorSvgFallback(floor);
    }

    let schematicParts = "";

    pipes.forEach((p, i) => {
      const path = p.path;
      if (!Array.isArray(path) || path.length < 2) return;
      const color = PIPE_COLORS[i % PIPE_COLORS.length];
      const strokeW = strokeWidthForDiameter(p.diameter);
      const tip = `${esc(p.diameter)} — ${esc(p.length)}${p.notes ? " (" + esc(p.notes) + ")" : ""}`;
      const d = path.map((pt, idx) => (idx === 0 ? "M" : "L") + pt[0] + "," + pt[1]).join(" ");
      schematicParts += `<path d="${d}" fill="none" stroke="${color}" stroke-width="${strokeW}" stroke-linecap="round" stroke-linejoin="round" cursor="help" title="${tip}"/>`;
    });

    const sprinklerPositions = sprinklers.positions || [];
    sprinklerPositions.forEach((pt, idx) => {
      const tip =
        sprinklerPositions.length > 1
          ? `Sprinkler ${idx + 1} of ${sprinklerPositions.length}`
          : "Sprinkler head";
      const x = pt[0];
      const y = pt[1];
      schematicParts += `<g cursor="help" title="${tip}" transform="translate(${x},${y})"><circle r="2.5" fill="none" stroke="${SPRINKLER_COLOR}" stroke-width="1"/><path d="M-2.5 0 L2.5 0 M0 -2.5 L0 2.5" stroke="${SPRINKLER_COLOR}" stroke-width="0.8"/></g>`;
    });

    const smokePositions = smoke.positions || [];
    smokePositions.forEach((pt, idx) => {
      const tip =
        smokePositions.length > 1
          ? `Smoke alarm ${idx + 1} of ${smokePositions.length}`
          : "Smoke alarm";
      const x = pt[0];
      const y = pt[1];
      schematicParts += `<g cursor="help" title="${tip}" transform="translate(${x},${y})"><rect x="-2" y="-1.5" width="4" height="3" rx="0.3" fill="none" stroke="${SMOKE_COLOR}" stroke-width="0.8"/></g>`;
    });

    other.forEach((e) => {
      const positions = e.positions || [];
      const cnt = e.count ?? 1;
      positions.forEach((pt, idx) => {
        const tip = `${esc(e.type)}${positions.length > 1 ? ` ${idx + 1} of ${positions.length}` : ""}${e.notes ? " — " + esc(e.notes) : ""}`;
        const x = pt[0];
        const y = pt[1];
        schematicParts += `<g cursor="help" title="${tip}" transform="translate(${x},${y})"><rect x="-1.5" y="-1.5" width="3" height="3" rx="0.3" fill="${OTHER_COLOR}"/></g>`;
      });
    });

    const truncate = (s, maxLen = 18) => {
      const str = String(s || "").trim();
      return str.length <= maxLen ? str : str.slice(0, maxLen) + "…";
    };
    const legendFontSize = 2.8;
    const legendDy = 3.5;
    const legendItems = [];
    pipes.forEach((p, i) => {
      const color = PIPE_COLORS[i % PIPE_COLORS.length];
      const tip = `${esc(p.diameter)} — ${esc(p.length)}${p.notes ? " (" + esc(p.notes) + ")" : ""}`;
      legendItems.push(
        `<g cursor="help" title="${tip}"><line x1="0" y1="0" x2="8" y2="0" stroke="${color}" stroke-width="1.5" stroke-linecap="round"/><text x="10" y="2.2" font-size="${legendFontSize}" fill="currentColor">${esc(truncate(p.diameter, 12))}</text></g>`
      );
    });
    if (sprinklerCount > 0) {
      legendItems.push(
        `<g cursor="help" title="Sprinkler heads: ${sprinklerCount}"><circle r="1.2" fill="none" stroke="${SPRINKLER_COLOR}" stroke-width="0.6"/><path d="M-1.2 0 L1.2 0 M0 -1.2 L0 1.2" stroke="${SPRINKLER_COLOR}" stroke-width="0.4"/><text x="3" y="2.2" font-size="${legendFontSize}" fill="currentColor">×${sprinklerCount}</text></g>`
      );
    }
    if (smokeCount > 0) {
      legendItems.push(
        `<g cursor="help" title="Smoke alarms: ${smokeCount}"><rect x="-1.4" y="-1" width="2.2" height="1.6" rx="0.25" fill="none" stroke="${SMOKE_COLOR}" stroke-width="0.4"/><text x="1.8" y="1.6" font-size="${legendFontSize}" fill="currentColor">×${smokeCount}</text></g>`
      );
    }
    other.forEach((e) => {
      const cnt = e.count ?? 1;
      const tip = `${esc(e.type)}: ${cnt}${e.notes ? " — " + esc(e.notes) : ""}`;
      const label = truncate(e.type, 14);
      legendItems.push(
        `<g cursor="help" title="${tip}"><rect x="-1" y="-1" width="1.8" height="1.8" rx="0.2" fill="${OTHER_COLOR}"/><text x="2" y="1.6" font-size="${legendFontSize}" fill="currentColor">${esc(label)}</text></g>`
      );
    });

    const legendRows = Math.ceil(legendItems.length / 2);
    const legendTitleHeight = 4;
    const legendHeight = legendTitleHeight + legendRows * legendDy;
    const legendTop = 100 - legendHeight;
    const col1X = 2;
    const col2X = 50;
    const itemsStartY = legendTop + legendTitleHeight;
    let legendSvg = "";
    legendItems.forEach((item, i) => {
      const lx = i % 2 === 0 ? col1X : col2X;
      const row = Math.floor(i / 2);
      const y = itemsStartY + row * legendDy;
      legendSvg += `<g transform="translate(${lx},${y})">${item}</g>`;
    });

    return `<div class="rounded-lg border border-gray-200 bg-gray-50 dark:border-gray-700 dark:bg-gray-900 overflow-hidden">
      <div class="flex items-center justify-between border-b border-gray-200 px-4 py-2 dark:border-gray-700">
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white">${esc(floor.name)}</h4>
      </div>
      <div class="p-4">
        <div class="rounded border border-gray-200 dark:border-gray-600 overflow-hidden bg-white dark:bg-gray-800" style="aspect-ratio: ${aspectRatio}">
          <svg width="100%" height="100%" viewBox="0 0 ${vbW} ${vbH}" class="floor-results-svg text-gray-700 dark:text-gray-300" preserveAspectRatio="xMidYMid meet">
            <rect x="0" y="0" width="100" height="100" fill="#fafafa" class="dark:fill-gray-900"/>
            ${schematicParts}
            <g fill="currentColor" class="text-gray-600 dark:text-gray-400" opacity="0.9">
              <rect x="0" y="${legendTop}" width="98" height="${legendHeight}" rx="2" fill="currentColor" opacity="0.08"/>
              <text x="4" y="${legendTop + 2.5}" font-size="3" font-weight="600">Legend</text>
              ${legendSvg}
            </g>
          </svg>
        </div>
      </div>
    </div>`;
  }

  function renderFloorSvgFallback(floor) {
    const pipes = floor.pipeSegments || [];
    const sprinklers = floor.sprinklerHeads || {};
    const smoke = floor.smokeAlarms || {};
    const other = floor.otherEquipment || [];
    const sprinklerCount = sprinklers.count ?? sprinklers.locations?.length ?? 0;
    const smokeCount = smoke.count ?? smoke.locations?.length ?? 0;
    const noData =
      pipes.length === 0 && sprinklerCount === 0 && smokeCount === 0 && other.length === 0;
    if (noData) return "";
    const msg = "Position data not available. Re-analyze the drawing to generate a schematic view.";
    let list = "";
    if (pipes.length > 0) list += `<li>Pipes: ${pipes.length} segment(s)</li>`;
    if (sprinklerCount > 0) list += `<li>Sprinklers: ${sprinklerCount}</li>`;
    if (smokeCount > 0) list += `<li>Smoke alarms: ${smokeCount}</li>`;
    if (other.length > 0)
      list += `<li>Other: ${other.map((e) => esc(e.type) + " ×" + (e.count ?? 1)).join(", ")}</li>`;
    return `<div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 dark:border-amber-800 dark:bg-amber-900/20"><h4 class="text-sm font-semibold text-amber-800 dark:text-amber-200">${esc(floor.name)}</h4><p class="mt-1 text-sm text-amber-700 dark:text-amber-300">${msg}</p><ul class="mt-2 list-disc list-inside text-sm text-amber-600 dark:text-amber-400">${list}</ul></div>`;
  }

  function renderAnalysis(parsed, scaleUsed, imageUrls = []) {
    if (!parsed) return '<p class="text-gray-500 dark:text-gray-400">Raw response only.</p>';

    const floors = normalizeFloors(parsed);
    let html = "";
    if (scaleUsed) {
      html += `<div class="mb-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-2 text-sm text-blue-800 dark:border-blue-800 dark:bg-blue-900/20 dark:text-blue-200"><strong>Scale used:</strong> ${esc(scaleUsed)}</div>`;
    }
    if (parsed.summary) {
      html += `<div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900"><p class="text-sm font-medium text-gray-700 dark:text-gray-300">Summary</p><p class="mt-1 text-gray-600 dark:text-gray-400">${String(parsed.summary)}</p></div>`;
    }

    const materials = parsed.materials;
    if (Array.isArray(materials) && materials.length > 0) {
      let matHtml =
        '<div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900 mt-4"><p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Materials</p><table class="min-w-full text-sm"><thead><tr class="border-b border-gray-200 dark:border-gray-600"><th class="text-left py-1 pr-3">Type</th><th class="text-left py-1 pr-3">Spec</th><th class="text-left py-1 pr-3">Quantity</th><th class="text-left py-1">Notes</th></tr></thead><tbody>';
      materials.forEach((m) => {
        matHtml += `<tr class="border-b border-gray-100 dark:border-gray-700"><td class="py-1 pr-3">${esc(m.type || "")}</td><td class="py-1 pr-3">${esc(m.spec || "")}</td><td class="py-1 pr-3">${esc(m.quantity || "")}</td><td class="py-1">${esc(m.notes || "")}</td></tr>`;
      });
      matHtml += "</tbody></table></div>";
      html += matHtml;
    }

    floors.forEach((floor, idx) => {
      const imgUrl = imageUrls[idx] || imageUrls[0];
      if (imgUrl) {
        html += `<div class="drawing-original-wrapper relative my-4 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-600" data-image-url="${esc(imgUrl)}" data-floor-index="${idx}" data-floor-name="${esc(floor.name || "Plan")}">
          <img src="${esc(imgUrl)}" alt="Original drawing - ${esc(floor.name || "Plan")}" class="max-h-80 w-full object-contain select-none" draggable="false" />
          <div class="drawing-selection-overlay absolute inset-0 cursor-crosshair pointer-events-none" aria-hidden="true"></div>
        </div>`;
      }
      html += renderFloorSvg(floor);
    });

    if (
      parsed.uncertainties &&
      Array.isArray(parsed.uncertainties) &&
      parsed.uncertainties.length > 0
    ) {
      html += `<div class="rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-900/20 mt-4"><p class="text-sm font-medium text-amber-800 dark:text-amber-200">Uncertainties</p><ul class="mt-1 list-disc list-inside text-sm text-amber-700 dark:text-amber-300">`;
      parsed.uncertainties.forEach((u) => {
        html += `<li>${esc(u)}</li>`;
      });
      html += "</ul></div>";
    }

    return html || '<p class="text-gray-500 dark:text-gray-400">No structured data extracted.</p>';
  }

  async function processFile(file) {
    hideStatus();
    if (resultsEl) resultsEl.classList.add("hidden");

    if (file.size > 10 * 1024 * 1024) {
      showStatus("File too large. Maximum 10MB.", "error");
      return;
    }

    const isPdf = file.type === "application/pdf";
    const isImage = file.type.startsWith("image/");

    if (!isPdf && !isImage) {
      showStatus("Please upload a PDF or image file.", "error");
      return;
    }

    let imageUrls = [];

    try {
      if (isPdf) {
        showStatus("Converting PDF pages to images...");
        const blobs = await pdfPagesToBlobs(file);
        showStatus(`Uploading ${blobs.length} page(s)...`);
        for (let i = 0; i < blobs.length; i++) {
          const url = await uploadImage(blobs[i], `page-${i + 1}.png`);
          imageUrls.push(url);
        }
      } else {
        showStatus("Uploading image...");
        const url = await uploadImage(file, file.name);
        imageUrls.push(url);
      }

      if (imageUrls.length === 0) {
        showStatus("No images to analyze.", "error");
        return;
      }

      showStatus("Drawing ready. Select regions and click Analyze.", "success");
      currentImageUrls = imageUrls;
      showViewer(imageUrls);
    } catch (err) {
      console.error("Drawing analyzer error:", err);
      showStatus(err?.message || "An error occurred", "error");
    }
  }

  async function runAnalysis() {
    if (!currentImageUrls.length) return;
    hideStatus();
    showStatus("Analyzing with AI...");

    const scaleInput = document.getElementById("drawing-scale");
    const scale = scaleInput?.value?.trim() || '1" = 10\'-0"';

    try {
      const res = await fetch("/api/agent/analyze-drawing", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          imageUrls: currentImageUrls,
          projectId: projectId || undefined,
          scale,
          userSelections: userSelections.length > 0 ? userSelections : undefined,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        showStatus(data.error || data.message || "Analysis failed", "error");
        return;
      }

      showStatus("Analysis complete.", "success");
      const parsed = data.analysis?.parsed;
      const raw = data.analysis?.rawResponse;
      const html =
        renderAnalysis(parsed, scale, currentImageUrls) +
        (raw && !parsed
          ? `<details class="mt-4"><summary class="cursor-pointer text-sm text-gray-500">Raw response</summary><pre class="mt-2 overflow-x-auto rounded bg-gray-100 p-3 text-xs dark:bg-gray-800">${raw.replace(/</g, "&lt;")}</pre></details>`
          : "");
      showResults(html, currentImageUrls, parsed);
      viewerSection?.classList.add("hidden");
    } catch (err) {
      console.error("Drawing analyzer error:", err);
      showStatus(err?.message || "An error occurred", "error");
    }
  }

  document.getElementById("drawing-analyze-btn")?.addEventListener("click", runAnalysis);
  document.getElementById("drawing-close-viewer-btn")?.addEventListener("click", () => {
    viewerSection?.classList.add("hidden");
    resultsEl?.classList.add("hidden");
    dropzoneContainer?.classList.remove("hidden");
    currentImageUrls = [];
    userSelections = [];
    document.getElementById("drawing-selection-hint")?.classList.add("hidden");
    document.getElementById("drawing-form-selection-hint")?.classList.add("hidden");
    hideStatus();
  });

  document.getElementById("drawing-new-btn")?.addEventListener("click", () => {
    resultsEl?.classList.add("hidden");
    dropzoneContainer?.classList.remove("hidden");
    currentImageUrls = [];
    userSelections = [];
    document.getElementById("drawing-selection-hint")?.classList.add("hidden");
    hideStatus();
    fileInput.value = "";
  });

  dropzone?.addEventListener("click", () => fileInput?.click());
  fileInput?.addEventListener("change", (e) => {
    const f = e.target?.files?.[0];
    if (f) processFile(f);
    e.target.value = "";
  });

  dropzone?.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropzone.classList.add("border-primary-500", "bg-primary-50/50");
  });
  dropzone?.addEventListener("dragleave", () => {
    dropzone.classList.remove("border-primary-500", "bg-primary-50/50");
  });
  dropzone?.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("border-primary-500", "bg-primary-50/50");
    const f = e.dataTransfer?.files?.[0];
    if (f) processFile(f);
  });

  // Selection mode: correct by selecting region on drawing
  let selectionMode = false;
  let selectionStart = null;
  let selectionRectEl = null;
  let selectionWrapper = null;
  const selectionForm = document.getElementById("drawing-selection-form");
  const selectionStatusEl = document.getElementById("correction-selection-status");

  /** When set, selection extracts value for this field (PdfExtractor-like flow) */
  let focusedFieldForSelection = null;

  document.getElementById("drawing-selection-toggle")?.addEventListener("click", () => {
    selectionMode = !selectionMode;
    focusedFieldForSelection = null;
    const wrappers = document.querySelectorAll(".drawing-original-wrapper");
    wrappers.forEach((w) => w.classList.toggle("selection-active", selectionMode));
    const btn = document.getElementById("drawing-selection-toggle");
    if (btn)
      btn.textContent = selectionMode ? "Cancel selection" : "Select region (click to enable)";
    const hint = document.getElementById("drawing-selection-hint");
    const formHint = document.getElementById("drawing-form-selection-hint");
    if (selectionMode && focusedFieldForSelection) formHint?.classList.remove("hidden");
    else formHint?.classList.add("hidden");
    if (selectionMode) hint?.classList.remove("hidden");
    else hint?.classList.add("hidden");
    if (!selectionMode) {
      selectionForm?.classList.add("hidden");
      selectionStart = null;
      if (selectionRectEl) selectionRectEl.remove();
    }
  });

  document.querySelectorAll(".drawing-field-input").forEach((input) => {
    input.addEventListener("focus", () => {
      focusedFieldForSelection = {
        input,
        fieldType: input.dataset.fieldType || "other",
        label: input.closest("label")?.querySelector("span")?.textContent?.trim() || input.id,
      };
      selectionMode = true;
      document
        .querySelectorAll(".drawing-original-wrapper")
        .forEach((w) => w.classList.add("selection-active"));
      document.getElementById("drawing-form-selection-hint")?.classList.remove("hidden");
    });
    input.addEventListener("blur", () => {
      if (!selectionStart) {
        focusedFieldForSelection = null;
        document.getElementById("drawing-form-selection-hint")?.classList.add("hidden");
      }
    });
  });

  document.getElementById("correction-selection-cancel")?.addEventListener("click", () => {
    selectionForm?.classList.add("hidden");
    selectionStart = null;
    if (selectionRectEl) selectionRectEl.remove();
    selectionRectEl = null;
  });

  // mousedown is on each overlay via setupOverlayListeners; mousemove/mouseup need document scope for drag
  document.addEventListener("mousemove", (e) => {
    if (!selectionStart || !selectionRectEl || !selectionWrapper) return;
    const overlay = selectionWrapper.querySelector(".drawing-selection-overlay");
    if (!overlay) return;
    const rect = overlay.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const left = Math.min(selectionStart.x, x);
    const top = Math.min(selectionStart.y, y);
    const width = Math.abs(x - selectionStart.x);
    const height = Math.abs(y - selectionStart.y);
    selectionRectEl.style.left = left + "px";
    selectionRectEl.style.top = top + "px";
    selectionRectEl.style.width = width + "px";
    selectionRectEl.style.height = height + "px";
  });

  async function cropImageToBlob(img, cropLeft, cropTop, cropWidth, cropHeight) {
    const canvas = document.createElement("canvas");
    canvas.width = Math.max(1, Math.round(cropWidth));
    canvas.height = Math.max(1, Math.round(cropHeight));
    const ctx = canvas.getContext("2d");
    if (!ctx) throw new Error("Canvas not supported");
    ctx.drawImage(img, cropLeft, cropTop, cropWidth, cropHeight, 0, 0, canvas.width, canvas.height);
    return new Promise((resolve, reject) => {
      canvas.toBlob(
        (blob) => (blob ? resolve(blob) : reject(new Error("toBlob failed"))),
        "image/png"
      );
    });
  }

  async function finishSelection(e) {
    if (!selectionStart || !selectionRectEl || !selectionWrapper) return;
    e?.preventDefault();
    const overlay = selectionWrapper.querySelector(".drawing-selection-overlay");
    if (!overlay) return;
    const rect = overlay.getBoundingClientRect();
    const style = selectionRectEl.style;
    let left = parseFloat(style.left) || 0;
    let top = parseFloat(style.top) || 0;
    let width = parseFloat(style.width) || 0;
    let height = parseFloat(style.height) || 0;
    if (width < 4 && height < 4) {
      left = selectionStart.x - 10;
      top = selectionStart.y - 10;
      width = 20;
      height = 20;
    }
    selectionRectEl.remove();
    selectionRectEl = null;

    const centerX = ((left + width / 2) / rect.width) * 100;
    const centerY = ((top + height / 2) / rect.height) * 100;
    const floorName = selectionWrapper.dataset.floorName || "Plan";
    const floorIndex = String(selectionWrapper.dataset.floorIndex || "0");

    const isInViewer = viewerContent?.contains(selectionWrapper);

    if (isInViewer) {
      const typeVal = guidedElementType?.value?.trim();
      const notes = guidedElementNotes?.value?.trim() || "";
      if (typeVal) {
        userSelections.push({
          floorIndex,
          floorName,
          elementType: typeVal,
          notes,
          region: { left, top, width, height },
          centerX,
          centerY,
        });
        renderSelectionsList();
      }
    } else if (focusedFieldForSelection && resultsEl?.contains(selectionWrapper)) {
      const img = selectionWrapper.querySelector("img");
      if (!img || !img.complete) {
        showStatus("Image not ready. Try again.", "error");
        selectionStart = null;
        selectionWrapper = null;
        return;
      }
      const scaleX = img.naturalWidth / rect.width;
      const scaleY = img.naturalHeight / rect.height;
      const cropLeft = Math.max(0, left * scaleX);
      const cropTop = Math.max(0, top * scaleY);
      const cropWidth = Math.min(img.naturalWidth - cropLeft, width * scaleX);
      const cropHeight = Math.min(img.naturalHeight - cropTop, height * scaleY);
      const fieldInput = focusedFieldForSelection.input;
      const fieldType = focusedFieldForSelection.fieldType;

      try {
        showStatus("Extracting value...");
        const blob = await cropImageToBlob(img, cropLeft, cropTop, cropWidth, cropHeight);
        const croppedUrl = await uploadImage(blob, `crop-${fieldType}.png`);
        const scaleInput = document.getElementById("drawing-scale");
        const scale = scaleInput?.value?.trim() || '1" = 10\'-0"';

        const res = await fetch("/api/agent/extract-drawing-field", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ imageUrl: croppedUrl, fieldType, scale }),
        });
        const data = await res.json();

        if (res.ok && data.value) {
          fieldInput.value = data.value;
          showStatus("Value extracted.", "success");
        } else {
          showStatus(data.error || data.message || "Extraction failed", "error");
        }
      } catch (err) {
        console.error("Extract error:", err);
        showStatus(err?.message || "Extraction failed", "error");
      } finally {
        focusedFieldForSelection = null;
        document.getElementById("drawing-form-selection-hint")?.classList.add("hidden");
      }
    } else {
      selectionWrapper.dataset.pendingCorrection = JSON.stringify({
        centerX,
        centerY,
        floorName,
        floorIndex,
      });
      selectionForm?.classList.remove("hidden");
      const correctionElementType = document.getElementById("correction-element-type");
      const correctionElementNotes = document.getElementById("correction-element-notes");
      if (correctionElementType) correctionElementType.value = "";
      if (correctionElementNotes) correctionElementNotes.value = "";
      if (selectionStatusEl) selectionStatusEl.textContent = "";
    }

    selectionStart = null;
    selectionWrapper = null;
  }

  document.addEventListener("mouseup", (e) => {
    if (selectionStart && selectionRectEl) finishSelection(e);
  });

  document.getElementById("correction-selection-submit")?.addEventListener("click", async () => {
    const wrapper = document.querySelector(".drawing-original-wrapper[data-pending-correction]");
    const typeVal = document.getElementById("correction-element-type")?.value?.trim();
    const notes = document.getElementById("correction-element-notes")?.value?.trim() || "";

    if (!wrapper || !typeVal) {
      if (selectionStatusEl) selectionStatusEl.textContent = "Please choose an element type.";
      return;
    }

    const pending = JSON.parse(wrapper.dataset.pendingCorrection || "{}");
    const label =
      typeVal === "ignore"
        ? "not an element (AI should ignore)"
        : typeVal === "other"
          ? `other: ${notes || "see notes"}`
          : typeVal.startsWith("pipe-")
            ? `pipe: ${typeVal.replace("pipe-", "")}${notes ? " — " + notes : ""}`
            : `${typeVal}${notes ? " — " + notes : ""}`;

    const title = `Drawing correction: ${pending.floorName}`;
    const content = `User selected a region (center ~${Math.round(pending.centerX)}%, ${Math.round(pending.centerY)}% of image) on a fire protection drawing and identified it as: ${label}. When analyzing similar drawings, use this identification.`;

    const btn = document.getElementById("correction-selection-submit");
    if (btn) btn.disabled = true;
    if (selectionStatusEl) selectionStatusEl.textContent = "Saving...";

    try {
      const res = await fetch("/api/agent/knowledge", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          title,
          content,
          category: "drawing_analysis",
          priority: 8,
        }),
      });
      const data = await res.json();

      if (!res.ok) throw new Error(data.error || data.message || "Failed to save");

      if (selectionStatusEl)
        selectionStatusEl.textContent = "Saved. Future analyses will use this.";
      selectionForm?.classList.add("hidden");
      delete wrapper.dataset.pendingCorrection;
    } catch (err) {
      if (selectionStatusEl) selectionStatusEl.textContent = err?.message || "Error saving";
    } finally {
      if (btn) btn.disabled = false;
    }
  });

  // Save correction to knowledge base (text form)
  document.getElementById("correction-submit")?.addEventListener("click", async () => {
    const titleEl = document.getElementById("correction-title");
    const contentEl = document.getElementById("correction-content");
    const statusEl = document.getElementById("correction-status");

    const title = titleEl?.value?.trim();
    const content = contentEl?.value?.trim();

    if (!title || !content) {
      if (statusEl) statusEl.textContent = "Please enter both title and correction.";
      return;
    }

    const btn = document.getElementById("correction-submit");
    if (btn) btn.disabled = true;
    if (statusEl) statusEl.textContent = "Saving...";

    try {
      const res = await fetch("/api/agent/knowledge", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          title,
          content,
          category: "drawing_analysis",
          priority: 5,
        }),
      });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || data.message || "Failed to save");
      }

      if (statusEl) statusEl.textContent = "Saved. Future analyses will use this.";
      titleEl.value = "";
      contentEl.value = "";
    } catch (err) {
      if (statusEl) statusEl.textContent = err?.message || "Error saving";
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>
