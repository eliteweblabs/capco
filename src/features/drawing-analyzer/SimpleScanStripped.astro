  // Scales the rendered drawing before sending to the API.
  // Larger = better text recognition but bigger payload; 1800px is a good balance for CAD drawings.
  function resizeForAnalysis(imageData: ImageData, maxSide = 1800): string {
    const scale = Math.min(1, maxSide / Math.max(imageData.width, imageData.height));
    const w = Math.round(imageData.width * scale);
    const h = Math.round(imageData.height * scale);
    const src = document.createElement("canvas");
    src.width = imageData.width; src.height = imageData.height;
    src.getContext("2d")?.putImageData(imageData, 0, 0);
    const out = document.createElement("canvas");
    out.width = w; out.height = h;
    const ctx = out.getContext("2d");
    if (!ctx) return "";
    ctx.drawImage(src, 0, 0, w, h);
    return out.toDataURL("image/jpeg", 0.82);
  }

  async function analyzeDrawingMetadata(imageData: ImageData) {
    const infoPanel = document.getElementById("drawing-info-panel");
    if (!infoPanel) return;
    metadataLoading = true;
    drawingMetadata = null;
    metadataError = null;
    sprinklerSchedule = null;
    drawingLegend = null;
    renderDrawingInfoPanel();

    try {
      const imageDataUrl = resizeForAnalysis(imageData);
      if (!imageDataUrl) { metadataLoading = false; renderDrawingInfoPanel(); return; }

      const res = await fetch("/api/drawing-analyzer/analyze-metadata", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ imageData: imageDataUrl }),
      });
      const json = await res.json();
      if (!res.ok) {
        metadataError = json?.error ?? `HTTP ${res.status}`;
      } else {
        drawingMetadata = json.summary ?? null;
        sprinklerSchedule = Array.isArray(json.schedule) && json.schedule.length > 0
          ? json.schedule as ScheduleRow[]
          : null;
        drawingLegend = Array.isArray(json.legend) && json.legend.length > 0
          ? json.legend as LegendRow[]
          : null;
      }
    } catch (err: any) {
      log("analyzeDrawingMetadata failed:", err);
      metadataError = err?.message ?? "Network error";
    } finally {
      metadataLoading = false;
      renderDrawingInfoPanel();
    }
  }

  async function renderPdfToImage(file: File): Promise<HTMLImageElement | null> {
    log("renderPdfToImage: starting with", file.name, `(${(file.size / 1024).toFixed(1)} KB)`);
    const pdfLib = getPdfLib();
    if (!pdfLib) { logError("renderPdfToImage: pdfjsLib not available"); return null; }

    // ── Cache PDF bytes so we only read the File once ─────────────────────────
    const pdfBytes = await file.arrayBuffer();

    // ── Step 1: probe native page dimensions at scale 1 ──────────────────────
    // This lets us compute the EXACT scale needed to hit our target resolution
    // instead of blindly trying high scales and falling back when they OOM.
    let scaleFallbacks: number[] = PDF_RENDER_SCALE_FALLBACKS;
    try {
      const probe = await pdfLib.getDocument({ data: pdfBytes.slice(0) }).promise;
      const pg1   = await probe.getPage(1);
      const vp1   = pg1.getViewport({ scale: 1 });
      const nW = vp1.width, nH = vp1.height;
      log(`renderPdfToImage: native page ${nW.toFixed(0)} × ${nH.toFixed(0)} pt (72 DPI units)`);

      // Scale to fill PDF_RENDER_TARGET_LONG_PX on the longest side
      let s = PDF_RENDER_TARGET_LONG_PX / Math.max(nW, nH);
      // Back off proportionally if total pixel count exceeds budget
      const totalPx = nW * s * nH * s;
      if (totalPx > PDF_RENDER_MAX_PIXELS) s *= Math.sqrt(PDF_RENDER_MAX_PIXELS / totalPx);
      // Round to one decimal place, floor at 2
      const s1 = Math.max(2, Math.round(s * 10) / 10);
      const s2 = Math.max(2, Math.round(s1 * 0.7 * 10) / 10);
      const s3 = Math.max(2, Math.round(s1 * 0.5 * 10) / 10);
      scaleFallbacks = [s1, s2, s3].filter((v, i, a) => a.indexOf(v) === i);
      log(`renderPdfToImage: target scale ${s1} (${(nW * s1).toFixed(0)}×${(nH * s1).toFixed(0)} px), fallbacks: ${scaleFallbacks.join(", ")}`);
    } catch (e) {
      logWarn("renderPdfToImage: probe failed, using legacy scale list", e);
    }

    // ── Step 2: render at the best scale that succeeds ────────────────────────
    for (const scale of scaleFallbacks) {
      try {
        log(`renderPdfToImage: trying scale ${scale}...`);
        logTime(`renderPdfToImage-scale-${scale}`);
        const pdf  = await pdfLib.getDocument({ data: pdfBytes.slice(0) }).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale });
        const c = document.createElement("canvas");
        c.width  = Math.max(1, Math.floor(viewport.width));
        c.height = Math.max(1, Math.floor(viewport.height));
        log(`renderPdfToImage: scale ${scale} → canvas ${c.width}×${c.height}`);
        const ctx = c.getContext("2d", { willReadFrequently: true });
        if (!ctx) {
          logWarn(`renderPdfToImage: scale ${scale} — no 2d context, skipping`);
          continue;
        }
        await page.render({ canvasContext: ctx, viewport }).promise;
        const img = new Image();
        img.src = c.toDataURL("image/png");
        await new Promise((resolve, reject) => { img.onload = resolve; img.onerror = reject; });
        lastPdfRenderScale = scale;
        lastPdfPage = page;
        lastPdfDoc  = pdf;
        logTimeEnd(`renderPdfToImage-scale-${scale}`);
        log(`renderPdfToImage: success at scale ${scale} → ${img.naturalWidth}×${img.naturalHeight} px`);
        return img;
      } catch (error) {
        logWarn(`renderPdfToImage: scale ${scale} failed:`, error);
      }
    }
    logError("renderPdfToImage: all scales failed");
    return null;
  }

  async function loadImageFromFile(file: File): Promise<HTMLImageElement | null> {
    log(
      "loadImageFromFile:",
      file.name,
      `(${(file.size / 1024).toFixed(1)} KB, type: ${file.type})`
    );
    return await new Promise((resolve: (image: HTMLImageElement | null) => void) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => {
          log(`loadImageFromFile: loaded ${img.naturalWidth}x${img.naturalHeight}`);
          resolve(img);
        };
        img.onerror = () => {
          logError("loadImageFromFile: image decode failed");
          resolve(null);
        };
        img.src = String(reader.result || "");
      };
      reader.onerror = () => {
        logError("loadImageFromFile: FileReader error");
        resolve(null);
      };
      reader.readAsDataURL(file);
    });
  }

  async function handleDrawingUpload(file: File) {
    if (!(file instanceof File)) {
      logWarn("handleDrawingUpload: not a File");
      return;
    }
    logTime("handleDrawingUpload");
    log(
      "handleDrawingUpload:",
      file.name,
      `(${(file.size / 1024).toFixed(1)} KB, type: ${file.type})`
    );
    setStatus("Rendering drawing...");
    showOverlay("Rendering drawing…");
    lastPdfRenderScale = 0;
    lastPdfDoc  = null;
    lastPdfPage = null;
    lastCropOffsetX = 0;
    lastCropOffsetY = 0;
    const isPdf = file.name.toLowerCase().endsWith(".pdf") || file.type === "application/pdf";
    const isSvg = file.name.toLowerCase().endsWith(".svg") || file.type === "image/svg+xml";
    log("handleDrawingUpload: format detected →", isPdf ? "PDF" : isSvg ? "SVG" : "Image");
    const img: HTMLImageElement | null = isPdf
      ? await renderPdfToImage(file)
      : await loadImageFromFile(file);
    if (!img || !(canvas instanceof HTMLCanvasElement)) {
      logError("handleDrawingUpload: failed to render image or no canvas");
      hideOverlay();
      toastError("Render Failed", "Could not render the drawing file.");
      return setStatus("Failed to render drawing");
    }
    const ctx = getCtx();
    if (!ctx) {
      logError("handleDrawingUpload: no 2d context");
      hideOverlay();
      return;
    }
    const ratio = Math.min(
      isSvg ? 10 : 1,
      DRAWING_RENDER_MAX_SIDE /
        Math.max(img.naturalWidth || img.width, img.naturalHeight || img.height)
    );
    canvas.width = Math.max(1, Math.round((img.naturalWidth || img.width) * ratio));
    canvas.height = Math.max(1, Math.round((img.naturalHeight || img.height) * ratio));
    log(
      "handleDrawingUpload: canvas sized to",
      canvas.width,
      "x",
      canvas.height,
      "ratio:",
      ratio.toFixed(4)
    );
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    showOverlay("Detecting regions…");
    log("handleDrawingUpload: imageData captured, building seed mask...");
    drawingState = {
      width: canvas.width,
      height: canvas.height,
      imageData,
      mask: imageToRegionSeedMask(imageData),
    };
    setStatus(
      `Rendered ${canvas.width}x${canvas.height}${lastPdfRenderScale ? ` @ PDF scale ${lastPdfRenderScale}` : ""}. Detecting regions...`
    );
    log("handleDrawingUpload: extracting baseline regions...");
    baselineRegions = extractBaselineRegions(drawingState);
    excludedRegionIndexes.clear();
    confirmedRegionIndexes.clear();
    lastCroppedImageData = null;
    workingImageData = null;
    layers = [];
    symbolScanResults = null;
    pipeAnalysisResults = null;
    pipeSubLayers = []; sprinklerSubLayers = []; sprinklerConnections = [];
    if (drawerControlsEl) drawerControlsEl.innerHTML = "";

    // Kick off metadata analysis on the original image (before any layer extraction).
    // Fire-and-forget — the info panel updates itself when the response arrives.
    analyzeDrawingMetadata(imageData);

    log("handleDrawingUpload: calling renderProcessingOnlyView...");
    renderProcessingOnlyView();
    logTimeEnd("handleDrawingUpload");
    log("handleDrawingUpload: complete ✓");
    hideOverlay();
    toastSuccess(
      "Drawing Ready",
      `${baselineRegions.length} region(s) detected. Confirm viable areas to continue.`
    );
  }

  // ── Event wiring ───────────────────────────────────────────────────

  async function loadSelectedDrawing() {
    if (!testSelect) {
      logWarn("loadSelectedDrawing: no select element");
      return;
    }
    const raw = testSelect.value;
    if (!raw) {
      logWarn("loadSelectedDrawing: empty select value");
      return;
    }
    const url = encodeURI(raw);
    const label = testSelect.options[testSelect.selectedIndex]?.textContent || raw;
    log("loadSelectedDrawing:", label, "→", url);
    setStatus(`Loading ${label}...`);
    showOverlay(`Loading ${label}…`);
    toastInfo("Loading Drawing", label);
    try {
      const res = await fetch(url, { cache: "no-store" });
      log("loadSelectedDrawing: fetch", res.status, res.statusText);
      if (!res.ok) {
        logError("loadSelectedDrawing: fetch failed", res.status, url);
        setStatus(`Failed to load ${label}`);
        toastError("Load Failed", `Could not fetch ${label}`);
        hideOverlay();
        return;
      }
      const blob = await res.blob();
      const filename = raw.split("/").pop() || "drawing.pdf";
      log(`loadSelectedDrawing: ${(blob.size / 1024).toFixed(1)} KB`);
      await handleDrawingUpload(
        new File([blob], filename, { type: blob.type || "application/pdf" })
      );
    } catch (err) {
      logError("loadSelectedDrawing: error", err);
      setStatus(`Error loading ${label}`);
      toastError("Load Error", `${label}: ${err}`);
      hideOverlay();
    }
  }

  drawingFileInput?.addEventListener("change", async () => {
    const file = drawingFileInput.files?.[0];
    log(
      "File input changed:",
      file ? `${file.name} (${(file.size / 1024).toFixed(1)} KB)` : "no file"
    );
    if (file) await handleDrawingUpload(file);
  });

  if (testSelect) {
    log("testSelect FOUND, options:", testSelect.options.length);
    testSelect.addEventListener("change", async () => {
      log("SELECT CHANGED →", testSelect.value);
      if (drawingFileInput) drawingFileInput.value = "";
      await loadSelectedDrawing();
    });
  } else {
    logWarn("testSelect NOT FOUND in DOM");
  }

  const onPointerMove = (e: PointerEvent) => {
    if (!drawingState) return;
    const { width: imgW, height: imgH } = drawingState;

    if (handleDragState) {
      const dx = (e.clientX - handleDragState.startX) / handleDragState.pxPerImgX;
      const dy = (e.clientY - handleDragState.startY) / handleDragState.pxPerImgY;
      const o = handleDragState.orig;
      const a = handleDragState.anchor;
      let x = o.x,
        y = o.y,
        w = o.w,
        h = o.h;

      if (a.includes("w")) {
        x = o.x + dx;
        w = o.w - dx;
      }
      if (a.includes("e")) {
        w = o.w + dx;
      }
      if (a.includes("n")) {
        y = o.y + dy;
        h = o.h - dy;
      }
      if (a.includes("s")) {
        h = o.h + dy;
      }

      if (w < MIN_REGION_SIZE) {
        if (a.includes("w")) x = o.x + o.w - MIN_REGION_SIZE;
        w = MIN_REGION_SIZE;
      }
      if (h < MIN_REGION_SIZE) {
        if (a.includes("n")) y = o.y + o.h - MIN_REGION_SIZE;
        h = MIN_REGION_SIZE;
      }
      x = clamp(x, 0, imgW - MIN_REGION_SIZE);
      y = clamp(y, 0, imgH - MIN_REGION_SIZE);
      w = clamp(w, MIN_REGION_SIZE, imgW - x);
      h = clamp(h, MIN_REGION_SIZE, imgH - y);

      baselineRegions[handleDragState.idx] = {
        x: Math.round(x),
        y: Math.round(y),
        w: Math.round(w),
        h: Math.round(h),
      };
      updateRegionBoxStyle(handleDragState.idx);
      return;
    }

    if (regionDragState) {
      const dx = (e.clientX - regionDragState.startX) / regionDragState.pxPerImgX;
      const dy = (e.clientY - regionDragState.startY) / regionDragState.pxPerImgY;
      const o = regionDragState.orig;
      const x = clamp(o.x + dx, 0, imgW - o.w);
      const y = clamp(o.y + dy, 0, imgH - o.h);
      baselineRegions[regionDragState.idx] = { x: Math.round(x), y: Math.round(y), w: o.w, h: o.h };
      updateRegionBoxStyle(regionDragState.idx);
      return;
    }
  };

  const onPointerUp = () => {
    const wasDragging = regionDragState || handleDragState;
    if (regionDragState) {
      const box = pipelineStepsEl?.querySelector(
        `.simple-scan-region-box[data-region-idx="${regionDragState.idx}"]`
      ) as HTMLElement | null;
      if (box) box.style.cursor = "";
    }
    regionDragState = null;
    handleDragState = null;
    if (wasDragging) {
      log("Drag ended, refreshing view");
      renderProcessingOnlyView();
    }
  };

  window.addEventListener("pointermove", onPointerMove);
  window.addEventListener("pointerup", onPointerUp);
  window.addEventListener("pointercancel", onPointerUp);
  runScanBtn?.addEventListener("click", async () => {
    log("Refresh button clicked — reloading drawing");
    if (drawingFileInput?.files?.[0]) {
      await handleDrawingUpload(drawingFileInput.files[0]);
    } else {
      await loadSelectedDrawing();
    }
  });
  log("Event listeners wired");

  // Auto-load the initially selected test drawing
  (async () => {
    try {
      log("Auto-load: waiting for pdfjsLib...");
      while (!getPdfLib()) await new Promise((r) => setTimeout(r, 100));
      log("Auto-load: pdfjsLib ready, loading selected drawing...");
      await loadSelectedDrawing();
    } catch (err) {
      logError("Auto-load: error", err);
      setStatus("Could not auto-load default drawing.");
    }
  })();
</script>

