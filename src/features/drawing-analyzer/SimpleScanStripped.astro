---
import { globalClasses } from "../../pages/api/global/global-classes";

const { globalFormLabel, mutedTextSmClasses, primaryTextClasses } = globalClasses();
---

<section class="relative" style="min-height:calc(100dvh - 120px)">

  {/* ── Drawer toggle button (always visible) ── */}
  <button
    id="drawer-toggle"
    type="button"
    class="absolute left-3 top-3 z-50 flex h-9 w-9 items-center justify-center rounded-lg bg-gray-900/80 text-white shadow-lg backdrop-blur hover:bg-gray-900 dark:bg-gray-100/80 dark:text-gray-900 dark:hover:bg-gray-100"
    title="Toggle controls"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
  </button>

  {/* ── Drawer (absolute, doesn't push content) ── */}
  <div
    id="scan-drawer"
    class="absolute left-0 top-0 z-40 h-full w-80 translate-x-0 overflow-y-auto rounded-r-xl bg-white/95 shadow-2xl backdrop-blur-sm transition-transform duration-200 dark:bg-gray-900/95"
  >
    <div class="space-y-4 p-4 pt-14">
      <p class={`text-sm font-semibold ${primaryTextClasses}`}>Drawing Analyzer</p>
      <p class={mutedTextSmClasses}>Select a floor plan to analyze.</p>

      <div>
        <label for="simple-scan-test-select" class={globalFormLabel}>Test Drawing</label>
        <select
          id="simple-scan-test-select"
          class="block w-full rounded border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-900 dark:border-gray-600 dark:bg-gray-800 dark:text-white"
        >
        </select>
      </div>

      <div>
        <label for="simple-scan-file" class={globalFormLabel}>Upload Override</label>
        <input id="simple-scan-file" type="file" accept=".pdf,image/*" class="block w-full text-sm" />
      </div>

      <div class="flex items-center gap-2">
        <button
          id="simple-scan-run"
          type="button"
          class="rounded bg-primary-600 px-3 py-1.5 text-sm text-white"
        >
          Refresh
        </button>
      </div>

      <p id="simple-scan-status" class={`${mutedTextSmClasses} break-words`}>Loading default drawing...</p>

      <div id="drawer-controls" class="space-y-3"></div>

      <details class="rounded border border-gray-200 dark:border-gray-700">
        <summary class="cursor-pointer px-3 py-2 text-xs font-semibold text-gray-600 dark:text-gray-400">Debug Output</summary>
        <pre
          id="simple-scan-results"
          class="max-h-48 overflow-auto p-3 text-[10px] leading-tight dark:bg-gray-900">
        </pre>
      </details>
    </div>
  </div>

  {/* ── Hidden canvas (processing only) ── */}
  <canvas
    id="simple-scan-canvas"
    class="hidden"></canvas>

  {/* ── Full-screen floor plan area ── */}
  <div id="simple-scan-pipeline-steps" class="flex w-full items-center justify-center" style="min-height:calc(100dvh - 120px)"></div>

</section>

<script src="/js/pdf.min.js" defer></script>
<script>
  // Drawer toggle
  const drawerEl = document.getElementById("scan-drawer") as HTMLDivElement | null;
  const drawerToggle = document.getElementById("drawer-toggle") as HTMLButtonElement | null;
  let drawerOpen = true;
  drawerToggle?.addEventListener("click", () => {
    drawerOpen = !drawerOpen;
    if (drawerEl) drawerEl.style.transform = drawerOpen ? "translateX(0)" : "translateX(-100%)";
  });

  const drawingFileInput = document.getElementById("simple-scan-file") as HTMLInputElement | null;
  const testSelect = document.getElementById("simple-scan-test-select") as HTMLSelectElement | null;
  const runScanBtn = document.getElementById("simple-scan-run") as HTMLButtonElement | null;
  const statusEl = document.getElementById("simple-scan-status") as HTMLParagraphElement | null;
  const canvas = document.getElementById("simple-scan-canvas") as HTMLCanvasElement | null;
  const resultsEl = document.getElementById("simple-scan-results") as HTMLPreElement | null;
  const pipelineStepsEl = document.getElementById(
    "simple-scan-pipeline-steps"
  ) as HTMLDivElement | null;
  const drawerControlsEl = document.getElementById("drawer-controls") as HTMLDivElement | null;

  const LOG_PREFIX = "[SimpleScan]";
  const log = (...args: any[]) => console.log(LOG_PREFIX, ...args);
  const logWarn = (...args: any[]) => console.warn(LOG_PREFIX, ...args);
  console.log("[SimpleScan] script init — testSelect:", !!testSelect, "fileInput:", !!drawingFileInput);
  const logError = (...args: any[]) => console.error(LOG_PREFIX, ...args);
  const logTime = (label: string) => console.time(`${LOG_PREFIX} ${label}`);
  const logTimeEnd = (label: string) => console.timeEnd(`${LOG_PREFIX} ${label}`);

  log("Script loaded, initializing...");

  const TEST_DRAWINGS_DIR = "/test-drawings";
  const TEST_DRAWINGS: Array<{ label: string; file: string }> = [
    { label: "Demo Plan", file: "demo-plan.pdf" },
    { label: "1062 Beacon St, Newton", file: "1062 Beacon St, Newton MA 02459 FP.pdf" },
    { label: "28 High St", file: "28 HIGH ST - FP.pdf" },
    { label: "60 Lane Park, Brighton", file: "60 Lane Park, Brighton FP.pdf" },
    { label: "63b0c5da (Unnamed)", file: "63b0c5da-2d15-428d-b5e1-26fe8cf51618.pdf" },
    { label: "85 Tremont St, Cambridge", file: "85 Tremont Street Cambridge MA FP.pdf" },
  ];
  const DRAWING_RENDER_MAX_SIDE = 10000;
  const PDF_RENDER_SCALE_FALLBACKS = [14, 12, 10, 8, 6, 4, 3];
  const MAX_REGIONS_TO_SCAN = 4;

  // Populate test drawing dropdown
  if (testSelect) {
    TEST_DRAWINGS.forEach((td, i) => {
      const opt = document.createElement("option");
      opt.value = `${TEST_DRAWINGS_DIR}/${td.file}`;
      opt.textContent = td.label;
      if (i === 0) opt.selected = true;
      testSelect.appendChild(opt);
    });
    log("Test drawings dropdown populated:", TEST_DRAWINGS.length, "item(s)");
  }

  let drawingState: {
    width: number;
    height: number;
    imageData: ImageData;
    mask: Uint8Array;
  } | null = null;
  let baselineRegions: Array<{ x: number; y: number; w: number; h: number }> = [];
  let excludedRegionIndexes = new Set<number>();
  let confirmedRegionIndexes = new Set<number>();
  let lastPdfRenderScale = 0;

  // ── Layer extraction state ──────────────────────────────────────────
  type ExtractedLayer = {
    name: string;
    visible: boolean;
    imageDataUrl: string;
    rawImageData: ImageData;
    pixelCount: number;
  };
  let workingImageData: ImageData | null = null;
  let showWorkingLayer = true;
  let layers: ExtractedLayer[] = [];

  let showRegionOverlays = true;
  let activeRegionIdx: number | null = null;
  let regionDragState: {
    idx: number;
    startX: number;
    startY: number;
    orig: { x: number; y: number; w: number; h: number };
    pxPerImgX: number;
    pxPerImgY: number;
  } | null = null;
  let handleDragState: {
    idx: number;
    anchor: string;
    startX: number;
    startY: number;
    orig: { x: number; y: number; w: number; h: number };
    pxPerImgX: number;
    pxPerImgY: number;
  } | null = null;

  const HANDLE_DEFS: Array<{ anchor: string; css: string }> = [
    { anchor: "nw", css: "top:-5px;left:-5px;cursor:nw-resize" },
    { anchor: "ne", css: "top:-5px;right:-5px;cursor:ne-resize" },
    { anchor: "sw", css: "bottom:-5px;left:-5px;cursor:sw-resize" },
    { anchor: "se", css: "bottom:-5px;right:-5px;cursor:se-resize" },
    { anchor: "n", css: "top:-5px;left:calc(50% - 5px);cursor:n-resize" },
    { anchor: "s", css: "bottom:-5px;left:calc(50% - 5px);cursor:s-resize" },
    { anchor: "w", css: "top:calc(50% - 5px);left:-5px;cursor:w-resize" },
    { anchor: "e", css: "top:calc(50% - 5px);right:-5px;cursor:e-resize" },
  ];
  const MIN_REGION_SIZE = 20;

  // ── Utilities ──────────────────────────────────────────────────────

  log("DOM elements:", {
    drawingFileInput: !!drawingFileInput,
    runScanBtn: !!runScanBtn,
    statusEl: !!statusEl,
    canvas: !!canvas,
    resultsEl: !!resultsEl,
    pipelineStepsEl: !!pipelineStepsEl,
  });

  const clamp = (v: number, min: number, max: number) => Math.min(max, Math.max(min, v));
  const getPdfLib = () => (window as any)["pdfjsLib"];
  const getCtx = () =>
    canvas instanceof HTMLCanvasElement
      ? canvas.getContext("2d", { willReadFrequently: true })
      : null;
  const setStatus = (text: string) => {
    log("Status →", text);
    statusEl && (statusEl.textContent = text);
  };

  function getImageScale(): { pxPerImgX: number; pxPerImgY: number } {
    if (!drawingState) return { pxPerImgX: 1, pxPerImgY: 1 };
    const el = document.getElementById("step1-image-container");
    if (!el) return { pxPerImgX: 1, pxPerImgY: 1 };
    const rect = el.getBoundingClientRect();
    return {
      pxPerImgX: rect.width / drawingState.width,
      pxPerImgY: rect.height / drawingState.height,
    };
  }

  function updateRegionBoxStyle(idx: number) {
    if (!drawingState || !pipelineStepsEl) return;
    const r = baselineRegions[idx];
    if (!r) return;
    const box = pipelineStepsEl.querySelector(
      `.simple-scan-region-box[data-region-idx="${idx}"]`
    ) as HTMLElement | null;
    if (!box) return;
    box.style.left = `${(r.x / drawingState.width) * 100}%`;
    box.style.top = `${(r.y / drawingState.height) * 100}%`;
    box.style.width = `${(r.w / drawingState.width) * 100}%`;
    box.style.height = `${(r.h / drawingState.height) * 100}%`;
  }

  // ── Core algorithms (copied exactly from SimpleScan) ───────────────

  function getComponents(
    mask: Uint8Array,
    width: number,
    height: number,
    minArea = 18,
    maxArea = 999999
  ) {
    logTime("getComponents");
    log("getComponents called:", { width, height, minArea, maxArea, maskPixels: mask.length });
    const visited = new Uint8Array(width * height);
    const qx = new Int32Array(width * height);
    const qy = new Int32Array(width * height);
    const out: Array<{ x: number; y: number; w: number; h: number; area: number }> = [];
    for (let y = 0; y < height; y += 1) {
      for (let x = 0; x < width; x += 1) {
        const start = y * width + x;
        if (!mask[start] || visited[start]) continue;
        let head = 0;
        let tail = 0;
        qx[tail] = x;
        qy[tail] = y;
        tail += 1;
        visited[start] = 1;
        let area = 0;
        let minX = x;
        let minY = y;
        let maxX = x;
        let maxY = y;
        while (head < tail) {
          const cx = qx[head];
          const cy = qy[head];
          head += 1;
          area += 1;
          if (cx < minX) minX = cx;
          if (cy < minY) minY = cy;
          if (cx > maxX) maxX = cx;
          if (cy > maxY) maxY = cy;
          for (let oy = -1; oy <= 1; oy += 1)
            for (let ox = -1; ox <= 1; ox += 1) {
              if (ox === 0 && oy === 0) continue;
              const nx = cx + ox;
              const ny = cy + oy;
              if (nx < 0 || ny < 0 || nx >= width || ny >= height) continue;
              const nidx = ny * width + nx;
              if (!mask[nidx] || visited[nidx]) continue;
              visited[nidx] = 1;
              qx[tail] = nx;
              qy[tail] = ny;
              tail += 1;
            }
        }
        if (area >= minArea && area <= maxArea)
          out.push({ x: minX, y: minY, w: maxX - minX + 1, h: maxY - minY + 1, area });
      }
    }
    logTimeEnd("getComponents");
    log(`getComponents result: ${out.length} component(s) found`);
    return out;
  }

  function extractBaselineRegions(state: typeof drawingState) {
    logTime("extractBaselineRegions");
    log("extractBaselineRegions called");
    if (!state) { logWarn("extractBaselineRegions: no state"); return []; }
    const { width, height, mask } = state;
    const canvasArea = Math.max(1, width * height);
    log("extractBaselineRegions: canvas", { width, height, canvasArea });
    const comps = getComponents(mask, width, height, 18, canvasArea * 0.9);
    if (comps.length === 0) { log("extractBaselineRegions: 0 components, returning empty"); logTimeEnd("extractBaselineRegions"); return []; }

    const edgeMargin = Math.max(6, Math.round(Math.min(width, height) * 0.02));
    const scored: Array<{ x: number; y: number; w: number; h: number; area: number; score: number }> = [];
    for (const c of comps) {
      const bboxArea = c.w * c.h;
      const bboxRatio = bboxArea / canvasArea;
      if (bboxRatio < 0.015 || bboxRatio > 0.72) continue;
      const aspect = c.w / Math.max(1, c.h);
      if (aspect < 0.35 || aspect > 3.0) continue;
      const inkRatio = c.area / Math.max(1, bboxArea);
      if (inkRatio < 0.0015 || inkRatio > 0.24) continue;

      const nearLeft = c.x <= edgeMargin;
      const nearTop = c.y <= edgeMargin;
      const nearRight = c.x + c.w >= width - edgeMargin;
      const nearBottom = c.y + c.h >= height - edgeMargin;
      const edgeTouchCount = [nearLeft, nearTop, nearRight, nearBottom].filter(Boolean).length;

      const cx = c.x + c.w / 2;
      const cy = c.y + c.h / 2;
      const centerDist =
        Math.hypot(cx - width / 2, cy - height / 2) /
        Math.max(1, Math.hypot(width / 2, height / 2));
      const centerBonus = 1 - clamp(centerDist, 0, 1);
      const frameBonus = clamp(1 - Math.abs(inkRatio - 0.06) / 0.14, 0, 1);
      const edgePenalty = edgeTouchCount >= 2 ? 0.22 : 0;
      const score = bboxRatio * 1.1 + frameBonus * 0.35 + centerBonus * 0.2 - edgePenalty;

      scored.push({ ...c, score });
    }

    scored.sort((a, b) => b.score - a.score);
    const selected: Array<{ x: number; y: number; w: number; h: number }> = [];
    for (const c of scored) {
      const overlaps = selected.some((k) => {
        const x0 = Math.max(c.x, k.x);
        const y0 = Math.max(c.y, k.y);
        const x1 = Math.min(c.x + c.w - 1, k.x + k.w - 1);
        const y1 = Math.min(c.y + c.h - 1, k.y + k.h - 1);
        if (x1 < x0 || y1 < y0) return false;
        const inter = (x1 - x0 + 1) * (y1 - y0 + 1);
        return inter / Math.max(1, Math.min(c.w * c.h, k.w * k.h)) > 0.58;
      });
      if (overlaps) continue;
      const pad = Math.max(8, Math.round(Math.min(c.w, c.h) * 0.03));
      selected.push({
        x: clamp(c.x - pad, 0, width - 1),
        y: clamp(c.y - pad, 0, height - 1),
        w: clamp(c.w + pad * 2, 1, width),
        h: clamp(c.h + pad * 2, 1, height),
      });
      if (selected.length >= 4) break;
    }
    logTimeEnd("extractBaselineRegions");
    log(`extractBaselineRegions result: ${scored.length} scored, ${selected.length} selected`);
    selected.forEach((r, i) => log(`  Region ${i}: x=${r.x} y=${r.y} w=${r.w} h=${r.h}`));
    return selected;
  }

  // ── Image / mask helpers ───────────────────────────────────────────

  function imageToRegionSeedMask(imageData: ImageData) {
    logTime("imageToRegionSeedMask");
    const { width, height, data } = imageData;
    log("imageToRegionSeedMask:", { width, height, totalPixels: width * height });
    const mask = new Uint8Array(width * height);
    let inkPixels = 0;
    for (let i = 0, p = 0; p < mask.length; p += 1, i += 4) {
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];
      const a = data[i + 3];
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      mask[p] = gray < 244 && a > 6 && spread < 88 ? 1 : 0;
      if (mask[p]) inkPixels++;
    }
    logTimeEnd("imageToRegionSeedMask");
    log(`imageToRegionSeedMask: ${inkPixels} ink pixels (${((inkPixels / mask.length) * 100).toFixed(2)}% of image)`);
    return mask;
  }

  function imageDataToDataUrl(imageData: ImageData) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.putImageData(imageData, 0, 0);
    return c.toDataURL("image/png");
  }

  function regionsMaskLayerToDataUrl(
    imageData: ImageData,
    regions: Array<{ x: number; y: number; w: number; h: number }>,
    selectedRegions: Array<{ x: number; y: number; w: number; h: number }> = [],
    excludedIndexes: Set<number> = new Set<number>()
  ) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.clearRect(0, 0, c.width, c.height);
    ctx.lineWidth = 2;
    regions.forEach((r, idx) => {
      if (excludedIndexes.has(idx)) return;
      ctx.strokeStyle = "rgba(56,189,248,0.95)";
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(56,189,248,0.14)";
      ctx.fillRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(12,74,110,0.95)";
      ctx.font = "12px sans-serif";
      ctx.fillText(`R${idx + 1}`, r.x + 4, r.y + 14);
    });
    selectedRegions.forEach((r) => {
      ctx.strokeStyle = "rgba(251,191,36,0.98)";
      ctx.lineWidth = 3;
      ctx.strokeRect(r.x, r.y, r.w, r.h);
    });
    return c.toDataURL("image/png");
  }

  let lastCroppedImageData: ImageData | null = null;

  function croppedMaskedSource(
    imageData: ImageData,
    selectedRegions: Array<{ x: number; y: number; w: number; h: number }> = []
  ): { dataUrl: string; croppedImageData: ImageData | null } {
    if (!Array.isArray(selectedRegions) || selectedRegions.length === 0) {
      lastCroppedImageData = null;
      return { dataUrl: imageDataToDataUrl(imageData), croppedImageData: null };
    }
    let minX = imageData.width;
    let minY = imageData.height;
    let maxX = 0;
    let maxY = 0;
    selectedRegions.forEach((r) => {
      minX = Math.min(minX, r.x);
      minY = Math.min(minY, r.y);
      maxX = Math.max(maxX, r.x + r.w);
      maxY = Math.max(maxY, r.y + r.h);
    });
    const padding = 10;
    minX = Math.max(0, minX - padding);
    minY = Math.max(0, minY - padding);
    maxX = Math.min(imageData.width, maxX + padding);
    maxY = Math.min(imageData.height, maxY + padding);
    const cropWidth = maxX - minX;
    const cropHeight = maxY - minY;
    const c = document.createElement("canvas");
    c.width = cropWidth;
    c.height = cropHeight;
    const ctx = c.getContext("2d");
    if (!ctx) return { dataUrl: "", croppedImageData: null };
    const sourceCanvas = document.createElement("canvas");
    sourceCanvas.width = imageData.width;
    sourceCanvas.height = imageData.height;
    const sourceCtx = sourceCanvas.getContext("2d");
    if (!sourceCtx) return { dataUrl: "", croppedImageData: null };
    sourceCtx.putImageData(imageData, 0, 0);
    ctx.drawImage(sourceCanvas, minX, minY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
    const croppedImageData = ctx.getImageData(0, 0, cropWidth, cropHeight);
    for (let y = 0; y < cropHeight; y += 1) {
      const row = y * cropWidth;
      for (let x = 0; x < cropWidth; x += 1) {
        const originalX = x + minX;
        const originalY = y + minY;
        const inside = selectedRegions.some(
          (r) =>
            originalX >= r.x &&
            originalY >= r.y &&
            originalX < r.x + r.w &&
            originalY < r.y + r.h
        );
        if (inside) continue;
        const i = (row + x) * 4;
        croppedImageData.data[i] = 255;
        croppedImageData.data[i + 1] = 255;
        croppedImageData.data[i + 2] = 255;
        croppedImageData.data[i + 3] = 255;
      }
    }
    ctx.putImageData(croppedImageData, 0, 0);
    lastCroppedImageData = croppedImageData;
    return { dataUrl: c.toDataURL("image/png"), croppedImageData };
  }

  function getMaskedByRegions(
    state: typeof drawingState,
    regions: Array<{ x: number; y: number; w: number; h: number }>
  ) {
    if (!state || !Array.isArray(regions) || regions.length === 0) return state!;
    const masked = new Uint8Array(state.mask);
    for (let y = 0; y < state.height; y += 1)
      for (let x = 0; x < state.width; x += 1) {
        if (!regions.some((r) => x >= r.x && y >= r.y && x < r.x + r.w && y < r.y + r.h))
          masked[y * state.width + x] = 0;
      }
    return { ...state, mask: masked };
  }

  // ── Region selection ───────────────────────────────────────────────

  function allRegionsResolved(): boolean {
    if (!baselineRegions.length) return false;
    for (let i = 0; i < baselineRegions.length; i++) {
      if (!excludedRegionIndexes.has(i) && !confirmedRegionIndexes.has(i)) return false;
    }
    return true;
  }

  function getActiveRegionSelection(state: typeof drawingState) {
    if (!state) {
      logWarn("getActiveRegionSelection: no state");
      return { regionsSource: [], selectedRegions: [], selectedRegionIndexes: new Set<number>() };
    }
    const fallback = [{ x: 0, y: 0, w: state.width, h: state.height }];
    const regionsSource = baselineRegions.length ? baselineRegions : fallback;
    const selectedWithIndex = regionsSource
      .map((region, idx) => ({ region, idx }))
      .filter((entry) => !excludedRegionIndexes.has(entry.idx) && confirmedRegionIndexes.has(entry.idx))
      .slice(0, MAX_REGIONS_TO_SCAN);
    log("getActiveRegionSelection:", {
      totalRegions: regionsSource.length,
      usingFallback: !baselineRegions.length,
      excluded: [...excludedRegionIndexes],
      confirmed: [...confirmedRegionIndexes],
      selected: selectedWithIndex.length,
    });
    return {
      regionsSource,
      selectedRegions: selectedWithIndex.map((entry) => entry.region),
      selectedRegionIndexes: new Set<number>(selectedWithIndex.map((entry) => entry.idx)),
    };
  }

  // ── Layer extraction engine ────────────────────────────────────────

  function initWorkingImage() {
    if (!lastCroppedImageData) {
      log("initWorkingImage: no cropped image available — skipping");
      return;
    }
    const src = lastCroppedImageData;
    workingImageData = new ImageData(
      new Uint8ClampedArray(src.data),
      src.width,
      src.height
    );
    layers = [];
    log("initWorkingImage: cloned cropped source", { width: src.width, height: src.height });
  }

  function resetLayers() {
    log("resetLayers");
    initWorkingImage();
    layers = [];
  }

  function extractPixelsByFilter(
    filterName: string,
    testFn: (r: number, g: number, b: number, a: number) => boolean
  ) {
    if (!workingImageData) initWorkingImage();
    if (!workingImageData) return;
    logTime(`extract:${filterName}`);
    const d = workingImageData.data;
    const { width, height } = workingImageData;
    const layerData = new ImageData(width, height);
    const ld = layerData.data;
    let count = 0;
    for (let i = 0; i < d.length; i += 4) {
      const r = d[i], g = d[i + 1], b = d[i + 2], a = d[i + 3];
      if (a < 2) continue;
      if (r === 255 && g === 255 && b === 255) continue;
      if (testFn(r, g, b, a)) {
        ld[i] = r; ld[i + 1] = g; ld[i + 2] = b; ld[i + 3] = a;
        d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
        count++;
      }
    }
    logTimeEnd(`extract:${filterName}`);
    log(`extract:${filterName}: ${count} pixels moved to layer`);
    if (count === 0) { logWarn(`extract:${filterName}: nothing found`); return; }
    layers.push({
      name: filterName,
      visible: true,
      imageDataUrl: imageDataToDataUrl(layerData),
      rawImageData: layerData,
      pixelCount: count,
    });
  }

  function extractColored() {
    extractPixelsByFilter("Pipes", (r, g, b) => {
      const max = Math.max(r, g, b);
      const min = Math.min(r, g, b);
      const sat = max > 0 ? (max - min) / max : 0;
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      return sat > 0.15 && gray < 240 && gray > 20;
    });
  }

  function extractText() {
    if (!workingImageData) return;
    const { width, height, data } = workingImageData;
    const visited = new Uint8Array(width * height);
    const components: Array<{ pixels: number[]; minX: number; minY: number; maxX: number; maxY: number }> = [];

    function floodFill(sx: number, sy: number) {
      const comp = { pixels: [] as number[], minX: sx, minY: sy, maxX: sx, maxY: sy };
      const stack = [sx + sy * width];
      visited[sy * width + sx] = 1;
      while (stack.length) {
        const pos = stack.pop()!;
        const px = pos % width;
        const py = (pos - px) / width;
        comp.pixels.push(pos);
        if (px < comp.minX) comp.minX = px;
        if (px > comp.maxX) comp.maxX = px;
        if (py < comp.minY) comp.minY = py;
        if (py > comp.maxY) comp.maxY = py;
        for (const [dx, dy] of [[-1,0],[1,0],[0,-1],[0,1]]) {
          const nx = px + dx, ny = py + dy;
          if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
          const ni = ny * width + nx;
          if (visited[ni]) continue;
          const i4 = ni * 4;
          const gray = data[i4] * 0.299 + data[i4+1] * 0.587 + data[i4+2] * 0.114;
          if (gray < 150 && data[i4+3] > 1 && !(data[i4] === 255 && data[i4+1] === 255 && data[i4+2] === 255)) {
            visited[ni] = 1;
            stack.push(ni);
          }
        }
      }
      return comp;
    }

    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x;
        if (visited[idx]) continue;
        const i4 = idx * 4;
        const gray = data[i4] * 0.299 + data[i4+1] * 0.587 + data[i4+2] * 0.114;
        if (gray >= 150 || data[i4+3] < 2 || (data[i4] === 255 && data[i4+1] === 255 && data[i4+2] === 255)) continue;
        const comp = floodFill(x, y);
        if (comp.pixels.length >= 3) components.push(comp);
      }
    }

    const textLayer = new ImageData(width, height);
    const td = textLayer.data;
    let count = 0;

    for (const comp of components) {
      const bw = comp.maxX - comp.minX + 1;
      const bh = comp.maxY - comp.minY + 1;
      const area = comp.pixels.length;
      const aspect = bw / Math.max(bh, 1);
      const density = area / (bw * bh);

      const isText = (
        bh < height * 0.04 &&
        bw < width * 0.15 &&
        area < 2000 &&
        density > 0.08 &&
        density < 0.9 &&
        aspect > 0.15 && aspect < 12
      );

      if (isText) {
        for (const pos of comp.pixels) {
          const i4 = pos * 4;
          td[i4] = data[i4]; td[i4+1] = data[i4+1]; td[i4+2] = data[i4+2]; td[i4+3] = data[i4+3];
          data[i4] = 255; data[i4+1] = 255; data[i4+2] = 255; data[i4+3] = 255;
          count++;
        }
      }
    }

    log(`extractText: analyzed ${components.length} components, ${count} text pixels extracted`);
    if (count === 0) { logWarn("extractText: no text found"); return; }
    layers.push({
      name: "Text / Labels",
      visible: true,
      imageDataUrl: imageDataToDataUrl(textLayer),
      rawImageData: textLayer,
      pixelCount: count,
    });
  }

  function extractDark() {
    extractPixelsByFilter("Dark Lines", (r, g, b) => {
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      return gray < 100 && spread < 60;
    });
  }

  function extractDashedRectangles() {
    if (!workingImageData) return;
    logTime("extractDashedRectangles");
    const { width, height, data } = workingImageData;

    function isInk(x: number, y: number): boolean {
      if (x < 0 || x >= width || y < 0 || y >= height) return false;
      const i = (y * width + x) * 4;
      if (data[i + 3] < 2) return false;
      if (data[i] === 255 && data[i + 1] === 255 && data[i + 2] === 255) return false;
      const gray = data[i] * 0.299 + data[i + 1] * 0.587 + data[i + 2] * 0.114;
      return gray < 220;
    }

    type Run = { start: number; end: number; len: number };

    function getRuns(max: number, pixel: (v: number) => boolean): Run[] {
      const runs: Run[] = [];
      let inRun = false, runStart = 0;
      for (let v = 0; v < max; v++) {
        if (pixel(v)) {
          if (!inRun) { inRun = true; runStart = v; }
        } else if (inRun) {
          runs.push({ start: runStart, end: v - 1, len: v - runStart });
          inRun = false;
        }
      }
      if (inRun) runs.push({ start: runStart, end: max - 1, len: max - runStart });
      return runs;
    }

    // --- Phase 1: discover the dominant dash/gap pattern via sampling ---
    const pairVotes = new Map<string, number>();
    const maxDash = 80;
    function quantize(v: number): number { return Math.round(v / 3) * 3; }

    function votePairs(runs: Run[]) {
      for (let i = 0; i < runs.length - 1; i++) {
        const a = runs[i], b = runs[i + 1];
        if (a.len > maxDash || b.len > maxDash || a.len < 2 || b.len < 2) continue;
        const gap = b.start - a.end - 1;
        if (gap < 1 || gap > 60) continue;
        const avgLen = quantize((a.len + b.len) / 2);
        const qGap = quantize(gap);
        if (avgLen < 2) continue;
        pairVotes.set(`${avgLen}:${qGap}`, (pairVotes.get(`${avgLen}:${qGap}`) || 0) + 1);
      }
    }

    for (let y = 0; y < height; y += 3) votePairs(getRuns(width, (x) => isInk(x, y)));
    for (let x = 0; x < width; x += 3) votePairs(getRuns(height, (y) => isInk(x, y)));

    if (pairVotes.size === 0) {
      logWarn("extractDashed: no run pairs found");
      logTimeEnd("extractDashedRectangles");
      return;
    }

    let bestKey = "", bestCount = 0;
    for (const [key, count] of pairVotes) {
      if (count > bestCount) { bestCount = count; bestKey = key; }
    }
    const patDash = Number(bestKey.split(":")[0]);
    const patGap = Number(bestKey.split(":")[1]);
    log(`extractDashed: pattern → dash ~${patDash}px, gap ~${patGap}px (${bestCount} votes)`);

    // --- Phase 2: find dashed segments on every row and column ---
    type Seg = { fixed: number; start: number; end: number; pixels: number[] };
    const hSegs: Seg[] = [];
    const vSegs: Seg[] = [];
    const lenTol = Math.max(patDash * 0.5, 3);
    const gapTol = Math.max(patGap * 0.7, 3);

    function findDashSegs(runs: Run[], fixed: number, dir: "h" | "v") {
      const segs: { start: number; end: number; runs: Run[] }[] = [];
      let chain: Run[] = [];
      for (let i = 0; i < runs.length; i++) {
        const r = runs[i];
        if (r.len > maxDash || Math.abs(r.len - patDash) > lenTol) {
          if (chain.length >= 2) segs.push({ start: chain[0].start, end: chain[chain.length - 1].end, runs: [...chain] });
          chain = [];
          continue;
        }
        if (chain.length > 0) {
          const prev = chain[chain.length - 1];
          const gap = r.start - prev.end - 1;
          if (Math.abs(gap - patGap) > gapTol) {
            if (chain.length >= 2) segs.push({ start: chain[0].start, end: chain[chain.length - 1].end, runs: [...chain] });
            chain = [r];
            continue;
          }
        }
        chain.push(r);
      }
      if (chain.length >= 2) segs.push({ start: chain[0].start, end: chain[chain.length - 1].end, runs: [...chain] });

      for (const seg of segs) {
        const pixels: number[] = [];
        for (const r of seg.runs) {
          for (let v = r.start; v <= r.end; v++) {
            const idx = dir === "h" ? fixed * width + v : v * width + fixed;
            pixels.push(idx);
          }
        }
        (dir === "h" ? hSegs : vSegs).push({ fixed, start: seg.start, end: seg.end, pixels });
      }
    }

    for (let y = 0; y < height; y++) findDashSegs(getRuns(width, (x) => isInk(x, y)), y, "h");
    for (let x = 0; x < width; x++) findDashSegs(getRuns(height, (y) => isInk(x, y)), x, "v");

    log(`extractDashed: ${hSegs.length} h-segments, ${vSegs.length} v-segments`);

    // --- Phase 3: merge nearby parallel segments into edges ---
    type Edge = { dir: "h" | "v"; fixedMin: number; fixedMax: number; fixedAvg: number; varStart: number; varEnd: number; pixels: number[] };

    function mergeSegs(segs: Seg[], fixTol: number, overlapMin: number): Edge[] {
      const sorted = [...segs].sort((a, b) => a.fixed - b.fixed || a.start - b.start);
      const used = new Set<number>();
      const edges: Edge[] = [];
      for (let i = 0; i < sorted.length; i++) {
        if (used.has(i)) continue;
        const group = [sorted[i]];
        used.add(i);
        for (let j = i + 1; j < sorted.length; j++) {
          if (used.has(j)) continue;
          if (sorted[j].fixed - sorted[i].fixed > fixTol) break;
          const oStart = Math.max(sorted[i].start, sorted[j].start);
          const oEnd = Math.min(sorted[i].end, sorted[j].end);
          if (oEnd - oStart >= overlapMin) { group.push(sorted[j]); used.add(j); }
        }
        const allPx: number[] = [];
        let fMin = Infinity, fMax = -Infinity, vStart = Infinity, vEnd = -Infinity;
        for (const s of group) {
          fMin = Math.min(fMin, s.fixed); fMax = Math.max(fMax, s.fixed);
          vStart = Math.min(vStart, s.start); vEnd = Math.max(vEnd, s.end);
          allPx.push(...s.pixels);
        }
        edges.push({ dir: "h", fixedMin: fMin, fixedMax: fMax, fixedAvg: Math.round((fMin + fMax) / 2), varStart: vStart, varEnd: vEnd, pixels: allPx });
      }
      return edges;
    }

    const thickness = Math.max(patDash * 0.5, 6);
    const hEdges = mergeSegs(hSegs, thickness, patDash);
    const vEdges = mergeSegs(vSegs, thickness, patDash);
    hEdges.forEach(e => e.dir = "h");
    vEdges.forEach(e => e.dir = "v");

    log(`extractDashed: ${hEdges.length} h-edges, ${vEdges.length} v-edges`);

    // --- Phase 4: find closed rectangles ---
    type Rect = { top: Edge; bottom: Edge; left: Edge; right: Edge };
    const rects: Rect[] = [];
    const cornerTol = thickness + patGap;

    for (let ti = 0; ti < hEdges.length; ti++) {
      const top = hEdges[ti];
      for (let bi = ti + 1; bi < hEdges.length; bi++) {
        const bottom = hEdges[bi];
        if (bottom.fixedAvg - top.fixedAvg < 30) continue;
        const oStart = Math.max(top.varStart, bottom.varStart);
        const oEnd = Math.min(top.varEnd, bottom.varEnd);
        if (oEnd - oStart < 30) continue;

        for (const left of vEdges) {
          if (Math.abs(left.fixedAvg - oStart) > cornerTol) continue;
          if (left.varStart > top.fixedAvg + cornerTol) continue;
          if (left.varEnd < bottom.fixedAvg - cornerTol) continue;

          for (const right of vEdges) {
            if (right.fixedAvg <= left.fixedAvg + 30) continue;
            if (Math.abs(right.fixedAvg - oEnd) > cornerTol) continue;
            if (right.varStart > top.fixedAvg + cornerTol) continue;
            if (right.varEnd < bottom.fixedAvg - cornerTol) continue;

            rects.push({ top, bottom, left, right });
          }
        }
      }
    }

    log(`extractDashed: ${rects.length} closed rectangles found`);

    // Collect edges to extract
    const edgesToExtract: Edge[] = [];
    if (rects.length > 0) {
      const rectEdges = new Set<Edge>();
      for (const r of rects) { rectEdges.add(r.top); rectEdges.add(r.bottom); rectEdges.add(r.left); rectEdges.add(r.right); }
      edgesToExtract.push(...rectEdges);
    } else {
      log(`extractDashed: no closed rects — falling back to all ${hEdges.length + vEdges.length} dashed edges`);
      edgesToExtract.push(...hEdges, ...vEdges);
    }

    if (edgesToExtract.length === 0) {
      logWarn("extractDashed: nothing to extract");
      logTimeEnd("extractDashedRectangles");
      return;
    }

    const layerData = new ImageData(width, height);
    const ld = layerData.data;
    let count = 0;
    const extracted = new Set<number>();

    for (const edge of edgesToExtract) {
      for (const pos of edge.pixels) {
        if (extracted.has(pos)) continue;
        extracted.add(pos);
        const i4 = pos * 4;
        if (data[i4] === 255 && data[i4 + 1] === 255 && data[i4 + 2] === 255) continue;
        ld[i4] = data[i4]; ld[i4+1] = data[i4+1]; ld[i4+2] = data[i4+2]; ld[i4+3] = data[i4+3];
        data[i4] = 255; data[i4+1] = 255; data[i4+2] = 255; data[i4+3] = 255;
        count++;
      }
    }

    logTimeEnd("extractDashedRectangles");
    const label = rects.length > 0
      ? `Dashed Rects (${rects.length}) ~${patDash}/${patGap}px`
      : `Dashed Segs (${edgesToExtract.length}) ~${patDash}/${patGap}px`;
    log(`extractDashed: ${count} pixels — ${label}`);
    if (count === 0) return;
    layers.push({
      name: label,
      visible: true,
      imageDataUrl: imageDataToDataUrl(layerData),
      rawImageData: layerData,
      pixelCount: count,
    });
  }

  function extractMidtones() {
    extractPixelsByFilter("Midtones / Gray", (r, g, b) => {
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      return gray >= 100 && gray < 220 && spread < 50;
    });
  }

  function extractRemaining() {
    extractPixelsByFilter("Remaining", (r, g, b, a) => {
      return !(r === 255 && g === 255 && b === 255) && a > 1;
    });
  }

  // ── Layer panel rendering ─────────────────────────────────────────

  function renderInlineLayerPanel() {
    const panel = document.getElementById("layer-inline-panel");
    const mainImg = document.getElementById("working-canvas-img") as HTMLImageElement | null;
    if (!panel) return;

    const totalExtracted = layers.reduce((sum, l) => sum + l.pixelCount, 0);

    const layerRows = layers.map((layer, i) =>
      `<label class="flex items-center gap-2 rounded px-2 py-1 hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer">
        <input type="checkbox" data-layer-toggle="${i}" ${layer.visible ? "checked" : ""} class="rounded" />
        <span class="flex-1 text-xs font-medium text-gray-800 dark:text-gray-200">${layer.name}</span>
        <span class="text-[10px] text-gray-400">${(layer.pixelCount / 1000).toFixed(1)}k px</span>
      </label>`
    ).join("");

    panel.innerHTML = `
      <p class="mb-2 text-xs text-gray-500 dark:text-gray-400">${layers.length} layer(s) extracted, ${totalExtracted.toLocaleString()} total pixels</p>
      <div class="mb-3 flex flex-wrap gap-2">
        <button type="button" data-extract="colored" class="rounded bg-amber-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-amber-700">Extract Pipes</button>
        <button type="button" data-extract="text" class="rounded bg-indigo-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-indigo-700">Extract Text</button>
        <button type="button" data-extract="dark" class="rounded bg-gray-800 px-2 py-1 text-[11px] font-semibold text-white hover:bg-gray-900 dark:bg-gray-600">Extract Dark Lines</button>
        <button type="button" data-extract="dashed" class="rounded bg-cyan-700 px-2 py-1 text-[11px] font-semibold text-white hover:bg-cyan-800">Extract Dashed Rects</button>
        <button type="button" data-extract="midtones" class="rounded bg-gray-500 px-2 py-1 text-[11px] font-semibold text-white hover:bg-gray-600">Extract Midtones</button>
        <button type="button" data-extract="remaining" class="rounded bg-slate-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-slate-700">Extract Remaining</button>
        ${layers.length > 0 ? '<button type="button" data-extract="reset" class="rounded bg-red-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-red-700">Reset Layers</button>' : ""}
      </div>
      <div class="mb-2 space-y-0.5">
        <label class="flex items-center gap-2 rounded px-2 py-1 hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer">
          <input type="checkbox" id="toggle-working-layer" ${showWorkingLayer ? "checked" : ""} class="rounded" />
          <span class="flex-1 text-xs font-medium text-gray-800 dark:text-gray-200">Working Document</span>
          <span class="text-[10px] text-gray-400">remaining</span>
        </label>
        ${layerRows}
      </div>
    `;

    updateCompositeImage();
    wireInlineLayerEvents(panel);
  }

  function updateCompositeImage() {
    const imgEl = document.getElementById("working-canvas-img") as HTMLImageElement | null;
    if (!imgEl) return;

    const w = workingImageData?.width || lastCroppedImageData?.width || 0;
    const h = workingImageData?.height || lastCroppedImageData?.height || 0;
    if (!w || !h) return;

    const compositeCanvas = document.createElement("canvas");
    compositeCanvas.width = w;
    compositeCanvas.height = h;
    const ctx = compositeCanvas.getContext("2d");
    if (!ctx) return;

    if (showWorkingLayer && workingImageData) {
      ctx.putImageData(workingImageData, 0, 0);
    }

    layers.forEach(layer => {
      if (!layer.visible) return;
      const tmp = document.createElement("canvas");
      tmp.width = layer.rawImageData.width;
      tmp.height = layer.rawImageData.height;
      const tmpCtx = tmp.getContext("2d");
      if (!tmpCtx) return;
      tmpCtx.putImageData(layer.rawImageData, 0, 0);
      ctx.drawImage(tmp, 0, 0);
    });

    imgEl.src = compositeCanvas.toDataURL("image/png");
  }

  function wireInlineLayerEvents(el: HTMLElement) {
    el.querySelectorAll("[data-extract]").forEach(btn => {
      btn.addEventListener("click", () => {
        const action = (btn as HTMLElement).getAttribute("data-extract");
        log("Layer extraction:", action);
        if (action === "colored") extractColored();
        else if (action === "text") extractText();
        else if (action === "dark") extractDark();
        else if (action === "dashed") extractDashedRectangles();
        else if (action === "midtones") extractMidtones();
        else if (action === "remaining") extractRemaining();
        else if (action === "reset") resetLayers();
        renderInlineLayerPanel();
      });
    });

    el.querySelector("#toggle-working-layer")?.addEventListener("change", (e) => {
      showWorkingLayer = (e.target as HTMLInputElement).checked;
      log("Toggle working layer →", showWorkingLayer);
      updateCompositeImage();
    });

    el.querySelectorAll("[data-layer-toggle]").forEach(cb => {
      cb.addEventListener("change", (e) => {
        const idx = Number((cb as HTMLElement).getAttribute("data-layer-toggle"));
        if (layers[idx]) {
          layers[idx].visible = (e.target as HTMLInputElement).checked;
          log(`Toggle layer ${idx} (${layers[idx].name}) →`, layers[idx].visible);
          updateCompositeImage();
        }
      });
    });
  }

  // ── Canvas overlay drawing ─────────────────────────────────────────

  function drawOverlay() {
    const ctx = getCtx();
    if (!ctx || !drawingState) { logWarn("drawOverlay: skipped (no ctx or state)"); return; }
    log("drawOverlay: drawing", baselineRegions.length, "region box(es)");
    ctx.putImageData(drawingState.imageData, 0, 0);
    ctx.lineWidth = 2;
    baselineRegions.forEach((r, idx) => {
      const excluded = excludedRegionIndexes.has(idx);
      ctx.strokeStyle = excluded ? "rgba(239,68,68,0.95)" : "rgba(56,189,248,0.95)";
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      if (excluded) {
        ctx.beginPath();
        ctx.moveTo(r.x + 3, r.y + 3);
        ctx.lineTo(r.x + r.w - 3, r.y + r.h - 3);
        ctx.moveTo(r.x + r.w - 3, r.y + 3);
        ctx.lineTo(r.x + 3, r.y + r.h - 3);
        ctx.stroke();
      }
    });
  }

  // ── Pipeline rendering ─────────────────────────────────────────────

  function renderPipelineSteps({
    sourceImageData,
    regions,
    selectedRegions,
  }: {
    sourceImageData: ImageData;
    regions: Array<{ x: number; y: number; w: number; h: number }>;
    selectedRegions: Array<{ x: number; y: number; w: number; h: number }>;
  }) {
    if (!pipelineStepsEl) { logWarn("renderPipelineSteps: no pipelineStepsEl"); return; }
    logTime("renderPipelineSteps");
    log("renderPipelineSteps:", {
      sourceSize: `${sourceImageData.width}x${sourceImageData.height}`,
      candidateRegions: regions.length,
      selectedRegions: selectedRegions.length,
      excludedCount: excludedRegionIndexes.size,
    });

    const imgW = sourceImageData.width;
    const imgH = sourceImageData.height;
    croppedMaskedSource(sourceImageData, selectedRegions);
    const step1BaseImageUrl = imageDataToDataUrl(sourceImageData);

    const step1SelectedEntries = regions
      .map((region, idx) => ({ region, idx }))
      .filter((entry) => !excludedRegionIndexes.has(entry.idx))
      .slice(0, MAX_REGIONS_TO_SCAN);

    const regionBoxesHtml = step1SelectedEntries.map(({ region: r, idx }) => {
      const leftPct = (r.x / imgW) * 100;
      const topPct = (r.y / imgH) * 100;
      const widthPct = (r.w / imgW) * 100;
      const heightPct = (r.h / imgH) * 100;
      const confirmed = confirmedRegionIndexes.has(idx);
      const borderColor = confirmed ? "border-emerald-500" : "border-sky-400";
      const bgColor = confirmed ? "bg-emerald-400/[0.15]" : "bg-sky-400/[0.12]";
      const handlesHtml = HANDLE_DEFS.map(h =>
        `<span data-handle="${h.anchor}" class="absolute z-20 h-[10px] w-[10px] rounded-full border border-white bg-blue-500 shadow-sm" style="${h.css};pointer-events:auto"></span>`
      ).join("");
      const checkIcon = confirmed
        ? `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`
        : `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
      const checkBg = confirmed
        ? "bg-emerald-500 border-emerald-700 text-white"
        : "bg-white/80 border-gray-400 text-gray-400 hover:border-emerald-500 hover:text-emerald-500";
      return `<div class="simple-scan-region-box absolute cursor-move" data-region-idx="${idx}" style="left:${leftPct}%;top:${topPct}%;width:${widthPct}%;height:${heightPct}%;display:${showRegionOverlays ? "block" : "none"}"><div class="pointer-events-none absolute inset-0 border-2 ${borderColor} ${bgColor}"></div><span class="pointer-events-none absolute left-1 top-0.5 text-[11px] font-bold text-sky-800 drop-shadow-[0_1px_1px_rgba(255,255,255,0.9)]">R${idx + 1}</span><button type="button" data-confirm-idx="${idx}" class="absolute left-1/2 top-1/2 z-30 flex h-8 w-8 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-2 ${checkBg} shadow-lg transition-colors" title="${confirmed ? "Unconfirm" : "Confirm"} R${idx + 1}">${checkIcon}</button><button type="button" data-remove-idx="${idx}" class="absolute -right-2 -top-2 z-30 flex h-5 w-5 items-center justify-center rounded-full border border-red-700 bg-red-600 text-[12px] font-bold leading-none text-white shadow hover:bg-red-700" title="Remove R${idx + 1}">×</button>${handlesHtml}</div>`;
    }).join("");

    const resetHtml = regions.length > 0
      ? `<div class="mb-2 flex flex-wrap items-center gap-2">${excludedRegionIndexes.size > 0 ? '<button type="button" id="simple-scan-reset-removed" class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600">Reset removed sections</button>' : ""}<button type="button" id="simple-scan-remove-all" class="rounded bg-red-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-red-700">Remove all sections</button></div>`
      : "";

    const resolved = allRegionsResolved();
    const hasConfirmed = confirmedRegionIndexes.size > 0;

    if (resolved && hasConfirmed) {
      if (!workingImageData) {
        initWorkingImage();
        extractColored();
        extractText();
        extractDashedRectangles();
        extractDark();
        extractMidtones();
        extractRemaining();
        log("Auto-extracted all layers:", layers.length);
      }
      const croppedUrl = lastCroppedImageData ? imageDataToDataUrl(lastCroppedImageData) : "";

      // Image only in main area
      pipelineStepsEl.innerHTML = `
        <div class="relative bg-white dark:bg-gray-900">
          <img id="working-canvas-img" src="${croppedUrl}" class="block w-full" />
        </div>
      `;

      // Controls in drawer
      if (drawerControlsEl) {
        drawerControlsEl.innerHTML = `
          <button type="button" id="simple-scan-back-to-regions" class="w-full rounded bg-gray-700 px-2 py-1.5 text-[11px] font-semibold text-white dark:bg-gray-600">← Back to regions</button>
          <div id="layer-inline-panel"></div>
        `;
        drawerControlsEl.querySelector("#simple-scan-back-to-regions")?.addEventListener("click", () => {
          log("Back to region confirmation");
          confirmedRegionIndexes.clear();
          workingImageData = null;
          layers = [];
          renderProcessingOnlyView();
        });
      }
      renderInlineLayerPanel();
    } else {
      const pending = regions.length - confirmedRegionIndexes.size - excludedRegionIndexes.size;

      // Image only in main area (with region overlays which are interactive on the image)
      pipelineStepsEl.innerHTML = `
        <div id="step1-image-container" class="relative bg-white dark:bg-gray-900" style="overflow:visible">
          <img src="${step1BaseImageUrl}" alt="Regions" class="block w-full select-none" draggable="false" />
          ${regionBoxesHtml}
        </div>
      `;

      // Controls in drawer
      if (drawerControlsEl) {
        drawerControlsEl.innerHTML = `
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">Confirm Viable Areas</p>
          <p class="mb-2 text-xs text-gray-500 dark:text-gray-400">${regions.length} detected · ${confirmedRegionIndexes.size} confirmed · ${excludedRegionIndexes.size} removed · ${pending} pending</p>
          ${resetHtml}
          <div class="flex flex-wrap items-center gap-2">
            <button type="button" id="simple-scan-toggle-overlays" class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600">${showRegionOverlays ? "Hide regions" : "Show regions"}</button>
          </div>
        `;
      }
      wireRegionEvents();
    }
    logTimeEnd("renderPipelineSteps");
    log("renderPipelineSteps: DOM updated");
  }

  function wireRegionEvents() {
    if (!pipelineStepsEl) return;

    pipelineStepsEl.querySelectorAll("[data-confirm-idx]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const idx = Number((btn as HTMLElement).getAttribute("data-confirm-idx"));
        if (!Number.isFinite(idx)) return;
        if (confirmedRegionIndexes.has(idx)) {
          log(`Region R${idx + 1} unconfirmed`);
          confirmedRegionIndexes.delete(idx);
        } else {
          log(`Region R${idx + 1} confirmed`);
          confirmedRegionIndexes.add(idx);
        }
        renderProcessingOnlyView();
      });
    });

    pipelineStepsEl.querySelectorAll("[data-remove-idx]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const idx = Number((btn as HTMLElement).getAttribute("data-remove-idx"));
        if (Number.isFinite(idx)) {
          log(`Region R${idx + 1} removed`);
          excludedRegionIndexes.add(idx);
          confirmedRegionIndexes.delete(idx);
          renderProcessingOnlyView();
        }
      });
    });

    drawerControlsEl?.querySelector("#simple-scan-reset-removed")?.addEventListener("click", () => {
      log("Reset removed regions");
      excludedRegionIndexes.clear();
      confirmedRegionIndexes.clear();
      renderProcessingOnlyView();
    });

    drawerControlsEl?.querySelector("#simple-scan-remove-all")?.addEventListener("click", () => {
      log("Remove all regions");
      baselineRegions.forEach((_, i) => excludedRegionIndexes.add(i));
      confirmedRegionIndexes.clear();
      renderProcessingOnlyView();
    });

    drawerControlsEl?.querySelector("#simple-scan-toggle-overlays")?.addEventListener("click", () => {
      showRegionOverlays = !showRegionOverlays;
      log("Toggle overlays →", showRegionOverlays);
      renderProcessingOnlyView();
    });

    pipelineStepsEl.querySelectorAll(".simple-scan-region-box").forEach(box => {
      box.addEventListener("pointerdown", (event: Event) => {
        const e = event as PointerEvent;
        if ((e.target as HTMLElement).closest("[data-handle]") || (e.target as HTMLElement).closest("[data-remove-idx]") || (e.target as HTMLElement).closest("[data-confirm-idx]")) return;
        e.preventDefault();
        const idx = Number((box as HTMLElement).getAttribute("data-region-idx"));
        if (!Number.isFinite(idx) || !baselineRegions[idx]) return;
        log("Region drag start:", idx);
        activeRegionIdx = idx;
        const scale = getImageScale();
        regionDragState = {
          idx, startX: e.clientX, startY: e.clientY,
          orig: { ...baselineRegions[idx] },
          pxPerImgX: scale.pxPerImgX, pxPerImgY: scale.pxPerImgY,
        };
        (box as HTMLElement).style.cursor = "grabbing";
      });
    });

    pipelineStepsEl.querySelectorAll("[data-handle]").forEach(handle => {
      handle.addEventListener("pointerdown", (event: Event) => {
        const e = event as PointerEvent;
        e.preventDefault();
        e.stopPropagation();
        const anchor = (handle as HTMLElement).getAttribute("data-handle") || "";
        const box = (handle as HTMLElement).closest(".simple-scan-region-box") as HTMLElement | null;
        const idx = Number(box?.getAttribute("data-region-idx"));
        if (!Number.isFinite(idx) || !baselineRegions[idx]) return;
        log("Handle drag start:", { idx, anchor });
        activeRegionIdx = idx;
        const scale = getImageScale();
        handleDragState = {
          idx, anchor, startX: e.clientX, startY: e.clientY,
          orig: { ...baselineRegions[idx] },
          pxPerImgX: scale.pxPerImgX, pxPerImgY: scale.pxPerImgY,
        };
      });
    });
  }

  // ── Main processing view ───────────────────────────────────────────

  function renderProcessingOnlyView() {
    logTime("renderProcessingOnlyView");
    log("renderProcessingOnlyView called");
    if (!drawingState) { logWarn("renderProcessingOnlyView: no drawingState, aborting"); return; }
    if (!baselineRegions.length) {
      log("renderProcessingOnlyView: no baseline regions yet, running extractBaselineRegions...");
      baselineRegions = extractBaselineRegions(drawingState);
    }
    const { regionsSource, selectedRegions } = getActiveRegionSelection(drawingState);

    renderPipelineSteps({
      sourceImageData: drawingState.imageData,
      regions: regionsSource,
      selectedRegions,
    });
    drawOverlay();

    const pending = baselineRegions.length - confirmedRegionIndexes.size - excludedRegionIndexes.size;
    const resolved = allRegionsResolved();
    const summary = {
      mode: "detect-and-extract",
      regionsDetected: baselineRegions.length,
      regionsConfirmed: confirmedRegionIndexes.size,
      regionsRemoved: excludedRegionIndexes.size,
      regionsPending: pending,
      allResolved: resolved,
    };
    if (resultsEl) resultsEl.textContent = JSON.stringify(summary, null, 2);
    log("renderProcessingOnlyView complete:", summary);
    logTimeEnd("renderProcessingOnlyView");
    if (resolved && confirmedRegionIndexes.size > 0) {
      setStatus(`All regions resolved. ${confirmedRegionIndexes.size} confirmed — ready for layer extraction.`);
    } else if (resolved && confirmedRegionIndexes.size === 0) {
      setStatus(`All regions removed. No viable areas to process.`);
    } else {
      setStatus(`${baselineRegions.length} region(s) detected. Confirm or remove each to continue. ${pending} pending.`);
    }
  }

  // ── PDF / Image loading ────────────────────────────────────────────

  async function renderPdfToImage(file: File): Promise<HTMLImageElement | null> {
    log("renderPdfToImage: starting with", file.name, `(${(file.size / 1024).toFixed(1)} KB)`);
    for (const scale of PDF_RENDER_SCALE_FALLBACKS) {
      try {
        log(`renderPdfToImage: trying scale ${scale}...`);
        logTime(`renderPdfToImage-scale-${scale}`);
        const pdfLib = getPdfLib();
        if (!pdfLib) { logError("renderPdfToImage: pdfjsLib not available"); return null; }
        const pdf = await pdfLib.getDocument({ data: await file.arrayBuffer() }).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale });
        const c = document.createElement("canvas");
        c.width = Math.max(1, Math.floor(viewport.width));
        c.height = Math.max(1, Math.floor(viewport.height));
        log(`renderPdfToImage: scale ${scale} → canvas ${c.width}x${c.height}`);
        const ctx = c.getContext("2d", { willReadFrequently: true });
        if (!ctx) { logWarn(`renderPdfToImage: scale ${scale} no 2d context, skipping`); continue; }
        await page.render({ canvasContext: ctx, viewport }).promise;
        const img = new Image();
        img.src = c.toDataURL("image/png");
        await new Promise((resolve, reject) => {
          img.onload = resolve;
          img.onerror = reject;
        });
        lastPdfRenderScale = scale;
        logTimeEnd(`renderPdfToImage-scale-${scale}`);
        log(`renderPdfToImage: success at scale ${scale}, image ${img.naturalWidth}x${img.naturalHeight}`);
        return img;
      } catch (error) {
        logWarn(`renderPdfToImage: scale ${scale} failed:`, error);
      }
    }
    logError("renderPdfToImage: all scales failed");
    return null;
  }

  async function loadImageFromFile(file: File): Promise<HTMLImageElement | null> {
    log("loadImageFromFile:", file.name, `(${(file.size / 1024).toFixed(1)} KB, type: ${file.type})`);
    return await new Promise((resolve: (image: HTMLImageElement | null) => void) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => {
          log(`loadImageFromFile: loaded ${img.naturalWidth}x${img.naturalHeight}`);
          resolve(img);
        };
        img.onerror = () => { logError("loadImageFromFile: image decode failed"); resolve(null); };
        img.src = String(reader.result || "");
      };
      reader.onerror = () => { logError("loadImageFromFile: FileReader error"); resolve(null); };
      reader.readAsDataURL(file);
    });
  }

  async function handleDrawingUpload(file: File) {
    if (!(file instanceof File)) { logWarn("handleDrawingUpload: not a File"); return; }
    logTime("handleDrawingUpload");
    log("handleDrawingUpload:", file.name, `(${(file.size / 1024).toFixed(1)} KB, type: ${file.type})`);
    setStatus("Rendering drawing...");
    lastPdfRenderScale = 0;
    const isPdf = file.name.toLowerCase().endsWith(".pdf") || file.type === "application/pdf";
    const isSvg = file.name.toLowerCase().endsWith(".svg") || file.type === "image/svg+xml";
    log("handleDrawingUpload: format detected →", isPdf ? "PDF" : isSvg ? "SVG" : "Image");
    const img: HTMLImageElement | null = isPdf
      ? await renderPdfToImage(file)
      : await loadImageFromFile(file);
    if (!img || !(canvas instanceof HTMLCanvasElement)) {
      logError("handleDrawingUpload: failed to render image or no canvas");
      return setStatus("Failed to render drawing");
    }
    const ctx = getCtx();
    if (!ctx) { logError("handleDrawingUpload: no 2d context"); return; }
    const ratio = Math.min(
      isSvg ? 10 : 1,
      DRAWING_RENDER_MAX_SIDE /
        Math.max(img.naturalWidth || img.width, img.naturalHeight || img.height)
    );
    canvas.width = Math.max(1, Math.round((img.naturalWidth || img.width) * ratio));
    canvas.height = Math.max(1, Math.round((img.naturalHeight || img.height) * ratio));
    log("handleDrawingUpload: canvas sized to", canvas.width, "x", canvas.height, "ratio:", ratio.toFixed(4));
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    log("handleDrawingUpload: imageData captured, building seed mask...");
    drawingState = {
      width: canvas.width,
      height: canvas.height,
      imageData,
      mask: imageToRegionSeedMask(imageData),
    };
    setStatus(
      `Rendered ${canvas.width}x${canvas.height}${lastPdfRenderScale ? ` @ PDF scale ${lastPdfRenderScale}` : ""}. Detecting regions...`
    );
    log("handleDrawingUpload: extracting baseline regions...");
    baselineRegions = extractBaselineRegions(drawingState);
    excludedRegionIndexes.clear();
    confirmedRegionIndexes.clear();
    lastCroppedImageData = null;
    workingImageData = null;
    layers = [];
    if (drawerControlsEl) drawerControlsEl.innerHTML = "";
    log("handleDrawingUpload: calling renderProcessingOnlyView...");
    renderProcessingOnlyView();
    logTimeEnd("handleDrawingUpload");
    log("handleDrawingUpload: complete ✓");
  }

  // ── Event wiring ───────────────────────────────────────────────────

  async function loadSelectedDrawing() {
    if (!testSelect) { logWarn("loadSelectedDrawing: no select element"); return; }
    const raw = testSelect.value;
    if (!raw) { logWarn("loadSelectedDrawing: empty select value"); return; }
    const url = encodeURI(raw);
    const label = testSelect.options[testSelect.selectedIndex]?.textContent || raw;
    log("loadSelectedDrawing:", label, "→", url);
    setStatus(`Loading ${label}...`);
    try {
      const res = await fetch(url, { cache: "no-store" });
      log("loadSelectedDrawing: fetch", res.status, res.statusText);
      if (!res.ok) { logError("loadSelectedDrawing: fetch failed", res.status, url); setStatus(`Failed to load ${label}`); return; }
      const blob = await res.blob();
      const filename = raw.split("/").pop() || "drawing.pdf";
      log(`loadSelectedDrawing: ${(blob.size / 1024).toFixed(1)} KB`);
      await handleDrawingUpload(new File([blob], filename, { type: blob.type || "application/pdf" }));
    } catch (err) {
      logError("loadSelectedDrawing: error", err);
      setStatus(`Error loading ${label}`);
    }
  }

  drawingFileInput?.addEventListener("change", async () => {
    const file = drawingFileInput.files?.[0];
    log("File input changed:", file ? `${file.name} (${(file.size / 1024).toFixed(1)} KB)` : "no file");
    if (file) await handleDrawingUpload(file);
  });

  if (testSelect) {
    log("testSelect FOUND, options:", testSelect.options.length);
    testSelect.addEventListener("change", async () => {
      log("SELECT CHANGED →", testSelect.value);
      if (drawingFileInput) drawingFileInput.value = "";
      await loadSelectedDrawing();
    });
  } else {
    logWarn("testSelect NOT FOUND in DOM");
  }

  const onPointerMove = (e: PointerEvent) => {
    if (!drawingState) return;
    const { width: imgW, height: imgH } = drawingState;

    if (handleDragState) {
      const dx = (e.clientX - handleDragState.startX) / handleDragState.pxPerImgX;
      const dy = (e.clientY - handleDragState.startY) / handleDragState.pxPerImgY;
      const o = handleDragState.orig;
      const a = handleDragState.anchor;
      let x = o.x, y = o.y, w = o.w, h = o.h;

      if (a.includes("w")) { x = o.x + dx; w = o.w - dx; }
      if (a.includes("e")) { w = o.w + dx; }
      if (a.includes("n")) { y = o.y + dy; h = o.h - dy; }
      if (a.includes("s")) { h = o.h + dy; }

      if (w < MIN_REGION_SIZE) { if (a.includes("w")) x = o.x + o.w - MIN_REGION_SIZE; w = MIN_REGION_SIZE; }
      if (h < MIN_REGION_SIZE) { if (a.includes("n")) y = o.y + o.h - MIN_REGION_SIZE; h = MIN_REGION_SIZE; }
      x = clamp(x, 0, imgW - MIN_REGION_SIZE);
      y = clamp(y, 0, imgH - MIN_REGION_SIZE);
      w = clamp(w, MIN_REGION_SIZE, imgW - x);
      h = clamp(h, MIN_REGION_SIZE, imgH - y);

      baselineRegions[handleDragState.idx] = { x: Math.round(x), y: Math.round(y), w: Math.round(w), h: Math.round(h) };
      updateRegionBoxStyle(handleDragState.idx);
      return;
    }

    if (regionDragState) {
      const dx = (e.clientX - regionDragState.startX) / regionDragState.pxPerImgX;
      const dy = (e.clientY - regionDragState.startY) / regionDragState.pxPerImgY;
      const o = regionDragState.orig;
      const x = clamp(o.x + dx, 0, imgW - o.w);
      const y = clamp(o.y + dy, 0, imgH - o.h);
      baselineRegions[regionDragState.idx] = { x: Math.round(x), y: Math.round(y), w: o.w, h: o.h };
      updateRegionBoxStyle(regionDragState.idx);
      return;
    }
  };

  const onPointerUp = () => {
    const wasDragging = regionDragState || handleDragState;
    if (regionDragState) {
      const box = pipelineStepsEl?.querySelector(
        `.simple-scan-region-box[data-region-idx="${regionDragState.idx}"]`
      ) as HTMLElement | null;
      if (box) box.style.cursor = "";
    }
    regionDragState = null;
    handleDragState = null;
    if (wasDragging) {
      log("Drag ended, refreshing view");
      renderProcessingOnlyView();
    }
  };

  window.addEventListener("pointermove", onPointerMove);
  window.addEventListener("pointerup", onPointerUp);
  window.addEventListener("pointercancel", onPointerUp);
  runScanBtn?.addEventListener("click", () => {
    log("Refresh Processing button clicked");
    renderProcessingOnlyView();
  });
  log("Event listeners wired");

  // Auto-load the initially selected test drawing
  (async () => {
    try {
      log("Auto-load: waiting for pdfjsLib...");
      while (!getPdfLib()) await new Promise((r) => setTimeout(r, 100));
      log("Auto-load: pdfjsLib ready, loading selected drawing...");
      await loadSelectedDrawing();
    } catch (err) {
      logError("Auto-load: error", err);
      setStatus("Could not auto-load default drawing.");
    }
  })();
</script>
