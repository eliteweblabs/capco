  function stopPlayback() {
    if (traceTimer !== null) {
      window.clearInterval(traceTimer);
      traceTimer = null;
    }
  }

  function buildGridFromMask(mask, width, height, comp, gridSize = BASE_GRID_SIZE) {
    const grid = new Array(gridSize * gridSize).fill(0);
    for (let gy = 0; gy < gridSize; gy += 1) {
      const y0 = comp.y + Math.floor((gy / gridSize) * comp.h);
      const y1 = comp.y + Math.floor(((gy + 1) / gridSize) * comp.h);
      for (let gx = 0; gx < gridSize; gx += 1) {
        const x0 = comp.x + Math.floor((gx / gridSize) * comp.w);
        const x1 = comp.x + Math.floor(((gx + 1) / gridSize) * comp.w);
        let on = 0;
        let total = 0;
        for (let y = y0; y <= Math.max(y0, y1 - 1); y += 1) {
          if (y < 0 || y >= height) continue;
          for (let x = x0; x <= Math.max(x0, x1 - 1); x += 1) {
            if (x < 0 || x >= width) continue;
            total += 1;
            if (mask[y * width + x]) on += 1;
          }
        }
        grid[gy * gridSize + gx] = total > 0 ? on / total : 0;
      }
    }
    return grid;
  }

  function scoreGridSimilarity(a, b) {
    if (!Array.isArray(a) || !Array.isArray(b) || a.length !== b.length || a.length === 0) return 0;
    let diffSum = 0;
    for (let i = 0; i < a.length; i += 1) diffSum += Math.abs(a[i] - b[i]);
    return clamp(1 - diffSum / a.length, 0, 1);
  }

  function buildPolarDetailProfile(mask, width, height, comp, bins = DETAIL_BINS) {
    const profile = new Array(bins).fill(0);
    const cx = comp.x + comp.w / 2;
    const cy = comp.y + comp.h / 2;
    const maxR = Math.max(1, Math.min(comp.w, comp.h) / 2);
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    for (let y = yStart; y <= yEnd; y += 1) {
      for (let x = xStart; x <= xEnd; x += 1) {
        const p = y * width + x;
        if (!mask[p]) continue;
        const dx = x + 0.5 - cx;
        const dy = y + 0.5 - cy;
        const radiusNorm = Math.hypot(dx, dy) / maxR;
        if (radiusNorm < 0.45 || radiusNorm > 1.08) continue;
        const theta = Math.atan2(dy, dx);
        const norm = theta < 0 ? theta + Math.PI * 2 : theta;
        const bin = clamp(Math.floor((norm / (Math.PI * 2)) * bins), 0, bins - 1);
        profile[bin] += 1;
      }
    }
    const maxVal = profile.reduce((m, v) => Math.max(m, v), 0);
    if (maxVal > 0) for (let i = 0; i < bins; i += 1) profile[i] /= maxVal;
    return profile;
  }

  function buildMachinePreviewDataUrl(imageData, mask, width, height, comp) {
    const preview = document.createElement("canvas");
    const size = 260;
    preview.width = size;
    preview.height = size;
    const ctx = preview.getContext("2d");
    if (!ctx) return "";
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, size, size);
    const bw = Math.max(1, comp.w);
    const bh = Math.max(1, comp.h);
    const scale = Math.min((size - 12) / bw, (size - 12) / bh);
    const dw = Math.max(1, Math.floor(bw * scale));
    const dh = Math.max(1, Math.floor(bh * scale));
    const ox = Math.floor((size - dw) / 2);
    const oy = Math.floor((size - dh) / 2);
    const srcCanvas = document.createElement("canvas");
    srcCanvas.width = imageData.width;
    srcCanvas.height = imageData.height;
    const srcCtx = srcCanvas.getContext("2d", { willReadFrequently: true });
    if (!srcCtx) return "";
    srcCtx.putImageData(imageData, 0, 0);
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = "high";
    ctx.drawImage(srcCanvas, comp.x, comp.y, bw, bh, ox, oy, dw, dh);

    const maskCanvas = document.createElement("canvas");
    maskCanvas.width = bw;
    maskCanvas.height = bh;
    const maskCtx = maskCanvas.getContext("2d");
    if (!maskCtx) return preview.toDataURL("image/png");
    const maskImageData = maskCtx.createImageData(bw, bh);
    for (let my = 0; my < bh; my += 1) {
      for (let mx = 0; mx < bw; mx += 1) {
        const sx = comp.x + mx;
        const sy = comp.y + my;
        const on = sx >= 0 && sy >= 0 && sx < width && sy < height ? mask[sy * width + sx] : 0;
        const idx = (my * bw + mx) * 4;
        if (on) {
          maskImageData.data[idx] = 0;
          maskImageData.data[idx + 1] = 0;
          maskImageData.data[idx + 2] = 0;
          maskImageData.data[idx + 3] = 255;
        } else {
          maskImageData.data[idx + 3] = 0;
        }
      }
    }
    maskCtx.putImageData(maskImageData, 0, 0);
    ctx.globalAlpha = 0.65;
    ctx.drawImage(maskCanvas, 0, 0, bw, bh, ox, oy, dw, dh);
    ctx.globalAlpha = 1;
    return preview.toDataURL("image/png");
  }

  function renderTraceFrame(index: number) {
    if (!traceFrames.length) {
      setPreviewSrc(templatePreviewEl, "");
      setPreviewSrc(machinePreviewEl, "");
      if (frameMetaEl) frameMetaEl.textContent = "Frame: none";
      if (machineVoteEl) {
        machineVoteEl.textContent = "-";
        machineVoteEl.classList.remove(
          "border-emerald-500",
          "bg-emerald-100",
          "text-emerald-700",
          "dark:bg-emerald-900/30",
          "dark:text-emerald-300",
          "border-red-500",
          "bg-red-100",
          "text-red-700",
          "dark:bg-red-900/30",
          "dark:text-red-300"
        );
      }
      traceCursor = -1;
      return;
    }
    const safeIndex = clamp(index, 0, traceFrames.length - 1);
    traceCursor = safeIndex;
    const frame = traceFrames[safeIndex];
    setPreviewSrc(templatePreviewEl, frame.templateUrl || "");
    setPreviewSrc(machinePreviewEl, frame.machinePreview || "");
    if (machineVoteEl) {
      const accepted = Boolean(frame.accepted);
      machineVoteEl.textContent = accepted ? "👍" : "👎";
      machineVoteEl.classList.toggle("border-emerald-500", accepted);
      machineVoteEl.classList.toggle("bg-emerald-100", accepted);
      machineVoteEl.classList.toggle("text-emerald-700", accepted);
      machineVoteEl.classList.toggle("dark:bg-emerald-900/30", accepted);
      machineVoteEl.classList.toggle("dark:text-emerald-300", accepted);
      machineVoteEl.classList.toggle("border-red-500", !accepted);
      machineVoteEl.classList.toggle("bg-red-100", !accepted);
      machineVoteEl.classList.toggle("text-red-700", !accepted);
      machineVoteEl.classList.toggle("dark:bg-red-900/30", !accepted);
      machineVoteEl.classList.toggle("dark:text-red-300", !accepted);
    }
    if (frameMetaEl) {
      const runnerUp =
        frame.secondLabel && Number.isFinite(frame.secondScore)
          ? ` - 2nd ${frame.secondLabel} ${(frame.secondScore * 100).toFixed(1)}%`
          : "";
      frameMetaEl.textContent =
        `Frame ${safeIndex + 1}/${traceFrames.length} - ` +
        `${frame.label} - Score ${(frame.score * 100).toFixed(1)}% - ` +
        `Detail ${((frame.detail || 0) * 100).toFixed(1)}% - ` +
        `Overlap ${((frame.puzzle || 0) * 100).toFixed(1)}% - ` +
        `${frame.accepted ? "accepted" : frame.ambiguous ? "ambiguous reject" : "rejected"}${runnerUp}`;
    }
  }

  function stepTrace(nextOffset = 1) {
    if (!traceFrames.length) return;
    const start = traceCursor < 0 ? 0 : traceCursor;
    renderTraceFrame(clamp(start + nextOffset, 0, traceFrames.length - 1));
  }

  function startPlayback() {
    if (!traceFrames.length) return;
    stopPlayback();
    if (traceCursor < 0) renderTraceFrame(0);
    traceTimer = window.setInterval(() => {
      if (traceCursor >= traceFrames.length - 1) {
        stopPlayback();
        return;
      }
      stepTrace(1);
    }, 500);
  }

  function imageToNeutralMask(imageData) {
    const { width, height, data } = imageData;
    const mask = new Uint8Array(width * height);
    for (let i = 0, p = 0; p < mask.length; p += 1, i += 4) {
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];
      const a = data[i + 3];
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      mask[p] = gray < 210 && a > 20 && spread < 42 ? 1 : 0;
    }
    return mask;
  }

  function imageToRegionSeedMask(imageData) {
    const { width, height, data } = imageData;
    const mask = new Uint8Array(width * height);
    for (let i = 0, p = 0; p < mask.length; p += 1, i += 4) {
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];
      const a = data[i + 3];
      const gray = r * 0.299 + g * 0.587 + b * 0.114;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      // Gentler region seed so we do not over-flatten like neutral-ink masking.
      mask[p] = gray < 244 && a > 6 && spread < 88 ? 1 : 0;
    }
    return mask;
  }

  function passesBlackColorGate(comp, imageData, mask, width, height) {
    let blackLike = 0;
    let considered = 0;
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    for (let y = yStart; y <= yEnd; y += 1) {
      for (let x = xStart; x <= xEnd; x += 1) {
        const p = y * width + x;
        if (!mask[p]) continue;
        const i = p * 4;
        const r = imageData.data[i];
        const g = imageData.data[i + 1];
        const b = imageData.data[i + 2];
        const a = imageData.data[i + 3];
        if (a < 16) continue;
        considered += 1;
        const luma = r * 0.299 + g * 0.587 + b * 0.114;
        const spread = Math.max(r, g, b) - Math.min(r, g, b);
        if (luma <= runtimeBlackInkMaxLuma && spread <= runtimeBlackInkMaxSpread) blackLike += 1;
      }
    }
    if (considered < 8) return false;
    return blackLike / considered >= runtimeBlackInkMinRatio;
  }

  function countEdgeInk(mask, width, height, comp, edge) {
    let count = 0;
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    if (xStart > xEnd || yStart > yEnd) return 0;
    if (edge === "top") {
      const y = yStart;
      for (let x = xStart; x <= xEnd; x += 1) if (mask[y * width + x]) count += 1;
      return count;
    }
    if (edge === "bottom") {
      const y = yEnd;
      for (let x = xStart; x <= xEnd; x += 1) if (mask[y * width + x]) count += 1;
      return count;
    }
    if (edge === "left") {
      const x = xStart;
      for (let y = yStart; y <= yEnd; y += 1) if (mask[y * width + x]) count += 1;
      return count;
    }
    const x = xEnd;
    for (let y = yStart; y <= yEnd; y += 1) if (mask[y * width + x]) count += 1;
    return count;
  }

  function countBoxInk(mask, width, height, comp) {
    let area = 0;
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    for (let y = yStart; y <= yEnd; y += 1) {
      const row = y * width;
      for (let x = xStart; x <= xEnd; x += 1) if (mask[row + x]) area += 1;
    }
    return area;
  }

  function trimComponentToDenseCore(comp, mask, width, height) {
    let out = { ...comp };
    const maxTrimSteps = 14;
    for (let step = 0; step < maxTrimSteps; step += 1) {
      if (out.w < 6 || out.h < 6) break;
      const topInk = countEdgeInk(mask, width, height, out, "top");
      const bottomInk = countEdgeInk(mask, width, height, out, "bottom");
      const leftInk = countEdgeInk(mask, width, height, out, "left");
      const rightInk = countEdgeInk(mask, width, height, out, "right");
      const topDensity = topInk / Math.max(1, out.w);
      const bottomDensity = bottomInk / Math.max(1, out.w);
      const leftDensity = leftInk / Math.max(1, out.h);
      const rightDensity = rightInk / Math.max(1, out.h);
      let changed = false;

      if (topDensity <= 0.09 && bottomDensity >= topDensity * 2.2) {
        out = { ...out, y: out.y + 1, h: out.h - 1 };
        changed = true;
      }
      if (bottomDensity <= 0.09 && topDensity >= bottomDensity * 2.2 && out.h > 5) {
        out = { ...out, h: out.h - 1 };
        changed = true;
      }
      if (leftDensity <= 0.09 && rightDensity >= leftDensity * 2.2 && out.w > 5) {
        out = { ...out, x: out.x + 1, w: out.w - 1 };
        changed = true;
      }
      if (rightDensity <= 0.09 && leftDensity >= rightDensity * 2.2 && out.w > 5) {
        out = { ...out, w: out.w - 1 };
        changed = true;
      }
      if (!changed) break;
    }
    if (out.w < 5 || out.h < 5) return null;
    out.area = countBoxInk(mask, width, height, out);
    if (out.area < 8) return null;
    return out;
  }

  function passesCandidateShapeGate(comp, templateMinDiameter, templateMaxDiameter) {
    const w = Math.max(1, comp.w);
    const h = Math.max(1, comp.h);
    const aspect = w / h;
    if (aspect < CANDIDATE_MIN_ASPECT || aspect > CANDIDATE_MAX_ASPECT) return false;
    const fill = comp.area / Math.max(1, w * h);
    if (fill < CANDIDATE_MIN_FILL || fill > CANDIDATE_MAX_FILL) return false;
    const diam = Math.min(w, h);
    if (Number.isFinite(templateMinDiameter) && Number.isFinite(templateMaxDiameter)) {
      const minAllowed = Math.max(3, templateMinDiameter * 0.5);
      const maxAllowed = Math.max(minAllowed + 3, templateMaxDiameter * 1.8);
      if (diam < minAllowed || diam > maxAllowed) return false;
    }
    return true;
  }

  function getComponents(mask, width, height, minArea = 18, maxArea = 999999) {
    const visited = new Uint8Array(width * height);
    const qx = new Int32Array(width * height);
    const qy = new Int32Array(width * height);
    const out = [];
    for (let y = 0; y < height; y += 1) {
      for (let x = 0; x < width; x += 1) {
        const start = y * width + x;
        if (!mask[start] || visited[start]) continue;
        let head = 0;
        let tail = 0;
        qx[tail] = x;
        qy[tail] = y;
        tail += 1;
        visited[start] = 1;
        let area = 0;
        let minX = x;
        let minY = y;
        let maxX = x;
        let maxY = y;
        while (head < tail) {
          const cx = qx[head];
          const cy = qy[head];
          head += 1;
          area += 1;
          if (cx < minX) minX = cx;
          if (cy < minY) minY = cy;
          if (cx > maxX) maxX = cx;
          if (cy > maxY) maxY = cy;
          for (let oy = -1; oy <= 1; oy += 1)
            for (let ox = -1; ox <= 1; ox += 1) {
              if (ox === 0 && oy === 0) continue;
              const nx = cx + ox;
              const ny = cy + oy;
              if (nx < 0 || ny < 0 || nx >= width || ny >= height) continue;
              const nidx = ny * width + nx;
              if (!mask[nidx] || visited[nidx]) continue;
              visited[nidx] = 1;
              qx[tail] = nx;
              qy[tail] = ny;
              tail += 1;
            }
        }
        if (area >= minArea && area <= maxArea)
          out.push({ x: minX, y: minY, w: maxX - minX + 1, h: maxY - minY + 1, area });
      }
    }
    return out;
  }

  function getMaskedByRegions(state, regions) {
    if (!state || !Array.isArray(regions) || regions.length === 0) return state;
    const masked = new Uint8Array(state.mask);
    for (let y = 0; y < state.height; y += 1)
      for (let x = 0; x < state.width; x += 1) {
        if (!regions.some((r) => x >= r.x && y >= r.y && x < r.x + r.w && y < r.y + r.h))
          masked[y * state.width + x] = 0;
      }
    return { ...state, mask: masked };
  }

  function buildRegionBoundsMask(width, height, regions) {
    const mask = new Uint8Array(width * height);
    if (!Array.isArray(regions) || regions.length === 0) return mask;
    for (const r of regions) {
      const x0 = clamp(Math.floor(r.x), 0, width - 1);
      const y0 = clamp(Math.floor(r.y), 0, height - 1);
      const x1 = clamp(Math.floor(r.x + r.w - 1), 0, width - 1);
      const y1 = clamp(Math.floor(r.y + r.h - 1), 0, height - 1);
      for (let y = y0; y <= y1; y += 1) {
        const row = y * width;
        for (let x = x0; x <= x1; x += 1) mask[row + x] = 1;
      }
    }
    return mask;
  }

  function buildFullMask(width, height) {
    const mask = new Uint8Array(width * height);
    mask.fill(1);
    return mask;
  }

  function subtractMask(baseMask, subtractingMask) {
    const len = Math.min(baseMask?.length || 0, subtractingMask?.length || 0);
    const out = new Uint8Array(len);
    for (let i = 0; i < len; i += 1) out[i] = baseMask[i] && !subtractingMask[i] ? 1 : 0;
    return out;
  }

  function extractBaselineRegions(state) {
    if (!state) return [];
    const { width, height, mask } = state;
    const canvasArea = Math.max(1, width * height);
    const comps = getComponents(mask, width, height, 18, canvasArea * 0.9);
    if (comps.length === 0) return [];

    const edgeMargin = Math.max(6, Math.round(Math.min(width, height) * 0.02));
    const scored = [];
    for (const c of comps) {
      const bboxArea = c.w * c.h;
      const bboxRatio = bboxArea / canvasArea;
      if (bboxRatio < 0.015 || bboxRatio > 0.72) continue;
      const aspect = c.w / Math.max(1, c.h);
      if (aspect < 0.35 || aspect > 3.0) continue;
      const inkRatio = c.area / Math.max(1, bboxArea);
      if (inkRatio < 0.0015 || inkRatio > 0.24) continue;

      const nearLeft = c.x <= edgeMargin;
      const nearTop = c.y <= edgeMargin;
      const nearRight = c.x + c.w >= width - edgeMargin;
      const nearBottom = c.y + c.h >= height - edgeMargin;
      const edgeTouchCount = [nearLeft, nearTop, nearRight, nearBottom].filter(Boolean).length;

      const cx = c.x + c.w / 2;
      const cy = c.y + c.h / 2;
      const centerDist =
        Math.hypot(cx - width / 2, cy - height / 2) /
        Math.max(1, Math.hypot(width / 2, height / 2));
      const centerBonus = 1 - clamp(centerDist, 0, 1);
      const frameBonus = clamp(1 - Math.abs(inkRatio - 0.06) / 0.14, 0, 1);
      const edgePenalty = edgeTouchCount >= 2 ? 0.22 : 0;
      const score = bboxRatio * 1.1 + frameBonus * 0.35 + centerBonus * 0.2 - edgePenalty;

      scored.push({ ...c, score });
    }

    scored.sort((a, b) => b.score - a.score);
    const selected: Array<{ x: number; y: number; w: number; h: number }> = [];
    for (const c of scored) {
      const overlaps = selected.some((k) => {
        const x0 = Math.max(c.x, k.x);
        const y0 = Math.max(c.y, k.y);
        const x1 = Math.min(c.x + c.w - 1, k.x + k.w - 1);
        const y1 = Math.min(c.y + c.h - 1, k.y + k.h - 1);
        if (x1 < x0 || y1 < y0) return false;
        const inter = (x1 - x0 + 1) * (y1 - y0 + 1);
        return inter / Math.max(1, Math.min(c.w * c.h, k.w * k.h)) > 0.58;
      });
      if (overlaps) continue;
      const pad = Math.max(8, Math.round(Math.min(c.w, c.h) * 0.03));
      selected.push({
        x: clamp(c.x - pad, 0, width - 1),
        y: clamp(c.y - pad, 0, height - 1),
        w: clamp(c.w + pad * 2, 1, width),
        h: clamp(c.h + pad * 2, 1, height),
      });
      if (selected.length >= 4) break;
    }
    return selected;
  }

  const detectTextLikeComponentIndexes = (comps) => {
    const out = new Set<number>();
    const valid = new Set<number>();
    const neighbors = new Map<number, Set<number>>();
    const cx = (c) => c.x + c.w / 2;
    const cy = (c) => c.y + c.h / 2;
    for (let i = 0; i < comps.length; i += 1) {
      const c = comps[i];
      if (!c) continue;
      const longSide = Math.max(c.w, c.h);
      const shortSide = Math.min(c.w, c.h);
      if (longSide > 300 || shortSide > 110) continue;
      valid.add(i);
      neighbors.set(i, new Set<number>());
    }
    const linked = (a, b) => {
      const aCx = cx(a);
      const aCy = cy(a);
      const bCx = cx(b);
      const bCy = cy(b);
      const gapX = Math.max(0, Math.max(a.x, b.x) - Math.min(a.x + a.w, b.x + b.w));
      const gapY = Math.max(0, Math.max(a.y, b.y) - Math.min(a.y + a.h, b.y + b.h));
      const hTol = Math.max(5, Math.min(a.h, b.h) * 1.05);
      const wTol = Math.max(5, Math.min(a.w, b.w) * 1.05);
      const baselineOk = Math.abs(aCy - bCy) <= hTol && gapX <= 30;
      const columnOk = Math.abs(aCx - bCx) <= wTol && gapY <= 30;
      const scaleRatio =
        Math.max(Math.max(a.w, a.h), Math.max(b.w, b.h)) /
        Math.max(1, Math.min(Math.max(a.w, a.h), Math.max(b.w, b.h)));
      return (baselineOk || columnOk) && scaleRatio <= 4.0;
    };
    const validList = Array.from(valid);
    for (let i = 0; i < validList.length; i += 1) {
      const aIdx = validList[i];
      const a = comps[aIdx];
      for (let j = i + 1; j < validList.length; j += 1) {
        const bIdx = validList[j];
        const b = comps[bIdx];
        if (!linked(a, b)) continue;
        neighbors.get(aIdx)?.add(bIdx);
        neighbors.get(bIdx)?.add(aIdx);
      }
    }
    // Loose proximity targeting: if it's in a nearby alphanumeric group, treat as text.
    validList.forEach((idx) => {
      if ((neighbors.get(idx)?.size || 0) >= 1) out.add(idx);
    });
    // One-hop expansion catches partial glyph fragments next to confident text.
    validList.forEach((idx) => {
      if (out.has(idx)) return;
      const nearText = Array.from(neighbors.get(idx) || []).some((n) => {
        if (out.has(n)) return true;
        return Array.from(neighbors.get(n) || []).some((m) => out.has(m));
      });
      if (!nearText) return;
      const c = comps[idx];
      const area = Number(c.area || 0);
      if (area <= 3200) out.add(idx);
    });
    return out;
  };

  async function loadImageDataFromUrl(src: string): Promise<ImageData | null> {
    return await new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        const c = document.createElement("canvas");
        c.width = img.naturalWidth || img.width;
        c.height = img.naturalHeight || img.height;
        const x = c.getContext("2d", { willReadFrequently: true });
        if (!x) return resolve(null);
        x.drawImage(img, 0, 0);
        resolve(x.getImageData(0, 0, c.width, c.height));
      };
      img.onerror = () => resolve(null);
      img.src = String(src || "");
    });
  }

  const signatureFromImageData = (d, gridSize = BASE_GRID_SIZE) => {
    if (!d) return null;
    const mask = imageToNeutralMask(d);
    const comps = getComponents(mask, d.width, d.height, 8, d.width * d.height);
    const c = comps.sort((a, b) => b.area - a.area)[0];
    if (!c) return null;
    return {
      aspect: c.w / Math.max(1, c.h),
      fill: c.area / Math.max(1, c.w * c.h),
      diameter: Math.min(c.w, c.h),
      grid: buildGridFromMask(mask, d.width, d.height, c, gridSize),
      detailProfile: buildPolarDetailProfile(mask, d.width, d.height, c, DETAIL_BINS),
    };
  };

  const scoreComponentVsTemplate = (comp, sig, compGrid, compDetail): MatchScore => {
    if (!sig)
      return {
        totalScore: 0,
        puzzleScore: 0,
        detailScore: 0,
        aspectScore: 0,
        fillScore: 0,
        diamScore: 0,
      };
    const aspect = comp.w / Math.max(1, comp.h);
    const fill = comp.area / Math.max(1, comp.w * comp.h);
    const diam = Math.min(comp.w, comp.h);
    const aspectScore = clamp(1 - Math.abs(aspect - sig.aspect) / 0.55, 0, 1);
    const fillScore = clamp(1 - Math.abs(fill - sig.fill) / 0.42, 0, 1);
    const diamScore = clamp(
      1 - Math.abs(diam - sig.diameter) / Math.max(8, sig.diameter * 0.7),
      0,
      1
    );
    const puzzleScore = scoreGridSimilarity(compGrid, sig.grid);
    const detailScore = scoreGridSimilarity(compDetail, sig.detailProfile || []);
    const totalScore =
      puzzleScore * 0.52 +
      detailScore * 0.28 +
      aspectScore * 0.1 +
      fillScore * 0.05 +
      diamScore * 0.05;
    return { totalScore, puzzleScore, detailScore, aspectScore, fillScore, diamScore };
  };

  async function getTemplateSignature(item, gridSize = BASE_GRID_SIZE) {
    const key = `${item.fileName}|${item.imageUrl}|${item.rawImageUrl || ""}|g:${gridSize}`;
    if (templateSignatureCache.has(key)) return templateSignatureCache.get(key);
    let d = await loadImageDataFromUrl(item.imageUrl);
    if (!d && item.rawImageUrl) d = await loadImageDataFromUrl(item.rawImageUrl);
    const sig = signatureFromImageData(d, gridSize);
    templateSignatureCache.set(key, sig);
    return sig;
  }

  function drawOverlay() {
    const ctx = getCtx();
    if (!ctx || !drawingState) return;
    ctx.putImageData(drawingState.imageData, 0, 0);
    ctx.lineWidth = 2;
    baselineRegions.forEach((r, idx) => {
      const excluded = excludedRegionIndexes.has(idx);
      ctx.strokeStyle = excluded ? "rgba(239,68,68,0.95)" : "rgba(56,189,248,0.95)";
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      if (excluded) {
        ctx.beginPath();
        ctx.moveTo(r.x + 3, r.y + 3);
        ctx.lineTo(r.x + r.w - 3, r.y + r.h - 3);
        ctx.moveTo(r.x + r.w - 3, r.y + 3);
        ctx.lineTo(r.x + 3, r.y + r.h - 3);
        ctx.stroke();
      }
    });
    detections.forEach((d) => {
      ctx.strokeStyle = d.color;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(d.x, d.y, Math.max(6, Number(d.radius || 8)), 0, Math.PI * 2);
      ctx.stroke();
    });
    if (step55Mode !== "off" || step55SelectedEndpoint) {
      step55Endpoints.forEach((ep) => {
        ctx.fillStyle = "rgba(34,211,238,0.92)";
        ctx.beginPath();
        ctx.arc(ep.x, ep.y, 3.4, 0, Math.PI * 2);
        ctx.fill();
      });
      if (step55SelectedEndpoint) {
        ctx.strokeStyle = "rgba(250,204,21,0.98)";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(step55SelectedEndpoint.x, step55SelectedEndpoint.y, 7, 0, Math.PI * 2);
        ctx.stroke();
      }
    }
  }

  async function renderProcessingOnlyView() {
    if (!drawingState) return;
    const renderToken = ++processingRenderToken;
    stopPlayback();
    traceFrames = [];
    traceCursor = -1;
    renderTraceFrame(-1);
    detections = [];
    matchSummary = null;
    renderMatchSummaryUi();
    if (!baselineRegions.length) baselineRegions = extractBaselineRegions(drawingState);
    const { regionsSource, selectedRegions, selectedRegionIndexes } =
      getActiveRegionSelection(drawingState);
    const selectedState = getMaskedByRegions(drawingState, selectedRegions);
    const step2BoundsMask = buildRegionBoundsMask(
      drawingState.width,
      drawingState.height,
      selectedRegions
    );
    const fullCanvasMask = buildFullMask(drawingState.width, drawingState.height);
    const selectedComps = getComponents(
      selectedState.mask,
      selectedState.width,
      selectedState.height,
      LINE_COMPONENT_MIN_AREA,
      20000
    );
    const step3AllowedMask = layerFlowState.step2ToStep3 ? step2BoundsMask : fullCanvasMask;
    const colorLineInfo = detectColoredPixelsWithinAllowedMask(
      drawingState.imageData,
      step3AllowedMask
    );
    const colorLineDeltaMask = colorLineInfo.colorMask;
    colorLineCandidatePool = [];
    let step4InputMask = layerFlowState.step2ToStep4
      ? new Uint8Array(selectedState.mask)
      : fullCanvasMask;
    if (layerFlowState.step3ExcludeFromStep4) {
      step4InputMask = subtractMask(step4InputMask, colorLineInfo.colorMask);
    }
    const lineInputCompsStep4 = getComponents(
      step4InputMask,
      drawingState.width,
      drawingState.height,
      LINE_COMPONENT_MIN_AREA,
      20000
    );
    const hairlineInfo = HAIRLINE_STEP_PAUSED
      ? {
          hairlineMask: new Uint8Array(step4InputMask.length),
          hairlineCount: 0,
          nsPixels: 0,
          ewPixels: 0,
          combinedPixels: 0,
          nsMinRun: HAIRLINE_NS_MIN_RUN,
          ewMinRun: HAIRLINE_EW_MIN_RUN,
          maxThickness: runtimeHairlineMaxThickness,
          maxGap: HAIRLINE_MAX_GAP,
          fallbackMinInkStrength: runtimeHairlineMinInkStrength,
          fallbackMaxSpread: HAIRLINE_FALLBACK_MAX_SPREAD,
        }
      : detectHairlineMaskOrthogonalPasses(
          step4InputMask,
          drawingState.imageData,
          drawingState.width,
          drawingState.height
        );
    const hairlineRemovedMask = HAIRLINE_STEP_PAUSED
      ? new Uint8Array(step4InputMask)
      : subtractMask(step4InputMask, hairlineInfo.hairlineMask);
    const hairlineRemovedDeltaMask = diffRemovedMask(step4InputMask, hairlineRemovedMask);

    const lineInputComps = getComponents(
      hairlineRemovedMask,
      drawingState.width,
      drawingState.height,
      LINE_COMPONENT_MIN_AREA,
      20000
    );
    const lineInfo = detectLineAndDashedComponentIndexes(
      lineInputComps,
      hairlineRemovedMask,
      drawingState.width,
      drawingState.height,
      selectedRegions
    );
    const step5Indexes = new Set<number>([
      ...Array.from(lineInfo.dashedIndexes || []),
      ...Array.from(lineInfo.junctionIndexes || []),
    ]);
    const invalidRemoved = Array.from(step55RemovedIndexes).filter((idx) => !step5Indexes.has(idx));
    invalidRemoved.forEach((idx) => step55RemovedIndexes.delete(idx));
    const step5EditedIndexes = new Set<number>(
      Array.from(step5Indexes).filter((idx) => !step55RemovedIndexes.has(idx))
    );
    const step5EditedDashedIndexes = new Set<number>(
      Array.from(lineInfo.dashedIndexes || []).filter((idx) => step5EditedIndexes.has(idx))
    );
    const step5EditedJunctionIndexes = new Set<number>(
      Array.from(lineInfo.junctionIndexes || []).filter((idx) => step5EditedIndexes.has(idx))
    );
    rebuildStep55InteractiveGeometry(lineInputComps, step5EditedIndexes);
    const dashedLinearCandidates = (lineInfo.dashedLineSegments || [])
      .filter((seg) => step5EditedDashedIndexes.has(Number(seg.idx)))
      .map((seg) => {
        const w = Math.abs(seg.x1 - seg.x0) + 1;
        const h = Math.abs(seg.y1 - seg.y0) + 1;
        const widthPx = Math.max(1, Number(seg.thickness || 1));
        const lengthPx = Math.max(w, h);
        const orientation = seg.horizontal ? "horizontal" : "vertical";
        const widthBand = widthPx <= 3 ? "thin" : widthPx <= 7 ? "medium" : "thick";
        return {
          idx: Number(seg.idx),
          x: Math.min(seg.x0, seg.x1),
          y: Math.min(seg.y0, seg.y1),
          w,
          h,
          area: w * h,
          style: "dashed-linear",
          orientation,
          widthPx,
          lengthPx,
          widthBand,
          offAxisDeg: 0,
        };
      });
    const junctionCandidates = lineInputComps
      .map((c, idx) => ({ c, idx }))
      .filter((x) => step5EditedJunctionIndexes.has(x.idx))
      .map(({ c, idx }) => {
        const widthPx = Math.min(c.w, c.h);
        const lengthPx = Math.max(c.w, c.h);
        const orientation = c.w >= c.h ? "horizontal" : "vertical";
        const style = "junction";
        const widthBand = widthPx <= 3 ? "thin" : widthPx <= 7 ? "medium" : "thick";
        const offAxisDeg = Number(lineInfo.axisMetaByIndex.get(idx) || 0);
        return {
          idx,
          x: c.x,
          y: c.y,
          w: c.w,
          h: c.h,
          area: c.area,
          style,
          orientation,
          widthPx,
          lengthPx,
          widthBand,
          offAxisDeg,
        };
      });
    lineCandidatePool = [...dashedLinearCandidates, ...junctionCandidates];
    const dashedLinearMask = lineSegmentsToMask(
      (lineInfo.dashedLineSegments || [])
        .filter((seg) => step5EditedDashedIndexes.has(Number(seg.idx)))
        .map((seg) => ({
          x0: seg.x0,
          y0: seg.y0,
          x1: seg.x1,
          y1: seg.y1,
          thickness: seg.thickness,
        })),
      drawingState.width,
      drawingState.height
    );
    const junctionRemovedMask = removeComponentBoxesFromMask(
      hairlineRemovedMask,
      drawingState.width,
      drawingState.height,
      lineInputComps,
      step5EditedJunctionIndexes
    );
    const lineRemovedMaskBase = subtractMask(junctionRemovedMask, dashedLinearMask);
    const dashLoopClosureMask = lineSegmentsToMask(
      lineInfo.loopClosureSegments,
      drawingState.width,
      drawingState.height
    );
    const manualConnectionMask = lineSegmentsToMask(
      step55AddedSegments,
      drawingState.width,
      drawingState.height
    );
    const lineRemovedMask = subtractMask(
      subtractMask(lineRemovedMaskBase, dashLoopClosureMask),
      manualConnectionMask
    );
    const lineRemovedDeltaMask = diffRemovedMask(hairlineRemovedMask, lineRemovedMask);
    const step6InputComps = getComponents(
      lineRemovedMask,
      drawingState.width,
      drawingState.height,
      LINE_COMPONENT_MIN_AREA,
      20000
    );
    const dashShieldMask = dilateMask(dashedLinearMask, drawingState.width, drawingState.height, 2);
    const componentOverlapsMask = (comp, testMask, minRatio = 0.08) => {
      if (!comp || !testMask) return false;
      const x0 = Math.max(0, comp.x);
      const y0 = Math.max(0, comp.y);
      const x1 = Math.min(drawingState.width - 1, comp.x + comp.w - 1);
      const y1 = Math.min(drawingState.height - 1, comp.y + comp.h - 1);
      let overlap = 0;
      const area = Math.max(1, (x1 - x0 + 1) * (y1 - y0 + 1));
      for (let y = y0; y <= y1; y += 1) {
        const row = y * drawingState.width;
        for (let x = x0; x <= x1; x += 1) {
          if (testMask[row + x]) overlap += 1;
        }
      }
      return overlap / area >= minRatio;
    };
    const residualLineInfo = detectLineAndDashedComponentIndexes(
      step6InputComps,
      lineRemovedMask,
      drawingState.width,
      drawingState.height,
      selectedRegions
    );
    const residualLinearIndexes = new Set<number>(Array.from(residualLineInfo.indexes || []));
    const residualDashShieldedIndexes = new Set<number>();
    step6InputComps.forEach((c, idx) => {
      if (componentOverlapsMask(c, dashShieldMask, 0.08)) residualDashShieldedIndexes.add(idx);
    });
    const ocrStep6 = useOcrTextDetection
      ? await detectTextLikeComponentIndexesOcr(
          step6InputComps,
          drawingState.imageData,
          lineRemovedMask,
          drawingState.width,
          drawingState.height,
          renderToken
        )
      : { indexes: new Set<number>(), boxes: 0, words: 0 };
    if (renderToken !== processingRenderToken) return;
    const textLikeRaw = useOcrTextDetection
      ? ocrStep6.indexes
      : detectTextLikeComponentIndexes(step6InputComps);
    const textLikeIndexes = new Set<number>(
      Array.from(textLikeRaw).filter(
        (idx) => !residualLinearIndexes.has(idx) && !residualDashShieldedIndexes.has(idx)
      )
    );
    const step6LinearShieldedCount = Math.max(0, textLikeRaw.size - textLikeIndexes.size);
    const step6DashShieldedCount = residualDashShieldedIndexes.size;
    const textRemovedMask = removeComponentBoxesFromMask(
      lineRemovedMask,
      drawingState.width,
      drawingState.height,
      step6InputComps,
      textLikeIndexes
    );
    const textRemovedDeltaMask = diffRemovedMask(lineRemovedMask, textRemovedMask);
    const lineWidthStats =
      lineCandidatePool.length > 0
        ? {
            min: Math.min(...lineCandidatePool.map((x) => x.widthPx)),
            max: Math.max(...lineCandidatePool.map((x) => x.widthPx)),
            avg:
              lineCandidatePool.reduce((sum, x) => sum + x.widthPx, 0) /
              Math.max(1, lineCandidatePool.length),
          }
        : { min: 0, max: 0, avg: 0 };
    const widthBandCounts = lineCandidatePool.reduce(
      (acc, x) => {
        acc[x.widthBand] += 1;
        return acc;
      },
      { thin: 0, medium: 0, thick: 0 }
    );
    const pipelinePayload = {
      sourceImageData: drawingState.imageData,
      step3SourceMask: step3AllowedMask,
      step4SourceMask: step4InputMask,
      step5SourceMask: hairlineRemovedMask,
      step6SourceMask: lineRemovedMask,
      step7SourceMask: textRemovedMask,
      colorLineDeltaMask,
      colorPixelCount: colorLineInfo.coloredPixelCount,
      hairlineRemovedDeltaMask,
      hairlineRemovedCount: hairlineInfo.hairlineCount,
      hairlineWidthThreshold: hairlineInfo.maxThickness,
      lineRemovedDeltaMask,
      lineDashedCount: lineInfo.dashedCount,
      lineJunctionCount: lineInfo.junctionCount,
      lineMagneticSeedCount: lineInfo.magneticSeedCount,
      lineLoopClosedCount: lineInfo.loopClosedClusterCount,
      textRemovedDeltaMask,
      textRemovedCount: textLikeIndexes.size,
      regions: regionsSource,
      selectedRegions,
      selectedRegionIndexes,
      matchSummary,
      matchDetections: detections,
    };
    lastPipelineSnapshot = pipelinePayload;
    renderPipelineSteps(pipelinePayload);
    drawOverlay();
    if (resultsEl)
      resultsEl.textContent = JSON.stringify(
        {
          mode: "processing-only",
          maxRegionsToScan: MAX_REGIONS_TO_SCAN,
          regionsDetected: baselineRegions.length,
          regionsSelected: selectedRegions.length,
          selectedComponents: selectedComps.length,
          layerFlowState,
          step4HairlinePaused: HAIRLINE_STEP_PAUSED,
          colorPixelsIdentified: colorLineInfo.coloredPixelCount,
          colorLineMinLuma: COLOR_LINE_MIN_LUMA,
          colorLineMinSpread: runtimeColorLineMinSpread,
          colorLineCandidatePoolCount: colorLineCandidatePool.length,
          colorLineCandidatePoolPreview: colorLineCandidatePool.slice(0, 24),
          componentsAfterColorLineStage: lineInputCompsStep4.length,
          step4HairlineRemovedCount: hairlineInfo.hairlineCount,
          step4HairlineNsPixels: hairlineInfo.nsPixels,
          step4HairlineEwPixels: hairlineInfo.ewPixels,
          step4HairlineCombinedPixels: hairlineInfo.combinedPixels,
          step4HairlineNsMinRun: hairlineInfo.nsMinRun,
          step4HairlineEwMinRun: hairlineInfo.ewMinRun,
          step4HairlineMaxThickness: hairlineInfo.maxThickness,
          step4HairlineMinRun: runtimeHairlineMinRun,
          step4HairlineMinSegmentLength: runtimeHairlineComponentMinLongSide,
          step4HairlineMaxGap: hairlineInfo.maxGap,
          step4HairlineFallbackMinInkStrength: hairlineInfo.fallbackMinInkStrength,
          step4HairlineFallbackMaxSpread: hairlineInfo.fallbackMaxSpread,
          dashedLayerIsolated: lineInfo.dashedCount,
          solidLinesDetectedNotHidden: lineInfo.solidCount,
          hairlinesDetectedNotHidden: lineInfo.hairlineCount,
          step5HiddenCount: step5EditedIndexes.size,
          step5DashedLinearCount: dashedLinearCandidates.length,
          step5JunctionCount: lineInfo.junctionCount,
          step55Mode,
          step55RemovedCount: step55RemovedIndexes.size,
          step55AddedConnections: step55AddedSegments.length,
          dashClustersQualifying: lineInfo.totalQualifyingDashClusters,
          dashClustersKept: lineInfo.keptDashClusters,
          dashClustersDroppedBySectionCap: lineInfo.droppedDashClustersBySectionCap,
          dashDroppedNonClosedClusters: lineInfo.droppedNonClosedDashClusters,
          dashMagneticSeedCount: lineInfo.magneticSeedCount,
          dashMagneticReachableCount: lineInfo.magneticReachableCount,
          dashLoopClosureEnabled: DASH_LOOP_CLOSURE_ENABLED,
          dashLoopClosedClusterCount: lineInfo.loopClosedClusterCount,
          dashLoopClosureSegmentCount: lineInfo.loopClosureSegments.length,
          step6TextLikeRemovedCount: textLikeIndexes.size,
          step6LinearShieldedCount,
          step6DashShieldedCount,
          step6TextMode: useOcrTextDetection ? "ocr" : "proximity",
          step6OcrBoxes: ocrStep6.boxes || 0,
          step6OcrWords: ocrStep6.words || 0,
          axisRejectedInterference: lineInfo.axisRejectedCount,
          axisAlignmentTolerancePercent: AXIS_ALIGNMENT_TOLERANCE_PERCENT,
          axisAlignmentMaxOffDeg: lineInfo.maxOffAxisDeg,
          dashAxisAlignmentTolerancePercent: DASH_AXIS_ALIGNMENT_TOLERANCE_PERCENT,
          dashAxisAlignmentMaxOffDeg: lineInfo.maxDashOffAxisDeg,
          dashMinAspect: DASH_SEED_MIN_ASPECT,
          dashPrimaryGapMultiplier: DASH_PRIMARY_GAP_MULTIPLIER,
          dashMinRunLength: runtimeDashNeighborMin,
          dashMaxClustersPerSection: DASH_MAX_CLUSTERS_PER_REGION,
          lineComponentMinArea: LINE_COMPONENT_MIN_AREA,
          lineCandidatePoolCount: lineCandidatePool.length,
          lineWidthStats,
          lineWidthBandCounts: widthBandCounts,
          componentsAfterLineDrop: getComponents(
            textRemovedMask,
            drawingState.width,
            drawingState.height,
            8,
            20000
          ).length,
          lineCandidatePoolPreview: lineCandidatePool.slice(0, 24),
          note: "Hard stop at Step 6. Layer flow toggles control whether each step feeds the next.",
          traceFrames: traceFrames.length,
        },
        null,
        2
      );
    setStatus(
      `Processing steps ready (hard stop at Step 6). ${selectedRegions.length} viable region(s), ${colorLineInfo.coloredPixelCount} color pixels identified (${layerFlowState.step2ToStep3 ? "Step 2 -> Step 3 on" : "Step 2 -> Step 3 off"}), ${HAIRLINE_STEP_PAUSED ? "Step 4 hairline layer paused (passthrough)" : `${hairlineInfo.hairlineCount} thin continuous line component(s) removed via NS/EW passes at Step 4`}, ${lineInfo.dashedCount} dashed component(s) + ${lineInfo.junctionCount} junction(s) isolated at Step 5 (${lineInfo.keptDashClusters} closed rectangle system(s), ${lineInfo.loopClosedClusterCount} forced closure${lineInfo.loopClosedClusterCount === 1 ? "" : "s"}, ${lineInfo.droppedNonClosedDashClusters} non-closed cluster${lineInfo.droppedNonClosedDashClusters === 1 ? "" : "s"} dropped), manual repairs: ${step55RemovedIndexes.size} removed + ${step55AddedSegments.length} connections, ${textLikeIndexes.size} text-like component(s) removed at Step 6 (${step6LinearShieldedCount} linear leftovers + ${step6DashShieldedCount} dash-overlap components protected from text classification, mode=${useOcrTextDetection ? "OCR" : "proximity"}).`
    );
    updateTextOcrUiMeta(
      useOcrTextDetection
        ? `last run: ${textLikeRaw.size} text components from OCR (${ocrStep6.boxes} boxes)`
        : `last run: ${textLikeRaw.size} text components from proximity`
    );
  }

  async function runSimpleScan() {
    if (!drawingState) return;
    setStatus("Scanning...");
    if (matchMetaEl) matchMetaEl.textContent = "Matching in progress...";
    stopPlayback();
    traceFrames = [];
    traceCursor = -1;
    renderTraceFrame(-1);
    if (!baselineRegions.length) baselineRegions = extractBaselineRegions(drawingState);
    const { selectedRegions: regions } = getActiveRegionSelection(drawingState);
    const selectedState = getMaskedByRegions(drawingState, regions);
    const rawComps = getComponents(
      selectedState.mask,
      selectedState.width,
      selectedState.height,
      18,
      20000
    );
    const ocrMatchTextInfo = useOcrTextDetection
      ? await detectTextLikeComponentIndexesOcr(
          rawComps,
          drawingState.imageData,
          selectedState.mask,
          selectedState.width,
          selectedState.height
        )
      : { indexes: new Set<number>(), boxes: 0, words: 0 };
    const textLike = useOcrTextDetection
      ? ocrMatchTextInfo.indexes
      : detectTextLikeComponentIndexes(rawComps);
    let colorDropped = 0;
    let trimDropped = 0;
    let shapeDropped = 0;
    const candidatePool = [];
    for (let i = 0; i < rawComps.length; i += 1) {
      if (textLike.has(i)) continue;
      const trimmed = trimComponentToDenseCore(
        rawComps[i],
        selectedState.mask,
        selectedState.width,
        selectedState.height
      );
      if (!trimmed) {
        trimDropped += 1;
        continue;
      }
      const c = trimmed;
      if (Math.min(c.w, c.h) < 6) continue;
      if (!passesCandidateShapeGate(c, Number.NaN, Number.NaN)) {
        shapeDropped += 1;
        continue;
      }
      if (
        !passesBlackColorGate(
          c,
          drawingState.imageData,
          selectedState.mask,
          selectedState.width,
          selectedState.height
        )
      ) {
        colorDropped += 1;
        continue;
      }
      candidatePool.push(c);
    }

    const totals = new Map();
    const sectionStats = [];
    detections = [];
    let matched = 0;

    if (candidatePool.length > 0) {
      await refreshItemLibrary(false);
      const targetItems = itemLibrary.filter((item) =>
        targetedLibraryFileNames.has(String(item?.fileName || ""))
      );
      if (targetItems.length === 0) {
        setStatus("No targeted library items selected. Select at least one item.");
        matchSummary = {
          totalMatches: 0,
          candidateCount: candidatePool.length,
          regions: regions.length,
          itemCounts: [],
        };
        renderMatchSummaryUi();
        if (lastPipelineSnapshot) {
          renderPipelineSteps({
            ...lastPipelineSnapshot,
            matchSummary,
            matchDetections: detections,
          });
        }
        if (resultsEl) {
          resultsEl.textContent = JSON.stringify(
            {
              note: "No targeted library items selected.",
              itemLibraryCount: itemLibrary.length,
              targetedLibraryFiles: Array.from(targetedLibraryFileNames),
            },
            null,
            2
          );
        }
        return;
      }
      const firstPassSignatures = (
        await Promise.all(
          targetItems.map(async (item) => ({
            item,
            sig: await getTemplateSignature(item, BASE_GRID_SIZE),
          }))
        )
      ).filter((x) => x.sig);
      const smallestTemplateDiameter = firstPassSignatures.reduce(
        (min, { sig }) => Math.min(min, Number(sig?.diameter || Number.POSITIVE_INFINITY)),
        Number.POSITIVE_INFINITY
      );
      const runtimeGridSize = Number.isFinite(smallestTemplateDiameter)
        ? clamp(Math.round(Math.max(10, smallestTemplateDiameter) * 2), 18, 160)
        : BASE_GRID_SIZE;
      const signatures =
        runtimeGridSize === BASE_GRID_SIZE
          ? firstPassSignatures
          : (
              await Promise.all(
                targetItems.map(async (item) => ({
                  item,
                  sig: await getTemplateSignature(item, runtimeGridSize),
                }))
              )
            ).filter((x) => x.sig);

      for (const c of candidatePool) {
        const compGrid = buildGridFromMask(
          selectedState.mask,
          selectedState.width,
          selectedState.height,
          c,
          runtimeGridSize
        );
        const compDetail = buildPolarDetailProfile(
          selectedState.mask,
          selectedState.width,
          selectedState.height,
          c,
          DETAIL_BINS
        );
        let best: Record<string, unknown> | null = null;
        let bestScore = 0;
        let bestPuzzleScore = 0;
        let bestDetailScore = 0;
        let secondBestScore = 0;
        let secondBestLabel = "";
        for (const { item, sig } of signatures) {
          const score: MatchScore = scoreComponentVsTemplate(c, sig, compGrid, compDetail);
          if (score.totalScore > bestScore) {
            secondBestScore = bestScore;
            secondBestLabel =
              typeof best?.displayName === "string"
                ? best.displayName
                : typeof best?.fileName === "string"
                  ? best.fileName
                  : "";
            bestScore = score.totalScore;
            bestPuzzleScore = score.puzzleScore;
            bestDetailScore = score.detailScore;
            best = item;
          } else if (score.totalScore > secondBestScore) {
            secondBestScore = score.totalScore;
            secondBestLabel =
              typeof item?.displayName === "string"
                ? item.displayName
                : typeof item?.fileName === "string"
                  ? item.fileName
                  : "";
          }
        }
        const isAmbiguous = bestScore - secondBestScore < runtimeAmbiguousMargin;
        const templateUrl =
          typeof best?.imageUrl === "string"
            ? best.imageUrl
            : typeof best?.rawImageUrl === "string"
              ? best.rawImageUrl
              : "";
        const machinePreview = buildMachinePreviewDataUrl(
          drawingState.imageData,
          selectedState.mask,
          selectedState.width,
          selectedState.height,
          c
        );
        traceFrames.push({
          section: 1,
          label:
            typeof best?.displayName === "string"
              ? best.displayName
              : typeof best?.fileName === "string"
                ? best.fileName
                : "no-template",
          score: bestScore,
          puzzle: bestPuzzleScore,
          detail: bestDetailScore,
          secondScore: secondBestScore,
          secondLabel: secondBestLabel,
          ambiguous: isAmbiguous,
          accepted: Boolean(
            best &&
            bestScore >= runtimeMatchThreshold &&
            bestPuzzleScore >= runtimeMinPuzzleOverlap &&
            !isAmbiguous
          ),
          templateUrl,
          machinePreview,
        });
        if (
          !best ||
          bestScore < runtimeMatchThreshold ||
          bestPuzzleScore < runtimeMinPuzzleOverlap ||
          isAmbiguous
        )
          continue;
        matched += 1;
        const fileName = typeof best.fileName === "string" ? best.fileName : "unknown";
        totals.set(fileName, (totals.get(fileName) || 0) + 1);
        detections.push({
          x: c.x + c.w / 2,
          y: c.y + c.h / 2,
          radius: Math.max(7, Math.round(Math.max(c.w, c.h) / 2) + 2),
          color: colorFromLabel(fileName),
          label: fileName,
        });
      }

      sectionStats.push({
        section: 1,
        components: rawComps.length,
        textDropped: textLike.size,
        trimDropped,
        shapeDropped,
        colorDropped,
        candidatePool: candidatePool.length,
        matches: matched,
        runtimeGridSize,
      });
    } else {
      sectionStats.push({
        section: 1,
        components: rawComps.length,
        textDropped: textLike.size,
        trimDropped,
        shapeDropped,
        colorDropped,
        candidatePool: 0,
        matches: 0,
        runtimeGridSize: BASE_GRID_SIZE,
      });
    }

    drawOverlay();
    const itemCounts = [...totals.entries()]
      .map(([fileName, count]) => ({ fileName, count }))
      .sort((a, b) => b.count - a.count);
    matchSummary = {
      totalMatches: itemCounts.reduce((s, x) => s + x.count, 0),
      candidateCount: candidatePool.length,
      regions: regions.length,
      itemCounts,
    };
    renderMatchSummaryUi();
    if (lastPipelineSnapshot) {
      renderPipelineSteps({
        ...lastPipelineSnapshot,
        matchSummary,
        matchDetections: detections,
      });
    }
    if (resultsEl)
      resultsEl.textContent = JSON.stringify(
        {
          matchThreshold: runtimeMatchThreshold,
          minPuzzleOverlap: runtimeMinPuzzleOverlap,
          ambiguousMargin: runtimeAmbiguousMargin,
          blackInkMaxLuma: runtimeBlackInkMaxLuma,
          blackInkMaxSpread: runtimeBlackInkMaxSpread,
          blackInkMinRatio: runtimeBlackInkMinRatio,
          maxRegionsToScan: MAX_REGIONS_TO_SCAN,
          itemLibraryCount: itemLibrary.length,
          targetedLibraryFiles: Array.from(targetedLibraryFileNames),
          textDetectionMode: useOcrTextDetection ? "ocr" : "proximity",
          ocrBoxes: ocrMatchTextInfo.boxes || 0,
          ocrWords: ocrMatchTextInfo.words || 0,
          traceFrames: traceFrames.length,
          regions: regions.length,
          itemCounts,
          sectionStats,
        },
        null,
        2
      );
    renderTraceFrame(0);
    setStatus(
      `Done. ${itemCounts.reduce((s, x) => s + x.count, 0)} matches from ${candidatePool.length} candidate(s).`
    );
  }

  async function renderPdfToImage(file: File): Promise<HTMLImageElement | null> {
    for (const scale of PDF_RENDER_SCALE_FALLBACKS) {
      try {
        const pdfLib = getPdfLib();
        if (!pdfLib) return null;
        const pdf = await pdfLib.getDocument({ data: await file.arrayBuffer() }).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale });
        const c = document.createElement("canvas");
        c.width = Math.max(1, Math.floor(viewport.width));
        c.height = Math.max(1, Math.floor(viewport.height));
        const ctx = c.getContext("2d", { willReadFrequently: true });
        if (!ctx) continue;
        await page.render({ canvasContext: ctx, viewport }).promise;
        const img = new Image();
        img.src = c.toDataURL("image/png");
        await new Promise((resolve, reject) => {
          img.onload = resolve;
          img.onerror = reject;
        });
        lastPdfRenderScale = scale;
        return img;
      } catch (error) {
        void error;
      }
    }
    return null;
  }

  async function loadImageFromFile(file: File): Promise<HTMLImageElement | null> {
    return await new Promise((resolve: (image: HTMLImageElement | null) => void) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = () => resolve(null);
        img.src = String(reader.result || "");
      };
      reader.onerror = () => resolve(null);
      reader.readAsDataURL(file);
    });
  }

  async function handleDrawingUpload(file: File) {
    if (!(file instanceof File)) return;
    setStatus("Rendering drawing...");
    lastPdfRenderScale = 0;
    const isPdf = file.name.toLowerCase().endsWith(".pdf") || file.type === "application/pdf";
    const isSvg = file.name.toLowerCase().endsWith(".svg") || file.type === "image/svg+xml";
    const img: HTMLImageElement | null = isPdf
      ? await renderPdfToImage(file)
      : await loadImageFromFile(file);
    if (!img || !(canvas instanceof HTMLCanvasElement))
      return setStatus("Failed to render drawing");
    const ctx = getCtx();
    if (!ctx) return;
    const ratio = Math.min(
      isSvg ? 10 : 1,
      DRAWING_RENDER_MAX_SIDE /
        Math.max(img.naturalWidth || img.width, img.naturalHeight || img.height)
    );
    canvas.width = Math.max(1, Math.round((img.naturalWidth || img.width) * ratio));
    canvas.height = Math.max(1, Math.round((img.naturalHeight || img.height) * ratio));
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    drawingState = {
      width: canvas.width,
      height: canvas.height,
      imageData,
      mask: imageToRegionSeedMask(imageData),
    };
    setStatus(
      `Rendered ${canvas.width}x${canvas.height}${lastPdfRenderScale ? ` @ PDF scale ${lastPdfRenderScale}` : ""}. Building processing steps...`
    );
    baselineRegions = extractBaselineRegions(drawingState);
    excludedRegionIndexes.clear();
    renderProcessingOnlyView();
  }

  drawingFileInput?.addEventListener("change", async () => {
    const file = drawingFileInput.files?.[0];
    if (file) await handleDrawingUpload(file);
  });
  const handleColorTuningInput = () => {
    runtimeColorLineMinSpread = clamp(Number(colorSpreadInput?.value || "38") || 38, 4, 90);
    runtimeHairlineMaxThickness = clamp(
      Number(hairlineWidthInput?.value || String(HAIRLINE_MAX_THICKNESS)) || HAIRLINE_MAX_THICKNESS,
      1.2,
      4.0
    );
    runtimeHairlineMinInkStrength = clamp(
      Math.round(
        Number(hairlineInkInput?.value || String(HAIRLINE_FALLBACK_MIN_INK_STRENGTH)) ||
          HAIRLINE_FALLBACK_MIN_INK_STRENGTH
      ),
      1,
      40
    );
    runtimeHairlineMinRun = clamp(
      Math.round(
        Number(hairlineRunInput?.value || String(HAIRLINE_NS_MIN_RUN)) || HAIRLINE_NS_MIN_RUN
      ),
      4,
      24
    );
    runtimeHairlineComponentMinLongSide = clamp(
      Math.round(
        Number(hairlineLengthInput?.value || String(HAIRLINE_COMPONENT_MIN_LONG_SIDE)) ||
          HAIRLINE_COMPONENT_MIN_LONG_SIDE
      ),
      6,
      48
    );
    runtimeDashNeighborMin = clamp(
      Math.round(
        Number(dashNeighborsInput?.value || String(DASH_MIN_RUN_LENGTH)) || DASH_MIN_RUN_LENGTH
      ),
      3,
      8
    );
    syncDashControlLabels();
    setOverlayVisible("step3", true);
    setOverlayVisible("step4", true);
    setOverlayVisible("step5", true);
    setOverlayVisible("step6", true);
    if (!drawingState) return;
    if (tuningRenderTimer !== null) window.clearTimeout(tuningRenderTimer);
    setStatus("Applying slider changes...");
    tuningRenderTimer = window.setTimeout(() => {
      tuningRenderTimer = null;
      renderProcessingOnlyView();
    }, 120);
  };
  const handleLayerFlowInput = () => {
    syncLayerFlowStateFromInputs();
    if (!drawingState) return;
    if (tuningRenderTimer !== null) window.clearTimeout(tuningRenderTimer);
    setStatus("Applying layer flow changes...");
    tuningRenderTimer = window.setTimeout(() => {
      tuningRenderTimer = null;
      renderProcessingOnlyView();
    }, 120);
  };
  const handleMatchTuningInput = () => {
    runtimeMatchThreshold = clamp(
      Number(matchThresholdInput?.value || String(MATCH_THRESHOLD)),
      0.45,
      0.98
    );
    runtimeMinPuzzleOverlap = clamp(
      Number(matchOverlapInput?.value || String(MIN_PUZZLE_OVERLAP)),
      0.1,
      0.95
    );
    runtimeAmbiguousMargin = clamp(
      Number(matchAmbiguousInput?.value || String(AMBIGUOUS_MARGIN)),
      0,
      0.2
    );
    runtimeBlackInkMaxLuma = clamp(
      Number(blackLumaInput?.value || String(BLACK_INK_MAX_LUMA)),
      60,
      220
    );
    runtimeBlackInkMaxSpread = clamp(
      Number(blackSpreadInput?.value || String(BLACK_INK_MAX_SPREAD)),
      8,
      90
    );
    runtimeBlackInkMinRatio = clamp(
      Number(blackRatioInput?.value || String(BLACK_INK_MIN_RATIO)),
      0.1,
      0.95
    );
    syncMatchControlLabels();
    if (matchMetaEl) {
      matchMetaEl.textContent =
        "Match parameters updated. Run Match (Targeted Library) to apply these settings.";
    }
  };
  const applyStep55InteractionAtPoint = (
    x: number,
    y: number,
    opts: { componentTolerance?: number; endpointTolerance?: number } = {}
  ) => {
    const componentTolerance = Math.max(10, Number(opts.componentTolerance || 18));
    const endpointTolerance = Math.max(10, Number(opts.endpointTolerance || 20));
    if (step55Mode === "off" || !drawingState) return;
    if (step55Mode === "cleanup") {
      const idx = findNearestStep55Component(x, y, componentTolerance);
      if (idx === null) return;
      if (step55RemovedIndexes.has(idx)) step55RemovedIndexes.delete(idx);
      else step55RemovedIndexes.add(idx);
      step55SelectedEndpoint = null;
      renderProcessingOnlyView();
      return;
    }
    if (step55Mode === "connect") {
      const endpoint = findNearestStep55Endpoint(x, y, endpointTolerance);
      if (!endpoint) return;
      if (!step55SelectedEndpoint) {
        step55SelectedEndpoint = { x: endpoint.x, y: endpoint.y };
        updateStep55Ui();
        return;
      }
      const a = step55SelectedEndpoint;
      const b = { x: endpoint.x, y: endpoint.y };
      if (Math.hypot(a.x - b.x, a.y - b.y) < 2) {
        step55SelectedEndpoint = null;
        updateStep55Ui();
        return;
      }
      const avgThickness =
        step55EditableComps.length > 0
          ? Math.max(
              1,
              Math.round(
                step55EditableComps.reduce((sum, c) => sum + c.thickness, 0) /
                  step55EditableComps.length
              )
            )
          : 1;
      if (Math.abs(a.x - b.x) > 2 && Math.abs(a.y - b.y) > 2) {
        step55AddedSegments.push({ x0: a.x, y0: a.y, x1: b.x, y1: a.y, thickness: avgThickness });
        step55AddedSegments.push({ x0: b.x, y0: a.y, x1: b.x, y1: b.y, thickness: avgThickness });
      } else {
        step55AddedSegments.push({ x0: a.x, y0: a.y, x1: b.x, y1: b.y, thickness: avgThickness });
      }
      step55SelectedEndpoint = null;
      renderProcessingOnlyView();
    }
  };
  const handleStep55CanvasClick = (event: MouseEvent) => {
    const p = getCanvasPointFromEvent(event);
    if (!p) return;
    applyStep55InteractionAtPoint(p.x, p.y, { componentTolerance: 22, endpointTolerance: 24 });
  };
  const handleStep55StepPanelClick = (event: MouseEvent, hitTarget: HTMLElement) => {
    if (!drawingState || step55Mode === "off") return;
    const rect = hitTarget.getBoundingClientRect();
    if (rect.width <= 0 || rect.height <= 0) return;
    const sx = drawingState.width / Math.max(1, rect.width);
    const sy = drawingState.height / Math.max(1, rect.height);
    const scaleAvg = (sx + sy) / 2;
    const x = clamp(
      ((event.clientX - rect.left) / rect.width) * drawingState.width,
      0,
      drawingState.width - 1
    );
    const y = clamp(
      ((event.clientY - rect.top) / rect.height) * drawingState.height,
      0,
      drawingState.height - 1
    );
    applyStep55InteractionAtPoint(x, y, {
      componentTolerance: clamp(Math.round(18 * scaleAvg), 20, 96),
      endpointTolerance: clamp(Math.round(22 * scaleAvg), 24, 110),
    });
  };
  const handleOverlayPointerMove = (event: PointerEvent) => {
    if (!overlayDragState) return;
    const t = ensureOverlayTransform(overlayDragState.key);
    t.x = overlayDragState.baseX + (event.clientX - overlayDragState.startX);
    t.y = overlayDragState.baseY + (event.clientY - overlayDragState.startY);
    applyOverlayTransformUi(overlayDragState.key);
  };
  const handleOverlayPointerUp = () => {
    overlayDragState = null;
  };
  colorSpreadInput?.addEventListener("input", handleColorTuningInput);
  hairlineWidthInput?.addEventListener("input", handleColorTuningInput);
  hairlineInkInput?.addEventListener("input", handleColorTuningInput);
  hairlineRunInput?.addEventListener("input", handleColorTuningInput);
  hairlineLengthInput?.addEventListener("input", handleColorTuningInput);
  dashNeighborsInput?.addEventListener("input", handleColorTuningInput);
  flowStep2Step3Input?.addEventListener("change", handleLayerFlowInput);
  flowStep2Step4Input?.addEventListener("change", handleLayerFlowInput);
  flowStep3Step4Input?.addEventListener("change", handleLayerFlowInput);
  matchThresholdInput?.addEventListener("input", handleMatchTuningInput);
  matchOverlapInput?.addEventListener("input", handleMatchTuningInput);
  matchAmbiguousInput?.addEventListener("input", handleMatchTuningInput);
  blackLumaInput?.addEventListener("input", handleMatchTuningInput);
  blackSpreadInput?.addEventListener("input", handleMatchTuningInput);
  blackRatioInput?.addEventListener("input", handleMatchTuningInput);
  textOcrToggleInput?.addEventListener("change", async () => {
    useOcrTextDetection = Boolean(textOcrToggleInput.checked);
    updateTextOcrUiMeta(useOcrTextDetection ? "loading OCR engine on demand" : "");
    if (drawingState) await renderProcessingOnlyView();
  });
  libraryRefreshBtn?.addEventListener("click", async () => {
    if (libraryMetaEl) libraryMetaEl.textContent = "Refreshing library...";
    await refreshItemLibrary(true);
  });
  librarySelectAllBtn?.addEventListener("click", () => {
    itemLibrary.forEach((item) => {
      const fileName = String(item?.fileName || "");
      if (fileName) targetedLibraryFileNames.add(fileName);
    });
    renderLibraryTargetingUi();
  });
  libraryClearAllBtn?.addEventListener("click", () => {
    targetedLibraryFileNames.clear();
    renderLibraryTargetingUi();
  });
  syncDashControlLabels();
  syncMatchControlLabels();
  syncLayerFlowStateFromInputs();
  renderMatchSummaryUi();
  if (textOcrToggleInput) textOcrToggleInput.checked = useOcrTextDetection;
  updateTextOcrUiMeta();
  renderLibraryTargetingUi();
  updateStep55Ui();
  step55ModeOffBtn?.addEventListener("click", () => setStep55Mode("off"));
  step55ModeCleanupBtn?.addEventListener("click", () => setStep55Mode("cleanup"));
  step55ModeConnectBtn?.addEventListener("click", () => setStep55Mode("connect"));
  step55ClearBtn?.addEventListener("click", () => {
    step55RemovedIndexes.clear();
    step55AddedSegments = [];
    step55SelectedEndpoint = null;
    updateStep55Ui();
    if (drawingState) renderProcessingOnlyView();
  });
  canvas?.addEventListener("click", handleStep55CanvasClick);
  pipelineStepsEl?.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    const hit = target?.closest?.("[data-step55-hit]") as HTMLElement | null;
    if (!hit) return;
    handleStep55StepPanelClick(event as MouseEvent, hit);
  });
  window.addEventListener("pointermove", handleOverlayPointerMove);
  window.addEventListener("pointerup", handleOverlayPointerUp);
  window.addEventListener("pointercancel", handleOverlayPointerUp);
  runScanBtn?.addEventListener("click", renderProcessingOnlyView);
  runMatchBtn?.addEventListener("click", runSimpleScan);
  playBtn?.addEventListener("click", startPlayback);
  pauseBtn?.addEventListener("click", stopPlayback);
  nextBtn?.addEventListener("click", () => {
    stopPlayback();
    stepTrace(1);
  });

  (async () => {
    try {
      while (!getPdfLib()) await new Promise((r) => setTimeout(r, 100));
      await refreshItemLibrary(true);
      const res = await fetch(DEFAULT_DRAWING_PUBLIC_PATH, { cache: "no-store" });
      const blob = await res.blob();
      await handleDrawingUpload(new File([blob], "demo-plan.pdf", { type: "application/pdf" }));
    } catch {
      setStatus("Could not auto-load default drawing.");
    }
  })();
</script>
