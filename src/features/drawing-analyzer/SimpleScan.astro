  function maskedSourceToDataUrl(imageData, selectedRegions = []) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    const out = new ImageData(
      new Uint8ClampedArray(imageData.data),
      imageData.width,
      imageData.height
    );
    if (Array.isArray(selectedRegions) && selectedRegions.length > 0) {
      for (let y = 0; y < out.height; y += 1) {
        const row = y * out.width;
        for (let x = 0; x < out.width; x += 1) {
          const inside = selectedRegions.some(
            (r) => x >= r.x && y >= r.y && x < r.x + r.w && y < r.y + r.h
          );
          if (inside) continue;
          const i = (row + x) * 4;
          out.data[i] = 255;
          out.data[i + 1] = 255;
          out.data[i + 2] = 255;
          out.data[i + 3] = 255;
        }
      }
    }
    ctx.putImageData(out, 0, 0);
    return c.toDataURL("image/png");
  }

  function maskedImageByMaskToDataUrl(imageData, mask) {
    if (!imageData || !mask || mask.length !== imageData.width * imageData.height) return "";
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    const out = new ImageData(
      new Uint8ClampedArray(imageData.data),
      imageData.width,
      imageData.height
    );
    for (let p = 0; p < mask.length; p += 1) {
      if (mask[p]) continue;
      const i = p * 4;
      out.data[i] = 255;
      out.data[i + 1] = 255;
      out.data[i + 2] = 255;
      out.data[i + 3] = 255;
    }
    ctx.putImageData(out, 0, 0);
    return c.toDataURL("image/png");
  }

  function diffRemovedMask(beforeMask, afterMask) {
    const len = Math.min(beforeMask?.length || 0, afterMask?.length || 0);
    const out = new Uint8Array(len);
    for (let i = 0; i < len; i += 1) out[i] = beforeMask[i] && !afterMask[i] ? 1 : 0;
    return out;
  }

  function dilateMask(mask, width, height, radius = IDENTIFIED_OVERLAY_STROKE_RADIUS) {
    if (!mask || radius <= 0) return mask;
    const out = new Uint8Array(mask.length);
    for (let y = 0; y < height; y += 1) {
      const row = y * width;
      for (let x = 0; x < width; x += 1) {
        const p = row + x;
        if (!mask[p]) continue;
        const y0 = Math.max(0, y - radius);
        const y1 = Math.min(height - 1, y + radius);
        const x0 = Math.max(0, x - radius);
        const x1 = Math.min(width - 1, x + radius);
        for (let yy = y0; yy <= y1; yy += 1) {
          const r = yy * width;
          for (let xx = x0; xx <= x1; xx += 1) out[r + xx] = 1;
        }
      }
    }
    return out;
  }

  function lineSegmentsToMask(segments, width, height) {
    const out = new Uint8Array(width * height);
    const stamp = (x, y, radius) => {
      const x0 = Math.max(0, x - radius);
      const x1 = Math.min(width - 1, x + radius);
      const y0 = Math.max(0, y - radius);
      const y1 = Math.min(height - 1, y + radius);
      for (let yy = y0; yy <= y1; yy += 1) {
        const row = yy * width;
        for (let xx = x0; xx <= x1; xx += 1) out[row + xx] = 1;
      }
    };
    for (const seg of segments || []) {
      let x0 = Math.round(seg.x0);
      let y0 = Math.round(seg.y0);
      const x1 = Math.round(seg.x1);
      const y1 = Math.round(seg.y1);
      const radius = Math.max(0, Math.round((Number(seg.thickness || 1) - 1) / 2));
      const dx = Math.abs(x1 - x0);
      const sx = x0 < x1 ? 1 : -1;
      const dy = -Math.abs(y1 - y0);
      const sy = y0 < y1 ? 1 : -1;
      let err = dx + dy;
      while (true) {
        if (x0 >= 0 && y0 >= 0 && x0 < width && y0 < height) stamp(x0, y0, radius);
        if (x0 === x1 && y0 === y1) break;
        const e2 = 2 * err;
        if (e2 >= dy) {
          err += dy;
          x0 += sx;
        }
        if (e2 <= dx) {
          err += dx;
          y0 += sy;
        }
      }
    }
    return out;
  }

  function colorMaskLayerToDataUrl(
    imageData,
    selectedRegions,
    removedMask,
    highlight = [239, 68, 68],
    useSourceColors = false
  ) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    const out = new Uint8ClampedArray(imageData.width * imageData.height * 4);
    const displayMask = dilateMask(
      removedMask,
      imageData.width,
      imageData.height,
      IDENTIFIED_OVERLAY_STROKE_RADIUS
    );
    for (let y = 0; y < imageData.height; y += 1) {
      const row = y * imageData.width;
      for (let x = 0; x < imageData.width; x += 1) {
        const p = row + x;
        const i = p * 4;
        const inside = selectedRegions.some(
          (r) => x >= r.x && y >= r.y && x < r.x + r.w && y < r.y + r.h
        );
        if (!inside) {
          out[i] = 255;
          out[i + 1] = 255;
          out[i + 2] = 255;
          out[i + 3] = 255;
          continue;
        }
        if (displayMask[p]) {
          if (useSourceColors) {
            out[i] = imageData.data[i];
            out[i + 1] = imageData.data[i + 1];
            out[i + 2] = imageData.data[i + 2];
          } else {
            out[i] = highlight[0];
            out[i + 1] = highlight[1];
            out[i + 2] = highlight[2];
          }
          out[i + 3] = 255;
          continue;
        }
        out[i] = 245;
        out[i + 1] = 245;
        out[i + 2] = 245;
        out[i + 3] = 255;
      }
    }
    ctx.putImageData(new ImageData(out, imageData.width, imageData.height), 0, 0);
    return c.toDataURL("image/png");
  }

  function removeComponentBoxesFromMask(mask, width, height, comps, indexesToRemove) {
    const out = new Uint8Array(mask);
    if (!Array.isArray(comps) || !(indexesToRemove instanceof Set) || indexesToRemove.size === 0)
      return out;
    indexesToRemove.forEach((idx) => {
      const comp = comps[idx];
      if (!comp) return;
      const xStart = Math.max(0, comp.x);
      const yStart = Math.max(0, comp.y);
      const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
      const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
      for (let y = yStart; y <= yEnd; y += 1) {
        const row = y * width;
        for (let x = xStart; x <= xEnd; x += 1) out[row + x] = 0;
      }
    });
    return out;
  }

  function estimateComponentAxisOffAngleDeg(comp, mask, width, height) {
    let count = 0;
    let sumX = 0;
    let sumY = 0;
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    for (let y = yStart; y <= yEnd; y += 1) {
      const row = y * width;
      for (let x = xStart; x <= xEnd; x += 1) {
        if (!mask[row + x]) continue;
        count += 1;
        sumX += x;
        sumY += y;
      }
    }
    if (count < 10) return Number.POSITIVE_INFINITY;
    const meanX = sumX / count;
    const meanY = sumY / count;
    let covXX = 0;
    let covYY = 0;
    let covXY = 0;
    for (let y = yStart; y <= yEnd; y += 1) {
      const row = y * width;
      for (let x = xStart; x <= xEnd; x += 1) {
        if (!mask[row + x]) continue;
        const dx = x - meanX;
        const dy = y - meanY;
        covXX += dx * dx;
        covYY += dy * dy;
        covXY += dx * dy;
      }
    }
    const theta = 0.5 * Math.atan2(2 * covXY, covXX - covYY);
    const deg = (Math.abs(theta) * 180) / Math.PI;
    const canonical = deg > 45 ? 90 - deg : deg;
    return Math.abs(canonical);
  }

  function detectColoredPixelsWithinAllowedMask(imageData, allowedMask = null) {
    const { width, height } = imageData;
    const colorMask = new Uint8Array(width * height);
    let coloredPixelCount = 0;
    for (let p = 0; p < colorMask.length; p += 1) {
      if (allowedMask && !allowedMask[p]) continue;
      const i = p * 4;
      const r = imageData.data[i];
      const g = imageData.data[i + 1];
      const b = imageData.data[i + 2];
      const a = imageData.data[i + 3];
      if (a < 16) continue;
      const luma = r * 0.299 + g * 0.587 + b * 0.114;
      if (luma < COLOR_LINE_MIN_LUMA) continue; // Ignore black/near-black ink.
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      if (spread < runtimeColorLineMinSpread) continue;
      colorMask[p] = 1;
      coloredPixelCount += 1;
    }
    return {
      colorMask,
      coloredPixelCount,
    };
  }

  function getComponentLongestAxisRunAndCoverage(comp, mask, width, height) {
    const xStart = Math.max(0, comp.x);
    const yStart = Math.max(0, comp.y);
    const xEnd = Math.min(width - 1, comp.x + comp.w - 1);
    const yEnd = Math.min(height - 1, comp.y + comp.h - 1);
    if (xStart > xEnd || yStart > yEnd) return { longestRun: 0, runCoverage: 0 };
    let maxHorizontalRun = 0;
    let maxVerticalRun = 0;
    for (let y = yStart; y <= yEnd; y += 1) {
      let run = 0;
      const row = y * width;
      for (let x = xStart; x <= xEnd; x += 1) {
        if (mask[row + x]) {
          run += 1;
          if (run > maxHorizontalRun) maxHorizontalRun = run;
        } else {
          run = 0;
        }
      }
    }
    for (let x = xStart; x <= xEnd; x += 1) {
      let run = 0;
      for (let y = yStart; y <= yEnd; y += 1) {
        if (mask[y * width + x]) {
          run += 1;
          if (run > maxVerticalRun) maxVerticalRun = run;
        } else {
          run = 0;
        }
      }
    }
    const longSide = Math.max(1, Math.max(comp.w, comp.h));
    const longestRun = Math.max(maxHorizontalRun, maxVerticalRun);
    const runCoverage = longestRun / longSide;
    return { longestRun, runCoverage };
  }

  function detectHairlineMaskOrthogonalPasses(mask, imageData, width, height) {
    const nsMask = new Uint8Array(width * height);
    const ewMask = new Uint8Array(width * height);
    const candidateMask = new Uint8Array(mask);

    // Faint-ink fallback: include very light grayscale strokes that the upstream binary mask may miss.
    for (let p = 0; p < candidateMask.length; p += 1) {
      if (candidateMask[p]) continue;
      const i = p * 4;
      const a = imageData.data[i + 3];
      if (a < 16) continue;
      const r = imageData.data[i];
      const g = imageData.data[i + 1];
      const b = imageData.data[i + 2];
      const luma = r * 0.299 + g * 0.587 + b * 0.114;
      const inkStrength = 255 - luma;
      const spread = Math.max(r, g, b) - Math.min(r, g, b);
      if (inkStrength >= runtimeHairlineMinInkStrength && spread <= HAIRLINE_FALLBACK_MAX_SPREAD) {
        candidateMask[p] = 1;
      }
    }

    const horizontalThicknessAt = (x, y) => {
      let left = x;
      let right = x;
      while (left - 1 >= 0 && candidateMask[y * width + (left - 1)]) left -= 1;
      while (right + 1 < width && candidateMask[y * width + (right + 1)]) right += 1;
      return right - left + 1;
    };
    const verticalThicknessAt = (x, y) => {
      let top = y;
      let bottom = y;
      while (top - 1 >= 0 && candidateMask[(top - 1) * width + x]) top -= 1;
      while (bottom + 1 < height && candidateMask[(bottom + 1) * width + x]) bottom += 1;
      return bottom - top + 1;
    };

    // North/South pass (gap tolerant, so faint broken lines still count as continuous paths).
    for (let x = 0; x < width; x += 1) {
      let y = 0;
      while (y < height) {
        while (y < height && !candidateMask[y * width + x]) y += 1;
        if (y >= height) break;
        let end = y;
        let startInk = y;
        let lastInk = y;
        let gap = 0;
        let thicknessSum = 0;
        let count = 0;
        while (end < height) {
          const on = candidateMask[end * width + x];
          if (on) {
            if (count === 0) startInk = end;
            lastInk = end;
            thicknessSum += horizontalThicknessAt(x, end);
            count += 1;
            gap = 0;
            end += 1;
            continue;
          }
          if (gap < HAIRLINE_MAX_GAP) {
            gap += 1;
            end += 1;
            continue;
          }
          break;
        }
        const runLen = Math.max(0, lastInk - startInk + 1);
        const avgThickness = count > 0 ? thicknessSum / count : Number.POSITIVE_INFINITY;
        if (runLen >= runtimeHairlineMinRun && avgThickness <= runtimeHairlineMaxThickness) {
          for (let yy = startInk; yy <= lastInk; yy += 1) {
            if (candidateMask[yy * width + x]) nsMask[yy * width + x] = 1;
          }
        }
        y = Math.max(lastInk + 1, end);
      }
    }

    // East/West pass (same gap-tolerant logic).
    for (let y = 0; y < height; y += 1) {
      let x = 0;
      while (x < width) {
        while (x < width && !candidateMask[y * width + x]) x += 1;
        if (x >= width) break;
        let end = x;
        let startInk = x;
        let lastInk = x;
        let gap = 0;
        let thicknessSum = 0;
        let count = 0;
        while (end < width) {
          const on = candidateMask[y * width + end];
          if (on) {
            if (count === 0) startInk = end;
            lastInk = end;
            thicknessSum += verticalThicknessAt(end, y);
            count += 1;
            gap = 0;
            end += 1;
            continue;
          }
          if (gap < HAIRLINE_MAX_GAP) {
            gap += 1;
            end += 1;
            continue;
          }
          break;
        }
        const runLen = Math.max(0, lastInk - startInk + 1);
        const avgThickness = count > 0 ? thicknessSum / count : Number.POSITIVE_INFINITY;
        if (runLen >= runtimeHairlineMinRun && avgThickness <= runtimeHairlineMaxThickness) {
          for (let xx = startInk; xx <= lastInk; xx += 1) {
            if (candidateMask[y * width + xx]) ewMask[y * width + xx] = 1;
          }
        }
        x = Math.max(lastInk + 1, end);
      }
    }

    const hairlineMask = new Uint8Array(width * height);
    let nsPixels = 0;
    let ewPixels = 0;
    let combinedPixels = 0;
    for (let p = 0; p < hairlineMask.length; p += 1) {
      if (nsMask[p]) nsPixels += 1;
      if (ewMask[p]) ewPixels += 1;
      if (nsMask[p] || ewMask[p]) {
        hairlineMask[p] = 1;
        combinedPixels += 1;
      }
    }
    const comps = getComponents(hairlineMask, width, height, LINE_COMPONENT_MIN_AREA, 20000);
    const filteredHairlineMask = new Uint8Array(width * height);
    let keptComponents = 0;
    for (const c of comps) {
      const longSide = Math.max(c.w, c.h);
      const shortSide = Math.min(c.w, c.h);
      if (longSide < runtimeHairlineComponentMinLongSide) continue;
      if (shortSide > HAIRLINE_COMPONENT_MAX_SHORT_SIDE) continue;
      keptComponents += 1;
      const x0 = Math.max(0, c.x);
      const y0 = Math.max(0, c.y);
      const x1 = Math.min(width - 1, c.x + c.w - 1);
      const y1 = Math.min(height - 1, c.y + c.h - 1);
      for (let yy = y0; yy <= y1; yy += 1) {
        const row = yy * width;
        for (let xx = x0; xx <= x1; xx += 1) {
          const p = row + xx;
          if (!hairlineMask[p]) continue;
          filteredHairlineMask[p] = 1;
        }
      }
    }
    return {
      hairlineMask: filteredHairlineMask,
      hairlineCount: keptComponents,
      nsPixels,
      ewPixels,
      combinedPixels,
      nsMinRun: runtimeHairlineMinRun,
      ewMinRun: runtimeHairlineMinRun,
      maxThickness: runtimeHairlineMaxThickness,
      maxGap: HAIRLINE_MAX_GAP,
      fallbackMinInkStrength: runtimeHairlineMinInkStrength,
      fallbackMaxSpread: HAIRLINE_FALLBACK_MAX_SPREAD,
    };
  }

  function detectLineAndDashedComponentIndexes(comps, mask, width, height, regions = []) {
    const out = new Set<number>();
    const solidIndexes = new Set<number>();
    const hairlineIndexes = new Set<number>();
    const dashedIndexes = new Set<number>();
    let solidCount = 0;
    let hairlineCount = 0;
    let dashedCount = 0;
    let axisRejectedCount = 0;
    const maxOffAxisDeg = 90 * AXIS_ALIGNMENT_TOLERANCE_PERCENT;
    const maxDashOffAxisDeg = 90 * DASH_AXIS_ALIGNMENT_TOLERANCE_PERCENT;
    const axisMetaByIndex = new Map<number, number>();
    const dashedLineSegments: Array<{
      idx: number;
      x0: number;
      y0: number;
      x1: number;
      y1: number;
      thickness: number;
      horizontal: boolean;
    }> = [];
    const dashedSeeds: Array<{
      idx: number;
      horizontal: boolean;
      cx: number;
      cy: number;
      sizePrimary: number;
      sizeSecondary: number;
      x: number;
      y: number;
      w: number;
      h: number;
    }> = [];
    const seedByIdx = new Map<number, (typeof dashedSeeds)[number]>();
    for (let i = 0; i < comps.length; i += 1) {
      const c = comps[i];
      const w = Math.max(1, c.w);
      const h = Math.max(1, c.h);
      const longSide = Math.max(w, h);
      const shortSide = Math.min(w, h);
      const aspect = longSide / shortSide;
      const fill = c.area / Math.max(1, w * h);
      const isSolidLine =
        longSide >= SOLID_LINE_MIN_LONG_SIDE &&
        shortSide <= SOLID_LINE_MAX_SHORT_SIDE &&
        aspect >= SOLID_LINE_MIN_ASPECT &&
        fill > 0.1 &&
        fill < 0.92;
      const isHairline =
        longSide >= HAIRLINE_MIN_LONG_SIDE &&
        shortSide <= HAIRLINE_MAX_SHORT_SIDE &&
        aspect >= HAIRLINE_MIN_ASPECT &&
        fill > 0.05 &&
        fill < 0.98;
      if (isSolidLine || isHairline) {
        const offAxisDeg = estimateComponentAxisOffAngleDeg(c, mask, width, height);
        if (!Number.isFinite(offAxisDeg) || offAxisDeg > maxOffAxisDeg) {
          axisRejectedCount += 1;
          continue;
        }
        axisMetaByIndex.set(i, offAxisDeg);
        out.add(i);
        solidIndexes.add(i);
        solidCount += 1;
        if (isHairline) {
          hairlineCount += 1;
          hairlineIndexes.add(i);
        }
        continue;
      }
      const isDashSeed =
        longSide >= DASH_SEED_MIN_LONG_SIDE &&
        longSide <= DASH_SEED_MAX_LONG_SIDE &&
        shortSide <= DASH_SEED_MAX_SHORT_SIDE &&
        aspect >= DASH_SEED_MIN_ASPECT &&
        c.area >= DASH_SEED_MIN_AREA &&
        c.area <= DASH_SEED_MAX_AREA;
      if (isDashSeed) {
        const offAxisDeg = estimateComponentAxisOffAngleDeg(c, mask, width, height);
        if (!Number.isFinite(offAxisDeg) || offAxisDeg > maxDashOffAxisDeg) {
          axisRejectedCount += 1;
          continue;
        }
        axisMetaByIndex.set(i, offAxisDeg);
        dashedSeeds.push({
          idx: i,
          horizontal: w >= h,
          cx: c.x + w / 2,
          cy: c.y + h / 2,
          sizePrimary: longSide,
          sizeSecondary: shortSide,
          x: c.x,
          y: c.y,
          w,
          h,
        });
        seedByIdx.set(i, dashedSeeds[dashedSeeds.length - 1]);
      }
    }
    const adjacency = new Map<number, Set<number>>();
    const looseAdjacency = new Map<number, Set<number>>();
    const sameAxisNeighbors = new Map<
      number,
      Array<{ idx: number; signedPrimary: number; absPrimary: number; secondary: number }>
    >();
    dashedSeeds.forEach((s) => {
      adjacency.set(s.idx, new Set<number>());
      looseAdjacency.set(s.idx, new Set<number>());
      sameAxisNeighbors.set(s.idx, []);
    });
    const connect = (map: Map<number, Set<number>>, aIdx: number, bIdx: number) => {
      map.get(aIdx)?.add(bIdx);
      map.get(bIdx)?.add(aIdx);
    };
    for (let i = 0; i < dashedSeeds.length; i += 1) {
      const a = dashedSeeds[i];
      for (let j = i + 1; j < dashedSeeds.length; j += 1) {
        const b = dashedSeeds[j];
        const maxPrimaryGap = Math.max(
          48,
          Math.max(a.sizePrimary, b.sizePrimary) * DASH_PRIMARY_GAP_MULTIPLIER
        );
        const maxSecondaryGap = Math.max(
          8,
          Math.max(a.sizeSecondary, b.sizeSecondary) * DASH_SECONDARY_GAP_MULTIPLIER
        );
        const maxPrimaryGapLoose = maxPrimaryGap * DASH_MAGNETIC_PRIMARY_GAP_MULTIPLIER;
        const maxSecondaryGapLoose = maxSecondaryGap * DASH_MAGNETIC_SECONDARY_GAP_MULTIPLIER;
        if (a.horizontal === b.horizontal) {
          const signedPrimary = a.horizontal ? b.cx - a.cx : b.cy - a.cy;
          const deltaPrimary = Math.abs(signedPrimary);
          const deltaSecondary = a.horizontal ? Math.abs(a.cy - b.cy) : Math.abs(a.cx - b.cx);
          if (deltaPrimary <= maxPrimaryGap && deltaSecondary <= maxSecondaryGap) {
            connect(adjacency, a.idx, b.idx);
            sameAxisNeighbors.get(a.idx)?.push({
              idx: b.idx,
              signedPrimary,
              absPrimary: deltaPrimary,
              secondary: deltaSecondary,
            });
            sameAxisNeighbors.get(b.idx)?.push({
              idx: a.idx,
              signedPrimary: -signedPrimary,
              absPrimary: deltaPrimary,
              secondary: deltaSecondary,
            });
          }
          if (deltaPrimary <= maxPrimaryGapLoose && deltaSecondary <= maxSecondaryGapLoose) {
            connect(looseAdjacency, a.idx, b.idx);
          }
          continue;
        }
        // Allow orthogonal continuity so dashed runs can turn at 90 degrees.
        const aX0 = a.x;
        const aY0 = a.y;
        const aX1 = a.x + a.w - 1;
        const aY1 = a.y + a.h - 1;
        const bX0 = b.x;
        const bY0 = b.y;
        const bX1 = b.x + b.w - 1;
        const bY1 = b.y + b.h - 1;
        const gapX = Math.max(0, Math.max(aX0 - bX1, bX0 - aX1));
        const gapY = Math.max(0, Math.max(aY0 - bY1, bY0 - aY1));
        const centerNearBase =
          Math.abs(a.cx - b.cx) <= maxPrimaryGap && Math.abs(a.cy - b.cy) <= maxPrimaryGap;
        const nearTurnBase = gapX <= maxSecondaryGap * 2 && gapY <= maxSecondaryGap * 2;
        if (nearTurnBase && centerNearBase) connect(adjacency, a.idx, b.idx);
        const centerNearLoose =
          Math.abs(a.cx - b.cx) <= maxPrimaryGapLoose &&
          Math.abs(a.cy - b.cy) <= maxPrimaryGapLoose;
        const nearTurnLoose = gapX <= maxSecondaryGapLoose * 2 && gapY <= maxSecondaryGapLoose * 2;
        if (nearTurnLoose && centerNearLoose) connect(looseAdjacency, a.idx, b.idx);
      }
    }

    // Pass 1: find reliable 3-dash seeds with roughly equal spacing.
    const magneticSeedSet = new Set<number>();
    dashedSeeds.forEach((seed) => {
      const neighbors = sameAxisNeighbors.get(seed.idx) || [];
      const left = neighbors.filter((n) => n.signedPrimary < 0);
      const right = neighbors.filter((n) => n.signedPrimary > 0);
      for (const l of left) {
        for (const r of right) {
          const d1 = l.absPrimary;
          const d2 = r.absPrimary;
          const maxD = Math.max(d1, d2, 1);
          const spacingDelta = Math.abs(d1 - d2) / maxD;
          const secondaryGate =
            Math.max(l.secondary, r.secondary) <= Math.max(8, seed.sizeSecondary * 2.4);
          if (spacingDelta > DASH_SEED_EQUAL_SPACING_TOLERANCE || !secondaryGate) continue;
          magneticSeedSet.add(seed.idx);
          magneticSeedSet.add(l.idx);
          magneticSeedSet.add(r.idx);
        }
      }
    });

    // Pass 2: magnetic follow from seed triples; fallback to base graph if no seeds found.
    const magneticReachable = new Set<number>();
    if (magneticSeedSet.size > 0) {
      const queue = Array.from(magneticSeedSet);
      queue.forEach((idx) => magneticReachable.add(idx));
      while (queue.length) {
        const cur = queue.shift() as number;
        const neighbors = looseAdjacency.get(cur);
        if (!neighbors) continue;
        neighbors.forEach((n) => {
          if (magneticReachable.has(n)) return;
          magneticReachable.add(n);
          queue.push(n);
        });
      }
    }
    const candidateDashIds =
      magneticSeedSet.size > 0 ? magneticReachable : new Set(dashedSeeds.map((s) => s.idx));

    const graphForClusters = magneticSeedSet.size > 0 ? looseAdjacency : adjacency;
    const visited = new Set<number>();
    const qualifyingClusters: Array<{
      ids: number[];
      size: number;
      area: number;
      cx: number;
      cy: number;
      score: number;
    }> = [];
    candidateDashIds.forEach((startIdx) => {
      if (visited.has(startIdx)) return;
      const stack = [startIdx];
      visited.add(startIdx);
      const cluster: number[] = [];
      while (stack.length) {
        const cur = stack.pop() as number;
        cluster.push(cur);
        const neighbors = graphForClusters.get(cur);
        if (!neighbors) continue;
        neighbors.forEach((n) => {
          if (!candidateDashIds.has(n) || visited.has(n)) return;
          visited.add(n);
          stack.push(n);
        });
      }
      if (cluster.length < runtimeDashNeighborMin) return;
      const metrics = cluster.reduce(
        (acc, idx) => {
          const c = comps[idx];
          const s = seedByIdx.get(idx);
          if (c) acc.area += Number(c.area || 0);
          if (s) {
            acc.cx += s.cx;
            acc.cy += s.cy;
            acc.n += 1;
          }
          return acc;
        },
        { area: 0, cx: 0, cy: 0, n: 0 }
      );
      const centerX = metrics.n > 0 ? metrics.cx / metrics.n : 0;
      const centerY = metrics.n > 0 ? metrics.cy / metrics.n : 0;
      qualifyingClusters.push({
        ids: cluster,
        size: cluster.length,
        area: metrics.area,
        cx: centerX,
        cy: centerY,
        score: cluster.length * 1000 + metrics.area,
      });
    });

    let droppedDashClustersBySectionCap = 0;
    let keptClusters = qualifyingClusters;
    if (Array.isArray(regions) && regions.length > 0) {
      const byRegion = new Map<number, typeof qualifyingClusters>();
      const unassigned: typeof qualifyingClusters = [];
      for (const cluster of qualifyingClusters) {
        const regionIdx = regions.findIndex(
          (r) =>
            cluster.cx >= r.x &&
            cluster.cy >= r.y &&
            cluster.cx < r.x + r.w &&
            cluster.cy < r.y + r.h
        );
        if (regionIdx === -1) {
          unassigned.push(cluster);
          continue;
        }
        if (!byRegion.has(regionIdx)) byRegion.set(regionIdx, []);
        byRegion.get(regionIdx)?.push(cluster);
      }
      keptClusters = [...unassigned];
      byRegion.forEach((clusters) => {
        const sorted = [...clusters].sort((a, b) => b.score - a.score);
        const kept = sorted.slice(0, DASH_MAX_CLUSTERS_PER_REGION);
        keptClusters.push(...kept);
        droppedDashClustersBySectionCap += Math.max(
          0,
          sorted.length - DASH_MAX_CLUSTERS_PER_REGION
        );
      });
    }

    const loopClosureSegments: Array<{
      x0: number;
      y0: number;
      x1: number;
      y1: number;
      thickness: number;
    }> = [];
    let loopClosedClusterCount = 0;
    let droppedNonClosedDashClusters = 0;
    const rectangleClusters: typeof keptClusters = [];
    const rectangleMeta: Array<{
      minX: number;
      minY: number;
      maxX: number;
      maxY: number;
      sideTol: number;
      avgDashLen: number;
      avgThickness: number;
    }> = [];
    if (DASH_LOOP_CLOSURE_ENABLED) {
      keptClusters.forEach((cluster) => {
        if (!cluster?.ids?.length || cluster.ids.length < 3) return;
        const seeds = cluster.ids
          .map((idx) => seedByIdx.get(idx))
          .filter((s): s is NonNullable<typeof s> => Boolean(s));
        if (seeds.length < 3) return;
        const minX = Math.min(...seeds.map((s) => s.x));
        const minY = Math.min(...seeds.map((s) => s.y));
        const maxX = Math.max(...seeds.map((s) => s.x + s.w - 1));
        const maxY = Math.max(...seeds.map((s) => s.y + s.h - 1));
        const avgDashLen =
          seeds.reduce((sum, s) => sum + Number(s.sizePrimary || 0), 0) / Math.max(1, seeds.length);
        const avgThickness =
          seeds.reduce((sum, s) => sum + Number(s.sizeSecondary || 0), 0) /
          Math.max(1, seeds.length);
        const minSideCoverage = avgDashLen * DASH_RECT_MIN_SIDE_DASH_LENGTHS;
        const sideTol = Math.max(
          3,
          Math.round(Math.max(1, avgThickness) * DASH_LOOP_CLOSURE_AXIS_TOLERANCE_MULTIPLIER)
        );
        let topCoverage = 0;
        let rightCoverage = 0;
        let bottomCoverage = 0;
        let leftCoverage = 0;
        let topSegments = 0;
        let rightSegments = 0;
        let bottomSegments = 0;
        let leftSegments = 0;
        seeds.forEach((s) => {
          const segLen = Number(s.sizePrimary || 0);
          if (s.horizontal && Math.abs(s.cy - minY) <= sideTol) {
            topCoverage += segLen;
            topSegments += 1;
          }
          if (s.horizontal && Math.abs(s.cy - maxY) <= sideTol) {
            bottomCoverage += segLen;
            bottomSegments += 1;
          }
          if (!s.horizontal && Math.abs(s.cx - minX) <= sideTol) {
            leftCoverage += segLen;
            leftSegments += 1;
          }
          if (!s.horizontal && Math.abs(s.cx - maxX) <= sideTol) {
            rightCoverage += segLen;
            rightSegments += 1;
          }
        });
        const minWeakCoverage = minSideCoverage * 0.6;
        const sideWeak = [
          topSegments >= 2 || topCoverage >= minWeakCoverage,
          rightSegments >= 2 || rightCoverage >= minWeakCoverage,
          bottomSegments >= 2 || bottomCoverage >= minWeakCoverage,
          leftSegments >= 2 || leftCoverage >= minWeakCoverage,
        ];
        const sideStrong = [
          topSegments >= DASH_RECT_MIN_SIDE_DASH_LENGTHS || topCoverage >= minSideCoverage,
          rightSegments >= DASH_RECT_MIN_SIDE_DASH_LENGTHS || rightCoverage >= minSideCoverage,
          bottomSegments >= DASH_RECT_MIN_SIDE_DASH_LENGTHS || bottomCoverage >= minSideCoverage,
          leftSegments >= DASH_RECT_MIN_SIDE_DASH_LENGTHS || leftCoverage >= minSideCoverage,
        ];
        const presentCount = sideWeak.filter(Boolean).length;
        const strongCount = sideStrong.filter(Boolean).length;
        if (presentCount < 3) {
          droppedNonClosedDashClusters += 1;
          return;
        }
        const rectArea = Math.max(1, (maxX - minX + 1) * (maxY - minY + 1));
        const minRectArea = avgDashLen * avgDashLen * DASH_RECT_MIN_AREA_MULTIPLIER;
        if (rectArea < minRectArea) {
          droppedNonClosedDashClusters += 1;
          return;
        }
        if (presentCount === 3) {
          if (strongCount < 3) {
            droppedNonClosedDashClusters += 1;
            return;
          }
          const thickness = Math.max(1, Math.round(avgThickness || 1));
          if (!sideWeak[0])
            loopClosureSegments.push({ x0: minX, y0: minY, x1: maxX, y1: minY, thickness });
          else if (!sideWeak[1])
            loopClosureSegments.push({ x0: maxX, y0: minY, x1: maxX, y1: maxY, thickness });
          else if (!sideWeak[2])
            loopClosureSegments.push({ x0: minX, y0: maxY, x1: maxX, y1: maxY, thickness });
          else loopClosureSegments.push({ x0: minX, y0: minY, x1: minX, y1: maxY, thickness });
          loopClosedClusterCount += 1;
        }
        rectangleClusters.push(cluster);
        rectangleMeta.push({
          minX,
          minY,
          maxX,
          maxY,
          sideTol,
          avgDashLen,
          avgThickness,
        });
      });
    } else {
      rectangleClusters.push(...keptClusters);
    }

    const junctionIndexes = new Set<number>();
    const dashedIndexSet = new Set<number>();
    rectangleClusters.forEach((cluster) => {
      cluster.ids.forEach((idx) => {
        out.add(idx);
        dashedIndexSet.add(idx);
        dashedIndexes.add(idx);
        dashedCount += 1;
        const seed = seedByIdx.get(idx);
        if (!seed) return;
        const thickness = Math.max(1, Math.round(Number(seed.sizeSecondary || 1)));
        if (seed.horizontal) {
          const y = Math.round(seed.cy);
          dashedLineSegments.push({
            idx,
            x0: seed.x,
            y0: y,
            x1: seed.x + seed.w - 1,
            y1: y,
            thickness,
            horizontal: true,
          });
          return;
        }
        const x = Math.round(seed.cx);
        dashedLineSegments.push({
          idx,
          x0: x,
          y0: seed.y,
          x1: x,
          y1: seed.y + seed.h - 1,
          thickness,
          horizontal: false,
        });
      });
    });
    for (let i = 0; i < comps.length; i += 1) {
      if (dashedIndexSet.has(i)) continue;
      const c = comps[i];
      if (!c) continue;
      const area = Number(c.area || 0);
      if (area <= 0 || area > DASH_JUNCTION_MAX_AREA) continue;
      const w = Math.max(1, Number(c.w || 0));
      const h = Math.max(1, Number(c.h || 0));
      const longSide = Math.max(w, h);
      const shortSide = Math.min(w, h);
      const aspect = longSide / Math.max(1, shortSide);
      if (aspect > 6.2 && shortSide <= 3) continue;
      const cx = c.x + w / 2;
      const cy = c.y + h / 2;
      let nearCornerJunction = false;
      for (const meta of rectangleMeta) {
        const cornerTol = Math.max(
          6,
          Math.round(Math.max(meta.avgThickness * 4, meta.avgDashLen * 0.33))
        );
        const corners = [
          { x: meta.minX, y: meta.minY },
          { x: meta.maxX, y: meta.minY },
          { x: meta.maxX, y: meta.maxY },
          { x: meta.minX, y: meta.maxY },
        ];
        const intersectsVertical = (x: number) =>
          c.x <= x + meta.sideTol && c.x + w - 1 >= x - meta.sideTol;
        const intersectsHorizontal = (y: number) =>
          c.y <= y + meta.sideTol && c.y + h - 1 >= y - meta.sideTol;
        for (const corner of corners) {
          if (Math.abs(cx - corner.x) > cornerTol || Math.abs(cy - corner.y) > cornerTol) continue;
          if (intersectsVertical(corner.x) && intersectsHorizontal(corner.y)) {
            nearCornerJunction = true;
            break;
          }
        }
        if (nearCornerJunction) break;
      }
      if (!nearCornerJunction) continue;
      junctionIndexes.add(i);
      out.add(i);
    }
    const junctionCount = junctionIndexes.size;

    const totalQualifyingDashClusters = qualifyingClusters.length;
    const keptDashClusters = rectangleClusters.length;
    const magneticSeedCount = magneticSeedSet.size;
    const magneticReachableCount = magneticReachable.size;
    return {
      indexes: out,
      solidIndexes,
      hairlineIndexes,
      dashedIndexes,
      solidCount,
      hairlineCount,
      dashedCount,
      totalQualifyingDashClusters,
      keptDashClusters,
      droppedDashClustersBySectionCap,
      droppedNonClosedDashClusters,
      magneticSeedCount,
      magneticReachableCount,
      loopClosureSegments,
      loopClosedClusterCount,
      junctionIndexes,
      junctionCount,
      axisRejectedCount,
      maxOffAxisDeg,
      maxDashOffAxisDeg,
      axisMetaByIndex,
      dashedLineSegments,
    };
  }

  function renderPipelineSteps({
    sourceImageData,
    step3SourceMask,
    step4SourceMask,
    step5SourceMask,
    step6SourceMask,
    step7SourceMask,
    colorLineDeltaMask,
    colorPixelCount,
    hairlineRemovedDeltaMask,
    hairlineRemovedCount,
    hairlineWidthThreshold,
    lineRemovedDeltaMask,
    lineDashedCount,
    lineJunctionCount,
    lineMagneticSeedCount,
    lineLoopClosedCount,
    textRemovedDeltaMask,
    textRemovedCount,
    regions,
    selectedRegions,
    selectedRegionIndexes,
    matchSummary: pipelineMatchSummary = null,
    matchDetections = [],
  }) {
    if (!pipelineStepsEl) return;
    step1RegionClipByKey = {};
    const viableBaseUrl = maskedSourceToDataUrl(sourceImageData, selectedRegions);
    const fullPlanRegion = [{ x: 0, y: 0, w: sourceImageData.width, h: sourceImageData.height }];
    const step3BaseUrl = maskedImageByMaskToDataUrl(sourceImageData, step3SourceMask);
    const step4BaseUrl = maskedImageByMaskToDataUrl(sourceImageData, step4SourceMask);
    const step5BaseUrl = maskedImageByMaskToDataUrl(sourceImageData, step5SourceMask);
    const step6BaseUrl = maskedImageByMaskToDataUrl(sourceImageData, step6SourceMask);
    const step7BaseUrl = maskedImageByMaskToDataUrl(sourceImageData, step7SourceMask);
    const step3OverlayRegions = layerFlowState.step2ToStep3 ? selectedRegions : fullPlanRegion;
    const step4PlusOverlayRegions = layerFlowState.step2ToStep4 ? selectedRegions : fullPlanRegion;
    const steps = [
      {
        key: "step1",
        title: "Step 1: Viable Area Detection",
        detail: `${regions.length} candidate region(s) detected, ${selectedRegions.length} selected, ${excludedRegionIndexes.size} removed`,
        baseImageUrl: imageDataToDataUrl(sourceImageData),
        overlayImageUrl: regionsMaskLayerToDataUrl(
          sourceImageData,
          regions,
          selectedRegions,
          excludedRegionIndexes
        ),
        sourceWidth: sourceImageData.width,
        sourceHeight: sourceImageData.height,
      },
      {
        title: "Step 2: Viable Area Applied",
        detail: "Everything outside selected viable area is removed before the heavier steps",
        imageUrl: viableBaseUrl,
      },
      {
        key: "step3",
        title: "Step 3: Identify Colored Lines (Remember Only)",
        detail: `${colorPixelCount} color pixel(s) identified (${layerFlowState.step2ToStep3 ? "input: Step 2 bounds" : "input: full canvas"}) | non-black luma>=${COLOR_LINE_MIN_LUMA}, color-diff>=${Math.round(runtimeColorLineMinSpread)}`,
        baseImageUrl: step3BaseUrl,
        overlayImageUrl: colorMaskLayerToDataUrl(
          sourceImageData,
          step3OverlayRegions,
          colorLineDeltaMask,
          [16, 185, 129],
          true
        ),
      },
      {
        key: "step4",
        title: "Step 4: Identify + Remove Hairlines",
        detail: HAIRLINE_STEP_PAUSED
          ? "Paused: passthrough only (kept as placeholder step; no hairlines removed)"
          : `${hairlineRemovedCount} hairline component(s) removed (continuous thinnest linear class; width<=${hairlineWidthThreshold}px, ink>=${Math.round(runtimeHairlineMinInkStrength)}, run>=${Math.round(runtimeHairlineMinRun)}px, seg>=${Math.round(runtimeHairlineComponentMinLongSide)}px)`,
        baseImageUrl: step4BaseUrl,
        overlayImageUrl: colorMaskLayerToDataUrl(
          sourceImageData,
          step4PlusOverlayRegions,
          hairlineRemovedDeltaMask,
          [147, 51, 234]
        ),
      },
      {
        key: "step5",
        title: "Step 5: Isolate + Hide Dashed Lines Layer",
        detail: `${lineDashedCount} dashed component(s) converted to linear dashed items + ${lineJunctionCount} corner junction(s) isolated (${layerFlowState.step2ToStep4 ? "Step 2 included" : "Step 2 excluded"}; ${layerFlowState.step3ExcludeFromStep4 ? "Step 3 excluded" : "Step 3 not excluded"}; rectangles only, weak side>=2 dashes to keep closed loops, 3-of-4 sides need >=${DASH_RECT_MIN_SIDE_DASH_LENGTHS} dashes and are force-closed)`,
        baseImageUrl: step5BaseUrl,
        overlayImageUrl: colorMaskLayerToDataUrl(
          sourceImageData,
          step4PlusOverlayRegions,
          lineRemovedDeltaMask,
          [249, 115, 22]
        ),
      },
      {
        key: "step6",
        title: "Step 6: Identify + Remove Alphanumeric Characters",
        detail: `${textRemovedCount} text-like component(s) removed from post-linear cleanup mask`,
        baseImageUrl: step6BaseUrl,
        overlayImageUrl: colorMaskLayerToDataUrl(
          sourceImageData,
          step4PlusOverlayRegions,
          textRemovedDeltaMask,
          [236, 72, 153]
        ),
      },
      {
        title: "Step 7: Post-Step-6 Output (Current Final)",
        detail: "Current handoff preview: this is the mask output after Step 6",
        imageUrl: step7BaseUrl,
      },
    ];
    const cards = steps.map((step) => {
      const step1SelectedRegionEntries =
        step.key === "step1" && Array.isArray(regions) && regions.length > 0
          ? regions
              .map((region, idx) => ({ region, idx }))
              .filter((entry) => !excludedRegionIndexes.has(entry.idx))
              .slice(0, MAX_REGIONS_TO_SCAN)
          : [];
      const step1RemoveButtons =
        step.key === "step1" &&
        step1SelectedRegionEntries.length > 0 &&
        step.sourceWidth > 0 &&
        step.sourceHeight > 0
          ? step1SelectedRegionEntries
              .map(({ region: r, idx }) => {
                const leftPct = clamp(((r.x + r.w - 12) / step.sourceWidth) * 100, 0, 98);
                const topPct = clamp(((r.y + 2) / step.sourceHeight) * 100, 0, 98);
                return `
                  <button
                    type="button"
                    data-remove-region-idx="${idx}"
                    class="simple-scan-remove-region-btn absolute z-30 h-5 w-5 rounded-full border border-red-700 bg-red-600 text-[12px] font-bold leading-none text-white shadow hover:bg-red-700"
                    style="left:${leftPct}%;top:${topPct}%;"
                    title="Remove this section from processing"
                    aria-label="Remove section ${idx + 1}"
                  >
                    ×
                  </button>
                `;
              })
              .join("")
          : "";
      const step1ResetButton =
        step.key === "step1" && Array.isArray(regions) && regions.length > 0
          ? `<div class="mb-2 flex flex-wrap items-center gap-2">${excludedRegionIndexes.size > 0 ? '<button type="button" id="simple-scan-reset-removed-regions" class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600">Reset removed sections</button>' : ""}<button type="button" id="simple-scan-remove-all-regions" class="rounded bg-red-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-red-700">Remove all sections</button></div>`
          : "";
      const step55InlineSlot =
        step.key === "step5"
          ? `<div id="simple-scan-step55-controls-slot" class="mb-2"></div>`
          : "";
      const step1RegionControls = "";
      const step1LayerTransforms = "";
      const overlayControls =
        step.overlayImageUrl && step.key
