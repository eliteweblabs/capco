  function colorFromLabel(label: string) {
    let hash = 0;
    for (let i = 0; i < label.length; i += 1) hash = (hash * 31 + label.charCodeAt(i)) | 0;
    const hue = Math.abs(hash) % 360;
    return `hsla(${hue}, 90%, 58%, 0.96)`;
  }

