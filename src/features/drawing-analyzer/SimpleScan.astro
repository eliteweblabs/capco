  async function refreshItemLibrary(forceReload = false) {
    if (!forceReload && itemLibrary.length > 0) return itemLibrary;
    try {
      const res = await fetch("/api/drawing-analyzer/item-library", { cache: "no-store" });
      const payload = await res.json().catch(() => ({}));
      itemLibrary = Array.isArray(payload?.items) ? payload.items : [];
      const validSet = new Set(
        itemLibrary.map((item) => String(item?.fileName || "")).filter(Boolean)
      );
      if (targetedLibraryFileNames.size === 0) {
        itemLibrary.forEach((item) => {
          const fileName = String(item?.fileName || "");
          if (fileName) targetedLibraryFileNames.add(fileName);
        });
      } else {
        targetedLibraryFileNames = new Set(
          Array.from(targetedLibraryFileNames).filter((fileName) => validSet.has(fileName))
        );
        if (targetedLibraryFileNames.size === 0) {
          validSet.forEach((fileName) => targetedLibraryFileNames.add(fileName));
        }
      }
      renderLibraryTargetingUi();
      return itemLibrary;
    } catch (error) {
      void error;
      if (libraryMetaEl)
        libraryMetaEl.textContent =
          "Failed to load item library from /api/drawing-analyzer/item-library.";
      renderLibraryTargetingUi();
      return [];
    }
