  async function loadTesseractGlobal() {
    if (window["Tesseract"]) return window["Tesseract"];
    if (!tesseractLoaderPromise) {
      tesseractLoaderPromise = new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js";
        script.async = true;
        script.onload = () => resolve(window["Tesseract"]);
        script.onerror = () => reject(new Error("Failed to load Tesseract.js"));
        document.head.appendChild(script);
      });
    }
    await tesseractLoaderPromise;
    return window["Tesseract"];
  }

  async function detectTextLikeComponentIndexesOcr(
    comps,
    imageData,
    mask,
    width,
    height,
    renderToken = 0
  ) {
    const tesseract = await loadTesseractGlobal();
    if (!tesseract || !Array.isArray(comps) || !imageData) {
      return { indexes: new Set<number>(), boxes: 0, words: 0 };
    }
    if (renderToken && renderToken !== processingRenderToken) {
      return { indexes: new Set<number>(), boxes: 0, words: 0 };
    }
    const sourceCanvas = document.createElement("canvas");
    sourceCanvas.width = width;
    sourceCanvas.height = height;
    const sourceCtx = sourceCanvas.getContext("2d");
    if (!sourceCtx) return { indexes: new Set<number>(), boxes: 0, words: 0 };
    const out = new ImageData(new Uint8ClampedArray(imageData.data), width, height);
    for (let p = 0; p < mask.length; p += 1) {
      if (mask[p]) continue;
      const i = p * 4;
      out.data[i] = 255;
      out.data[i + 1] = 255;
      out.data[i + 2] = 255;
      out.data[i + 3] = 255;
    }
    sourceCtx.putImageData(out, 0, 0);

    const maxSide = Math.max(width, height);
    const scale = maxSide > 1900 ? 1900 / maxSide : 1;
    const scanCanvas = document.createElement("canvas");
    scanCanvas.width = Math.max(1, Math.round(width * scale));
    scanCanvas.height = Math.max(1, Math.round(height * scale));
    const scanCtx = scanCanvas.getContext("2d");
    if (!scanCtx) return { indexes: new Set<number>(), boxes: 0, words: 0 };
    scanCtx.drawImage(sourceCanvas, 0, 0, scanCanvas.width, scanCanvas.height);

    const tesseractAny = tesseract as any;
    const result = await tesseractAny.recognize(scanCanvas, "eng", {
      logger: () => undefined,
    });
    if (renderToken && renderToken !== processingRenderToken) {
      return { indexes: new Set<number>(), boxes: 0, words: 0 };
    }
    const words = Array.isArray((result as any)?.data?.words) ? (result as any).data.words : [];
    const inv = scale > 0 ? 1 / scale : 1;
    const boxes = words
      .map((w) => {
        const text = String(w?.text || "").trim();
        if (!text) return null;
        const hasAlnum = /[A-Za-z0-9]/.test(text);
        if (!hasAlnum) return null;
        const conf = Number(w?.confidence ?? 0);
        if (Number.isFinite(conf) && conf < 35) return null;
        const x0 = Math.round(Number(w?.bbox?.x0 ?? 0) * inv);
        const y0 = Math.round(Number(w?.bbox?.y0 ?? 0) * inv);
        const x1 = Math.round(Number(w?.bbox?.x1 ?? 0) * inv);
        const y1 = Math.round(Number(w?.bbox?.y1 ?? 0) * inv);
        return { x0, y0, x1, y1 };
      })
      .filter(Boolean);
    const textIndexes = new Set<number>();
    const overlapRatio = (c, b) => {
      const ix0 = Math.max(c.x, b.x0);
      const iy0 = Math.max(c.y, b.y0);
      const ix1 = Math.min(c.x + c.w - 1, b.x1);
      const iy1 = Math.min(c.y + c.h - 1, b.y1);
      if (ix1 < ix0 || iy1 < iy0) return 0;
      const inter = (ix1 - ix0 + 1) * (iy1 - iy0 + 1);
      const compArea = Math.max(1, c.w * c.h);
      return inter / compArea;
    };
    for (let i = 0; i < comps.length; i += 1) {
      const c = comps[i];
      if (!c) continue;
      if (
        boxes.some((b) => {
          const centerX = c.x + c.w / 2;
          const centerY = c.y + c.h / 2;
          const centerIn = centerX >= b.x0 && centerX <= b.x1 && centerY >= b.y0 && centerY <= b.y1;
          return centerIn || overlapRatio(c, b) >= 0.22;
        })
      ) {
        textIndexes.add(i);
      }
    }
    return { indexes: textIndexes, boxes: boxes.length, words: words.length };
  }

  function setStep55Mode(nextMode: "off" | "cleanup" | "connect") {
    step55Mode = nextMode;
    if (step55Mode !== "connect") step55SelectedEndpoint = null;
    updateStep55Ui();
  }

  function updateStep55Ui() {
    const applyActiveState = (btn: HTMLButtonElement | null, active: boolean) => {
      if (!btn) return;
      btn.classList.toggle("bg-primary-600", active);
      btn.classList.toggle("dark:bg-primary-500", active);
      btn.classList.toggle("bg-gray-700", !active);
      btn.classList.toggle("dark:bg-gray-600", !active);
    };
    applyActiveState(step55ModeOffBtn, step55Mode === "off");
    applyActiveState(step55ModeCleanupBtn, step55Mode === "cleanup");
    applyActiveState(step55ModeConnectBtn, step55Mode === "connect");
    if (canvas) canvas.style.cursor = step55Mode === "off" ? "default" : "crosshair";
    if (pipelineStepsEl) {
      pipelineStepsEl.querySelectorAll("[data-step55-hit]").forEach((el) => {
        (el as HTMLElement).style.cursor = step55Mode === "off" ? "default" : "crosshair";
      });
    }
    if (step55MetaEl) {
      const connectHint =
        step55Mode === "connect" && step55SelectedEndpoint
          ? ` | selected endpoint: (${Math.round(step55SelectedEndpoint.x)}, ${Math.round(step55SelectedEndpoint.y)})`
          : "";
      step55MetaEl.textContent = `Mode: ${step55Mode} | removed fragments: ${step55RemovedIndexes.size} | added connections: ${step55AddedSegments.length}${connectHint}`;
    }
  }

  function getCanvasPointFromEvent(event: MouseEvent) {
    if (!canvas || !drawingState) return null;
    const rect = canvas.getBoundingClientRect();
    if (rect.width <= 0 || rect.height <= 0) return null;
    const scaleX = drawingState.width / rect.width;
    const scaleY = drawingState.height / rect.height;
    return {
      x: clamp((event.clientX - rect.left) * scaleX, 0, drawingState.width - 1),
      y: clamp((event.clientY - rect.top) * scaleY, 0, drawingState.height - 1),
    };
  }

  function findNearestStep55Component(x: number, y: number, tolerance = 18) {
    let best: { idx: number; dist: number } | null = null;
    for (const c of step55EditableComps) {
      const cx = c.x + c.w / 2;
      const cy = c.y + c.h / 2;
      const dx = x - cx;
      const dy = y - cy;
      const dist = Math.hypot(dx, dy);
      if (dist > tolerance) continue;
      if (!best || dist < best.dist) best = { idx: c.idx, dist };
    }
    return best?.idx ?? null;
  }

  function findNearestStep55Endpoint(x: number, y: number, tolerance = 20) {
    let best: { endpoint: { x: number; y: number; idx: number }; dist: number } | null = null;
    for (const ep of step55Endpoints) {
      const dist = Math.hypot(x - ep.x, y - ep.y);
      if (dist > tolerance) continue;
      if (!best || dist < best.dist) best = { endpoint: ep, dist };
    }
    return best?.endpoint ?? null;
  }

  function rebuildStep55InteractiveGeometry(lineInputComps, step5Indexes: Set<number>) {
    step55EditableComps = lineInputComps
      .map((c, idx) => ({ c, idx }))
      .filter((x) => step5Indexes.has(x.idx))
      .map(({ c, idx }) => {
        const orientation = c.w >= c.h ? "horizontal" : "vertical";
        return {
          idx,
          x: c.x,
          y: c.y,
          w: c.w,
          h: c.h,
          orientation,
          thickness: Math.max(1, Math.round(Math.min(c.w, c.h))),
        };
      });
    step55Endpoints = [];
    step55EditableComps.forEach((c) => {
      if (c.orientation === "horizontal") {
        const y = c.y + c.h / 2;
        step55Endpoints.push({ x: c.x, y, idx: c.idx });
        step55Endpoints.push({ x: c.x + c.w - 1, y, idx: c.idx });
      } else {
        const x = c.x + c.w / 2;
        step55Endpoints.push({ x, y: c.y, idx: c.idx });
        step55Endpoints.push({ x, y: c.y + c.h - 1, idx: c.idx });
      }
    });
    updateStep55Ui();
  }

  function getActiveRegionSelection(state) {
    const fallback = [{ x: 0, y: 0, w: state.width, h: state.height }];
    const regionsSource = baselineRegions.length ? baselineRegions : fallback;
    const selectedWithIndex = regionsSource
      .map((region, idx) => ({ region, idx }))
      .filter((entry) => !excludedRegionIndexes.has(entry.idx))
      .slice(0, MAX_REGIONS_TO_SCAN);
    return {
      regionsSource,
      selectedRegions: selectedWithIndex.map((entry) => entry.region),
      selectedRegionIndexes: new Set<number>(selectedWithIndex.map((entry) => entry.idx)),
    };
  }

  function regionsOverlayToDataUrl(
    imageData,
    regions,
    selectedRegions = [],
    excludedIndexes: Set<number> = new Set<number>()
  ) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.putImageData(imageData, 0, 0);
    ctx.lineWidth = 2;
    regions.forEach((r, idx) => {
      if (excludedIndexes.has(idx)) return;
      ctx.strokeStyle = "rgba(56,189,248,0.95)";
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(56,189,248,0.14)";
      ctx.fillRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(12,74,110,0.95)";
      ctx.font = "12px sans-serif";
      ctx.fillText(`R${idx + 1}`, r.x + 4, r.y + 14);
    });
    selectedRegions.forEach((r) => {
      ctx.strokeStyle = "rgba(251,191,36,0.98)";
      ctx.lineWidth = 3;
      ctx.strokeRect(r.x, r.y, r.w, r.h);
    });
    return c.toDataURL("image/png");
  }

  function imageDataToDataUrl(imageData) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.putImageData(imageData, 0, 0);
    return c.toDataURL("image/png");
  }

  function regionsMaskLayerToDataUrl(
    imageData,
    regions,
    selectedRegions = [],
    excludedIndexes: Set<number> = new Set<number>()
  ) {
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.clearRect(0, 0, c.width, c.height);
    ctx.lineWidth = 2;
    regions.forEach((r, idx) => {
      if (excludedIndexes.has(idx)) return;
      ctx.strokeStyle = "rgba(56,189,248,0.95)";
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(56,189,248,0.14)";
      ctx.fillRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = "rgba(12,74,110,0.95)";
      ctx.font = "12px sans-serif";
      ctx.fillText(`R${idx + 1}`, r.x + 4, r.y + 14);
    });
    selectedRegions.forEach((r) => {
      ctx.strokeStyle = "rgba(251,191,36,0.98)";
      ctx.lineWidth = 3;
      ctx.strokeRect(r.x, r.y, r.w, r.h);
    });
    return c.toDataURL("image/png");
  }

  function regionMaskLayerToDataUrl(imageData, region, regionIndex = 0) {
    if (!region) return "";
    const c = document.createElement("canvas");
    c.width = imageData.width;
    c.height = imageData.height;
    const ctx = c.getContext("2d");
    if (!ctx) return "";
    ctx.clearRect(0, 0, c.width, c.height);
    ctx.strokeStyle = "rgba(56,189,248,0.95)";
    ctx.lineWidth = 2;
    ctx.strokeRect(region.x, region.y, region.w, region.h);
    ctx.fillStyle = "rgba(56,189,248,0.14)";
    ctx.fillRect(region.x, region.y, region.w, region.h);
    ctx.strokeStyle = "rgba(251,191,36,0.98)";
    ctx.lineWidth = 3;
    ctx.strokeRect(region.x, region.y, region.w, region.h);
    ctx.fillStyle = "rgba(12,74,110,0.95)";
    ctx.font = "12px sans-serif";
    ctx.fillText(`R${regionIndex + 1}`, region.x + 4, region.y + 14);
