---
import { globalClasses } from "../../pages/api/global/global-classes";

const { globalFormLabel, mutedTextSmClasses, primaryTextClasses } = globalClasses();
---

<section class="space-y-3">
  <p class={`text-sm font-semibold ${primaryTextClasses}`}>Simple Scan</p>
  <p class={mutedTextSmClasses}>
    Barebones section scan + item-library matching on the default plan.
  </p>

  <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
    <div class="rounded border border-gray-300 p-2 dark:border-gray-700">
      <p
        class="mb-1 text-xs font-semibold uppercase tracking-wide text-gray-600 dark:text-gray-300"
      >
        Template (target object)
      </p>
      <img
        id="simple-scan-template-preview"
        alt="Current template preview"
        class="h-52 w-full rounded border border-gray-200 bg-gray-50 object-contain dark:border-gray-700 dark:bg-gray-900"
      />
    </div>
    <div class="rounded border border-gray-300 p-2 dark:border-gray-700">
      <p
        class="mb-1 flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-gray-600 dark:text-gray-300"
      >
        <span>Machine view (candidate mask)</span>
        <span
          id="simple-scan-machine-vote"
          class="inline-flex min-w-14 items-center justify-center rounded border border-gray-300 px-1.5 py-0.5 text-[10px] font-bold dark:border-gray-600"
          >-</span
        >
      </p>
      <img
        id="simple-scan-machine-preview"
        alt="Current machine candidate preview"
        class="h-52 w-full rounded border border-gray-200 bg-gray-50 object-contain dark:border-gray-700 dark:bg-gray-900"
      />
    </div>
  </div>

  <div
    class="flex flex-wrap items-center gap-2 rounded border border-gray-300 p-2 dark:border-gray-700"
  >
    <button
      id="simple-scan-play"
      type="button"
      class="rounded bg-gray-700 px-3 py-1.5 text-xs font-semibold text-white dark:bg-gray-600"
    >
      Play
    </button>
    <button
      id="simple-scan-pause"
      type="button"
      class="rounded bg-gray-700 px-3 py-1.5 text-xs font-semibold text-white dark:bg-gray-600"
    >
      Pause
    </button>
    <button
      id="simple-scan-next"
      type="button"
      class="rounded bg-gray-700 px-3 py-1.5 text-xs font-semibold text-white dark:bg-gray-600"
    >
      Next
    </button>
    <p id="simple-scan-frame-meta" class={mutedTextSmClasses}>Frame: none</p>
  </div>

  <div>
    <label for="simple-scan-file" class={globalFormLabel}>Drawing (optional override)</label>
    <input id="simple-scan-file" type="file" accept=".pdf,image/*" class="block w-full text-sm" />
  </div>

  <div class="flex items-center gap-2">
    <button
      id="simple-scan-run"
      type="button"
      class="rounded bg-primary-600 px-3 py-1.5 text-sm text-white"
    >
      Refresh Processing
    </button>
    <p id="simple-scan-status" class={mutedTextSmClasses}>Loading default drawing...</p>
  </div>

  <div
    id="simple-scan-library-controls"
    class="rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <div class="mb-2 flex flex-wrap items-center gap-2">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
        Library Targeting
      </p>
      <button
        id="simple-scan-library-refresh"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Refresh Library
      </button>
      <button
        id="simple-scan-library-select-all"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Select All
      </button>
      <button
        id="simple-scan-library-clear-all"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Clear All
      </button>
    </div>
    <p id="simple-scan-library-meta" class={`mb-2 text-xs ${mutedTextSmClasses}`}>
      Loading library...
    </p>
    <div id="simple-scan-library-list" class="flex flex-wrap gap-2"></div>
  </div>

  <div
    id="simple-scan-layer-flow-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Layer Flow Controls
    </p>
    <div class="mb-3 space-y-1">
      <label class={`flex items-center gap-2 text-xs ${mutedTextSmClasses}`}>
        <input id="simple-scan-flow-step2-step3" type="checkbox" checked />
        Include Step 2 viable-area layer in Step 3
      </label>
      <label class={`flex items-center gap-2 text-xs ${mutedTextSmClasses}`}>
        <input id="simple-scan-flow-step2-step4" type="checkbox" checked />
        Include Step 2 viable-area layer in Step 4
      </label>
      <label class={`flex items-center gap-2 text-xs ${mutedTextSmClasses}`}>
        <input id="simple-scan-flow-step3-step4" type="checkbox" />
        Exclude Step 3 colored layer from Step 4 input
      </label>
    </div>
  </div>

  <div
    id="simple-scan-step3-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Step 3 Color-Line Controls
    </p>
    <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Color difference from grayscale
        <span id="simple-scan-color-spread-val" class="ml-1 font-semibold">38</span>
        <input
          id="simple-scan-color-spread"
          type="range"
          min="4"
          max="90"
          step="1"
          value="38"
          class="mt-1 w-full"
        />
      </label>
    </div>
  </div>

  <div
    id="simple-scan-step4-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Step 4 Hairline Controls
    </p>
    <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Hairline max width
        <span id="simple-scan-hairline-width-val" class="ml-1 font-semibold">2.6</span>
        <input
          id="simple-scan-hairline-width"
          type="range"
          min="1.2"
          max="4.0"
          step="0.1"
          value="2.6"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Hairline min ink strength
        <span id="simple-scan-hairline-ink-val" class="ml-1 font-semibold">6</span>
        <input
          id="simple-scan-hairline-ink"
          type="range"
          min="1"
          max="40"
          step="1"
          value="6"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Hairline min run length
        <span id="simple-scan-hairline-run-val" class="ml-1 font-semibold">12</span>
        <input
          id="simple-scan-hairline-run"
          type="range"
          min="4"
          max="24"
          step="1"
          value="12"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Hairline min segment length
        <span id="simple-scan-hairline-length-val" class="ml-1 font-semibold">20</span>
        <input
          id="simple-scan-hairline-length"
          type="range"
          min="6"
          max="48"
          step="1"
          value="20"
          class="mt-1 w-full"
        />
      </label>
    </div>
  </div>

  <div
    id="simple-scan-step5-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Step 5 Dashed-Layer Control
    </p>
    <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Minimum dashed run length
        <span id="simple-scan-dash-neighbors-val" class="ml-1 font-semibold">3</span>
        <input
          id="simple-scan-dash-neighbors"
          type="range"
          min="3"
          max="8"
          step="1"
          value="3"
          class="mt-1 w-full"
        />
      </label>
    </div>
  </div>

  <div
    id="simple-scan-step6-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Step 6 Alphanumeric Controls
    </p>
    <label class={`flex items-center gap-2 text-xs ${mutedTextSmClasses}`}>
      <input id="simple-scan-text-ocr-toggle" type="checkbox" />
      Use OCR-based alphanumeric detection (experimental)
    </label>
    <p id="simple-scan-text-ocr-meta" class={`mt-1 text-xs ${mutedTextSmClasses}`}>
      Text mode: proximity grouping
    </p>
  </div>

  <div
    id="simple-scan-step55-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">
      Step 5.5 Human Repair
    </p>
    <p class={`mb-2 text-xs ${mutedTextSmClasses}`}>
      Cleanup: click fragment/orphan to remove. Connect: click two endpoints to draw repair.
    </p>
    <div class="flex flex-wrap items-center gap-2">
      <button
        id="simple-scan-step55-mode-off"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Off
      </button>
      <button
        id="simple-scan-step55-mode-cleanup"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Cleanup
      </button>
      <button
        id="simple-scan-step55-mode-connect"
        type="button"
        class="rounded bg-gray-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-gray-600"
      >
        Connect
      </button>
      <button
        id="simple-scan-step55-clear"
        type="button"
        class="rounded bg-red-700 px-2 py-1 text-[11px] font-semibold text-white dark:bg-red-600"
      >
        Clear Repairs
      </button>
    </div>
    <p id="simple-scan-step55-meta" class={`mt-2 text-xs ${mutedTextSmClasses}`}>
      Human repair off.
    </p>
  </div>

  <div
    id="simple-scan-step8-controls"
    class="hidden rounded border border-gray-300 p-3 dark:border-gray-700"
  >
    <div class="flex flex-wrap items-center gap-2">
      <button
        id="simple-scan-run-match"
        type="button"
        class="rounded bg-emerald-600 px-3 py-1.5 text-sm text-white"
      >
        Run Match (Targeted Library)
      </button>
      <p id="simple-scan-match-meta" class={mutedTextSmClasses}>
        Run matching after preprocessing to populate final results.
      </p>
    </div>
    <div class="mt-2 grid grid-cols-1 gap-2 md:grid-cols-2">
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Match threshold
        <span id="simple-scan-match-threshold-val" class="ml-1 font-semibold">0.82</span>
        <input
          id="simple-scan-match-threshold"
          type="range"
          min="0.45"
          max="0.98"
          step="0.01"
          value="0.82"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Min overlap
        <span id="simple-scan-match-overlap-val" class="ml-1 font-semibold">0.40</span>
        <input
          id="simple-scan-match-overlap"
          type="range"
          min="0.10"
          max="0.95"
          step="0.01"
          value="0.40"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Ambiguity margin
        <span id="simple-scan-match-ambiguous-val" class="ml-1 font-semibold">0.03</span>
        <input
          id="simple-scan-match-ambiguous"
          type="range"
          min="0.00"
          max="0.20"
          step="0.005"
          value="0.03"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Black gate: max luma
        <span id="simple-scan-black-luma-val" class="ml-1 font-semibold">130</span>
        <input
          id="simple-scan-black-luma"
          type="range"
          min="60"
          max="220"
          step="1"
          value="130"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Black gate: max spread
        <span id="simple-scan-black-spread-val" class="ml-1 font-semibold">36</span>
        <input
          id="simple-scan-black-spread"
          type="range"
          min="8"
          max="90"
          step="1"
          value="36"
          class="mt-1 w-full"
        />
      </label>
      <label class={`text-xs ${mutedTextSmClasses}`}>
        Black gate: min ratio
        <span id="simple-scan-black-ratio-val" class="ml-1 font-semibold">0.42</span>
        <input
          id="simple-scan-black-ratio"
          type="range"
          min="0.10"
          max="0.95"
          step="0.01"
          value="0.42"
          class="mt-1 w-full"
        />
      </label>
    </div>
    <div id="simple-scan-match-counts" class="mt-2 flex flex-wrap gap-2"></div>
  </div>

  <canvas
    id="simple-scan-canvas"
    class="block max-w-full rounded border border-gray-300 dark:border-gray-700"></canvas>
  <pre
    id="simple-scan-results"
    class="max-h-[42vh] overflow-auto rounded border border-gray-300 bg-gray-50 p-3 text-xs dark:border-gray-700 dark:bg-gray-900">
  </pre>

  <div class="rounded border border-gray-300 p-3 dark:border-gray-700">
    <p class="mb-2 text-sm font-semibold text-gray-800 dark:text-gray-100">
      Preprocessing Timeline
    </p>
    <div id="simple-scan-pipeline-steps" class="space-y-3"></div>
  </div>
</section>

<script src="/js/pdf.min.js" defer></script>
<script>
  const drawingFileInput = document.getElementById("simple-scan-file") as HTMLInputElement | null;
  const runScanBtn = document.getElementById("simple-scan-run") as HTMLButtonElement | null;
  const runMatchBtn = document.getElementById("simple-scan-run-match") as HTMLButtonElement | null;
  const statusEl = document.getElementById("simple-scan-status") as HTMLParagraphElement | null;
  const canvas = document.getElementById("simple-scan-canvas") as HTMLCanvasElement | null;
  const resultsEl = document.getElementById("simple-scan-results") as HTMLPreElement | null;
  const templatePreviewEl = document.getElementById(
    "simple-scan-template-preview"
  ) as HTMLImageElement | null;
  const machinePreviewEl = document.getElementById(
    "simple-scan-machine-preview"
  ) as HTMLImageElement | null;
  const machineVoteEl = document.getElementById(
    "simple-scan-machine-vote"
  ) as HTMLSpanElement | null;
  const frameMetaEl = document.getElementById(
    "simple-scan-frame-meta"
  ) as HTMLParagraphElement | null;
  const playBtn = document.getElementById("simple-scan-play") as HTMLButtonElement | null;
  const pauseBtn = document.getElementById("simple-scan-pause") as HTMLButtonElement | null;
  const nextBtn = document.getElementById("simple-scan-next") as HTMLButtonElement | null;
  const pipelineStepsEl = document.getElementById(
    "simple-scan-pipeline-steps"
  ) as HTMLDivElement | null;
  const layerFlowControlsEl = document.getElementById(
    "simple-scan-layer-flow-controls"
  ) as HTMLDivElement | null;
  const step3ControlsEl = document.getElementById(
    "simple-scan-step3-controls"
  ) as HTMLDivElement | null;
  const step4ControlsEl = document.getElementById(
    "simple-scan-step4-controls"
  ) as HTMLDivElement | null;
  const step5ControlsEl = document.getElementById(
    "simple-scan-step5-controls"
  ) as HTMLDivElement | null;
  const step6ControlsEl = document.getElementById(
    "simple-scan-step6-controls"
  ) as HTMLDivElement | null;
  const step55ControlsEl = document.getElementById(
    "simple-scan-step55-controls"
  ) as HTMLDivElement | null;
  const step8ControlsEl = document.getElementById(
    "simple-scan-step8-controls"
  ) as HTMLDivElement | null;
  const matchMetaEl = document.getElementById(
    "simple-scan-match-meta"
  ) as HTMLParagraphElement | null;
  const matchCountsEl = document.getElementById(
    "simple-scan-match-counts"
  ) as HTMLDivElement | null;
  const matchThresholdInput = document.getElementById(
    "simple-scan-match-threshold"
  ) as HTMLInputElement | null;
  const matchThresholdVal = document.getElementById(
    "simple-scan-match-threshold-val"
  ) as HTMLSpanElement | null;
  const matchOverlapInput = document.getElementById(
    "simple-scan-match-overlap"
  ) as HTMLInputElement | null;
  const matchOverlapVal = document.getElementById(
    "simple-scan-match-overlap-val"
  ) as HTMLSpanElement | null;
  const matchAmbiguousInput = document.getElementById(
    "simple-scan-match-ambiguous"
  ) as HTMLInputElement | null;
  const matchAmbiguousVal = document.getElementById(
    "simple-scan-match-ambiguous-val"
  ) as HTMLSpanElement | null;
  const blackLumaInput = document.getElementById(
    "simple-scan-black-luma"
  ) as HTMLInputElement | null;
  const blackLumaVal = document.getElementById(
    "simple-scan-black-luma-val"
  ) as HTMLSpanElement | null;
  const blackSpreadInput = document.getElementById(
    "simple-scan-black-spread"
  ) as HTMLInputElement | null;
  const blackSpreadVal = document.getElementById(
    "simple-scan-black-spread-val"
  ) as HTMLSpanElement | null;
  const blackRatioInput = document.getElementById(
    "simple-scan-black-ratio"
  ) as HTMLInputElement | null;
  const blackRatioVal = document.getElementById(
    "simple-scan-black-ratio-val"
  ) as HTMLSpanElement | null;
  const colorSpreadInput = document.getElementById(
    "simple-scan-color-spread"
  ) as HTMLInputElement | null;
  const colorSpreadVal = document.getElementById(
    "simple-scan-color-spread-val"
  ) as HTMLSpanElement | null;
  const dashNeighborsInput = document.getElementById(
    "simple-scan-dash-neighbors"
  ) as HTMLInputElement | null;
  const dashNeighborsVal = document.getElementById(
    "simple-scan-dash-neighbors-val"
  ) as HTMLSpanElement | null;
  const step55ModeOffBtn = document.getElementById(
    "simple-scan-step55-mode-off"
  ) as HTMLButtonElement | null;
  const step55ModeCleanupBtn = document.getElementById(
    "simple-scan-step55-mode-cleanup"
  ) as HTMLButtonElement | null;
  const step55ModeConnectBtn = document.getElementById(
    "simple-scan-step55-mode-connect"
  ) as HTMLButtonElement | null;
  const step55ClearBtn = document.getElementById(
    "simple-scan-step55-clear"
  ) as HTMLButtonElement | null;
  const step55MetaEl = document.getElementById(
    "simple-scan-step55-meta"
  ) as HTMLParagraphElement | null;
  const hairlineWidthInput = document.getElementById(
    "simple-scan-hairline-width"
  ) as HTMLInputElement | null;
  const hairlineWidthVal = document.getElementById(
    "simple-scan-hairline-width-val"
  ) as HTMLSpanElement | null;
  const hairlineInkInput = document.getElementById(
    "simple-scan-hairline-ink"
  ) as HTMLInputElement | null;
  const hairlineInkVal = document.getElementById(
    "simple-scan-hairline-ink-val"
  ) as HTMLSpanElement | null;
  const hairlineRunInput = document.getElementById(
    "simple-scan-hairline-run"
  ) as HTMLInputElement | null;
  const hairlineRunVal = document.getElementById(
    "simple-scan-hairline-run-val"
  ) as HTMLSpanElement | null;
  const hairlineLengthInput = document.getElementById(
    "simple-scan-hairline-length"
  ) as HTMLInputElement | null;
  const hairlineLengthVal = document.getElementById(
    "simple-scan-hairline-length-val"
  ) as HTMLSpanElement | null;
  const flowStep2Step3Input = document.getElementById(
    "simple-scan-flow-step2-step3"
  ) as HTMLInputElement | null;
  const flowStep2Step4Input = document.getElementById(
    "simple-scan-flow-step2-step4"
  ) as HTMLInputElement | null;
  const flowStep3Step4Input = document.getElementById(
    "simple-scan-flow-step3-step4"
  ) as HTMLInputElement | null;
  const textOcrToggleInput = document.getElementById(
    "simple-scan-text-ocr-toggle"
  ) as HTMLInputElement | null;
  const textOcrMetaEl = document.getElementById(
    "simple-scan-text-ocr-meta"
  ) as HTMLParagraphElement | null;
  const libraryRefreshBtn = document.getElementById(
    "simple-scan-library-refresh"
  ) as HTMLButtonElement | null;
  const librarySelectAllBtn = document.getElementById(
    "simple-scan-library-select-all"
  ) as HTMLButtonElement | null;
  const libraryClearAllBtn = document.getElementById(
    "simple-scan-library-clear-all"
  ) as HTMLButtonElement | null;
  const libraryMetaEl = document.getElementById(
    "simple-scan-library-meta"
  ) as HTMLParagraphElement | null;
  const libraryListEl = document.getElementById(
    "simple-scan-library-list"
  ) as HTMLDivElement | null;

  const DEFAULT_DRAWING_PUBLIC_PATH = "/demo-plan.pdf";
  const DRAWING_RENDER_MAX_SIDE = 10000;
  const PDF_RENDER_SCALE_FALLBACKS = [14, 12, 10, 8, 6, 4, 3];
  const MATCH_THRESHOLD = 0.82;
  const BASE_GRID_SIZE = 28;
  const MIN_PUZZLE_OVERLAP = 0.4;
  const DETAIL_BINS = 48;
  const AMBIGUOUS_MARGIN = 0.03;
  const BLACK_INK_MAX_LUMA = 130;
  const BLACK_INK_MAX_SPREAD = 36;
  const BLACK_INK_MIN_RATIO = 0.42;
  const MAX_REGIONS_TO_SCAN = 4;
  const AXIS_ALIGNMENT_TOLERANCE_PERCENT = 0.01;
  const LINE_COMPONENT_MIN_AREA = 3;
  const HAIRLINE_STEP_PAUSED = false;
  const HAIRLINE_NS_MIN_RUN = 12;
  const HAIRLINE_EW_MIN_RUN = 12;
  const HAIRLINE_MAX_THICKNESS = 2.6;
  const HAIRLINE_MAX_GAP = 2;
  const HAIRLINE_FALLBACK_MIN_INK_STRENGTH = 6;
  const HAIRLINE_FALLBACK_MAX_SPREAD = 80;
  const HAIRLINE_COMPONENT_MIN_LONG_SIDE = 20;
  const HAIRLINE_COMPONENT_MAX_SHORT_SIDE = 3;
  const SOLID_LINE_MIN_LONG_SIDE = 14;
  const SOLID_LINE_MAX_SHORT_SIDE = 8;
  const SOLID_LINE_MIN_ASPECT = 5.2;
  const HAIRLINE_MIN_LONG_SIDE = 10;
  const HAIRLINE_MAX_SHORT_SIDE = 2;
  const HAIRLINE_MIN_ASPECT = 6.5;
  const DASH_SEED_MIN_LONG_SIDE = 4;
  const DASH_SEED_MAX_LONG_SIDE = 72;
  const DASH_SEED_MAX_SHORT_SIDE = 9;
  const DASH_SEED_MIN_ASPECT = 1.4;
  const DASH_SEED_MIN_AREA = 3;
  const DASH_SEED_MAX_AREA = 520;
  const DASH_PRIMARY_GAP_MULTIPLIER = 4.8;
  const DASH_SECONDARY_GAP_MULTIPLIER = 3.4;
  const DASH_MIN_RUN_LENGTH = 3;
  const DASH_MAX_CLUSTERS_PER_REGION = 3;
  const DASH_AXIS_ALIGNMENT_TOLERANCE_PERCENT = 0.06;
