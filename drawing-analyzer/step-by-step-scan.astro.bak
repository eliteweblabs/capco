---
import LayoutFullWidth from "../../components/layouts/LayoutFullWidth.astro";
import { checkAuth } from "../../lib/auth";
import { isAdminOrSuperAdmin } from "../../lib/user-utils";

const { currentUser, session } = await checkAuth(Astro.cookies);
const currentRole = currentUser?.profile?.role;
const isLocalBypass = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
if (!isLocalBypass && (!currentUser || !session)) return Astro.redirect("/auth/login");
if (!isLocalBypass && !isAdminOrSuperAdmin(currentRole)) return Astro.redirect("/dashboard");
---

<LayoutFullWidth title="Step-by-Step Scanner" classList="p-0" description="Progressive fire protection plan analysis">
<div class="h-screen flex bg-gray-900 text-white overflow-hidden">

  <!-- Collapsible Sidebar -->
  <div id="sidebar" class="bg-gray-800 border-r border-gray-700 flex flex-col transition-all duration-300 w-80 shrink-0">
    <!-- Sidebar Header -->
    <div class="bg-gray-700 border-b border-gray-600 p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Step-by-Step Scanner</h2>
      <button id="sidebar-toggle" class="text-gray-400 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
        </svg>
      </button>
    </div>

    <!-- Sidebar Content -->
    <div class="flex-1 overflow-auto p-4 space-y-6">
      <!-- Plan Selection -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Floor Plan</label>
        <select id="plan-select" class="w-full bg-gray-700 text-gray-200 border border-gray-600 rounded px-3 py-2 text-sm">
          <option value="">Select a test plan...</option>
          <option value="demo-plan">Demo Plan (SimpleScan default)</option>
          <option value="85-tremont">85 Tremont Street Cambridge MA FP.pdf</option>
          <option value="lane-park">Lane Park plan (5 heads)</option>
        </select>
      </div>

      <!-- Plan Status -->
      <div id="plan-status" class="text-xs text-gray-400">
        Ready to load plan
      </div>

      <!-- Debug Log -->
      <div class="mt-4">
        <div class="text-xs font-medium text-gray-400 mb-1">Debug Log:</div>
        <div id="debug-log" class="text-xs text-gray-300 bg-gray-900 p-2 rounded max-h-32 overflow-y-auto font-mono"></div>
      </div>

      <!-- Steps Progress -->
      <div id="steps-container" class="space-y-4">
        <div class="text-sm font-medium text-gray-300">Processing Steps</div>
        <!-- Steps will be populated here -->
      </div>
    </div>
  </div>

  <!-- Main Content Area -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Main Toolbar (when sidebar collapsed) -->
    <div id="main-toolbar" class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center gap-4 hidden">
      <button id="sidebar-expand" class="text-gray-400 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
        </svg>
      </button>
      <span id="current-plan-title" class="text-sm text-gray-300 font-semibold"></span>
    </div>

    <!-- Plan Viewer -->
    <div class="flex-1 overflow-auto bg-gray-950 flex items-center justify-center">
      <!-- Upload prompt (shown when no file loaded) -->
      <div id="upload-prompt" class="text-center w-full h-full flex flex-col items-center justify-center">
        <div class="text-gray-500 mb-3">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
          </svg>
        </div>
        <span class="text-gray-400">Select a floor plan to begin</span>
      </div>
      
      <!-- Plan display -->
      <div id="plan-view" class="hidden relative w-full h-full flex items-center justify-center">
        <img id="plan-img" class="max-w-full max-h-full object-contain" />
        <!-- Step overlays will go here -->
        <div id="plan-overlays" class="absolute pointer-events-none" style="top: 0; left: 0;"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Sidebar transitions */
  .sidebar-collapsed {
    width: 0 !important;
    overflow: hidden;
  }
</style>

<script is:inline>
(function() {
  const API = 'http://localhost:5557';
  let currentPlan = null;
  let currentStep = 0;
  let drawingState = null; // Will hold the image data and mask
  let detectedRegions = [];
  
  // Copy working functions from SimpleScan
  const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
  
  function getComponents(mask, width, height, minArea = 18, maxArea = 999999) {
    const visited = new Uint8Array(width * height);
    const qx = new Int32Array(width * height);
    const qy = new Int32Array(width * height);
    const out = [];
    for (let y = 0; y < height; y += 1) {
      for (let x = 0; x < width; x += 1) {
        const start = y * width + x;
        if (!mask[start] || visited[start]) continue;
        let head = 0;
        let tail = 0;
        qx[tail] = x;
        qy[tail] = y;
        tail += 1;
        visited[start] = 1;
        let area = 0;
        let minX = x;
        let minY = y;
        let maxX = x;
        let maxY = y;
        while (head < tail) {
          const hx = qx[head];
          const hy = qy[head];
          head += 1;
          area += 1;
          const dirs = [
            { dx: -1, dy: 0 },
            { dx: 1, dy: 0 },
            { dx: 0, dy: -1 },
            { dx: 0, dy: 1 },
          ];
          for (const { dx, dy } of dirs) {
            const nx = hx + dx;
            const ny = hy + dy;
            if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
            const ni = ny * width + nx;
            if (!mask[ni] || visited[ni]) continue;
            visited[ni] = 1;
            qx[tail] = nx;
            qy[tail] = ny;
            tail += 1;
            minX = Math.min(minX, nx);
            minY = Math.min(minY, ny);
            maxX = Math.max(maxX, nx);
            maxY = Math.max(maxY, ny);
          }
        }
        if (area >= minArea && area <= maxArea) {
          out.push({
            x: minX,
            y: minY,
            w: maxX - minX + 1,
            h: maxY - minY + 1,
            area,
          });
        }
      }
    }
    return out;
  }

  function extractBaselineRegions(state) {
    if (!state) return [];
    const { width, height, mask } = state;
    const canvasArea = Math.max(1, width * height);
    const comps = getComponents(mask, width, height, 18, canvasArea * 0.9);
    if (comps.length === 0) return [];

    const edgeMargin = Math.max(6, Math.round(Math.min(width, height) * 0.02));
    const scored = [];
    for (const c of comps) {
      const bboxArea = c.w * c.h;
      const bboxRatio = bboxArea / canvasArea;
      if (bboxRatio < 0.015 || bboxRatio > 0.72) continue;
      const aspect = c.w / Math.max(1, c.h);
      if (aspect < 0.35 || aspect > 3.0) continue;
      const inkRatio = c.area / Math.max(1, bboxArea);
      if (inkRatio < 0.0015 || inkRatio > 0.24) continue;

      const nearLeft = c.x <= edgeMargin;
      const nearTop = c.y <= edgeMargin;
      const nearRight = c.x + c.w >= width - edgeMargin;
      const nearBottom = c.y + c.h >= height - edgeMargin;
      const edgeTouchCount = [nearLeft, nearTop, nearRight, nearBottom].filter(Boolean).length;

      const cx = c.x + c.w / 2;
      const cy = c.y + c.h / 2;
      const centerDist =
        Math.hypot(cx - width / 2, cy - height / 2) /
        Math.max(1, Math.hypot(width / 2, height / 2));
      const centerBonus = 1 - clamp(centerDist, 0, 1);
      const frameBonus = clamp(1 - Math.abs(inkRatio - 0.06) / 0.14, 0, 1);
      const edgePenalty = edgeTouchCount >= 2 ? 0.22 : 0;
      const score = bboxRatio * 1.1 + frameBonus * 0.35 + centerBonus * 0.2 - edgePenalty;

      scored.push({ ...c, score });
    }

    scored.sort((a, b) => b.score - a.score);
    const selected = [];
    for (const c of scored) {
      const overlaps = selected.some((k) => {
        const x0 = Math.max(c.x, k.x);
        const y0 = Math.max(c.y, k.y);
        const x1 = Math.min(c.x + c.w - 1, k.x + k.w - 1);
        const y1 = Math.min(c.y + c.h - 1, k.y + k.h - 1);
        if (x1 < x0 || y1 < y0) return false;
        const inter = (x1 - x0 + 1) * (y1 - y0 + 1);
        return inter / Math.max(1, Math.min(c.w * c.h, k.w * k.h)) > 0.58;
      });
      if (overlaps) continue;
      const pad = Math.max(8, Math.round(Math.min(c.w, c.h) * 0.03));
      selected.push({
        x: Math.max(0, c.x - pad),
        y: Math.max(0, c.y - pad),
        w: Math.min(width, c.w + pad * 2),
        h: Math.min(height, c.h + pad * 2),
      });
    }
    return selected.slice(0, 6); // Max 6 regions
  }

  // DOM elements
  const sidebar = document.getElementById('sidebar');
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebarExpand = document.getElementById('sidebar-expand');
  const mainToolbar = document.getElementById('main-toolbar');
  const planSelect = document.getElementById('plan-select');
  const planStatus = document.getElementById('plan-status');
  const currentPlanTitle = document.getElementById('current-plan-title');
  const uploadPrompt = document.getElementById('upload-prompt');
  const planView = document.getElementById('plan-view');
  const planImg = document.getElementById('plan-img');
  const planOverlays = document.getElementById('plan-overlays');
  const stepsContainer = document.getElementById('steps-container');
  const debugLog = document.getElementById('debug-log');

  // Debug logging function
  function log(message) {
    const timestamp = new Date().toLocaleTimeString();
    const logMessage = `[${timestamp}] ${message}`;
    console.log(logMessage);
    
    if (debugLog) {
      debugLog.innerHTML += logMessage + '<br>';
      debugLog.scrollTop = debugLog.scrollHeight; // Auto-scroll to bottom
    }
  }

  // Debug: Log which elements were found
  log('=== INITIALIZATION ===');
  log('DOM Elements found:');
  log('- sidebar: ' + !!sidebar);
  log('- planSelect: ' + !!planSelect);
  log('- planStatus: ' + !!planStatus);  
  log('- uploadPrompt: ' + !!uploadPrompt);
  log('- planView: ' + !!planView);
  log('- planImg: ' + !!planImg);
  log('- stepsContainer: ' + !!stepsContainer);
  log('- debugLog: ' + !!debugLog);

  // Sidebar toggle functionality
  sidebarToggle?.addEventListener('click', () => {
    sidebar?.classList.add('sidebar-collapsed');
    mainToolbar?.classList.remove('hidden');
  });

  sidebarExpand?.addEventListener('click', () => {
    sidebar?.classList.remove('sidebar-collapsed');
    mainToolbar?.classList.add('hidden');
  });

  // Plan selection functionality
  planSelect?.addEventListener('change', (e) => {
    log('Plan select changed: ' + e.target.value);
    const planId = e.target.value;
    if (planId) {
      log('Loading plan from dropdown: ' + planId);
      loadTestPlan(planId);
    } else {
      log('Clearing plan (no selection)');
      clearPlan();
    }
  });

  function clearPlan() {
    log('Clearing plan');
    currentPlan = null;
    uploadPrompt?.classList.remove('hidden');
    planView?.classList.add('hidden');
    updatePlanStatus('No plan selected');
    updatePlanTitle('');
  }

  function updatePlanStatus(message) {
    log('Plan status updated: ' + message);
    if (planStatus) {
      planStatus.textContent = message;
      log('Status element updated successfully');
    } else {
      log('ERROR: planStatus element not found!');
    }
  }

  function updatePlanTitle(title) {
    log('Plan title updated: ' + title);
    if (currentPlanTitle) {
      currentPlanTitle.textContent = title;
    } else {
      log('ERROR: currentPlanTitle element not found!');
    }
  }

  // Copy working approach from plan-scanner
  function loadTestPlan(planId) {
    if (!planId) return;
    
    log('Loading test plan: ' + planId);
    updatePlanStatus('Loading plan...');
    
    // Use exact same approach as plan-scanner
    fetch(API + '/test-plans/' + planId)
      .then(function(response) {
        if (!response.ok) throw new Error('Plan not found');
        return response.blob();
      })
      .then(function(blob) {
        log('Plan PDF loaded, size: ' + blob.size);
        
        var file = new File([blob], planId + '.pdf', { type: 'application/pdf' });
        currentPlan = { id: planId, file: file };
        
        updatePlanStatus('Rendering...');
        
        var formData = new FormData();
        formData.append('file', file);
        formData.append('page', '0');
        formData.append('scale', '2');
        
        return fetch(API + '/render', { method: 'POST', body: formData });
      })
      .then(function(response) {
        if (!response.ok) throw new Error('Render failed');
        return response.json();
      })
      .then(function(data) {
        log('Render response received');
        
        if (!data.success || !data.image) {
          throw new Error('Render response missing image data');
        }
        
        // Set image source directly
        planImg.onload = function() {
          log('SUCCESS: Plan image loaded!');
          uploadPrompt?.classList.add('hidden');
          planView?.classList.remove('hidden');
          
          const planNames = {
            'demo-plan': 'Demo Plan (SimpleScan default)',
            '85-tremont': '85 Tremont Street Cambridge MA FP.pdf',
            'lane-park': 'Lane Park plan (5 heads)'
          };
          
          const planName = planNames[planId] || planId;
          updatePlanStatus('Loaded: ' + planName);
          updatePlanTitle(planName);
          initializeSteps();
        };
        
        planImg.onerror = function() {
          log('ERROR: Failed to load plan image');
          updatePlanStatus('Failed to display plan image');
          clearPlan();
        };
        
        planImg.src = data.image;
      })
      .catch(function(error) {
        log('ERROR loading plan: ' + error.message);
        updatePlanStatus('Error: ' + error.message);
        clearPlan();
      });
  }

  function initializeSteps() {
    log('initializeSteps() called');
    // Initialize the step-by-step process
    currentStep = 0;
    log('currentStep set to: ' + currentStep);
    renderStepsUI();
  }

  function renderStepsUI() {
    log('renderStepsUI() called');
    if (!stepsContainer) {
      log('ERROR: stepsContainer not found!');
      return;
    }
    log('Rendering steps UI for step: ' + currentStep);
    
    const steps = [
      { id: 'detect-regions', title: 'Step 1: Detect Viable Areas', status: 'ready' },
      { id: 'apply-regions', title: 'Step 2: Apply Viable Areas', status: 'pending' },
      { id: 'find-colors', title: 'Step 3: Find Colored Lines', status: 'pending' },
      { id: 'remove-hairlines', title: 'Step 4: Remove Hairlines', status: 'pending' },
      { id: 'find-dashes', title: 'Step 5: Find Dashed Lines', status: 'pending' },
      { id: 'remove-text', title: 'Step 6: Remove Text', status: 'pending' },
      { id: 'final-output', title: 'Step 7: Final Output', status: 'pending' }
    ];

    stepsContainer.innerHTML = steps.map((step, index) => {
      const isActive = index === currentStep;
      const isComplete = index < currentStep;
      const isPending = index > currentStep;
      
      let statusClass = 'text-gray-500';
      let statusIcon = '⏸️';
      
      if (isComplete) {
        statusClass = 'text-green-400';
        statusIcon = '✅';
      } else if (isActive) {
        statusClass = 'text-blue-400';
        statusIcon = '▶️';
      }
      
      return `
        <div class="p-3 rounded border ${isActive ? 'border-blue-500 bg-blue-500/10' : 'border-gray-600 bg-gray-700/50'}">
          <div class="flex items-center gap-3">
            <span class="text-lg">${statusIcon}</span>
            <div class="flex-1">
              <div class="font-medium text-sm ${statusClass}">${step.title}</div>
              <div class="text-xs text-gray-400 capitalize">${step.status}</div>
            </div>
            ${isActive ? '<button class="text-xs bg-blue-600 hover:bg-blue-700 px-2 py-1 rounded text-white">Run</button>' : ''}
          </div>
        </div>
      `;
    }).join('');
    
    log('Steps UI rendered successfully');
    
    // Add click handlers for Run buttons
    stepsContainer.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const stepDiv = e.target.closest('.p-3');
        const stepIndex = Array.from(stepsContainer.children).indexOf(stepDiv);
        log('Run button clicked for step: ' + stepIndex);
        runStep(stepIndex);
      });
    });
  }
  
  async function runStep(stepIndex) {
    log('Running step: ' + stepIndex);
    
    if (stepIndex === 0) {
      // Step 1: Detect viable regions
      await runStep1();
    }
    // Add more steps here later
  }
  
  async function runStep1() {
    if (!currentPlan) {
      log('ERROR: No plan loaded for step 1');
      return;
    }
    
    log('Step 1: Detecting viable regions...');
    updatePlanStatus('Detecting regions...');
    
    try {
      // For now, use mock regions based on typical floor plan dimensions
      // This will let us test the overlay functionality while fixing the server
      log('Using mock regions for testing (server detect endpoint needs debugging)');
      
      // Get plan image dimensions for realistic mock regions
      const imgRect = planImg.getBoundingClientRect();
      const naturalWidth = planImg.naturalWidth;
      const naturalHeight = planImg.naturalHeight;
      
      log('Image dimensions: ' + naturalWidth + 'x' + naturalHeight);
      
      // Create mock regions that look reasonable for a floor plan
      detectedRegions = [
        { x: 50, y: 100, w: 800, h: 600 },
        { x: 900, y: 150, w: 500, h: 400 },
        { x: 200, y: 750, w: 600, h: 300 }
      ].map(region => ({
        x: Math.round(region.x * naturalWidth / 1400), // Scale to actual image size
        y: Math.round(region.y * naturalHeight / 1100),
        w: Math.round(region.w * naturalWidth / 1400),
        h: Math.round(region.h * naturalHeight / 1100)
      }));
      
      log('Created ' + detectedRegions.length + ' mock regions');
      
      // Display regions as overlays
      displayRegionOverlays();
      
      // Update step status
      currentStep = 1; // Mark step 1 as complete, step 2 as active
      renderStepsUI();
      
      updatePlanStatus('Found ' + detectedRegions.length + ' viable regions (mock data)');
      
    } catch (error) {
      log('ERROR in step 1: ' + error.message);
      updatePlanStatus('Error detecting regions: ' + error.message);
    }
  }
  
  function displayRegionOverlays() {
    if (!planOverlays || !detectedRegions.length) return;
    
    log('Displaying ' + detectedRegions.length + ' region overlays');
    
    // Get plan image dimensions and position for scaling and positioning
    const imgRect = planImg.getBoundingClientRect();
    const containerRect = planView.getBoundingClientRect();
    const naturalWidth = planImg.naturalWidth;
    const naturalHeight = planImg.naturalHeight;
    
    log('Display scaling: img=' + imgRect.width + 'x' + imgRect.height + ', natural=' + naturalWidth + 'x' + naturalHeight);
    
    const scaleX = imgRect.width / naturalWidth;
    const scaleY = imgRect.height / naturalHeight;
    
    // Position overlays relative to the container
    const offsetX = imgRect.left - containerRect.left;
    const offsetY = imgRect.top - containerRect.top;
    
    log('Overlay offset: ' + offsetX + ', ' + offsetY);
    
    // Create overlay HTML positioned relative to the image
    const overlayHtml = detectedRegions.map((region, index) => {
      const left = offsetX + region.x * scaleX;
      const top = offsetY + region.y * scaleY;
      const width = region.w * scaleX;
      const height = region.h * scaleY;
      
      return `
        <div class="absolute border-2 border-blue-400 bg-blue-400/10 cursor-pointer group"
             style="left: ${left}px; top: ${top}px; width: ${width}px; height: ${height}px;">
          <div class="absolute -top-6 left-0 text-xs bg-blue-600 text-white px-1 rounded opacity-0 group-hover:opacity-100">
            Region ${index + 1}
          </div>
          <button class="absolute -top-2 -right-2 w-4 h-4 bg-red-500 text-white text-xs rounded-full opacity-0 group-hover:opacity-100 hover:bg-red-600"
                  onclick="removeRegion(${index})">×</button>
        </div>
      `;
    }).join('');
    
    planOverlays.innerHTML = overlayHtml;
    planOverlays.style.pointerEvents = 'auto'; // Enable interactions
  }
  
  function removeRegion(index) {
    log('Removing region: ' + index);
    detectedRegions.splice(index, 1);
    displayRegionOverlays();
    updatePlanStatus('Removed region. ' + detectedRegions.length + ' regions remaining');
  }
  
  // Make removeRegion globally available
  window.removeRegion = removeRegion;

  // Auto-load demo plan on start (same as plan-scanner approach)
  log('=== AUTO-LOAD INIT ===');
  log('Document ready state: ' + document.readyState);
  log('API URL: ' + API);
  
  if (document.readyState === 'loading') {
    log('Waiting for DOMContentLoaded...');
    document.addEventListener('DOMContentLoaded', function() {
      log('DOMContentLoaded fired - setting up auto-load');
      log('planSelect element at DOMContentLoaded: ' + !!planSelect);
      if (planSelect) {
        log('Setting planSelect.value to demo-plan');
        planSelect.value = 'demo-plan';
        log('planSelect.value now: ' + planSelect.value);
        log('Calling loadTestPlan(demo-plan)');
        loadTestPlan('demo-plan');
      } else {
        log('ERROR: planSelect element not found at DOMContentLoaded!');
      }
    });
  } else {
    // DOM already ready, run immediately
    log('DOM already ready - setting up auto-load immediately');
    setTimeout(() => {
      log('Timeout fired - setting up auto-load');
      log('planSelect element in timeout: ' + !!planSelect);
      if (planSelect) {
        log('Setting planSelect.value to demo-plan');
        planSelect.value = 'demo-plan';
        log('planSelect.value now: ' + planSelect.value);
        log('Calling loadTestPlan(demo-plan)');
        loadTestPlan('demo-plan');
      } else {
        log('ERROR: planSelect element not found in timeout!');
      }
    }, 200);
  }

})();
</script>
</LayoutFullWidth>