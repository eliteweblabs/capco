# build output
dist/

# Playwright
test-results/
playwright-report/
blob-report/
e2e/.auth/

# Generated data (created by npm run generate-global-functions, runs before dev/build)
src/data/global-functions.generated.json
# Unused icons backup (created by npm run trim:icons)
src/lib/icon-data-unused-backup.json
# Manifest (built at deploy; dynamic endpoint serves per-request)
public/manifest.json
# Favicon (per-site, often customized)
public/favicon.png
public/favicon.svg
.vercel/
# generated types
.astro/

# Legal pages generated per installation (`npm run build:legal-pages` / policygen)
src/pages/privacy.astro
src/pages/terms.astro

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
.env.backup
.env.production.backup
.env.*

# macOS-specific files
.DS_Store

# Local Netlify folder
.netlify/

# Railway exports (contains sensitive credentials)
railway-export-*/
calcom-export-*/

# Project documentation - keep on GitHub but ignore future changes
scope.md
private.key

# Certificate files (never commit these!)
*.p12
*.pfx
*.pem
*.key
*.crt
*.cer
certs/
*.cert

# Client-specific content (unique per deployment)
content/
public/data/config.json
public/data/config-*.json
# Allow per-site configs to be committed (needed for Railway — RAILWAY_PROJECT_NAME drives filename)
!public/data/config-capco-design-group.json
!public/data/config-rothco-built-llc.json
!public/data/config-mavsafe.json


# But keep the default/template content files (needed for Railway deployments)
!content/pages/*.md
!content/README.md
!site-config.json.example

# Allow client-specific customizations (these stay gitignored)
content/pages/*-custom.md
content/client-specific/

# Client configs directory (contains all client .env files)
configs/*.env
!configs/README.md
db_cluster-*.backup

# Supabase seed backups (may contain sensitive tokens)
supabase/seed*.backup
supabase/*.backup
# --- Full SQL dumps / DB exports (never commit — noise + secrets risk) ---
# Dedicated dump directories (any depth)
**/sql-dumps/
**/db-dumps/
**/database-dumps/
**/supabase-dumps/
**/pg-dump*/
**/sql_backup/

# pg_dump / dashboard export naming (keep supabase/migrations/ + sql-queriers hand scripts)
*_full.sql*
*_supabase_export.sql
capco_supabase_export.sql
**/backup.sql
**/seed-clean.sql
**/seed-full.sql
**/schema-import-*.sql
**/complete-schema-import-*.sql
**/*_database_dump.sql
**/*_pg_dump.sql

# Clone script secrets and dumps (never commit)
scripts/clone-site-and-db.env
scripts/clone-dump-*.sql
