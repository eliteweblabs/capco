# Clone Site + DB – Example env
# Copy to clone-site-and-db.env and fill in values. Never commit clone-site-and-db.env.
#
# Usage: cp clone-site-and-db.example.env clone-site-and-db.env && edit clone-site-and-db.env
#        ./scripts/clone-site-and-db.sh

# --- SOURCE (clone FROM) ---
# Project ref: the ID segment from your Supabase project URL
SOURCE_SUPABASE_REF=
# From Supabase Dashboard > Project Settings > Database
SOURCE_SUPABASE_DB_PASSWORD=

# --- DESTINATION (clone TO) ---
# Create new Supabase project first at supabase.com, then:
DEST_SUPABASE_REF=
DEST_SUPABASE_DB_PASSWORD=
# From Supabase Dashboard > API: anon public key and service_role secret
DEST_SUPABASE_ANON_KEY=
DEST_SUPABASE_SERVICE_ROLE_KEY=

# --- RAILWAY (for output checklist) ---
DEST_RAILWAY_PROJECT_NAME=New Client Site
DEST_RAILWAY_DOMAIN=
GITHUB_REPO=

# Use Docker for pg_dump/psql if not installed locally (brew install postgresql)
USE_DOCKER_FOR_PG_DUMP=0
